# Copy to .env.local and fill in real values. Never commit real secrets.

# Supabase database connection strings.
# Get from: Project Settings → Database → Connection string.
# Session pooler (port 5432): use for schema DDL, migrations, psql, `make db-*` targets.
SUPABASE_DB=postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:5432/postgres

# Transaction pooler (port 6543): use for runtime app / Edge Functions / high-concurrency reads.
SUPABASE_DB_TXN=postgresql://postgres.<project-ref>:<password>@aws-<n>-<region>.pooler.supabase.com:6543/postgres

# Public env vars (shipped to client bundle; safe to expose).
PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=
PUBLIC_R2_MEDIA_URL=https://media.rastrum.app
PUBLIC_R2_TILES_URL=https://tiles.rastrum.app

# Server-side only (Edge Functions). Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=
PLANTNET_API_KEY=
ANTHROPIC_API_KEY=

# Cloudflare R2 (module 10) — used by the get-upload-url Edge Function only.
# When PUBLIC_R2_MEDIA_URL is set, the client switches off Supabase Storage
# and asks the Edge Function for presigned R2 PUT URLs instead.
CF_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rastrum-media
