{
  "name": "rastrum",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "npm run build:og && node scripts/build-search-index.js && astro build && node scripts/sitemap-hreflang.js",
    "build:og": "npx --yes tsx scripts/generate-og.ts",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:mobile": "playwright test --project=mobile-chrome",
    "test:lhci": "lhci autorun",
    "test:audit": "npm run build && npm run test:e2e && npm run test:lhci",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^6.0.2",
    "@mlc-ai/web-llm": "^0.2.82",
    "@supabase/supabase-js": "^2.104.1",
    "@types/papaparse": "^5.5.2",
    "astro": "^5.18.1",
    "dexie": "^4.4.2",
    "exifr": "^7.1.3",
    "fuse.js": "^7.3.0",
    "jszip": "^3.10.1",
    "maplibre-gl": "^5.24.0",
    "onnxruntime-web": "^1.20.1",
    "papaparse": "^5.5.3",
    "pmtiles": "^4.4.1",
    "tailwindcss": "^3.4.19",
    "wavesurfer.js": "^7.12.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@resvg/resvg-js": "^2.6.2",
    "@types/jszip": "^3.4.0",
    "@vitest/coverage-v8": "^4.1.5",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "satori": "^0.26.0",
    "vitest": "^4.1.5"
  }
}
