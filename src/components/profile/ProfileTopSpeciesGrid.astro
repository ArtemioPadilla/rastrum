---
import type { Locale } from '../../i18n/utils';
import { t } from '../../i18n/utils';

interface Props {
  lang: Locale;
  viewer: 'self' | 'signed_in' | 'anonymous';
  targetUserId?: string;
  ownerOnly?: boolean;
}

const { lang, ownerOnly = false } = Astro.props;
const tr = t(lang);
const heading = lang === 'es' ? 'Especies más vistas' : 'Top species';
const ownerPill = (tr as unknown as { privacy?: { owner_only_badge?: string } }).privacy?.owner_only_badge ?? (lang === 'es' ? '🔒 Solo tú lo ves' : '🔒 Only you see this');
---

<section
  data-widget="top-species"
  data-target-user-id={Astro.props.targetUserId}
  class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4 mb-6"
>
  <header class="flex items-baseline justify-between mb-3">
    <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider">{heading}</h2>
    {ownerOnly && (
      <span class="text-[10px] font-medium text-emerald-700 dark:text-emerald-400 bg-emerald-50 dark:bg-emerald-900/30 px-1.5 py-0.5 rounded">
        {ownerPill}
      </span>
    )}
  </header>

  <p data-state="empty" class="hidden text-xs text-zinc-500 italic py-4">
    {lang === 'es' ? 'Aún sin especies destacadas.' : 'No species yet.'}
  </p>

  <ul data-grid class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 gap-2"></ul>
</section>

<script>
  import { getSupabase } from '../../lib/supabase';
  import { capTopSpecies, type TopSpeciesRow } from '../../lib/profile-widgets';
  import { escAttr } from '../../lib/karma';

  async function hydrate(el: HTMLElement) {
    const grid = el.querySelector<HTMLUListElement>('[data-grid]');
    const empty = el.querySelector<HTMLElement>('[data-state="empty"]');
    if (!grid) return;

    let supabase;
    try { supabase = getSupabase(); } catch { return; }
    let userId = el.dataset.targetUserId ?? null;
    if (!userId) {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) return;
      userId = user.id;
    }
    const { data } = await supabase
      .from('profile_top_species')
      .select('taxon_id, scientific_name, obs_count, thumbnail_url')
      .eq('user_id', userId);
    const rows = capTopSpecies((data ?? []) as TopSpeciesRow[]);
    if (!rows.length) {
      empty?.classList.remove('hidden');
      grid.classList.add('hidden');
      return;
    }
    grid.innerHTML = rows
      .map((r) => {
        const href = `/explore/species/?taxon=${encodeURIComponent(r.taxon_id)}`;
        const imgPart = r.thumbnail_url
          ? `<img src="${escAttr(r.thumbnail_url)}" alt="${escAttr(r.scientific_name)}" loading="lazy" class="w-full aspect-square object-cover" />`
          : `<div class="w-full aspect-square bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-400 text-2xl">${r.scientific_name.charAt(0)}</div>`;
        return `<li class="rounded-lg border border-zinc-200 dark:border-zinc-800 overflow-hidden hover:border-emerald-400 transition-colors">
          <a href="${escAttr(href)}" class="block">
            ${imgPart}
            <div class="p-2">
              <p class="text-xs italic text-emerald-700 dark:text-emerald-400 truncate">${escAttr(r.scientific_name)}</p>
              <p class="text-[10px] text-zinc-500">${r.obs_count} obs</p>
            </div>
          </a>
        </li>`;
      })
      .join('');
  }

  document.querySelectorAll<HTMLElement>('[data-widget="top-species"]').forEach(hydrate);
</script>
