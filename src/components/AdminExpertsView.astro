---
/**
 * AdminExpertsView — admin review queue for `expert_applications`.
 *
 * AUTHZ MODEL (v1.0.x):
 *   The `users` table has no `is_admin` column today. Per the v1.0.x brief
 *   we proxy admin access by `users.is_expert = true`. When a real
 *   `is_admin boolean` lands (idempotent ALTER … ADD COLUMN), swap the
 *   gate predicate below. Schema notes:
 *
 *     -- Proposed (don't apply yet — needs reviewer note):
 *     ALTER TABLE public.users
 *       ADD COLUMN IF NOT EXISTS is_admin boolean NOT NULL DEFAULT false;
 *
 * APPROVE / REJECT FLOW:
 *   - Approve: flips `expert_applications.status = 'approved'` AND mirrors
 *     into `users.is_expert = true` + appends to `expert_taxa`. The latter
 *     happens in two RPC calls because RLS doesn't permit cross-table
 *     UPDATE through a single statement.
 *   - Reject: flips `status = 'rejected'`. No mirror.
 *   In both cases `reviewed_at = now()`. Admin can leave a note in a future
 *   iteration; today the row gets a generic "approved by admin" stub.
 */
import { t, getLocalizedPath, routes } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const tr = t(lang);
const adminTr = tr.admin.experts;
const profilePath = getLocalizedPath(lang, routes.profile[lang] + '/');
---

<div class="max-w-5xl mx-auto">
  <header class="mb-6">
    <h1 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
      {adminTr.title}
    </h1>
    <p class="mt-1 text-sm text-zinc-600 dark:text-zinc-400">{adminTr.subtitle}</p>
  </header>

  <div
    id="admin-not-auth"
    class="hidden rounded-lg border border-amber-300 dark:border-amber-700/60 bg-amber-50 dark:bg-amber-900/20 p-4 text-sm text-amber-900 dark:text-amber-100"
  >
    <p>{adminTr.not_authorized}</p>
    <a href={profilePath} class="mt-3 inline-block text-sm text-amber-800 dark:text-amber-200 hover:underline">
      ← {adminTr.back_to_profile}
    </a>
  </div>

  <div id="admin-loading" class="text-sm text-zinc-500 italic">{adminTr.loading}</div>

  <div id="admin-empty" class="hidden rounded-lg border border-zinc-200 dark:border-zinc-800 p-6 text-sm text-zinc-600 dark:text-zinc-400">
    {adminTr.empty}
  </div>

  <div id="admin-table-wrap" class="hidden overflow-x-auto rounded-lg border border-zinc-200 dark:border-zinc-800">
    <table class="min-w-full divide-y divide-zinc-200 dark:divide-zinc-800 text-sm">
      <thead class="bg-zinc-50 dark:bg-zinc-900/50 text-xs font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider">
        <tr>
          <th scope="col" class="px-3 py-2 text-left">{adminTr.col_user}</th>
          <th scope="col" class="px-3 py-2 text-left">{adminTr.col_taxa}</th>
          <th scope="col" class="px-3 py-2 text-left">{adminTr.col_credentials}</th>
          <th scope="col" class="px-3 py-2 text-left">{adminTr.col_institution}</th>
          <th scope="col" class="px-3 py-2 text-left">{adminTr.col_orcid}</th>
          <th scope="col" class="px-3 py-2 text-left">{adminTr.col_submitted}</th>
          <th scope="col" class="px-3 py-2 text-right">{adminTr.col_actions}</th>
        </tr>
      </thead>
      <tbody id="admin-rows" class="divide-y divide-zinc-200 dark:divide-zinc-800 bg-white dark:bg-zinc-950"></tbody>
    </table>
  </div>

  <p
    id="admin-error"
    class="hidden mt-4 text-sm text-red-600 dark:text-red-400"
  ></p>

  <p class="mt-6 text-xs text-zinc-500">
    <a href={profilePath} class="hover:underline">← {adminTr.back_to_profile}</a>
  </p>

  <div
    id="admin-i18n"
    class="hidden"
    data-label-approve={adminTr.approve}
    data-label-reject={adminTr.reject}
    data-label-approving={adminTr.approving}
    data-label-rejecting={adminTr.rejecting}
    data-label-approved={adminTr.approved}
    data-label-rejected={adminTr.rejected}
    data-label-error={adminTr.error_generic}
    data-label-empty={adminTr.empty}
    data-label-not-auth={adminTr.not_authorized}
  ></div>
</div>

<script>
  import { getSupabase } from '../lib/supabase';

  type AppRow = {
    id: string;
    user_id: string;
    taxa: string[];
    credentials: string;
    institution: string | null;
    orcid: string | null;
    status: string;
    created_at: string;
  };

  type UserLite = {
    id: string;
    username: string | null;
    display_name: string | null;
    is_expert: boolean | null;
    expert_taxa: string[] | null;
  };

  const i18nEl = document.getElementById('admin-i18n');
  const labels = {
    approve:   i18nEl?.dataset.labelApprove   ?? 'Approve',
    reject:    i18nEl?.dataset.labelReject    ?? 'Reject',
    approving: i18nEl?.dataset.labelApproving ?? 'Approving…',
    rejecting: i18nEl?.dataset.labelRejecting ?? 'Rejecting…',
    approved:  i18nEl?.dataset.labelApproved  ?? 'Approved',
    rejected:  i18nEl?.dataset.labelRejected  ?? 'Rejected',
    error:     i18nEl?.dataset.labelError     ?? 'Something went wrong',
    empty:     i18nEl?.dataset.labelEmpty     ?? 'No pending applications.',
    notAuth:   i18nEl?.dataset.labelNotAuth   ?? 'Not authorized',
  };

  function show(id: string) { document.getElementById(id)?.classList.remove('hidden'); }
  function hide(id: string) { document.getElementById(id)?.classList.add('hidden'); }

  function escapeHtml(s: string): string {
    return s.replace(/[<>&'"]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;',"'":'&#39;','"':'&quot;'}[c]!));
  }

  function showError(msg: string) {
    const el = document.getElementById('admin-error');
    if (!el) return;
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  function clearError() {
    document.getElementById('admin-error')?.classList.add('hidden');
  }

  function rowHtml(row: AppRow, profile: UserLite | undefined): string {
    const name = profile?.display_name || profile?.username || row.user_id.slice(0, 8);
    const submitted = new Date(row.created_at).toLocaleDateString();
    const taxaHtml = row.taxa.map(t => `<span class="inline-block rounded bg-zinc-100 dark:bg-zinc-800 px-1.5 py-0.5 text-[10px] font-mono text-zinc-700 dark:text-zinc-300 mr-1">${escapeHtml(t)}</span>`).join('');
    return `
      <tr data-row="${escapeHtml(row.id)}" class="align-top">
        <td class="px-3 py-2 text-zinc-900 dark:text-zinc-100">${escapeHtml(name)}</td>
        <td class="px-3 py-2">${taxaHtml}</td>
        <td class="px-3 py-2 text-zinc-700 dark:text-zinc-300 max-w-md whitespace-pre-line">${escapeHtml(row.credentials)}</td>
        <td class="px-3 py-2 text-zinc-700 dark:text-zinc-300">${escapeHtml(row.institution ?? '—')}</td>
        <td class="px-3 py-2 text-zinc-700 dark:text-zinc-300 font-mono text-xs">${escapeHtml(row.orcid ?? '—')}</td>
        <td class="px-3 py-2 text-zinc-500 text-xs">${escapeHtml(submitted)}</td>
        <td class="px-3 py-2 text-right whitespace-nowrap">
          <button type="button" data-action="approve" data-id="${escapeHtml(row.id)}" data-user="${escapeHtml(row.user_id)}" data-taxa="${escapeHtml(row.taxa.join(','))}"
            class="rounded-lg bg-emerald-700 hover:bg-emerald-800 px-3 py-1.5 text-xs font-semibold text-white">${escapeHtml(labels.approve)}</button>
          <button type="button" data-action="reject" data-id="${escapeHtml(row.id)}"
            class="rounded-lg border border-red-300 dark:border-red-900/50 px-3 py-1.5 text-xs font-medium text-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 ml-2">${escapeHtml(labels.reject)}</button>
          <span data-status class="hidden ml-2 text-xs"></span>
        </td>
      </tr>
    `;
  }

  async function loadAndRender() {
    const tbody = document.getElementById('admin-rows');
    if (!tbody) return;

    let supabase;
    try { supabase = getSupabase(); }
    catch {
      hide('admin-loading');
      show('admin-not-auth');
      return;
    }

    const { data: { user } } = await supabase.auth.getUser();
    if (!user) {
      hide('admin-loading');
      show('admin-not-auth');
      return;
    }

    // v1.0.x: gate by is_expert as the admin proxy. is_admin will replace this.
    const { data: me } = await supabase
      .from('users')
      .select('is_expert')
      .eq('id', user.id)
      .maybeSingle<{ is_expert: boolean | null }>();
    if (!me?.is_expert) {
      hide('admin-loading');
      show('admin-not-auth');
      return;
    }

    const { data: rows, error } = await supabase
      .from('expert_applications')
      .select('id, user_id, taxa, credentials, institution, orcid, status, created_at')
      .eq('status', 'pending')
      .order('created_at', { ascending: true });

    if (error) {
      hide('admin-loading');
      showError(error.message);
      return;
    }

    if (!rows || rows.length === 0) {
      hide('admin-loading');
      show('admin-empty');
      return;
    }

    const userIds = Array.from(new Set(rows.map(r => r.user_id)));
    const { data: profiles } = await supabase
      .from('users')
      .select('id, username, display_name, is_expert, expert_taxa')
      .in('id', userIds);
    const byId = new Map<string, UserLite>();
    (profiles ?? []).forEach((p: UserLite) => byId.set(p.id, p));

    tbody.innerHTML = rows.map((r: AppRow) => rowHtml(r, byId.get(r.user_id))).join('');
    hide('admin-loading');
    show('admin-table-wrap');

    tbody.querySelectorAll<HTMLButtonElement>('button[data-action="approve"]').forEach(btn => {
      btn.addEventListener('click', () => approveRow(btn));
    });
    tbody.querySelectorAll<HTMLButtonElement>('button[data-action="reject"]').forEach(btn => {
      btn.addEventListener('click', () => rejectRow(btn));
    });
  }

  function rowStatusEl(rowId: string): HTMLElement | null {
    return document.querySelector(`tr[data-row="${rowId}"] [data-status]`);
  }

  async function approveRow(btn: HTMLButtonElement) {
    clearError();
    const rowId = btn.dataset.id!;
    const userId = btn.dataset.user!;
    const taxa = (btn.dataset.taxa ?? '').split(',').filter(Boolean);
    const status = rowStatusEl(rowId);

    btn.disabled = true;
    btn.textContent = labels.approving;
    const supabase = getSupabase();

    // Mirror into users first — if it fails, the application stays pending
    // and the admin can retry. We refetch expert_taxa so existing taxa are
    // preserved across multiple approvals.
    const { data: existing, error: fetchErr } = await supabase
      .from('users')
      .select('expert_taxa')
      .eq('id', userId)
      .maybeSingle<{ expert_taxa: string[] | null }>();
    if (fetchErr) {
      btn.disabled = false; btn.textContent = labels.approve;
      showError(fetchErr.message); return;
    }
    const merged = Array.from(new Set([...(existing?.expert_taxa ?? []), ...taxa]));

    const { error: userErr } = await supabase
      .from('users')
      .update({ is_expert: true, expert_taxa: merged, updated_at: new Date().toISOString() })
      .eq('id', userId);
    if (userErr) {
      btn.disabled = false; btn.textContent = labels.approve;
      showError(userErr.message); return;
    }

    const { error: appErr } = await supabase
      .from('expert_applications')
      .update({ status: 'approved', reviewed_at: new Date().toISOString() })
      .eq('id', rowId);
    if (appErr) {
      btn.disabled = false; btn.textContent = labels.approve;
      showError(appErr.message); return;
    }

    if (status) {
      status.textContent = '✓ ' + labels.approved;
      status.className = 'ml-2 text-xs text-emerald-600 dark:text-emerald-400';
      status.classList.remove('hidden');
    }
    // Hide the row's action buttons — leave the row in place for context.
    btn.classList.add('hidden');
    const rejectBtn = document.querySelector<HTMLButtonElement>(`button[data-action="reject"][data-id="${rowId}"]`);
    rejectBtn?.classList.add('hidden');
  }

  async function rejectRow(btn: HTMLButtonElement) {
    clearError();
    const rowId = btn.dataset.id!;
    const status = rowStatusEl(rowId);
    btn.disabled = true;
    btn.textContent = labels.rejecting;
    const supabase = getSupabase();

    const { error } = await supabase
      .from('expert_applications')
      .update({ status: 'rejected', reviewed_at: new Date().toISOString() })
      .eq('id', rowId);
    if (error) {
      btn.disabled = false; btn.textContent = labels.reject;
      showError(error.message); return;
    }

    if (status) {
      status.textContent = '✓ ' + labels.rejected;
      status.className = 'ml-2 text-xs text-zinc-500';
      status.classList.remove('hidden');
    }
    btn.classList.add('hidden');
    const approveBtn = document.querySelector<HTMLButtonElement>(`button[data-action="approve"][data-id="${rowId}"]`);
    approveBtn?.classList.add('hidden');
  }

  loadAndRender().catch((err) => {
    showError(err instanceof Error ? err.message : labels.error);
  });
</script>
