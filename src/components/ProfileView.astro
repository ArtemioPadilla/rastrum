---
import { t, getLocalizedPath, routes } from '../i18n/utils';
import WatchlistView from './WatchlistView.astro';
import StreakCard from './StreakCard.astro';
import Skeleton from './Skeleton.astro';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const tr = t(lang);
const myObservationsPath = getLocalizedPath(lang, routes.profileObservations[lang] + '/');
const expertApplyPath = getLocalizedPath(lang, routes.profileExpertApply[lang] + '/');
const validatePath = getLocalizedPath(lang, routes.profileValidate[lang] + '/');
const k = (tr as unknown as { karma: Record<string, string> }).karma;
---

<div class="max-w-3xl mx-auto pb-28 sm:pb-6">
  <!-- Signed-out state -->
  <div id="signed-out" class="hidden py-16 text-center">
    <p class="text-zinc-600 dark:text-zinc-400">{tr.profile.not_signed_in}</p>
    <a href={`/${lang}/${lang === 'es' ? 'ingresar' : 'sign-in'}/`} class="mt-4 inline-block rounded-lg bg-emerald-700 hover:bg-emerald-800 px-4 py-2 text-sm font-semibold text-white">
      {tr.auth.sign_in}
    </a>
  </div>

  <!-- Signed-in state -->
  <div id="signed-in" class="hidden">
    <header class="mb-8">
      <!-- Row 1: avatar + name -->
      <div class="flex items-center gap-4 mb-3">
        <div class="shrink-0">
          <img
            id="avatar-img"
            src=""
            alt=""
            class="w-16 h-16 md:w-20 md:h-20 rounded-full bg-zinc-200 dark:bg-zinc-800 object-cover"
          />
        </div>
        <div class="min-w-0 flex-1">
          <h1 id="display-name" class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 break-words">
            —
          </h1>
          <p class="text-sm text-zinc-500 dark:text-zinc-400 break-all">
            <span id="username-at">@—</span>
            <span id="region-sep" class="hidden"> · </span>
            <span id="region"></span>
          </p>
          <p id="bio" class="mt-1 text-sm text-zinc-700 dark:text-zinc-300 hidden"></p>
        </div>
      </div>
      <!-- Row 2: action buttons -->
      <div class="flex flex-wrap gap-2">
        <a
          href={`/${lang}/${lang === 'es' ? 'perfil/editar' : 'profile/edit'}/`}
          class="rounded-lg border border-emerald-600/60 px-3 py-1.5 text-xs font-semibold text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 text-center"
        >
          {tr.profile.edit}
        </a>
        <a
          href={`/${lang}/${lang === 'es' ? 'perfil/exportar' : 'profile/export'}/`}
          class="rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-1.5 text-xs font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 text-center"
        >
          {tr.profile.export}
        </a>
        <a
          href={`/${lang}/${lang === 'es' ? 'perfil/importar' : 'profile/import'}/`}
          class="rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-1.5 text-xs font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 text-center"
        >
          {((tr as unknown as { import?: { title?: string } }).import?.title) ?? (lang === 'es' ? 'Importar fotos' : 'Import photos')}
        </a>
      </div>
    </header>

    <!-- Quick links (self only) -->
    <nav class="flex flex-wrap gap-2 mb-6 text-xs">
      <a
        href={myObservationsPath}
        class="inline-flex items-center rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-1.5 font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40"
      >
        {tr.profile.my_observations_link}
      </a>
      <a
        href={expertApplyPath}
        class="inline-flex items-center rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-1.5 font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40"
      >
        {tr.expert.apply_title}
      </a>
      <a
        href={validatePath}
        class="inline-flex items-center rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-1.5 font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40"
      >
        {(tr as unknown as { validation: { dashboard_title: string } }).validation.dashboard_title}
      </a>
    </nav>

    <!-- Streak card (module 08) -->
    <StreakCard lang={lang} />

    <!-- Karma & expertise section -->
    <section id="karma-section" class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4 space-y-3 mb-6">
      <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider">
        {k.section_title}
      </h2>
      <div class="flex items-baseline gap-3">
        <span id="karma-total" class="text-3xl font-bold text-emerald-700 dark:text-emerald-400">—</span>
        <span class="text-xs text-zinc-500 dark:text-zinc-400">{k.total_label}</span>
        <span id="karma-weekly" class="ml-auto text-xs font-medium text-emerald-700 dark:text-emerald-400"></span>
      </div>
      <div>
        <h3 class="text-xs font-medium text-zinc-700 dark:text-zinc-300 mb-1">{k.expertise_heading}</h3>
        <ul id="karma-expertise-list" class="space-y-1 text-sm">
          <li class="text-xs text-zinc-500 italic">{k.expertise_empty}</li>
        </ul>
      </div>
    </section>

    <!-- Stats strip -->
    <section class="grid grid-cols-3 gap-3 mb-10">
      <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4">
        <p class="text-2xl font-bold text-zinc-900 dark:text-zinc-100" id="stat-observations">0</p>
        <p class="text-xs text-zinc-500 dark:text-zinc-400">{tr.profile.total_observations}</p>
      </div>
      <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4">
        <p class="text-2xl font-bold text-zinc-900 dark:text-zinc-100" id="stat-species">0</p>
        <p class="text-xs text-zinc-500 dark:text-zinc-400">{tr.profile.species_count}</p>
      </div>
      <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4">
        <p class="text-2xl font-bold text-zinc-900 dark:text-zinc-100" id="stat-rg">0</p>
        <p class="text-xs text-zinc-500 dark:text-zinc-400">{tr.profile.research_grade}</p>
      </div>
    </section>

    <!-- Badges (module 08) -->
    <section id="badges-section" class="hidden mb-8">
      <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider mb-3">
        {lang === 'es' ? 'Insignias' : 'Badges'}
      </h2>
      <ul id="badges-list" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2"></ul>
    </section>

    <!-- Recent activity feed (module 08) -->
    <section>
      <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider mb-3">
        {tr.profile.section_activity}
      </h2>
      <div id="activity-skeleton">
        <Skeleton variant="card" count={3} ariaLabel={tr.profile.my_observations_loading} />
      </div>
      <ul id="activity-list" class="space-y-2"></ul>
      <div id="no-observations" class="hidden rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700 p-8 text-center">
        <p class="text-sm text-zinc-500 dark:text-zinc-400">{tr.profile.no_observations_yet}</p>
      </div>
    </section>

    <!-- Watchlist (followed users + species) — module 08 -->
    <WatchlistView lang={lang} />
  </div>
</div>

<script>
  import { getSupabase } from '../lib/supabase';
  import type { UserProfile } from '../lib/types';

  const signedOut = document.getElementById('signed-out') as HTMLDivElement | null;
  const signedIn = document.getElementById('signed-in') as HTMLDivElement | null;
  const avatarImg = document.getElementById('avatar-img') as HTMLImageElement | null;
  const displayName = document.getElementById('display-name');
  const usernameAt = document.getElementById('username-at');
  const region = document.getElementById('region');
  const regionSep = document.getElementById('region-sep');
  const bio = document.getElementById('bio');
  const statObs = document.getElementById('stat-observations');
  const statSpecies = document.getElementById('stat-species');
  const statRG = document.getElementById('stat-rg');

  function initialsAvatar(name: string): string {
    const clean = name.trim().slice(0, 2).toUpperCase();
    const svg = `<svg xmlns='http://www.w3.org/2000/svg' width='96' height='96' viewBox='0 0 96 96'>
      <rect width='96' height='96' fill='#10b981'/>
      <text x='50%' y='58%' text-anchor='middle' fill='white' font-family='system-ui,sans-serif' font-size='40' font-weight='700'>${clean}</text>
    </svg>`;
    return 'data:image/svg+xml;utf8,' + encodeURIComponent(svg);
  }

  async function run() {
    const supabase = getSupabase();
    const { data: { user } } = await supabase.auth.getUser();

    if (!user) {
      signedOut?.classList.remove('hidden');
      return;
    }

    const { data: profile } = await supabase
      .from('users')
      .select('*')
      .eq('id', user.id)
      .maybeSingle<UserProfile>();

    if (!profile) {
      signedOut?.classList.remove('hidden');
      return;
    }

    signedIn?.classList.remove('hidden');

    const name = profile.display_name || profile.username || user.email?.split('@')[0] || 'Observer';
    if (displayName) displayName.textContent = name;
    if (usernameAt) usernameAt.textContent = profile.username ? '@' + profile.username : (user.email ?? '');

    if (avatarImg) {
      avatarImg.src = profile.avatar_url || initialsAvatar(name);
      avatarImg.alt = name;
    }

    if (profile.region_primary) {
      if (region) region.textContent = profile.region_primary;
      regionSep?.classList.remove('hidden');
    }

    if (profile.bio && bio) {
      bio.textContent = profile.bio;
      bio.classList.remove('hidden');
    }

    const stats = profile.stats_json;
    if (statObs) statObs.textContent = String(stats?.total_observations ?? profile.observation_count ?? 0);
    if (statSpecies) statSpecies.textContent = String(stats?.species_count ?? 0);
    if (statRG) statRG.textContent = String(stats?.research_grade_count ?? 0);

    // Badges (only show if the user opted into gamification)
    if (profile.gamification_opt_in) {
      const { data: rows } = await supabase
        .from('user_badges')
        .select('awarded_at, badges:badge_key(key,name_es,name_en,tier,category)')
        .eq('user_id', user.id)
        .is('revoked_at', null)
        .order('awarded_at', { ascending: false })
        .limit(40);
      const earned = (rows ?? []).map(r => r.badges as unknown as { key: string; name_es: string; name_en: string; tier: string; category: string });
      if (earned.length) {
        const sec = document.getElementById('badges-section');
        const list = document.getElementById('badges-list');
        const isEs2 = document.documentElement.lang === 'es';
        sec?.classList.remove('hidden');
        if (list) {
          const tierColor = (t: string) =>
            t === 'platinum' ? 'bg-zinc-200 text-zinc-800 dark:bg-zinc-300 dark:text-zinc-900' :
            t === 'gold'     ? 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300' :
            t === 'silver'   ? 'bg-zinc-100 text-zinc-700 dark:bg-zinc-800 dark:text-zinc-200' :
                               'bg-orange-50 text-orange-800 dark:bg-orange-900/20 dark:text-orange-300';
          list.innerHTML = earned.map(b => `
            <li class="rounded-lg border border-zinc-200 dark:border-zinc-800 p-3">
              <div class="text-xs uppercase tracking-wider mb-1 ${tierColor(b.tier)} inline-block px-1.5 py-0.5 rounded">${b.tier}</div>
              <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100">${isEs2 ? b.name_es : b.name_en}</p>
              <p class="text-xs text-zinc-500 capitalize">${b.category}</p>
            </li>
          `).join('');
        }
      }
    }

    // Load activity events (last 20). subject_id points at the
    // observation for kinds like 'observation_created' /
    // 'observation_research_grade' — needed so each row is clickable
    // and can hydrate a thumbnail.
    const { data: events } = await supabase
      .from('activity_events')
      .select('id, kind, payload, created_at, read_at, subject_id')
      .eq('actor_id', user.id)
      .order('created_at', { ascending: false })
      .limit(20);

    const list = document.getElementById('activity-list') as HTMLUListElement | null;
    const empty = document.getElementById('no-observations');
    document.getElementById('activity-skeleton')?.classList.add('hidden');
    if (!events?.length) {
      empty?.classList.remove('hidden');
      return;
    }
    const isEs = document.documentElement.lang === 'es';
    const labels: Record<string,(p: Record<string, unknown> | null) => string> = {
      observation_created: (p) => isEs
        ? `Observación nueva${p?.state_province ? ' en ' + p.state_province : ''}`
        : `New observation${p?.state_province ? ' in ' + p.state_province : ''}`,
      observation_research_grade: (p) => isEs
        ? `Grado-investigación: ${p?.scientific_name ?? ''}`
        : `Reached research-grade: ${p?.scientific_name ?? ''}`,
      observation_id_accepted: () => isEs ? 'Identificación aceptada' : 'Identification accepted',
      observation_id_changed:  () => isEs ? 'Identificación cambió'   : 'Identification changed',
      badge_earned: (p) => isEs ? `Insignia obtenida: ${p?.badge_key ?? ''}` : `Badge earned: ${p?.badge_key ?? ''}`,
      streak_milestone: (p) => isEs ? `Racha de ${p?.days ?? ''} días` : `${p?.days ?? ''}-day streak`,
      first_of_species_in_region: (p) => isEs
        ? `Primera ${p?.scientific_name ?? ''} en la región`
        : `First ${p?.scientific_name ?? ''} in region`,
      first_observation_of_day: () => isEs ? 'Primera observación del día' : 'First observation of the day',
      comment_received: () => isEs ? 'Comentario recibido' : 'Comment received',
      validation_given: () => isEs ? 'Validación dada' : 'Validation given',
      validation_received: () => isEs ? 'Validación recibida' : 'Validation received',
      follow_received: () => isEs ? 'Nuevo seguidor' : 'New follower',
    };
    // Hydrate observation-flavored events with species name + primary
    // photo via a single batched lookup (one query per joined table).
    // Without this, "New observation" rows show no thumbnail and no
    // link — users can't tell which observation any given row refers
    // to. The kinds we hydrate are observation_created and
    // observation_research_grade; both store the obs id in subject_id.
    const obsKinds = new Set(['observation_created', 'observation_research_grade']);
    const obsEventIds = events
      .filter(e => obsKinds.has(e.kind as string) && e.subject_id)
      .map(e => e.subject_id as string);
    const obsMeta = new Map<string, { sci: string | null; photo: string | null; obscured: boolean }>();
    if (obsEventIds.length > 0) {
      const [{ data: obsRows }, { data: idRows }, { data: mediaRows }] = await Promise.all([
        supabase.from('observations').select('id, sync_status, obscure_level').in('id', obsEventIds),
        supabase.from('identifications').select('observation_id, scientific_name, is_primary').in('observation_id', obsEventIds).eq('is_primary', true),
        supabase.from('media_files').select('observation_id, url, is_primary').in('observation_id', obsEventIds),
      ]);
      const sciByObs = new Map<string, string>();
      for (const r of (idRows ?? [])) {
        const oid = (r as { observation_id: string }).observation_id;
        const sci = (r as { scientific_name?: string | null }).scientific_name;
        if (sci) sciByObs.set(oid, sci);
      }
      const photoByObs = new Map<string, string>();
      for (const m of (mediaRows ?? [])) {
        const oid = (m as { observation_id: string }).observation_id;
        const url = (m as { url?: string | null }).url;
        const primary = (m as { is_primary?: boolean }).is_primary;
        if (!url) continue;
        if (primary || !photoByObs.has(oid)) photoByObs.set(oid, url);
      }
      for (const o of (obsRows ?? [])) {
        const id = (o as { id: string }).id;
        obsMeta.set(id, {
          sci:      sciByObs.get(id) ?? null,
          photo:    photoByObs.get(id) ?? null,
          obscured: (o as { obscure_level?: string }).obscure_level === 'full',
        });
      }
    }

    function escAttr(s: string): string {
      return s.replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' } as Record<string, string>)[c]);
    }

    if (list) {
      list.innerHTML = events.map(ev => {
        const fn = labels[ev.kind as string] ?? ((p: Record<string, unknown> | null) => `${ev.kind}${p ? ' — ' + JSON.stringify(p) : ''}`);
        const text = fn(ev.payload as Record<string, unknown> | null);
        const date = new Date(ev.created_at as string).toLocaleDateString();
        const obsId = (ev.subject_id as string | null) ?? null;
        const meta  = obsId ? obsMeta.get(obsId) : undefined;
        const sci   = meta?.sci ?? null;
        const photo = meta?.photo ?? null;
        const isObs = obsKinds.has(ev.kind as string) && !!obsId;
        const href  = isObs ? `/share/obs/?id=${encodeURIComponent(obsId!)}` : null;

        const inner = `
          ${photo ? `<img src="${escAttr(photo)}" alt="" loading="lazy" class="w-12 h-12 rounded-lg object-cover bg-zinc-100 dark:bg-zinc-800 shrink-0" />` : `<span class="mt-1 w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></span>`}
          <div class="flex-1 min-w-0">
            <p class="text-sm text-zinc-800 dark:text-zinc-200">${text}</p>
            ${sci ? `<p class="text-sm italic text-emerald-700 dark:text-emerald-400 truncate">${escAttr(sci)}</p>` : ''}
            <p class="text-xs text-zinc-500">${date}</p>
          </div>`;

        return href
          ? `<li><a href="${href}" class="flex items-start gap-3 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 hover:border-emerald-400 dark:hover:border-emerald-700 transition-colors p-3">${inner}</a></li>`
          : `<li class="flex items-start gap-3 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-3">${inner}</li>`;
      }).join('');
    }

    // Mark all as read in the background
    const unreadIds = events.filter(e => !e.read_at).map(e => e.id);
    if (unreadIds.length) {
      supabase.from('activity_events')
        .update({ read_at: new Date().toISOString() })
        .in('id', unreadIds)
        .then(() => { /* fire and forget */ });
    }
  }

  run().catch(console.error);
</script>

<script>
  import { getSupabase } from '../lib/supabase';
  import { formatDelta } from '../lib/karma';

  (async function hydrateKarma() {
    function escAttr(s: string): string {
      return s.replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' } as Record<string, string>)[c]);
    }

    const totalEl   = document.getElementById('karma-total');
    const weeklyEl  = document.getElementById('karma-weekly');
    const listEl    = document.getElementById('karma-expertise-list') as HTMLUListElement | null;
    if (!totalEl || !listEl) return;

    const supabase = getSupabase();
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return;

    const [{ data: u }, { data: events }, { data: expertise }] = await Promise.all([
      supabase.from('users').select('karma_total').eq('id', user.id).maybeSingle(),
      supabase.from('karma_events')
        .select('delta, created_at')
        .eq('user_id', user.id)
        .gte('created_at', new Date(Date.now() - 7 * 86400000).toISOString()),
      supabase.from('user_expertise')
        .select('taxon_id, score, verified_at, taxa(scientific_name)')
        .eq('user_id', user.id)
        .order('score', { ascending: false })
        .limit(5),
    ]);

    const userRow = u as { karma_total?: number } | null;
    totalEl.textContent = String(Math.round(userRow?.karma_total ?? 0));
    const eventList = (events ?? []) as Array<{ delta: number; created_at: string }>;
    const weekly = eventList.reduce((acc, e) => acc + Number(e.delta), 0);
    if (weeklyEl) weeklyEl.textContent = weekly !== 0 ? formatDelta(weekly) : '';

    const rows = (expertise ?? []) as Array<{
      taxon_id: string; score: number; verified_at: string | null;
      taxa: { scientific_name: string } | { scientific_name: string }[] | null;
    }>;
    if (rows.length > 0) {
      listEl.innerHTML = rows.map((r) => {
        const tx = Array.isArray(r.taxa) ? r.taxa[0] : r.taxa;
        const name = tx?.scientific_name ?? '—';
        const ver = r.verified_at
          ? '<span class="ml-1 text-emerald-700 dark:text-emerald-400" title="verified">✓</span>'
          : '';
        return `<li class="flex items-center gap-2"><span class="italic">${escAttr(name)}</span>${ver}<span class="ml-auto font-mono text-xs">${Math.round(r.score)}</span></li>`;
      }).join('');
    }
  })();
</script>
