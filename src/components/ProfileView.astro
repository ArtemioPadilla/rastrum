---
import { t, getLocalizedPath, routes, type Locale } from '../i18n/utils';
import StreakCard from './StreakCard.astro';
import ExpertiseLegendBadge from './ExpertiseLegendBadge.astro';
import ExpertiseCoverageGrid from './ExpertiseCoverageGrid.astro';
import Skeleton from './Skeleton.astro';
import PrivacyIntroBanner from './PrivacyIntroBanner.astro';
import ProfileObservationMap from './profile/ProfileObservationMap.astro';
import ProfileCalendarHeatmap from './profile/ProfileCalendarHeatmap.astro';
import ProfileTaxonomicDonut from './profile/ProfileTaxonomicDonut.astro';
import ProfileTopSpeciesGrid from './profile/ProfileTopSpeciesGrid.astro';
import ProfileStreakRing from './profile/ProfileStreakRing.astro';
import ProfileKarmaSection from './profile/ProfileKarmaSection.astro';
import ProfilePokedexLink from './profile/ProfilePokedexLink.astro';
import ProfileBadgesGrid from './profile/ProfileBadgesGrid.astro';
import ProfileActivityTimeline from './profile/ProfileActivityTimeline.astro';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const tr = t(lang);
const locale = lang as Locale;

const myObservationsPath    = getLocalizedPath(lang, routes.profileObservations[locale] + '/');
const settingsPath          = getLocalizedPath(lang, routes.profileSettings[locale] + '/profile/');
const publicProfileBase     = getLocalizedPath(lang, routes.profileUser[locale] + '/');
const importPath            = getLocalizedPath(lang, routes.profileImport[locale] + '/');
const cameraTrapPath        = getLocalizedPath(lang, routes.profileImportCameraTrap[locale] + '/');
const exportPath            = getLocalizedPath(lang, routes.profileExport[locale] + '/');
const tokensPath            = getLocalizedPath(lang, routes.profileTokens[locale] + '/');
const k = (tr as unknown as { karma: Record<string, string> }).karma;
const expertApplyPath = getLocalizedPath(lang, lang === 'es' ? '/es/perfil/aplicar-experto/' : '/en/profile/expert-apply/');
const ep = (tr as unknown as { profile: { expert_prompt: Record<string, string> } }).profile.expert_prompt;
const pt = (tr as unknown as { profile: Record<string, string> }).profile;
---

<div class="max-w-3xl mx-auto pb-28 sm:pb-6">
  <!-- Signed-out state -->
  <div id="signed-out" class="hidden py-16 text-center">
    <p class="text-zinc-600 dark:text-zinc-400">{tr.profile.not_signed_in}</p>
    <a href={`/${lang}/${lang === 'es' ? 'ingresar' : 'sign-in'}/`} class="mt-4 inline-block rounded-lg bg-emerald-700 hover:bg-emerald-800 px-4 py-2 text-sm font-semibold text-white">
      {tr.auth.sign_in}
    </a>
  </div>

  <!-- Signed-in state -->
  <div id="signed-in" class="hidden">
    <PrivacyIntroBanner lang={lang} />

    <aside id="sponsoring-discovery" class="hidden rounded-lg border border-emerald-300 dark:border-emerald-700 p-4 bg-emerald-50 dark:bg-emerald-900/20 mb-6">
      <p class="text-sm">{tr.sponsoring.discovery_card_title}</p>
      <a href={getLocalizedPath(lang, routes.sponsoring[locale] + '/')} class="mt-2 inline-block text-emerald-700 hover:text-emerald-900 font-medium text-sm">
        {tr.sponsoring.discovery_card_cta} →
      </a>
    </aside>

    <!-- Identity strip -->
    <header class="mb-8">
      <div class="flex items-start gap-4">
        <!-- Avatar (large) -->
        <div class="shrink-0">
          <img
            id="avatar-img"
            src=""
            alt=""
            class="w-20 h-20 md:w-24 md:h-24 rounded-full bg-zinc-200 dark:bg-zinc-800 object-cover"
          />
        </div>

        <!-- Name + handle + meta -->
        <div class="min-w-0 flex-1">
          <h1 id="display-name" class="text-xl md:text-2xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 break-words">
            —
          </h1>
          <p class="text-sm text-zinc-500 dark:text-zinc-400 break-all">
            <span id="username-at">@—</span>
            <span id="region-sep" class="hidden"> · </span>
            <span id="region"></span>
          </p>
          <p id="joined-date" class="text-xs text-zinc-400 dark:text-zinc-500 mt-0.5 hidden"></p>
          <p id="bio" class="mt-1 text-sm text-zinc-700 dark:text-zinc-300 hidden"></p>
        </div>

        <!-- Actions (top-right of strip) -->
        <div class="flex flex-col sm:flex-row items-end sm:items-center gap-2 shrink-0">
          <a
            id="view-public-link"
            href="#"
            class="text-xs font-medium text-emerald-700 dark:text-emerald-400 hover:underline hidden"
          >
            {tr.profile.view_public} ↗
          </a>
          <a
            href={settingsPath}
            class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-100 dark:bg-zinc-800 hover:bg-zinc-200 dark:hover:bg-zinc-700 px-3 py-1.5 text-sm font-semibold text-zinc-800 dark:text-zinc-100 transition-colors"
          >
            <svg aria-hidden="true" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {tr.profile.settings_link}
          </a>
        </div>
      </div>
    </header>

    <!-- Expert-apply CTA (#223) — shown only when user qualifies and hasn't dismissed -->
    <div id="expert-prompt" class="hidden rounded-xl border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-950/30 p-4 mb-6">
      <p class="text-sm font-semibold text-amber-800 dark:text-amber-300" id="expert-prompt-heading">{ep.heading}</p>
      <p class="text-xs text-zinc-600 dark:text-zinc-400 mt-1" id="expert-prompt-body"></p>
      <div class="flex gap-2 mt-3 flex-wrap">
        <a href={expertApplyPath}
          class="min-h-[36px] rounded-lg bg-emerald-700 hover:bg-emerald-800 text-white font-semibold text-xs px-4 flex items-center transition-colors">
          {ep.cta}
        </a>
        <button type="button" id="expert-prompt-dismiss"
          class="min-h-[36px] rounded-lg border border-zinc-300 dark:border-zinc-700 text-xs px-4 text-zinc-600 dark:text-zinc-400 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 transition-colors">
          {ep.dismiss}
        </button>
      </div>
    </div>

    <!-- Expert-pending notice — shown when application is under review -->
    <div id="expert-pending" class="hidden rounded-xl border border-blue-200 dark:border-blue-800 bg-blue-50 dark:bg-blue-950/30 px-4 py-3 mb-6 text-xs text-blue-800 dark:text-blue-300">
      {ep.pending}
    </div>

    <!-- Stats row -->
    <section class="grid grid-cols-3 gap-3 mb-8">      <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4">
        <p class="text-2xl font-bold text-zinc-900 dark:text-zinc-100" id="stat-observations">0</p>
        <p class="text-xs text-zinc-500 dark:text-zinc-400">{tr.profile.total_observations}</p>
      </div>
      <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4">
        <p class="text-2xl font-bold text-zinc-900 dark:text-zinc-100" id="stat-watchlist">0</p>
        <p class="text-xs text-zinc-500 dark:text-zinc-400">{lang === 'es' ? 'Seguimiento' : 'Watchlist'}</p>
      </div>
      <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4" id="stat-streak-card">
        <p class="text-2xl font-bold text-zinc-900 dark:text-zinc-100" id="stat-streak">0</p>
        <p class="text-xs text-zinc-500 dark:text-zinc-400">{lang === 'es' ? 'Racha diaria' : 'Day streak'}</p>
      </div>
    </section>

    <!-- Streak card (module 08) — hidden, used for data only -->
    <div class="hidden">
      <StreakCard lang={lang} />
    </div>

    <!-- Module 25 v1.2.1 widgets (owner view always sees, "Only you" pill
         flagged on visitor-hidden facets at runtime). -->
    <ProfileObservationMap lang={lang} viewer="self" />
    <ProfileCalendarHeatmap lang={lang} viewer="self" />
    <ProfileTaxonomicDonut lang={lang} viewer="self" />
    <ProfileTopSpeciesGrid lang={lang} viewer="self" />
    <ProfileStreakRing lang={lang} viewer="self" />
    <ProfileKarmaSection lang={lang} viewer="self" />
    <ExpertiseLegendBadge lang={lang} class="mb-2" />
    <ExpertiseCoverageGrid lang={lang} />
    <ProfilePokedexLink lang={lang} viewer="self" />
    <ProfileBadgesGrid lang={lang} viewer="self" />
    <ProfileActivityTimeline lang={lang} viewer="self" />

    <!-- Legacy karma & expertise section (module 23) — kept hidden as a
         data hydration target while the new ProfileKarmaSection above is the
         visible widget. The ProfileView script still reads from these
         elements; once the legacy karma block is removed in v1.3, the
         hidden flag below can drop too. -->
    <section id="karma-section" class="hidden rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4 space-y-3 mb-6">
      <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider">
        {k.section_title}
      </h2>
      <div class="flex items-baseline gap-3">
        <span id="karma-total" class="text-3xl font-bold text-emerald-700 dark:text-emerald-400">—</span>
        <span class="text-xs text-zinc-500 dark:text-zinc-400">{k.total_label}</span>
        <span id="karma-weekly" class="ml-auto text-xs font-medium text-emerald-700 dark:text-emerald-400"></span>
      </div>
      <div>
        <h3 class="text-xs font-medium text-zinc-700 dark:text-zinc-300 mb-1">{k.expertise_heading}</h3>
        <ul id="karma-expertise-list" class="space-y-1 text-sm">
          <li class="text-xs text-zinc-500 italic">{k.expertise_empty}</li>
        </ul>
      </div>
    </section>

    <!-- Data tools (#222) — Import / Camera-trap / Export / API tokens -->
    <section class="mb-8">
      <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider mb-3">
        {pt.tools_heading}
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <a href={importPath} class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4 hover:border-emerald-400 dark:hover:border-emerald-700 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 transition-colors group">
          <div class="text-xl mb-2">📥</div>
          <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-emerald-700 dark:group-hover:text-emerald-400">{pt.tools_import}</p>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-0.5">{pt.tools_import_desc}</p>
        </a>
        <a href={cameraTrapPath} class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4 hover:border-emerald-400 dark:hover:border-emerald-700 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 transition-colors group">
          <div class="text-xl mb-2">📷</div>
          <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-emerald-700 dark:group-hover:text-emerald-400">{pt.tools_camera_trap}</p>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-0.5">{pt.tools_camera_trap_desc}</p>
        </a>
        <a href={exportPath} class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4 hover:border-emerald-400 dark:hover:border-emerald-700 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 transition-colors group">
          <div class="text-xl mb-2">📤</div>
          <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-emerald-700 dark:group-hover:text-emerald-400">{pt.tools_export}</p>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-0.5">{pt.tools_export_desc}</p>
        </a>
        <a href={tokensPath} class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4 hover:border-emerald-400 dark:hover:border-emerald-700 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 transition-colors group">
          <div class="text-xl mb-2">🔑</div>
          <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-emerald-700 dark:group-hover:text-emerald-400">{pt.tools_tokens}</p>
          <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-0.5">{pt.tools_tokens_desc}</p>
        </a>
      </div>
    </section>

    <!-- Recent observations preview -->
    <section class="mb-10">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider">
          {tr.profile.section_activity}
        </h2>
        <a
          href={myObservationsPath}
          class="text-xs font-medium text-emerald-700 dark:text-emerald-400 hover:underline"
        >
          {tr.profile.my_observations_link} →
        </a>
      </div>

      <div id="recent-skeleton">
        <Skeleton variant="card" count={4} ariaLabel={tr.profile.my_observations_loading} />
      </div>

      <!-- 4-thumbnail grid -->
      <div id="recent-grid" class="hidden grid grid-cols-2 sm:grid-cols-4 gap-3"></div>

      <div id="no-observations" class="hidden rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700 p-8 text-center">
        <p class="text-sm text-zinc-500 dark:text-zinc-400">{tr.profile.no_observations_yet}</p>
        <a href={`/${lang}/${lang === 'es' ? 'observar' : 'observe'}/`} class="mt-3 inline-block text-sm font-medium text-emerald-700 dark:text-emerald-400 hover:underline">
          {tr.profile.my_observations_cta}
        </a>
      </div>
    </section>

    <!-- Badges (module 08) — superseded by ProfileBadgesGrid above; kept
         hidden so the old hydrate script still has a target. -->
    <section id="badges-section" class="hidden mb-8" data-legacy="true">
      <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider mb-3">
        {lang === 'es' ? 'Insignias' : 'Badges'}
      </h2>
      <ul id="badges-list" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2"></ul>
    </section>
  </div>
</div>

<script>
  import { getSupabase } from '../lib/supabase';
  import { escAttr } from '../lib/karma';
  import type { UserProfile } from '../lib/types';
  import { listCredentials } from '../lib/sponsorships';

  const signedOut    = document.getElementById('signed-out') as HTMLDivElement | null;
  const signedIn     = document.getElementById('signed-in') as HTMLDivElement | null;
  const avatarImg    = document.getElementById('avatar-img') as HTMLImageElement | null;
  const displayName  = document.getElementById('display-name');
  const usernameAt   = document.getElementById('username-at');
  const region       = document.getElementById('region');
  const regionSep    = document.getElementById('region-sep');
  const bio          = document.getElementById('bio');
  const joinedDate   = document.getElementById('joined-date');
  const statObs      = document.getElementById('stat-observations');
  const statWatchlist = document.getElementById('stat-watchlist');
  const statStreak   = document.getElementById('stat-streak');
  const viewPublicLink = document.getElementById('view-public-link') as HTMLAnchorElement | null;

  function initialsAvatar(name: string): string {
    const clean = name.trim().slice(0, 2).toUpperCase();
    const svg = `<svg xmlns='http://www.w3.org/2000/svg' width='96' height='96' viewBox='0 0 96 96'>
      <rect width='96' height='96' fill='#10b981'/>
      <text x='50%' y='58%' text-anchor='middle' fill='white' font-family='system-ui,sans-serif' font-size='40' font-weight='700'>${clean}</text>
    </svg>`;
    return 'data:image/svg+xml;utf8,' + encodeURIComponent(svg);
  }

  async function run() {
    const supabase = getSupabase();
    const { data: { user } } = await supabase.auth.getUser();

    if (!user) {
      signedOut?.classList.remove('hidden');
      return;
    }

    const { data: profile } = await supabase
      .from('users')
      .select('*')
      .eq('id', user.id)
      .maybeSingle<UserProfile>();

    if (!profile) {
      signedOut?.classList.remove('hidden');
      return;
    }

    signedIn?.classList.remove('hidden');

    const name = profile.display_name || profile.username || user.email?.split('@')[0] || 'Observer';
    if (displayName) displayName.textContent = name;
    if (usernameAt) usernameAt.textContent = profile.username ? '@' + profile.username : (user.email ?? '');

    if (avatarImg) {
      avatarImg.src = profile.avatar_url || initialsAvatar(name);
      avatarImg.alt = name;
    }

    if (profile.username && viewPublicLink) {
      const lang = document.documentElement.lang || 'en';
      // Canonical visitor route is /{lang}/u/?username=<handle>; the
      // path-segment form /{lang}/profile/u/<handle>/ is NOT a route
      // (only the legacy /profile/u/ index exists, and it 301-redirects
      // to /u/). Linking by path-segment 404s.
      viewPublicLink.href = `/${lang}/u/?username=${encodeURIComponent(profile.username)}`;
      viewPublicLink.classList.remove('hidden');
    }

    if (profile.region_primary) {
      if (region) region.textContent = profile.region_primary;
      regionSep?.classList.remove('hidden');
    }

    if (profile.bio && bio) {
      bio.textContent = profile.bio;
      bio.classList.remove('hidden');
    }

    if (profile.created_at && joinedDate) {
      const lang = document.documentElement.lang || 'en';
      const since = lang === 'es' ? 'Miembro desde' : 'Member since';
      joinedDate.textContent = `${since} ${new Date(profile.created_at as string).toLocaleDateString()}`;
      joinedDate.classList.remove('hidden');
    }

    const stats = profile.stats_json;
    if (statObs)   statObs.textContent   = String(stats?.total_observations ?? profile.observation_count ?? 0);
    if (statStreak) statStreak.textContent = String(stats?.current_streak ?? 0);

    // Watchlist count
    const { count: watchlistCount } = await supabase
      .from('watchlist_entries')
      .select('*', { count: 'exact', head: true })
      .eq('user_id', user.id);
    if (statWatchlist) statWatchlist.textContent = String(watchlistCount ?? 0);

    // Expert-apply CTA (#223)
    void (async () => {
      try {
        const { evaluateExpertEligibility } = await import('../lib/expert');
        const DISMISS_KEY = 'rastrum.profile.expertPromptDismissed';
        const dismissed = sessionStorage.getItem(DISMISS_KEY) === '1';

        const { data: expertiseRow } = await supabase
          .from('user_expertise')
          .select('taxon_count')
          .eq('user_id', user.id)
          .maybeSingle<{ taxon_count: number }>();

        const eligibility = evaluateExpertEligibility(
          {
            species_count: profile.species_count ?? 0,
            is_expert: profile.is_expert ?? false,
            expert_application_status: (profile as unknown as { expert_application_status?: string | null }).expert_application_status as 'pending' | 'approved' | 'rejected' | null,
          },
          { taxon_count: expertiseRow?.taxon_count ?? 0 },
        );

        const promptEl  = document.getElementById('expert-prompt');
        const pendingEl = document.getElementById('expert-pending');
        const bodyEl    = document.getElementById('expert-prompt-body');
        const isEs      = document.documentElement.lang === 'es';

        if (eligibility.reason === 'pending') {
          pendingEl?.classList.remove('hidden');
        } else if (eligibility.qualifies && !dismissed && promptEl) {
          const bodyTpl = isEs
            ? `Has identificado {species} especies en {taxa} taxones distintos. Aplica al estatus de experto para que tus validaciones tengan 3× de peso.`
            : `You've identified {species} species across {taxa} different taxa. Apply for expert status to get 3× weight on community validations.`;
          if (bodyEl) {
            bodyEl.textContent = bodyTpl
              .replace('{species}', String(eligibility.speciesCount))
              .replace('{taxa}', String(eligibility.taxonCount));
          }
          promptEl.classList.remove('hidden');
          document.getElementById('expert-prompt-dismiss')?.addEventListener('click', () => {
            sessionStorage.setItem(DISMISS_KEY, '1');
            promptEl.classList.add('hidden');
          }, { once: true });
        }
      } catch { /* non-fatal */ }
    })();

    // Badges
    if (profile.gamification_opt_in) {
      const { data: rows } = await supabase
        .from('user_badges')
        .select('awarded_at, badges:badge_key(key,name_es,name_en,tier,category)')
        .eq('user_id', user.id)
        .is('revoked_at', null)
        .order('awarded_at', { ascending: false })
        .limit(8);
      const earned = (rows ?? []).map(r => r.badges as unknown as { key: string; name_es: string; name_en: string; tier: string; category: string });
      if (earned.length) {
        const sec  = document.getElementById('badges-section');
        const list = document.getElementById('badges-list');
        const isEs = document.documentElement.lang === 'es';
        if (sec && !sec.dataset.legacy) sec.classList.remove('hidden');
        if (list) {
          const tierColor = (tier: string) =>
            tier === 'platinum' ? 'bg-zinc-200 text-zinc-800 dark:bg-zinc-300 dark:text-zinc-900' :
            tier === 'gold'     ? 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300' :
            tier === 'silver'   ? 'bg-zinc-100 text-zinc-700 dark:bg-zinc-800 dark:text-zinc-200' :
                                  'bg-orange-50 text-orange-800 dark:bg-orange-900/20 dark:text-orange-300';
          list.innerHTML = earned.map(b => `
            <li class="rounded-lg border border-zinc-200 dark:border-zinc-800 p-3">
              <div class="text-xs uppercase tracking-wider mb-1 ${tierColor(b.tier)} inline-block px-1.5 py-0.5 rounded">${b.tier}</div>
              <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100">${isEs ? b.name_es : b.name_en}</p>
              <p class="text-xs text-zinc-500 capitalize">${b.category}</p>
            </li>
          `).join('');
        }
      }
    }

    // Recent observations — 4 thumbnails
    const { data: obsRows } = await supabase
      .from('observations')
      .select('id, sync_status, obscure_level, observed_at')
      .eq('user_id', user.id)
      .eq('sync_status', 'synced')
      .order('observed_at', { ascending: false })
      .limit(4);

    const skeleton = document.getElementById('recent-skeleton');
    const grid     = document.getElementById('recent-grid');
    const empty    = document.getElementById('no-observations');
    skeleton?.classList.add('hidden');

    if (!obsRows?.length) {
      empty?.classList.remove('hidden');
      return;
    }

    const obsIds = obsRows.map(o => (o as { id: string }).id);
    const [{ data: idRows }, { data: mediaRows }] = await Promise.all([
      supabase.from('identifications').select('observation_id, scientific_name, is_primary').in('observation_id', obsIds).eq('is_primary', true),
      supabase.from('media_files').select('observation_id, url, is_primary').in('observation_id', obsIds),
    ]);

    const sciByObs   = new Map<string, string>();
    const photoByObs = new Map<string, string>();
    for (const r of (idRows ?? [])) {
      const oid = (r as { observation_id: string }).observation_id;
      const sci = (r as { scientific_name?: string | null }).scientific_name;
      if (sci) sciByObs.set(oid, sci);
    }
    for (const m of (mediaRows ?? [])) {
      const oid     = (m as { observation_id: string }).observation_id;
      const url     = (m as { url?: string | null }).url;
      const primary = (m as { is_primary?: boolean }).is_primary;
      if (!url) continue;
      if (primary || !photoByObs.has(oid)) photoByObs.set(oid, url);
    }

    if (grid) {
      grid.innerHTML = obsRows.map(o => {
        const id    = (o as { id: string }).id;
        const photo = photoByObs.get(id);
        const sci   = sciByObs.get(id);
        const href  = `/share/obs/?id=${encodeURIComponent(id)}`;
        return `
          <a href="${escAttr(href)}" class="block rounded-lg border border-zinc-200 dark:border-zinc-800 overflow-hidden hover:border-emerald-400 dark:hover:border-emerald-700 transition-colors aspect-square bg-zinc-100 dark:bg-zinc-800">
            ${photo
              ? `<img src="${escAttr(photo)}" alt="${escAttr(sci ?? '')}" loading="lazy" class="w-full h-full object-cover" />`
              : `<div class="w-full h-full flex items-center justify-center text-zinc-400"><svg aria-hidden="true" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909"/></svg></div>`
            }
          </a>`;
      }).join('');
      grid.classList.remove('hidden');
    }
  }

  run().catch(console.error);

  (async () => {
    try {
      const creds = await listCredentials();
      if (creds.length === 0) {
        document.getElementById('sponsoring-discovery')?.classList.remove('hidden');
      }
    } catch { /* not authed or fn unavailable — silent */ }
  })();
</script>

<script>
  import { getSupabase } from '../lib/supabase';
  import { formatDelta, escAttr } from '../lib/karma';

  (async function hydrateKarma() {
    const totalEl   = document.getElementById('karma-total');
    const weeklyEl  = document.getElementById('karma-weekly');
    const listEl    = document.getElementById('karma-expertise-list') as HTMLUListElement | null;
    if (!totalEl || !listEl) return;

    const supabase = getSupabase();
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return;

    const [{ data: u }, { data: events }, { data: expertise }] = await Promise.all([
      supabase.from('users').select('karma_total').eq('id', user.id).maybeSingle(),
      supabase.from('karma_events')
        .select('delta, created_at')
        .eq('user_id', user.id)
        .gte('created_at', new Date(Date.now() - 7 * 86400000).toISOString()),
      supabase.from('user_expertise')
        .select('taxon_id, score, verified_at, taxa(scientific_name)')
        .eq('user_id', user.id)
        .order('score', { ascending: false })
        .limit(5),
    ]);

    const userRow = u as { karma_total?: number } | null;
    totalEl.textContent = String(Math.round(userRow?.karma_total ?? 0));
    const eventList = (events ?? []) as Array<{ delta: number; created_at: string }>;
    const weekly = eventList.reduce((acc, e) => acc + Number(e.delta), 0);
    if (weeklyEl) weeklyEl.textContent = weekly !== 0 ? formatDelta(weekly) : '';

    const rows = (expertise ?? []) as Array<{
      taxon_id: string; score: number; verified_at: string | null;
      taxa: { scientific_name: string } | { scientific_name: string }[] | null;
    }>;
    if (rows.length > 0) {
      listEl.innerHTML = rows.map((r) => {
        const tx = Array.isArray(r.taxa) ? r.taxa[0] : r.taxa;
        const name = tx?.scientific_name ?? '—';
        const ver = r.verified_at
          ? '<span class="ml-1 text-emerald-700 dark:text-emerald-400" title="verified">✓</span>'
          : '';
        return `<li class="flex items-center gap-2"><span class="italic">${escAttr(name)}</span>${ver}<span class="ml-auto font-mono text-xs">${Math.round(r.score)}</span></li>`;
      }).join('');
    }
  })();
</script>
