---
import { t } from '../i18n/utils';
interface Props { lang: 'en' | 'es' }
const { lang } = Astro.props;
const tr = t(lang);
const privacyHeading = tr.sponsoring.privacy_heading;
const noActiveText   = tr.sponsoring.no_active;
const i18nBag = {
  no_active: noActiveText,
  this_month_template: tr.sponsoring.quota_card_unit,
  exhausted: tr.sponsoring.quota_exhausted_red,
  amber_template: tr.sponsoring.quota_remaining_amber,
  sponsored_by: tr.sponsoring.quota_card_sponsors,
  show_publicly_template: tr.sponsoring.show_sponsor_publicly,
  decline: tr.sponsoring.decline_sponsorship,
  decline_confirm: tr.sponsoring.confirm_decline,
  privacy_section: privacyHeading,
  cancel: tr.sponsoring.confirm_cancel,
  ok: tr.sponsoring.confirm_ok,
  request_btn:                 tr.sponsoring.request_btn,
  request_dialog_title:        tr.sponsoring.request_dialog_title,
  request_sponsor_username:    tr.sponsoring.request_sponsor_username,
  request_message:             tr.sponsoring.request_message,
  request_send:                tr.sponsoring.request_send,
  request_withdraw:            tr.sponsoring.request_withdraw,
  my_requests_section:         tr.sponsoring.my_requests_section,
  my_requests_empty:           tr.sponsoring.my_requests_empty,
  request_status_pending:      tr.sponsoring.request_status_pending,
  request_status_approved:     tr.sponsoring.request_status_approved,
  request_status_rejected:     tr.sponsoring.request_status_rejected,
  request_status_withdrawn:    tr.sponsoring.request_status_withdrawn,
  confirm_withdraw_request:    lang === 'es' ? '¿Retirar esta solicitud?' : 'Withdraw this request?',
};
---

<section class="max-w-3xl mx-auto p-6 space-y-8">
  <header>
    <h1 class="text-2xl md:text-3xl font-bold text-zinc-900 dark:text-zinc-100">
      {tr.sponsoring.quota_card_title}
    </h1>
  </header>

  <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 p-6 bg-white dark:bg-zinc-900">
    <div id="quota-summary" class="text-lg font-semibold">—</div>
    <div class="h-2 mt-3 rounded bg-zinc-200 dark:bg-zinc-800 overflow-hidden">
      <div id="quota-fill" class="h-full bg-emerald-600 transition-all" style="width: 0%"></div>
    </div>
    <div id="quota-banner" class="mt-3 text-sm hidden"></div>
    <div id="quota-sponsors" class="mt-4 text-sm text-zinc-600 dark:text-zinc-400">—</div>
  </div>

  <section>
    <div class="flex items-center justify-between mb-2">
      <h2 class="text-lg font-semibold">{tr.sponsoring.my_requests_section}</h2>
      <button id="request-btn" type="button" class="rounded-lg bg-emerald-700 hover:bg-emerald-800 text-white px-3 py-1.5 text-sm font-medium">{tr.sponsoring.request_btn}</button>
    </div>
    <ul id="my-requests-list" class="space-y-2 text-sm"></ul>
  </section>

  <section>
    <h2 class="text-lg font-semibold mb-2">{privacyHeading}</h2>
    <ul id="privacy-list" class="space-y-2 text-sm"></ul>
  </section>

  <script type="application/json" id="sponsored-by-i18n" set:html={JSON.stringify(i18nBag)} />

  <dialog id="sb-confirm-dialog" class="rounded-xl p-6 max-w-md backdrop:bg-black/50 bg-white dark:bg-zinc-900 text-zinc-900 dark:text-zinc-100">
    <p id="sb-confirm-message" class="text-sm">—</p>
    <div class="mt-4 flex gap-2 justify-end">
      <button type="button" id="sb-confirm-no" class="px-3 py-1.5 text-sm rounded border border-zinc-300 dark:border-zinc-700">{i18nBag.cancel}</button>
      <button type="button" id="sb-confirm-yes" class="px-3 py-1.5 text-sm rounded bg-red-600 text-white">{i18nBag.ok}</button>
    </div>
  </dialog>

  <dialog id="request-dialog" class="rounded-xl p-6 max-w-md backdrop:bg-black/50 bg-white dark:bg-zinc-900 text-zinc-900 dark:text-zinc-100">
    <h3 class="text-lg font-semibold mb-2">{tr.sponsoring.request_dialog_title}</h3>
    <form method="dialog" class="space-y-3">
      <div>
        <label class="block text-sm font-medium" for="req-username-input">{tr.sponsoring.request_sponsor_username}</label>
        <input id="req-username-input" name="username" required class="mt-1 block w-full rounded border border-zinc-300 dark:border-zinc-700 px-3 py-2 text-sm bg-white dark:bg-zinc-900" />
      </div>
      <div>
        <label class="block text-sm font-medium" for="req-message-input">{tr.sponsoring.request_message}</label>
        <textarea id="req-message-input" name="message" maxlength="280" rows="3" class="mt-1 block w-full rounded border border-zinc-300 dark:border-zinc-700 px-3 py-2 text-sm bg-white dark:bg-zinc-900"></textarea>
      </div>
      <div class="flex gap-2 justify-end">
        <button type="button" id="req-cancel" class="px-3 py-1.5 text-sm rounded border border-zinc-300 dark:border-zinc-700">{tr.sponsoring.confirm_cancel}</button>
        <button type="submit" class="px-3 py-1.5 text-sm rounded bg-emerald-700 text-white">{tr.sponsoring.request_send}</button>
      </div>
    </form>
  </dialog>
</section>

<script>
  import { listSponsorships, getUsage, patchSponsorship, revokeSponsorship } from '../lib/sponsorships';

  const escHtml = (s: string): string => s
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');

  const i18nNode = document.getElementById('sponsored-by-i18n') as HTMLScriptElement | null;
  const i18nBag = JSON.parse(i18nNode?.textContent ?? '{}') as {
    no_active: string;
    this_month_template: string;
    exhausted: string;
    amber_template: string;
    sponsored_by: string;
    show_publicly_template: string;
    decline: string;
    decline_confirm: string;
    privacy_section: string;
    cancel: string;
    ok: string;
    request_btn: string;
    request_dialog_title: string;
    request_sponsor_username: string;
    request_message: string;
    request_send: string;
    request_withdraw: string;
    my_requests_section: string;
    my_requests_empty: string;
    request_status_pending: string;
    request_status_approved: string;
    request_status_rejected: string;
    request_status_withdrawn: string;
    confirm_withdraw_request: string;
  };

  function showConfirm(message: string): Promise<boolean> {
    return new Promise((resolve) => {
      const dlg = document.getElementById('sb-confirm-dialog') as HTMLDialogElement | null;
      const msgEl = document.getElementById('sb-confirm-message');
      const yes = document.getElementById('sb-confirm-yes');
      const no = document.getElementById('sb-confirm-no');
      if (!dlg || !msgEl || !yes || !no) { resolve(false); return; }
      msgEl.textContent = message;
      const cleanup = () => { yes.onclick = null; no.onclick = null; };
      yes.onclick = () => { cleanup(); dlg.close(); resolve(true); };
      no.onclick  = () => { cleanup(); dlg.close(); resolve(false); };
      dlg.showModal();
    });
  }

  async function refresh() {
    let sponsorships: Awaited<ReturnType<typeof listSponsorships>> = [];
    try { sponsorships = await listSponsorships('beneficiary'); } catch { /* not authed or fn unavailable */ }

    const summary  = document.getElementById('quota-summary');
    const fill     = document.getElementById('quota-fill') as HTMLElement | null;
    const banner   = document.getElementById('quota-banner');
    const sponsors = document.getElementById('quota-sponsors');
    const privList = document.getElementById('privacy-list');
    if (!summary || !fill || !banner || !sponsors || !privList) return;

    const active = sponsorships.filter(s => s.status === 'active');
    if (active.length === 0) {
      summary.textContent = i18nBag.no_active;
      sponsors.textContent = '';
      privList.innerHTML = '';
      return;
    }
    active.sort((a, b) => a.priority - b.priority);
    const primary = active[0];
    let usage: Awaited<ReturnType<typeof getUsage>> | null = null;
    try { usage = await getUsage(primary.id); } catch { /* ignore */ }
    if (!usage) return;

    summary.textContent = i18nBag.this_month_template
      .replace(/\{used\}/g, String(usage.usedThisMonth))
      .replace(/\{cap\}/g, String(usage.cap));
    const pct = Math.min(100, Math.round(usage.pctUsed * 100));
    fill.style.width = `${pct}%`;

    banner.classList.add('hidden');
    if (usage.pctUsed >= 1.0) {
      banner.className = 'mt-3 text-sm rounded-lg p-3 bg-red-50 dark:bg-red-900/30 text-red-900 dark:text-red-200';
      banner.textContent = i18nBag.exhausted;
      banner.classList.remove('hidden');
    } else if (usage.pctUsed >= 0.80) {
      banner.className = 'mt-3 text-sm rounded-lg p-3 bg-amber-50 dark:bg-amber-900/30 text-amber-900 dark:text-amber-200';
      const remaining = usage.cap - usage.usedThisMonth;
      const sponsorLabel = `${primary.sponsor_id.slice(0, 8)}…`;
      banner.textContent = i18nBag.amber_template
        .replace(/\{remaining\}/g, String(remaining))
        .replace(/\{sponsor\}/g, sponsorLabel);
      banner.classList.remove('hidden');
    }

    sponsors.textContent = `${i18nBag.sponsored_by} ${active.length}`;

    privList.innerHTML = '';
    for (const s of active) {
      const li = document.createElement('li');
      li.className = 'flex items-center justify-between border-b border-zinc-200 dark:border-zinc-800 pb-2';
      const sponsorLabel = `${s.sponsor_id.slice(0, 8)}…`;
      const showPubliclyLabel = i18nBag.show_publicly_template.replace(/\{sponsor\}/g, sponsorLabel);
      li.innerHTML = `
        <span>${escHtml(sponsorLabel)}</span>
        <label class="flex items-center gap-2 text-xs">
          <input type="checkbox" data-toggle-public="${escHtml(s.id)}" ${s.beneficiary_public ? 'checked' : ''} />
          ${escHtml(showPubliclyLabel)}
        </label>
        <button data-decline="${escHtml(s.id)}" class="text-sm text-red-600">${escHtml(i18nBag.decline)}</button>`;
      privList.appendChild(li);
    }
  }

  document.getElementById('privacy-list')?.addEventListener('change', async (e) => {
    const target = e.target as HTMLInputElement;
    if (target.dataset.togglePublic) {
      try { await patchSponsorship(target.dataset.togglePublic, { beneficiary_public: target.checked }); }
      catch (err) { alert(`Error: ${(err as Error).message}`); }
    }
  });

  document.getElementById('privacy-list')?.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;
    if (target.dataset.decline) {
      if (await showConfirm(i18nBag.decline_confirm ?? 'Decline this sponsorship?')) {
        try { await revokeSponsorship(target.dataset.decline); await refresh(); }
        catch (err) { alert(`Error: ${(err as Error).message}`); }
      }
    }
  });

  refresh();

  async function refreshMyRequests() {
    const list = document.getElementById('my-requests-list');
    if (!list) return;
    const { listRequests } = await import('../lib/sponsorships');
    let requests: Awaited<ReturnType<typeof listRequests>> = [];
    try {
      requests = await listRequests('requester');
    } catch (err) {
      console.error('[sponsored-by] refreshMyRequests failed:', err);
    }
    list.innerHTML = '';
    if (requests.length === 0) {
      list.innerHTML = `<li class="text-zinc-500">${escHtml(i18nBag.my_requests_empty ?? '')}</li>`;
      return;
    }
    const supabase = (await import('../lib/supabase')).getSupabase();
    const ids = Array.from(new Set(requests.map(r => r.target_sponsor_id)));
    let usersMap: Record<string, { username: string; display_name?: string }> = {};
    if (ids.length > 0) {
      const { data: users } = await supabase.from('users').select('id,username,display_name').in('id', ids);
      const userRows = (users ?? []) as Array<{ id: string; username: string; display_name?: string }>;
      usersMap = Object.fromEntries(userRows.map(u => [u.id, u]));
    }
    const statusLabel: Record<string, string> = {
      pending:   i18nBag.request_status_pending,
      approved:  i18nBag.request_status_approved,
      rejected:  i18nBag.request_status_rejected,
      withdrawn: i18nBag.request_status_withdrawn,
    };
    for (const req of requests) {
      const u = usersMap[req.target_sponsor_id];
      const name = u?.display_name || u?.username || (req.target_sponsor_id.slice(0, 8) + '…');
      const li = document.createElement('li');
      li.className = 'flex items-center justify-between border-b border-zinc-200 dark:border-zinc-800 pb-2';
      const withdrawBtn = req.status === 'pending'
        ? `<button data-withdraw="${escHtml(req.id)}" class="text-xs text-red-600">${escHtml(i18nBag.request_withdraw)}</button>`
        : '';
      li.innerHTML = `
        <span>
          ${escHtml(name)}
          <span class="ml-2 text-xs text-zinc-500">${escHtml(statusLabel[req.status] ?? req.status)}</span>
        </span>
        ${withdrawBtn}`;
      list.appendChild(li);
    }
  }

  document.getElementById('request-btn')?.addEventListener('click', () => {
    (document.getElementById('request-dialog') as HTMLDialogElement | null)?.showModal();
  });
  document.getElementById('req-cancel')?.addEventListener('click', () => {
    (document.getElementById('request-dialog') as HTMLDialogElement | null)?.close();
  });
  document.getElementById('request-dialog')?.querySelector('form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const sponsor_username = (document.getElementById('req-username-input') as HTMLInputElement).value.trim();
    const message = (document.getElementById('req-message-input') as HTMLTextAreaElement).value.trim() || undefined;
    if (!sponsor_username) return;
    const { createRequest } = await import('../lib/sponsorships');
    try {
      await createRequest({ sponsor_username, message });
      (document.getElementById('req-username-input') as HTMLInputElement).value = '';
      (document.getElementById('req-message-input') as HTMLTextAreaElement).value = '';
      (document.getElementById('request-dialog') as HTMLDialogElement | null)?.close();
      await refreshMyRequests();
    } catch (err) { alert((err as Error).message); }
  });
  document.getElementById('my-requests-list')?.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;
    if (target.dataset.withdraw) {
      if (await showConfirm(i18nBag.confirm_withdraw_request ?? 'Withdraw this request?')) {
        const { withdrawRequest } = await import('../lib/sponsorships');
        await withdrawRequest(target.dataset.withdraw);
        await refreshMyRequests();
      }
    }
  });

  refreshMyRequests();
</script>
