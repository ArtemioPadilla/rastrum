---
import { t } from '../i18n/utils';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const tr = t(lang);
const buildSha = import.meta.env.PUBLIC_BUILD_SHA || 'dev';
const appVersion = import.meta.env.PUBLIC_VERSION || 'dev';
const repoSlug = 'ArtemioPadilla/rastrum';
---

<button
  id="report-issue-btn"
  type="button"
  aria-label={tr.report.button_label}
  title={tr.report.button_label}
  class="fixed bottom-[calc(5rem+env(safe-area-inset-bottom))] sm:bottom-4 right-4 z-40 w-14 h-14 rounded-full flex items-center justify-center shadow-lg bg-white text-emerald-700 ring-1 ring-emerald-600/20 hover:bg-emerald-50 hover:ring-emerald-600/40 dark:bg-zinc-900 dark:text-emerald-400 dark:ring-emerald-500/30 dark:hover:bg-zinc-800 dark:hover:ring-emerald-500/50 transition-all hover:scale-105 hover:shadow-xl focus:outline-none focus:ring-2 focus:ring-emerald-500"
>
  <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round"
      d="M7.5 8.25h9m-9 3.75h6m-7.5 4.5L4.5 19V5.25A1.25 1.25 0 0 1 5.75 4h12.5A1.25 1.25 0 0 1 19.5 5.25v9.5A1.25 1.25 0 0 1 18.25 16h-9.5L6 18l-1.5-1.5z" />
  </svg>
  <span class="sr-only">{tr.report.button_label}</span>
</button>

<dialog
  id="report-issue-modal"
  data-repo={repoSlug}
  data-lang={lang}
  data-build-sha={buildSha}
  data-app-version={appVersion}
  data-l-steps-label={tr.report.steps_label}
  data-l-steps-placeholder={tr.report.steps_placeholder}
  data-l-expected-label={tr.report.expected_label}
  data-l-expected-placeholder={tr.report.expected_placeholder}
  data-l-diagnostics-toggle={tr.report.diagnostics_toggle}
  data-l-diagnostics-env={tr.report.diagnostics_env}
  data-l-diagnostics-console={tr.report.diagnostics_console}
  data-l-diagnostics-network={tr.report.diagnostics_network}
  data-l-diagnostics-none={tr.report.diagnostics_none}
  data-l-copy={tr.report.copy_diagnostics}
  data-l-copied={tr.report.copied}
  class="rounded-lg backdrop:bg-black/60 p-0 w-[min(92vw,560px)] max-h-[88vh] overflow-hidden bg-white text-zinc-900 dark:bg-zinc-900 dark:text-zinc-100 shadow-2xl border border-zinc-200 dark:border-zinc-800"
>
  <form method="dialog" class="flex flex-col max-h-[88vh]">
    <header class="flex items-center justify-between px-5 py-3 border-b border-zinc-200 dark:border-zinc-800 sticky top-0 bg-white dark:bg-zinc-900 z-10">
      <h2 class="text-base font-semibold">{tr.report.modal_title}</h2>
      <button
        type="button"
        id="report-close-btn"
        aria-label={tr.report.cancel}
        class="p-1.5 rounded hover:bg-zinc-100 dark:hover:bg-zinc-800 min-w-[44px] min-h-[44px] flex items-center justify-center"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
      </button>
    </header>
    <div class="px-5 py-4 space-y-4 overflow-y-auto flex-1">
      <!-- Type -->
      <div>
        <label for="report-type" class="block text-sm font-medium mb-1">{tr.report.type_label}</label>
        <select
          id="report-type"
          class="w-full rounded border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500"
        >
          <option value="bug">{tr.report.type_bug}</option>
          <option value="feature">{tr.report.type_feature}</option>
          <option value="question">{tr.report.type_question}</option>
          <option value="translation">{tr.report.type_translation}</option>
        </select>
      </div>
      <!-- Title -->
      <div>
        <label for="report-title" class="block text-sm font-medium mb-1">{tr.report.title_label}</label>
        <input
          type="text"
          id="report-title"
          maxlength="120"
          placeholder={tr.report.title_placeholder}
          class="w-full rounded border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-800 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500"
        />
      </div>
      <!-- Description -->
      <div>
        <label for="report-description" class="block text-sm font-medium mb-1">{tr.report.description_label}</label>
        <textarea
          id="report-description"
          rows="4"
          placeholder={tr.report.description_placeholder}
          class="w-full rounded border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-800 px-3 py-2 text-sm resize-y focus:outline-none focus:ring-2 focus:ring-emerald-500"
        ></textarea>
      </div>
      <!-- Bug-only: steps + expected (shown/hidden by JS) -->
      <div id="report-bug-fields" class="space-y-4">
        <div>
          <label for="report-steps" class="block text-sm font-medium mb-1">{tr.report.steps_label}</label>
          <textarea
            id="report-steps"
            rows="3"
            placeholder={tr.report.steps_placeholder}
            class="w-full rounded border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-800 px-3 py-2 text-sm resize-y focus:outline-none focus:ring-2 focus:ring-emerald-500"
          ></textarea>
        </div>
        <div>
          <label for="report-expected" class="block text-sm font-medium mb-1">{tr.report.expected_label}</label>
          <textarea
            id="report-expected"
            rows="2"
            placeholder={tr.report.expected_placeholder}
            class="w-full rounded border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-800 px-3 py-2 text-sm resize-y focus:outline-none focus:ring-2 focus:ring-emerald-500"
          ></textarea>
        </div>
      </div>
      <!-- Diagnostics accordion -->
      <details id="report-diagnostics" class="group">
        <summary class="flex items-center gap-2 cursor-pointer text-xs font-medium text-zinc-600 dark:text-zinc-400 select-none py-1">
          <svg class="w-3.5 h-3.5 transition-transform group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          {tr.report.diagnostics_toggle}
          <span id="report-diag-count" class="inline-flex items-center justify-center rounded-full bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-300 text-[10px] font-bold min-w-[18px] h-[18px] px-1 hidden">0</span>
        </summary>
        <div class="mt-2 space-y-3">
          <!-- Environment -->
          <div>
            <p class="text-[11px] font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wide mb-1">{tr.report.diagnostics_env}</p>
            <pre
              id="report-env-block"
              class="text-xs bg-zinc-50 dark:bg-zinc-800/60 border border-zinc-200 dark:border-zinc-700 rounded p-2 whitespace-pre-wrap break-all max-h-28 overflow-auto"
            ></pre>
          </div>
          <!-- Console errors -->
          <div>
            <p class="text-[11px] font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wide mb-1">{tr.report.diagnostics_console}</p>
            <pre
              id="report-console-block"
              class="text-xs bg-zinc-50 dark:bg-zinc-800/60 border border-zinc-200 dark:border-zinc-700 rounded p-2 whitespace-pre-wrap break-all max-h-32 overflow-auto"
            ></pre>
          </div>
          <!-- Network errors -->
          <div>
            <p class="text-[11px] font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wide mb-1">{tr.report.diagnostics_network}</p>
            <pre
              id="report-network-block"
              class="text-xs bg-zinc-50 dark:bg-zinc-800/60 border border-zinc-200 dark:border-zinc-700 rounded p-2 whitespace-pre-wrap break-all max-h-32 overflow-auto"
            ></pre>
          </div>
        </div>
      </details>
    </div>
    <footer class="sticky bottom-0 flex items-center justify-between gap-2 px-5 py-3 border-t border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 z-10">
      <button
        type="button"
        id="report-copy-btn"
        class="min-h-[44px] px-3 py-2 rounded text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:bg-zinc-100 dark:hover:bg-zinc-800 inline-flex items-center gap-1.5 transition-colors"
        title={tr.report.copy_diagnostics}
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        <span id="report-copy-label">{tr.report.copy_diagnostics}</span>
      </button>
      <div class="flex items-center gap-2">
        <button
          type="button"
          id="report-cancel-btn"
          class="min-h-[44px] px-4 py-2 rounded text-sm font-medium border border-zinc-300 dark:border-zinc-700 hover:bg-zinc-100 dark:hover:bg-zinc-800"
        >
          {tr.report.cancel}
        </button>
        <button
          type="button"
          id="report-submit-btn"
          class="min-h-[44px] px-4 py-2 rounded text-sm font-semibold bg-emerald-700 hover:bg-emerald-800 text-white focus:outline-none focus:ring-2 focus:ring-emerald-500"
        >
          {tr.report.open_on_github}
        </button>
      </div>
    </footer>
  </form>
</dialog>

<!--
  is:inline so the capture hooks install at parse time, before any
  module-graph code runs. This catches errors from the earliest moments.
-->
<script is:inline>
(function () {
  // ── Telemetry capture (runs once, survives SPA navigations) ──────────
  var W = window;
  if (!W.__rastrum_diag) {
    var MAX = 30;
    var diag = { console: [], network: [], errors: [] };
    W.__rastrum_diag = diag;

    // 1. console.error + console.warn + console.log (filtered to [rastrum] prefix)
    var origError = console.error.bind(console);
    var origWarn  = console.warn.bind(console);
    var origLog   = console.log.bind(console);
    // Prefix filter: only capture app-namespaced logs to avoid library noise
    // (MapLibre, Supabase internals, etc. flood console.log with tile/network data).
    // Any log whose first argument starts with '[rastrum]', '[manage-panel]',
    // '[sync]', '[identify]' etc. is considered an app log.
    var APP_LOG_PREFIX = /^\[rastrum|^\[manage-panel|^\[sync|^\[identify|^\[retry|^\[observe/;
    function capture(level, args) {
      var firstArg = args.length > 0 ? String(args[0]) : '';
      // For log level: only capture if it looks like an app log
      if (level === 'log' && !APP_LOG_PREFIX.test(firstArg)) return;
      var msg = Array.prototype.map.call(args, function (a) {
        if (a === null) return 'null';
        if (a === undefined) return 'undefined';
        if (a instanceof Error) return a.message + '\n' + (a.stack || '');
        if (typeof a === 'object') { try { return JSON.stringify(a); } catch { return String(a); } }
        return String(a);
      }).join(' ');
      diag.console.push({ ts: new Date().toISOString(), level: level, msg: msg.slice(0, 500) });
      if (diag.console.length > MAX) diag.console.shift();
    }
    console.error = function () { capture('error', arguments); origError.apply(console, arguments); };
    console.warn  = function () { capture('warn',  arguments); origWarn.apply(console, arguments); };
    console.log   = function () { capture('log',   arguments); origLog.apply(console, arguments); };

    // 2. Unhandled errors + promise rejections
    W.addEventListener('error', function (ev) {
      diag.errors.push({
        ts: new Date().toISOString(),
        msg: (ev.message || 'Unknown error').slice(0, 300),
        src: ev.filename ? (ev.filename + ':' + ev.lineno + ':' + ev.colno) : ''
      });
      if (diag.errors.length > MAX) diag.errors.shift();
    });
    W.addEventListener('unhandledrejection', function (ev) {
      var r = ev.reason;
      var msg = r instanceof Error ? (r.message + '\n' + (r.stack || '')) : String(r || 'Unhandled rejection');
      diag.errors.push({ ts: new Date().toISOString(), msg: msg.slice(0, 300), src: 'promise' });
      if (diag.errors.length > MAX) diag.errors.shift();
    });

    // 3. Network error capture (wrap fetch)
    var origFetch = W.fetch;
    if (origFetch) {
      W.fetch = function () {
        var url = arguments[0];
        var urlStr = typeof url === 'string' ? url : (url && url.url ? url.url : String(url));
        var method = 'GET';
        if (arguments[1] && arguments[1].method) method = arguments[1].method;
        if (typeof url === 'object' && url.method) method = url.method;
        return origFetch.apply(W, arguments).then(function (res) {
          if (!res.ok) {
            diag.network.push({
              ts: new Date().toISOString(),
              method: method.toUpperCase(),
              url: urlStr.slice(0, 200),
              status: res.status,
              statusText: res.statusText || ''
            });
            if (diag.network.length > MAX) diag.network.shift();
          }
          return res;
        }, function (err) {
          diag.network.push({
            ts: new Date().toISOString(),
            method: method.toUpperCase(),
            url: urlStr.slice(0, 200),
            status: 0,
            statusText: err && err.message ? err.message.slice(0, 100) : 'Network error'
          });
          if (diag.network.length > MAX) diag.network.shift();
          throw err;
        });
      };
    }
  }

  // ── Modal wiring ─────────────────────────────────────────────────────
  var btn = document.getElementById('report-issue-btn');
  var modal = document.getElementById('report-issue-modal');
  if (!btn || !modal) return;

  var dlg = modal;
  var repo = dlg.dataset.repo || '';
  var lang = dlg.dataset.lang || 'en';
  var buildSha = dlg.dataset.buildSha || 'dev';
  var appVersion = dlg.dataset.appVersion || document.querySelector('meta[name="app-version"]')?.content || 'dev';
  var noneLabel = dlg.dataset.lDiagnosticsNone || 'None captured';
  var copyLabel = dlg.dataset.lCopy || 'Copy diagnostics';
  var copiedLabel = dlg.dataset.lCopied || 'Copied!';

  var typeEl    = document.getElementById('report-type');
  var titleEl   = document.getElementById('report-title');
  var descEl    = document.getElementById('report-description');
  var stepsEl   = document.getElementById('report-steps');
  var expectedEl = document.getElementById('report-expected');
  var bugFields = document.getElementById('report-bug-fields');
  var envBlock  = document.getElementById('report-env-block');
  var consBlock = document.getElementById('report-console-block');
  var netBlock  = document.getElementById('report-network-block');
  var diagCount = document.getElementById('report-diag-count');
  var closeBtn  = document.getElementById('report-close-btn');
  var cancelBtn = document.getElementById('report-cancel-btn');
  var submitBtn = document.getElementById('report-submit-btn');
  var copyBtn   = document.getElementById('report-copy-btn');
  var copyLabelEl = document.getElementById('report-copy-label');

  // Show/hide bug-specific fields based on type
  function syncBugFields() {
    var isBug = !typeEl || typeEl.value === 'bug';
    if (bugFields) bugFields.style.display = isBug ? '' : 'none';
  }
  if (typeEl) typeEl.addEventListener('change', syncBugFields);
  syncBugFields();

  // ── Build environment string ─────────────────────────────────────────
  function getEnvString() {
    var lines = [];
    lines.push('URL: ' + location.href);
    lines.push('User Agent: ' + navigator.userAgent);
    lines.push('Locale: ' + lang);
    lines.push('Version: ' + appVersion);
    lines.push('Build SHA: ' + buildSha);
    lines.push('Online: ' + (navigator.onLine ? 'yes' : 'no'));
    lines.push('Viewport: ' + innerWidth + 'x' + innerHeight);
    lines.push('Time: ' + new Date().toISOString());
    try {
      var conn = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
      if (conn) {
        lines.push('Connection: ' + (conn.effectiveType || '?') + (conn.downlink ? ' / ' + conn.downlink + ' Mbps' : ''));
      }
    } catch (_) { /* ignore */ }
    return lines.join('\n');
  }

  // ── Build console errors string ──────────────────────────────────────
  function getConsoleString() {
    var diag = window.__rastrum_diag;
    if (!diag) return noneLabel;
    var items = diag.console.concat(diag.errors);
    if (!items.length) return noneLabel;
    // Sort by timestamp, most recent last
    items.sort(function (a, b) { return a.ts < b.ts ? -1 : 1; });
    // Take last 10
    var recent = items.slice(-10);
    return recent.map(function (e) {
      var prefix = e.level ? '[' + e.level + ']' : '[error]';
      var src = e.src ? ' (' + e.src + ')' : '';
      return e.ts + ' ' + prefix + ' ' + e.msg + src;
    }).join('\n---\n');
  }

  // ── Build network errors string ──────────────────────────────────────
  function getNetworkString() {
    var diag = window.__rastrum_diag;
    if (!diag || !diag.network.length) return noneLabel;
    var recent = diag.network.slice(-10);
    return recent.map(function (e) {
      return e.ts + ' ' + e.method + ' ' + e.url + ' → ' + (e.status || 'ERR') + (e.statusText ? ' ' + e.statusText : '');
    }).join('\n');
  }

  // ── Count total diagnostic items ─────────────────────────────────────
  function getDiagItemCount() {
    var diag = window.__rastrum_diag;
    if (!diag) return 0;
    return diag.console.length + diag.errors.length + diag.network.length;
  }

  // ── Refresh diagnostics panel ────────────────────────────────────────
  function refreshDiagnostics() {
    if (envBlock)  envBlock.textContent  = getEnvString();
    if (consBlock) consBlock.textContent = getConsoleString();
    if (netBlock)  netBlock.textContent  = getNetworkString();
    var count = getDiagItemCount();
    if (diagCount) {
      diagCount.textContent = String(count);
      diagCount.classList.toggle('hidden', count === 0);
    }
  }

  // ── Build full diagnostics text for clipboard ────────────────────────
  function buildFullDiagnostics() {
    var sections = [];
    sections.push('## Environment\n' + getEnvString());
    var cons = getConsoleString();
    if (cons !== noneLabel) sections.push('## Console Errors\n```\n' + cons + '\n```');
    var net = getNetworkString();
    if (net !== noneLabel) sections.push('## Failed Requests\n```\n' + net + '\n```');
    // Include user-entered fields for context
    var title = (titleEl && titleEl.value) ? titleEl.value.trim() : '';
    var desc  = (descEl && descEl.value) ? descEl.value.trim() : '';
    var header = '';
    if (title) header += '**Title:** ' + title + '\n';
    if (desc)  header += '**Description:** ' + desc + '\n';
    return (header ? header + '\n' : '') + sections.join('\n\n');
  }

  // ── GitHub URL builder per template type ─────────────────────────────
  function buildGithubUrl() {
    var type = (typeEl && typeEl.value) || 'bug';
    var title = (titleEl && titleEl.value) ? titleEl.value.trim() : '';
    var desc  = (descEl && descEl.value) ? descEl.value.trim() : '';
    var base  = 'https://github.com/' + repo + '/issues/new';

    // GitHub Issue Forms: query params must match the `id` fields in the .yml template.
    // The `body` param is ignored when using .yml templates.
    var params = new URLSearchParams();

    if (type === 'bug') {
      params.set('template', 'bug.yml');
      params.set('title', '[Bug]: ' + title);
      params.set('description', desc);
      params.set('steps', (stepsEl && stepsEl.value) ? stepsEl.value.trim() : '');
      params.set('expected', (expectedEl && expectedEl.value) ? expectedEl.value.trim() : '');
      // Actual = description (user describes what happened)
      params.set('actual', desc);
      // Environment block with full diagnostics
      var envLines = getEnvString();
      var consStr = getConsoleString();
      var netStr  = getNetworkString();
      var envFull = envLines;
      if (consStr !== noneLabel) envFull += '\n\nConsole errors:\n' + consStr;
      if (netStr  !== noneLabel) envFull += '\n\nFailed requests:\n' + netStr;
      params.set('environment', envFull);
    } else if (type === 'feature') {
      params.set('template', 'feature.yml');
      params.set('title', '[Feature]: ' + title);
      params.set('problem', desc);
    } else if (type === 'question') {
      params.set('template', 'question.yml');
      params.set('title', '[Question]: ' + title);
      params.set('question', desc);
    } else if (type === 'translation') {
      params.set('template', 'translation.yml');
      params.set('title', '[i18n]: ' + title);
      params.set('current', desc);
    }

    return base + '?' + params.toString();
  }

  // ── Copy to clipboard ────────────────────────────────────────────────
  function copyDiagnostics() {
    var text = buildFullDiagnostics();
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text).then(function () {
        flashCopied();
      }, function () {
        fallbackCopy(text);
      });
    } else {
      fallbackCopy(text);
    }
  }

  function fallbackCopy(text) {
    var ta = document.createElement('textarea');
    ta.value = text;
    ta.style.cssText = 'position:fixed;left:-9999px;top:-9999px';
    document.body.appendChild(ta);
    ta.select();
    try { document.execCommand('copy'); flashCopied(); } catch (_) { /* silent */ }
    document.body.removeChild(ta);
  }

  function flashCopied() {
    if (!copyLabelEl) return;
    copyLabelEl.textContent = copiedLabel;
    setTimeout(function () { copyLabelEl.textContent = copyLabel; }, 1800);
  }

  // ── Open / close ─────────────────────────────────────────────────────
  function openModal() {
    refreshDiagnostics();
    syncBugFields();
    if (typeof dlg.showModal === 'function') dlg.showModal();
    else dlg.setAttribute('open', '');
  }

  function closeModal() {
    if (typeof dlg.close === 'function') dlg.close();
    else dlg.removeAttribute('open');
  }

  btn.addEventListener('click', openModal);
  if (closeBtn)  closeBtn.addEventListener('click', closeModal);
  if (cancelBtn) cancelBtn.addEventListener('click', closeModal);
  if (copyBtn)   copyBtn.addEventListener('click', copyDiagnostics);
  if (submitBtn) submitBtn.addEventListener('click', function () {
    var url = buildGithubUrl();
    window.open(url, '_blank', 'noopener,noreferrer');
    closeModal();
  });
})();
</script>
