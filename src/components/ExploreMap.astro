---
import { t } from '../i18n/utils';
import TimeSlider from './TimeSlider.astro';

interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;
const tr = t(lang);
---

<div>
  <h1 class="text-2xl font-bold tracking-tight mb-2">{tr.map.title}</h1>
  <p class="text-sm text-zinc-500 mb-4" id="map-status">{tr.map.loading}</p>
  <div class="relative">
    <div id="map" class="w-full h-[70vh] rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-100 dark:bg-zinc-900"></div>
    <div id="map-skeleton" class="absolute inset-0 w-full h-full rounded-lg bg-zinc-200 dark:bg-zinc-800 animate-pulse" aria-hidden="true"></div>
    <!-- Places layer toggle -->
    <button
      id="places-layer-toggle"
      class="hidden absolute top-3 right-3 z-10 flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-lg bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-700 shadow-sm hover:border-emerald-400 transition-colors"
      data-active="false"
    >
      <span>🗺️</span>
      <span id="places-toggle-label">{lang === 'es' ? 'Mostrar áreas' : 'Show areas'}</span>
    </button>
  </div>
  <p id="map-source-note" class="hidden mt-2 text-[11px] text-zinc-500 dark:text-zinc-400"></p>
  <p id="map-offline-hint" class="hidden mt-2 text-xs text-amber-700 dark:text-amber-400"></p>
  <TimeSlider lang={lang} />
</div>

<link rel="stylesheet" href="https://unpkg.com/maplibre-gl@4/dist/maplibre-gl.css" />

<script>
  import maplibregl from 'maplibre-gl';
  import { Protocol } from 'pmtiles';
  import { getSupabase } from '../lib/supabase';
  import {
    decideTileSource,
    getPmtilesCacheStatus,
    getPmtilesMxUrl,
  } from '../lib/offline-map';

  const isEs = document.documentElement.lang === 'es';
  const tr = (en: string, es: string): string => (isEs ? es : en);

  const container = document.getElementById('map');
  const status = document.getElementById('map-status');
  const sourceNote = document.getElementById('map-source-note');
  const offlineHint = document.getElementById('map-offline-hint');
  const skeleton = document.getElementById('map-skeleton');
  if (!container) throw new Error('no map container');

  const hideSkeleton = () => skeleton?.classList.add('hidden');

  const KINGDOM_COLORS: Record<string, string> = {
    Plantae:  '#16a34a',
    Animalia: '#dc2626',
    Fungi:    '#9333ea',
  };
  const DEFAULT_COLOR = '#6b7280';

  // Register MapLibre's pmtiles protocol up-front so a `pmtiles://…`
  // style URL resolves correctly regardless of whether we end up using
  // the cached archive on this load. The protocol delegates to fetch(),
  // which the browser satisfies from the Cache API entry we wrote in
  // src/lib/offline-map.ts.
  const pmProtocol = new Protocol();
  maplibregl.addProtocol('pmtiles', pmProtocol.tile);

  const REMOTE_STYLE = 'https://tiles.openfreemap.org/styles/liberty';

  /**
   * Inline minimal pmtiles style spec. We don't pull in
   * `protomaps-themes-base` to keep the bundle small — a flat-fill +
   * water + roads/labels rendering is enough for a fallback offline
   * basemap on top of which we paint observations.
   */
  function buildPmtilesStyle(pmtilesUrl: string): maplibregl.StyleSpecification {
    return {
      version: 8,
      glyphs: 'https://demotiles.maplibre.org/font/{fontstack}/{range}.pbf',
      sources: {
        'protomaps': {
          type: 'vector',
          url: `pmtiles://${pmtilesUrl}`,
          attribution: '© OpenStreetMap contributors',
        },
      },
      layers: [
        { id: 'background', type: 'background', paint: { 'background-color': '#f4f4f5' } },
        {
          id: 'water',
          type: 'fill',
          source: 'protomaps',
          'source-layer': 'water',
          paint: { 'fill-color': '#bfdbfe' },
        },
        {
          id: 'landuse',
          type: 'fill',
          source: 'protomaps',
          'source-layer': 'landuse',
          paint: { 'fill-color': '#e7e5e4', 'fill-opacity': 0.5 },
        },
        {
          id: 'roads',
          type: 'line',
          source: 'protomaps',
          'source-layer': 'roads',
          paint: { 'line-color': '#a1a1aa', 'line-width': 0.6 },
        },
        {
          id: 'boundaries',
          type: 'line',
          source: 'protomaps',
          'source-layer': 'boundaries',
          paint: { 'line-color': '#71717a', 'line-width': 0.4, 'line-dasharray': [2, 2] },
        },
      ],
    };
  }

  function emptyOfflineState(message: string): void {
    if (status) {
      status.textContent = message;
      status.classList.remove('hidden');
    }
    if (offlineHint) {
      offlineHint.textContent = message;
      offlineHint.classList.remove('hidden');
    }
  }

  async function chooseStyle(): Promise<{
    style: string | maplibregl.StyleSpecification;
    note: string;
  } | null> {
    const url = getPmtilesMxUrl();
    const cacheStatus = await getPmtilesCacheStatus().catch(() => ({ cached: false, approxBytes: 0 }));
    const decision = decideTileSource({
      configured: !!url,
      hasCache: cacheStatus.cached,
      online: navigator.onLine,
    });

    switch (decision) {
      case 'cached': {
        // Configured + cached: render entirely from the local archive
        // even when online (fastest path, also works offline).
        if (!url) return { style: REMOTE_STYLE, note: tr('Using online tiles', 'Usando tiles en línea') };
        return {
          style: buildPmtilesStyle(url),
          note: tr('Using offline map · cached on this device', 'Usando mapa sin conexión · guardado en este dispositivo'),
        };
      }
      case 'remote':
      case 'unconfigured':
        // Either no env var set, or set but archive not yet cached and
        // we're online: fall back to the existing OpenFreeMap style.
        return { style: REMOTE_STYLE, note: tr('Using online tiles', 'Usando tiles en línea') };
      case 'offline-no-cache':
        // Offline + no cache: don't try to construct a map at all,
        // surface a clear empty state with a path to recover.
        return null;
    }
  }

  const choice = await chooseStyle();
  if (!choice) {
    hideSkeleton();
    emptyOfflineState(
      tr(
        "You are offline and the Mexico map isn't downloaded yet. Open Profile → Edit → Offline maps to download it next time you have Wi-Fi.",
        'Estás sin conexión y el mapa de México aún no está descargado. Abre Perfil → Editar → Mapas sin conexión para descargarlo la próxima vez que tengas Wi-Fi.',
      ),
    );
    throw new Error('offline-no-cache');
  }

  const map = new maplibregl.Map({
    container,
    style: choice.style,
    center: [-96.72, 17.06],
    zoom: 6,
    attributionControl: { compact: true },
  });

  map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');

  if (sourceNote) {
    sourceNote.textContent = choice.note;
    sourceNote.classList.remove('hidden');
  }

  map.on('load', async () => {
    status?.classList.add('hidden');
    hideSkeleton();

    const supabase = getSupabase();
    // Join taxa via primary_taxon_id so the cluster colors actually reflect
    // kingdom diversity (Plantae green / Animalia amber / Fungi violet / …).
    // RLS still gates the rows.
    const { data, error } = await supabase
      .from('observations')
      .select('id, location, location_obscured, obscure_level, observed_at, taxa:primary_taxon_id(kingdom)')
      .eq('sync_status', 'synced')
      .limit(500);

    if (error) {
      if (status) { status.textContent = error.message; status.classList.remove('hidden'); }
      return;
    }

    const features: GeoJSON.Feature[] = [];
    for (const row of data ?? []) {
      // Prefer location_obscured for sensitive observations (non-owner
      // viewers should see the coarsened point, not precise coords).
      // Fall back to precise location when obscure_level is 'none' or
      // when location_obscured is unavailable.
      const precise = (row as { location: unknown }).location as GeoJSON.Point | null;
      const obscured = (row as { location_obscured: unknown }).location_obscured as GeoJSON.Point | null;
      const level = (row as { obscure_level?: string }).obscure_level;
      const geom = (level && level !== 'none' && obscured?.coordinates) ? obscured : precise;
      if (!geom?.coordinates) continue;
      const observedAt = (row as { observed_at?: string | null }).observed_at ?? null;
      const observedMonth = observedAt ? new Date(observedAt).getUTCMonth() : null;
      const taxon = (row as { taxa?: { kingdom?: string | null } | null }).taxa;
      const kingdom = taxon?.kingdom ?? 'Unknown';
      features.push({
        type: 'Feature',
        geometry: geom,
        properties: {
          id: row.id,
          kingdom,
          observed_month: observedMonth,
          pending: false,
        },
      });
    }

    // Merge in the user's local Dexie unsynced rows so a just-uploaded
    // observation appears immediately, before the round-trip to Supabase
    // resolves. Marked `pending: true` so the styling can differentiate
    // (semi-transparent / dashed outline). RLS guarantees we only ever
    // see our own local rows here.
    try {
      const { getDB } = await import('../lib/db');
      const db = getDB();
      const local = await db.observations
        .where('sync_status').anyOf('pending', 'error')
        .toArray();
      for (const rec of local) {
        const loc = rec.data?.location;
        if (!loc || !Number.isFinite(loc.lat) || !Number.isFinite(loc.lng)) continue;
        if (loc.lat === 0 && loc.lng === 0) continue;
        const ts = rec.data?.createdAt;
        const observedMonth = ts ? new Date(ts).getUTCMonth() : null;
        features.push({
          type: 'Feature',
          geometry: { type: 'Point', coordinates: [loc.lng, loc.lat] } as GeoJSON.Point,
          properties: {
            id: rec.id,
            kingdom: 'Unknown',
            observed_month: observedMonth,
            pending: true,
          },
        });
      }
    } catch { /* Dexie unavailable in this environment */ }

    if (!features.length) {
      if (status) {
        status.textContent = isEs ? 'Aún no hay observaciones que mostrar.' : 'No observations to show yet.';
        status.classList.remove('hidden');
      }
    }

    document.dispatchEvent(
      new CustomEvent('rastrum:time-slider-count', {
        detail: { count: features.length, ready: features.length > 0 },
      }),
    );

    const allFeatures = features;
    let activeMonth: number | null = null;

    function applyMonthFilter(): void {
      const filtered = activeMonth === null
        ? allFeatures
        : allFeatures.filter((f) => {
            const m = (f.properties as { observed_month?: number | null } | null)?.observed_month;
            return typeof m === 'number' && m === activeMonth;
          });
      const src = map.getSource('observations') as maplibregl.GeoJSONSource | undefined;
      src?.setData({ type: 'FeatureCollection', features: filtered });
      document.dispatchEvent(
        new CustomEvent('rastrum:time-slider-count', {
          detail: { count: filtered.length, ready: allFeatures.length > 0 },
        }),
      );
    }

    document.addEventListener('rastrum:time-slider-change', (ev) => {
      const detail = (ev as CustomEvent<{ month: number | null }>).detail || { month: null };
      activeMonth = typeof detail.month === 'number' ? detail.month : null;
      applyMonthFilter();
    });

    map.addSource('observations', {
      type: 'geojson',
      data: { type: 'FeatureCollection', features: allFeatures },
      cluster: true,
      clusterMaxZoom: 14,
      clusterRadius: 50,
    });

    map.addLayer({
      id: 'clusters',
      type: 'circle',
      source: 'observations',
      filter: ['has', 'point_count'],
      paint: {
        'circle-color': ['step', ['get', 'point_count'], '#10b981', 10, '#059669', 50, '#047857'],
        'circle-radius': ['step', ['get', 'point_count'], 18, 10, 26, 50, 34],
      },
    });
    map.addLayer({
      id: 'cluster-count',
      type: 'symbol',
      source: 'observations',
      filter: ['has', 'point_count'],
      layout: {
        'text-field': ['get', 'point_count_abbreviated'],
        'text-font': ['Noto Sans Regular'],
        'text-size': 12,
      },
      paint: { 'text-color': '#ffffff' },
    });
    map.addLayer({
      id: 'pin',
      type: 'circle',
      source: 'observations',
      filter: ['!', ['has', 'point_count']],
      paint: {
        'circle-color': [
          'match', ['get', 'kingdom'],
          'Plantae',  KINGDOM_COLORS.Plantae,
          'Animalia', KINGDOM_COLORS.Animalia,
          'Fungi',    KINGDOM_COLORS.Fungi,
          DEFAULT_COLOR,
        ],
        'circle-radius': 7,
        'circle-stroke-width': 2,
        'circle-stroke-color': '#ffffff',
      },
    });

    // ── Places layer (toggle) ────────────────────────────────────────────────
    const toggleBtn = document.getElementById('places-layer-toggle') as HTMLButtonElement | null;
    const toggleLabel = document.getElementById('places-toggle-label');
    const placeBase = isEs ? '/es/explorar/lugares/?slug=' : '/en/explore/places/?slug=';
    let placesLoaded = false;

    // Show toggle button once map is ready
    toggleBtn?.classList.remove('hidden');

    toggleBtn?.addEventListener('click', async () => {
      const isActive = toggleBtn.dataset.active === 'true';

      if (!placesLoaded) {
        // Load places GeoJSON from RPC on first activation
        const supabase = getSupabase();
        const { data: geojson } = await supabase.rpc('places_map_geojson', { p_limit: 150 });
        if (geojson) {
          map.addSource('places-source', { type: 'geojson', data: geojson });
          map.addLayer({
            id: 'places-fill',
            type: 'fill',
            source: 'places-source',
            paint: { 'fill-color': '#10b981', 'fill-opacity': 0.12 },
          });
          map.addLayer({
            id: 'places-outline',
            type: 'line',
            source: 'places-source',
            paint: { 'line-color': '#059669', 'line-width': 1.5 },
          });

          // Popup on click
          map.on('click', 'places-fill', (e) => {
            const props = e.features?.[0]?.properties as { name?: string; obs_count?: number; slug?: string } | undefined;
            if (!props?.slug) return;
            new maplibregl.Popup({ closeButton: true, maxWidth: '240px' })
              .setLngLat(e.lngLat)
              .setHTML(`<div class="text-sm font-medium">${props.name ?? props.slug}</div><div class="text-xs text-zinc-500 mt-0.5">${props.obs_count ?? 0} obs</div><a href="${placeBase}${props.slug}" class="text-xs text-emerald-600 hover:underline mt-1 block">${isEs ? 'Ver lugar →' : 'View place →'}</a>`)
              .addTo(map);
          });
          map.on('mouseenter', 'places-fill', () => { map.getCanvas().style.cursor = 'pointer'; });
          map.on('mouseleave', 'places-fill', () => { map.getCanvas().style.cursor = ''; });

          placesLoaded = true;
        }
      }

      // Toggle visibility
      const visibility = isActive ? 'none' : 'visible';
      ['places-fill', 'places-outline'].forEach(layerId => {
        if (map.getLayer(layerId)) map.setLayoutProperty(layerId, 'visibility', visibility);
      });

      toggleBtn.dataset.active = isActive ? 'false' : 'true';
      if (toggleLabel) {
        toggleLabel.textContent = isActive
          ? (isEs ? 'Mostrar áreas' : 'Show areas')
          : (isEs ? 'Ocultar áreas' : 'Hide areas');
      }
      toggleBtn.classList.toggle('border-emerald-400', !isActive);
      toggleBtn.classList.toggle('text-emerald-700', !isActive);
    });
  });
</script>
