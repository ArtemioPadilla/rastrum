---
import type { Locale } from '../i18n/utils';
import { t } from '../i18n/utils';

interface Props {
  lang: Locale;
  /**
   * Visitor mode — when set, the view resolves the username from
   * `?username=` in the URL at script time, looks up the target user,
   * gates on `can_see_facet(target, 'pokedex', viewer)`, and renders
   * that user's pokedex. When unset, the view falls back to the
   * signed-in viewer's own pokedex (owner self-view).
   */
  visitor?: boolean;
}
const { lang, visitor = false } = Astro.props;
const tr = t(lang);
const px = (tr as unknown as { pokedex: Record<string, unknown> }).pokedex;
const title       = px?.title       as string;
const subtitle    = px?.subtitle    as string;
const subheading  = px?.subheading  as string | undefined;
const empty       = px?.empty       as string;
const visitorTitle    = px?.visitor_title    as string | undefined;
const visitorSubtitle = px?.visitor_subtitle as string | undefined;
const visitorEmpty    = px?.visitor_empty    as string | undefined;
const visitorPrivate  = px?.visitor_private  as string | undefined;
const visitorNotFound = px?.visitor_not_found as string | undefined;
const visitorNotFoundCta = px?.visitor_not_found_cta as string | undefined;
const visitorBack     = px?.visitor_back_to_profile as string | undefined;
const visitorPageTitle = px?.visitor_page_title as string | undefined;
const visitorLoadError = px?.visitor_load_error as string | undefined;
const bucketMap   = (px?.bucket as Record<string, string> | undefined) ?? {};
const bucketLabels = JSON.stringify(bucketMap);
const exploreRecentHref = `/${lang}/${lang === 'es' ? 'explorar/recientes' : 'explore/recent'}/`;
---

<section
  class="max-w-5xl mx-auto px-4 py-6"
  data-pokedex-root
  data-mode={visitor ? 'visitor' : 'owner'}
  data-lang={lang}
  data-label-visitor-title={visitorTitle ?? ''}
  data-label-visitor-subtitle={visitorSubtitle ?? ''}
  data-label-visitor-empty={visitorEmpty ?? ''}
  data-label-visitor-private={visitorPrivate ?? ''}
  data-label-visitor-not-found={visitorNotFound ?? ''}
  data-label-visitor-page-title={visitorPageTitle ?? ''}
  data-label-empty-owner={empty}
>
  <header class="mb-5">
    <h1 data-pokedex-title class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
      {title}
    </h1>
    <p data-pokedex-subtitle class="text-sm text-zinc-600 dark:text-zinc-400 mt-1">{subtitle}</p>
    {subheading && !visitor && <p class="text-xs text-zinc-500 dark:text-zinc-500 mt-1">{subheading}</p>}
    {visitor && (
      <p class="mt-2 text-xs">
        <a data-pokedex-back-link href="#" class="text-emerald-700 dark:text-emerald-400 hover:underline">{visitorBack}</a>
      </p>
    )}
  </header>

  <p id="pokedex-loading" class="text-sm text-zinc-500 text-center py-8">…</p>
  <p id="pokedex-empty"   class="hidden text-sm text-zinc-500 text-center py-8 rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700">{empty}</p>
  {visitor && (
    <div id="pokedex-not-found" class="hidden py-8 text-center">
      <p class="text-base font-semibold text-zinc-900 dark:text-zinc-100">{visitorNotFound}</p>
      <a href={exploreRecentHref} class="mt-2 inline-block text-sm text-emerald-700 dark:text-emerald-400 hover:underline">{visitorNotFoundCta}</a>
    </div>
  )}
  {visitor && (
    <p id="pokedex-private" class="hidden text-sm text-zinc-500 text-center py-8 rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700">{visitorPrivate}</p>
  )}
  {visitor && (
    <p id="pokedex-error" class="hidden text-sm text-red-700 dark:text-red-400 text-center py-8 rounded-lg border border-red-300 dark:border-red-800">{visitorLoadError}</p>
  )}

  <div id="pokedex-groups" class="space-y-6" data-bucket-labels={bucketLabels}></div>
</section>

<script>
  import { getSupabase } from '../lib/supabase';
  import { rarityTier, escAttr, type Bucket } from '../lib/karma';

  const root      = document.querySelector<HTMLElement>('[data-pokedex-root]');
  const groupsEl  = document.getElementById('pokedex-groups');
  const loading   = document.getElementById('pokedex-loading');
  const emptyEl   = document.getElementById('pokedex-empty');
  const notFound  = document.getElementById('pokedex-not-found');
  const privateEl = document.getElementById('pokedex-private');
  const errorEl   = document.getElementById('pokedex-error');
  const titleEl    = root?.querySelector<HTMLElement>('[data-pokedex-title]');
  const subtitleEl = root?.querySelector<HTMLElement>('[data-pokedex-subtitle]');
  const backLink   = root?.querySelector<HTMLAnchorElement>('[data-pokedex-back-link]');
  const isEs     = document.documentElement.lang === 'es';
  const mode     = root?.dataset.mode ?? 'owner';
  const lang     = (root?.dataset.lang === 'es' ? 'es' : 'en') as 'en' | 'es';

  type DexRow = {
    taxon_id: string;
    scientific_name: string;
    kingdom: string | null;
    rarity_bucket: number | null;
    first_observed_at: string;
    obs_count: number;
  };

  function bucketLabel(bucket: number | null): string {
    if (!groupsEl) return '';
    let labels: Record<string, string> = {};
    try {
      labels = JSON.parse(groupsEl.dataset.bucketLabels ?? '{}') as Record<string, string>;
    } catch { /* noop */ }
    const key = String(Math.max(1, Math.min(5, bucket ?? 1)));
    return labels[key] ?? '';
  }

  function readUsername(): string {
    const params = new URLSearchParams(window.location.search);
    return (params.get('username') || '').trim();
  }

  function applyVisitorChrome(handle: string) {
    const tplTitle    = root?.dataset.labelVisitorTitle ?? '';
    const tplSubtitle = root?.dataset.labelVisitorSubtitle ?? '';
    if (titleEl && tplTitle) titleEl.textContent = tplTitle.replaceAll('{handle}', handle);
    if (subtitleEl && tplSubtitle) subtitleEl.textContent = tplSubtitle.replaceAll('{handle}', handle);
    if (backLink) {
      backLink.href = `/${lang}/u/?username=${encodeURIComponent(handle)}`;
    }
    const titleTpl = root?.dataset.labelVisitorPageTitle ?? '@{handle}\'s Pokédex — Rastrum';
    document.title = titleTpl.replaceAll('{handle}', handle);
  }

  async function loadFromView(supabase: ReturnType<typeof getSupabase>, userId: string): Promise<DexRow[] | null> {
    const { data, error } = await supabase
      .from('profile_pokedex')
      .select('taxon_id, scientific_name, kingdom, rarity_bucket, first_observed_at, obs_count')
      .eq('user_id', userId);
    if (error) return null;
    return (data ?? []) as DexRow[];
  }

  async function loadFallback(supabase: ReturnType<typeof getSupabase>, userId: string): Promise<DexRow[]> {
    const { data } = await supabase
      .from('observations')
      .select('observed_at, identifications!inner(scientific_name, taxon_id, is_primary)')
      .eq('observer_id', userId)
      .eq('identifications.is_primary', true)
      .order('observed_at', { ascending: false });
    const rows = (data ?? []) as Array<{
      observed_at: string;
      identifications: Array<{ scientific_name: string; taxon_id: string; is_primary: boolean }>;
    }>;
    const byTaxon = new Map<string, { name: string; first: string; count: number }>();
    for (const r of rows) {
      for (const id of r.identifications) {
        const prev = byTaxon.get(id.taxon_id);
        if (prev) { prev.count++; if (r.observed_at < prev.first) prev.first = r.observed_at; }
        else byTaxon.set(id.taxon_id, { name: id.scientific_name, first: r.observed_at, count: 1 });
      }
    }
    const taxonIds = Array.from(byTaxon.keys());
    if (!taxonIds.length) return [];
    const { data: rarity } = await supabase
      .from('taxon_rarity').select('taxon_id, bucket').in('taxon_id', taxonIds);
    const rarityMap = new Map<string, number>();
    for (const r of (rarity ?? []) as Array<{ taxon_id: string; bucket: number }>) {
      rarityMap.set(r.taxon_id, r.bucket ?? 1);
    }
    return Array.from(byTaxon.entries()).map(([taxonId, v]) => ({
      taxon_id: taxonId,
      scientific_name: v.name,
      kingdom: null,
      rarity_bucket: rarityMap.get(taxonId) ?? 1,
      first_observed_at: v.first,
      obs_count: v.count,
    }));
  }

  function render(rows: DexRow[]) {
    if (!groupsEl) return;
    if (!rows.length) {
      if (mode === 'visitor' && emptyEl) {
        const tpl = root?.dataset.labelVisitorEmpty ?? '';
        // fallback to owner-empty copy if visitor copy missing
        emptyEl.textContent = tpl || (root?.dataset.labelEmptyOwner ?? '');
      }
      emptyEl?.classList.remove('hidden');
      loading?.classList.add('hidden');
      return;
    }
    const byKingdom = new Map<string, DexRow[]>();
    for (const r of rows) {
      const k = r.kingdom ?? 'Unknown';
      if (!byKingdom.has(k)) byKingdom.set(k, []);
      byKingdom.get(k)!.push(r);
    }
    const kingdoms = Array.from(byKingdom.keys()).sort();

    groupsEl.innerHTML = kingdoms.map((k) => {
      const items = byKingdom.get(k)!.sort((a, b) => b.obs_count - a.obs_count);
      const cards = items.map((v) => {
        const stars = rarityTier((v.rarity_bucket ?? 1) as Bucket);
        const date = new Date(v.first_observed_at).toLocaleDateString();
        const countLabel = v.obs_count === 1
          ? (isEs ? `${v.obs_count} observación` : `${v.obs_count} observation`)
          : (isEs ? `${v.obs_count} observaciones` : `${v.obs_count} observations`);
        const tier = bucketLabel(v.rarity_bucket);
        return `<li class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-3 text-sm">
          <div class="font-medium italic text-emerald-700 dark:text-emerald-400">${escAttr(v.scientific_name)}</div>
          <div class="mt-1 text-xs text-zinc-500">${stars}${tier ? ` · ${escAttr(tier)}` : ''} · ${countLabel}</div>
          <div class="text-[11px] text-zinc-400 mt-0.5">${escAttr(date)}</div>
        </li>`;
      }).join('');
      return `<div>
        <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider mb-2">${escAttr(k)}</h2>
        <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">${cards}</ul>
      </div>`;
    }).join('');
    loading?.classList.add('hidden');
  }

  async function runOwner() {
    if (!groupsEl) return;
    let supabase;
    try { supabase = getSupabase(); } catch {
      loading?.classList.add('hidden');
      emptyEl?.classList.remove('hidden');
      return;
    }
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) {
      loading?.classList.add('hidden');
      emptyEl?.classList.remove('hidden');
      return;
    }
    let rows = await loadFromView(supabase, user.id);
    if (rows === null) rows = await loadFallback(supabase, user.id);
    render(rows);
  }

  async function runVisitor() {
    if (!groupsEl) return;
    const username = readUsername();
    if (!username || !/^[a-zA-Z0-9_]{3,30}$/.test(username)) {
      loading?.classList.add('hidden');
      notFound?.classList.remove('hidden');
      return;
    }
    let supabase;
    try { supabase = getSupabase(); } catch {
      // Misconfigured client = error path, not "not found".
      loading?.classList.add('hidden');
      errorEl?.classList.remove('hidden');
      return;
    }
    const { data: { user: viewer } } = await supabase.auth.getUser();
    const { data: profile, error: lookupErr } = await supabase
      .from('users')
      .select('id, username')
      .eq('username', username)
      .maybeSingle<{ id: string; username: string | null }>();
    // maybeSingle treats "0 rows" as data=null + error=null. PGRST116 on a
    // narrower path also flags zero rows. Anything else is a real error.
    if (lookupErr && lookupErr.code !== 'PGRST116') {
      loading?.classList.add('hidden');
      errorEl?.classList.remove('hidden');
      return;
    }
    if (!profile) {
      loading?.classList.add('hidden');
      notFound?.classList.remove('hidden');
      return;
    }
    applyVisitorChrome(profile.username ?? username);
    const isOwner = viewer?.id === profile.id;
    if (!isOwner) {
      const { data: facetData } = await supabase.rpc('can_see_facet', {
        target: profile.id,
        facet: 'pokedex',
        viewer: viewer?.id ?? null,
      });
      const canSee = facetData === true;
      if (!canSee) {
        loading?.classList.add('hidden');
        privateEl?.classList.remove('hidden');
        return;
      }
    }
    let rows = await loadFromView(supabase, profile.id);
    if (rows === null) rows = await loadFallback(supabase, profile.id);
    render(rows);
  }

  if (mode === 'visitor') {
    runVisitor().catch(() => {
      loading?.classList.add('hidden');
      errorEl?.classList.remove('hidden');
    });
  } else {
    runOwner().catch(() => {
      loading?.classList.add('hidden');
      emptyEl?.classList.remove('hidden');
    });
  }
</script>
