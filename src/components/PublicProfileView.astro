---
/**
 * PublicProfileView — per-username public profile.
 *
 * Astro is configured for static output (output: 'static'), so we cannot
 * statically pre-render every username. The route is a single shell page
 * that hydrates from `?username=…` at runtime, mirroring the /share/obs/
 * pattern. RLS does the gating: users.profile_public must be true for the
 * row to be readable; otherwise we show a "not found" state.
 *
 * The existing FollowButton is mounted with no targetUserId and the script
 * fills it in via dataset once we resolve the username → user_id.
 */
import { t, getLocalizedPath, routes } from '../i18n/utils';
import FollowButton from './FollowButton.astro';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const tr = t(lang);
const observePath = getLocalizedPath(lang, routes.observe[lang] + '/');
---

<div
  class="rastrum-public-profile max-w-3xl mx-auto"
  data-lang={lang}
  data-label-not-found={tr.profile.public_profile_not_found}
  data-label-no-username={tr.profile.public_profile_no_username}
  data-label-private={tr.profile.public_profile_private}
  data-label-no-observations={tr.profile.public_profile_no_observations}
  data-label-member-since={tr.profile.public_profile_member_since}
  data-label-loading={tr.profile.public_profile_loading}
  data-label-recent={tr.profile.public_profile_recent}
  data-label-unknown-species={tr.profile.my_observations_unknown_species}
  data-share-obs-base="/share/obs/"
>
  <div id="pp-loading" class="py-12 text-center text-sm text-zinc-500 dark:text-zinc-400">
    {tr.profile.public_profile_loading}
  </div>

  <div id="pp-not-found" class="hidden py-12 text-center text-sm text-zinc-600 dark:text-zinc-400">
    <p id="pp-not-found-msg">{tr.profile.public_profile_not_found}</p>
    <a href={observePath} class="mt-3 inline-block text-emerald-700 dark:text-emerald-400 hover:underline">
      ← {tr.nav.observe}
    </a>
  </div>

  <article id="pp-profile" class="hidden">
    <header class="flex items-start gap-4 md:gap-6 mb-8">
      <div class="shrink-0">
        <img
          id="pp-avatar"
          src=""
          alt=""
          class="w-20 h-20 md:w-24 md:h-24 rounded-full bg-zinc-200 dark:bg-zinc-800 object-cover"
        />
      </div>
      <div class="min-w-0 flex-1">
        <h1 id="pp-name" class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100 truncate">—</h1>
        <p class="text-sm text-zinc-500 dark:text-zinc-500 mt-0.5">
          <span id="pp-handle">@—</span>
          <span id="pp-region-sep" class="hidden"> · </span>
          <span id="pp-region"></span>
        </p>
        <p id="pp-bio" class="mt-2 text-sm text-zinc-700 dark:text-zinc-300 hidden"></p>
        <p id="pp-since" class="mt-2 text-xs text-zinc-500 dark:text-zinc-500"></p>
        <p id="pp-credentialed" class="hidden mt-2 inline-flex items-center gap-1 rounded-full bg-amber-100 dark:bg-amber-900/30 px-2 py-0.5 text-xs font-semibold text-amber-800 dark:text-amber-300">
          ★ {tr.expert.credentialed_badge}
        </p>
      </div>
      <div class="shrink-0">
        <FollowButton lang={lang} />
      </div>
    </header>

    <section class="grid grid-cols-3 gap-3 mb-8">
      <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4">
        <p id="pp-stat-obs" class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">0</p>
        <p class="text-xs text-zinc-500 dark:text-zinc-400">{tr.profile.total_observations}</p>
      </div>
      <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4">
        <p id="pp-stat-species" class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">0</p>
        <p class="text-xs text-zinc-500 dark:text-zinc-400">{tr.profile.species_count}</p>
      </div>
      <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4">
        <p id="pp-stat-streak" class="text-2xl font-bold text-zinc-900 dark:text-zinc-100">—</p>
        <p class="text-xs text-zinc-500 dark:text-zinc-400">{tr.social.streak_current}</p>
      </div>
    </section>

    <section id="pp-badges-section" class="hidden mb-8">
      <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider mb-3">
        {lang === 'es' ? 'Insignias' : 'Badges'}
      </h2>
      <ul id="pp-badges-list" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2"></ul>
    </section>

    <section>
      <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider mb-3">
        {tr.profile.public_profile_recent}
      </h2>
      <ul id="pp-obs-list" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3"></ul>
      <p id="pp-obs-empty" class="hidden rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700 p-6 text-center text-sm text-zinc-500 dark:text-zinc-400">
        {tr.profile.public_profile_no_observations}
      </p>
    </section>
  </article>
</div>

<script>
  import { getSupabase } from '../lib/supabase';
  import { formatStreakDays, type StreakRow } from '../lib/social';

  type Lang = 'en' | 'es';

  type PublicUser = {
    id: string;
    username: string | null;
    display_name: string | null;
    bio: string | null;
    avatar_url: string | null;
    region_primary: string | null;
    profile_public: boolean;
    gamification_opt_in: boolean;
    is_expert: boolean | null;
    credentialed_researcher: boolean | null;
    joined_at: string | null;
    observation_count: number | null;
    stats_json: { species_count?: number } | null;
  };

  type ObsRow = {
    id: string;
    observed_at: string;
    state_province: string | null;
    identifications: Array<{ scientific_name: string; is_primary: boolean }> | { scientific_name: string; is_primary: boolean } | null;
    media_files: Array<{ url: string; is_primary: boolean }>;
  };

  type BadgeRow = {
    awarded_at: string;
    badges: { key: string; name_es: string; name_en: string; tier: string; category: string } | null;
  };

  function initialsAvatar(name: string): string {
    const clean = (name || '?').trim().slice(0, 2).toUpperCase();
    const svg = `<svg xmlns='http://www.w3.org/2000/svg' width='96' height='96' viewBox='0 0 96 96'><rect width='96' height='96' fill='#10b981'/><text x='50%' y='58%' text-anchor='middle' fill='white' font-family='system-ui,sans-serif' font-size='40' font-weight='700'>${clean}</text></svg>`;
    return 'data:image/svg+xml;utf8,' + encodeURIComponent(svg);
  }

  function show(id: string) { document.getElementById(id)?.classList.remove('hidden'); }
  function hide(id: string) { document.getElementById(id)?.classList.add('hidden'); }

  function tierClass(tier: string): string {
    if (tier === 'platinum') return 'bg-zinc-200 text-zinc-800 dark:bg-zinc-300 dark:text-zinc-900';
    if (tier === 'gold')     return 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300';
    if (tier === 'silver')   return 'bg-zinc-100 text-zinc-700 dark:bg-zinc-800 dark:text-zinc-200';
    return 'bg-orange-50 text-orange-800 dark:bg-orange-900/20 dark:text-orange-300';
  }

  async function init() {
    const root = document.querySelector<HTMLElement>('.rastrum-public-profile');
    if (!root) return;
    const lang = (root.dataset.lang === 'es' ? 'es' : 'en') as Lang;

    const params = new URLSearchParams(window.location.search);
    const username = (params.get('username') || params.get('u') || '').trim();

    if (!username || !/^[a-zA-Z0-9_]{3,30}$/.test(username)) {
      hide('pp-loading');
      const msg = document.getElementById('pp-not-found-msg');
      if (msg) msg.textContent = root.dataset.labelNoUsername ?? '';
      show('pp-not-found');
      return;
    }

    let supabase;
    try {
      supabase = getSupabase();
    } catch {
      hide('pp-loading');
      show('pp-not-found');
      return;
    }

    const { data: profile } = await supabase
      .from('users')
      .select('id, username, display_name, bio, avatar_url, region_primary, profile_public, gamification_opt_in, is_expert, credentialed_researcher, joined_at, observation_count, stats_json')
      .eq('username', username)
      .maybeSingle<PublicUser>();

    if (!profile) {
      hide('pp-loading');
      show('pp-not-found');
      return;
    }

    if (!profile.profile_public) {
      hide('pp-loading');
      const msg = document.getElementById('pp-not-found-msg');
      if (msg) msg.textContent = root.dataset.labelPrivate ?? '';
      show('pp-not-found');
      return;
    }

    hide('pp-loading');
    show('pp-profile');

    const name = profile.display_name || profile.username || 'Observer';
    const nameEl = document.getElementById('pp-name');
    if (nameEl) nameEl.textContent = name;
    document.title = `${name} — Rastrum`;

    const handleEl = document.getElementById('pp-handle');
    if (handleEl) handleEl.textContent = profile.username ? '@' + profile.username : '';

    const avatarEl = document.getElementById('pp-avatar') as HTMLImageElement | null;
    if (avatarEl) {
      avatarEl.src = profile.avatar_url || initialsAvatar(name);
      avatarEl.alt = name;
    }

    if (profile.region_primary) {
      const rEl = document.getElementById('pp-region');
      if (rEl) rEl.textContent = profile.region_primary;
      show('pp-region-sep');
    }

    if (profile.bio) {
      const bEl = document.getElementById('pp-bio');
      if (bEl) {
        bEl.textContent = profile.bio;
        bEl.classList.remove('hidden');
      }
    }

    if (profile.joined_at) {
      const sinceLabel = root.dataset.labelMemberSince ?? '';
      const sEl = document.getElementById('pp-since');
      if (sEl) sEl.textContent = `${sinceLabel}: ${new Date(profile.joined_at).toLocaleDateString(lang === 'es' ? 'es' : 'en')}`;
    }

    if (profile.credentialed_researcher) show('pp-credentialed');

    const obsEl = document.getElementById('pp-stat-obs');
    if (obsEl) obsEl.textContent = String(profile.observation_count ?? 0);
    const spEl = document.getElementById('pp-stat-species');
    if (spEl) spEl.textContent = String(profile.stats_json?.species_count ?? 0);

    // Streak (only if user opted in to gamification — RLS gates the row anyway)
    const streakEl = document.getElementById('pp-stat-streak');
    if (profile.gamification_opt_in && streakEl) {
      const { data: streak } = await supabase
        .from('user_streaks')
        .select('current_days, longest_days, last_qualifying_day, updated_at')
        .eq('user_id', profile.id)
        .maybeSingle<StreakRow>();
      streakEl.textContent = formatStreakDays(streak?.current_days ?? 0, lang);
    }

    // Wire FollowButton with the resolved user_id.
    const followRoot = document.querySelector<HTMLElement>('.rastrum-public-profile .rastrum-follow-btn');
    if (followRoot) {
      followRoot.dataset.targetId = profile.id;
      document.dispatchEvent(new CustomEvent('rastrum:follow-ready'));
    }

    // Badges
    if (profile.gamification_opt_in) {
      const { data: badgeRows } = await supabase
        .from('user_badges')
        .select('awarded_at, badges:badge_key(key,name_es,name_en,tier,category)')
        .eq('user_id', profile.id)
        .is('revoked_at', null)
        .order('awarded_at', { ascending: false })
        .limit(20);
      const badges = (badgeRows ?? []) as unknown as BadgeRow[];
      const list = document.getElementById('pp-badges-list');
      if (list && badges.length) {
        show('pp-badges-section');
        list.innerHTML = badges.map(b => {
          if (!b.badges) return '';
          const name = lang === 'es' ? b.badges.name_es : b.badges.name_en;
          return `<li class="rounded-lg border border-zinc-200 dark:border-zinc-800 p-3">
            <div class="text-xs uppercase tracking-wider mb-1 ${tierClass(b.badges.tier)} inline-block px-1.5 py-0.5 rounded">${b.badges.tier}</div>
            <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100">${name}</p>
            <p class="text-xs text-zinc-500 capitalize">${b.badges.category}</p>
          </li>`;
        }).join('');
      }
    }

    // Recent observations (top 12)
    const { data: obs } = await supabase
      .from('observations')
      .select('id, observed_at, state_province, identifications!inner(scientific_name, is_primary), media_files(url, is_primary)')
      .eq('observer_id', profile.id)
      .eq('sync_status', 'synced')
      .eq('identifications.is_primary', true)
      .order('observed_at', { ascending: false })
      .limit(12);

    const obsList = document.getElementById('pp-obs-list');
    const obsEmpty = document.getElementById('pp-obs-empty');
    if (!obs?.length) {
      obsEmpty?.classList.remove('hidden');
      return;
    }

    const shareBase = root.dataset.shareObsBase ?? '/share/obs/';
    const unknown = root.dataset.labelUnknownSpecies ?? 'Unidentified';
    if (obsList) {
      obsList.innerHTML = (obs as ObsRow[]).map(o => {
        const ident = Array.isArray(o.identifications) ? o.identifications[0] : o.identifications;
        const photo = (o.media_files ?? []).find(m => m.is_primary)?.url ?? (o.media_files ?? [])[0]?.url ?? '';
        const date = new Date(o.observed_at).toLocaleDateString(lang === 'es' ? 'es' : 'en');
        const name = ident?.scientific_name ?? unknown;
        const safeName = name.replace(/</g, '&lt;');
        const region = (o.state_province ?? '').replace(/</g, '&lt;');
        return `<li class="rounded-lg overflow-hidden border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50">
          <a href="${shareBase}?id=${o.id}" class="block">
            <div class="aspect-square bg-zinc-100 dark:bg-zinc-800">
              ${photo ? `<img src="${photo}" alt="${safeName}" class="w-full h-full object-cover" loading="lazy" />` : ''}
            </div>
            <div class="p-2">
              <p class="text-xs italic font-medium text-zinc-900 dark:text-zinc-100 truncate">${safeName}</p>
              <p class="text-[11px] text-zinc-500 truncate">${date}${region ? ' · ' + region : ''}</p>
            </div>
          </a>
        </li>`;
      }).join('');
    }
  }

  init().catch(() => {
    hide('pp-loading');
    show('pp-not-found');
  });
</script>
