---
import { t } from '../i18n/utils';
interface Props { lang: 'en' | 'es' }
const { lang } = Astro.props;
const tr = t(lang);
const s = (tr as unknown as { docs_sponsorships: Record<string, string> }).docs_sponsorships;
---

<article class="prose prose-zinc dark:prose-invert max-w-none">
  <h1>{s.title}</h1>
  <p class="lead text-lg text-zinc-600 dark:text-zinc-400">
    {s.subtitle}
  </p>

  <h2>{s.what_heading}</h2>
  <p>{s.what_body}</p>

  <h2>{s.sponsor_heading}</h2>
  <p>{s.sponsor_body}</p>
  <ol>
    <li>{s.sponsor_step_1}</li>
    <li>{s.sponsor_step_2}</li>
    <li>{s.sponsor_step_3}</li>
    <li>{s.sponsor_step_4}</li>
  </ol>

  <h2>{s.request_heading}</h2>
  <p>{s.request_body}</p>
  <p>{s.request_detail}</p>

  <h2>{s.pool_heading}</h2>
  <p>{s.pool_body}</p>
  <p>{s.pool_detail}</p>

  <h2>{s.rules_heading}</h2>
  <ul>
    <li><strong>{s.rule_byo_wins}:</strong> {s.rule_byo_wins_detail}</li>
    <li><strong>{s.rule_monthly_cap}:</strong> {s.rule_monthly_cap_detail}</li>
    <li><strong>{s.rule_auto_pause}:</strong> {s.rule_auto_pause_detail}</li>
    <li><strong>{s.rule_karma}:</strong> {s.rule_karma_detail}</li>
  </ul>

  <h2>{s.privacy_heading}</h2>
  <p>{s.privacy_body}</p>
  <ul>
    <li>{s.privacy_sponsor_public}</li>
    <li>{s.privacy_beneficiary_private}</li>
    <li>{s.privacy_mutual_optin}</li>
  </ul>

  <h2>{s.cost_heading}</h2>
  <p>{s.cost_body}</p>
  <p>{s.cost_detail}</p>

  <h2>{s.faq_heading}</h2>
  <h3>{s.faq_photos_q}</h3>
  <p>{s.faq_photos_a}</p>

  <h3>{s.faq_revoke_q}</h3>
  <p>{s.faq_revoke_a}</p>

  <h3>{s.faq_self_q}</h3>
  <p>{s.faq_self_a}</p>

  <p class="text-sm text-zinc-500 mt-8">
    {s.spec_link}
    <a href="https://github.com/ArtemioPadilla/rastrum/blob/main/docs/specs/modules/27-ai-sponsorships.md" class="underline">docs/specs/modules/27-ai-sponsorships.md</a>
  </p>
</article>
