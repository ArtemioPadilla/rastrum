---
/**
 * ConsoleModDisputesView — moderator queue for license disputes.
 * Gate: moderator OR admin role.
 * Queries the `license_disputes` table; gracefully handles missing table.
 */
import { t } from '../i18n/utils';

interface Props { lang: 'en' | 'es' }
const { lang } = Astro.props;
const tr = t(lang);
const isEs = lang === 'es';
---

<section class="max-w-5xl">
  <div id="disputes-not-auth" class="hidden rounded border border-amber-300 dark:border-amber-700/60 bg-amber-50 dark:bg-amber-900/20 p-3 text-sm text-amber-900 dark:text-amber-100">
    {tr.console.not_authorized}
  </div>

  <div id="disputes-shell" class="hidden space-y-4">
    <div class="flex items-center justify-between flex-wrap gap-2">
      <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100">
        {isEs ? 'Disputas de licencia' : 'License disputes'}
      </h2>
      <div class="flex items-center gap-2">
        <select id="disputes-status-filter" class="rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-1.5 text-sm">
          <option value="open">{isEs ? 'Abiertas' : 'Open'}</option>
          <option value="resolved">{isEs ? 'Resueltas' : 'Resolved'}</option>
          <option value="all">{isEs ? 'Todas' : 'All'}</option>
        </select>
        <button id="disputes-refresh" type="button" class="rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-1.5 text-sm hover:bg-zinc-50 dark:hover:bg-zinc-800/40">
          {isEs ? 'Actualizar' : 'Refresh'}
        </button>
      </div>
    </div>

    <div id="disputes-loading" class="text-sm text-zinc-500 dark:text-zinc-400 italic">
      {isEs ? 'Cargando disputas…' : 'Loading disputes…'}
    </div>

    <div id="disputes-not-configured" class="hidden rounded-lg border border-zinc-200 dark:border-zinc-800 p-8 text-center">
      <p class="text-zinc-500 dark:text-zinc-400">
        {isEs ? 'La tabla de disputas de licencia no está configurada aún.' : 'License disputes table not configured yet.'}
      </p>
    </div>

    <div id="disputes-empty" class="hidden rounded-lg border border-zinc-200 dark:border-zinc-800 p-8 text-center">
      <p class="text-zinc-500 dark:text-zinc-400">
        {isEs ? 'No hay disputas de licencia pendientes.' : 'No pending license disputes.'}
      </p>
    </div>

    <div id="disputes-list" class="hidden space-y-2"></div>

    <nav id="disputes-pager" class="hidden flex items-center justify-between text-sm">
      <button id="disputes-prev" type="button" class="px-3 py-1.5 rounded-lg border border-zinc-300 dark:border-zinc-700 disabled:opacity-50" disabled>
        ←
      </button>
      <span id="disputes-page" class="text-zinc-500"></span>
      <button id="disputes-next" type="button" class="px-3 py-1.5 rounded-lg border border-zinc-300 dark:border-zinc-700 disabled:opacity-50" disabled>
        →
      </button>
    </nav>
  </div>
</section>

<script>
  import { getSupabase } from '../lib/supabase';
  import { getUserRoles } from '../lib/user-roles';
  import { escapeHtml } from '../lib/escape';

  const PAGE_SIZE = 20;
  let currentPage = 0;
  let currentFilter = 'open';

  const isEs = document.documentElement.lang === 'es';
  const shell = document.getElementById('disputes-shell');
  const notAuth = document.getElementById('disputes-not-auth');
  const listEl = document.getElementById('disputes-list');
  const loadingEl = document.getElementById('disputes-loading');
  const emptyEl = document.getElementById('disputes-empty');
  const notConfiguredEl = document.getElementById('disputes-not-configured');
  const pagerEl = document.getElementById('disputes-pager');
  const pageLabel = document.getElementById('disputes-page');
  const prevBtn = document.getElementById('disputes-prev') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('disputes-next') as HTMLButtonElement | null;
  const filterEl = document.getElementById('disputes-status-filter') as HTMLSelectElement | null;
  const refreshBtn = document.getElementById('disputes-refresh');

  function show(id: string) { document.getElementById(id)?.classList.remove('hidden'); }
  function hide(id: string) { document.getElementById(id)?.classList.add('hidden'); }

  function statusPill(s: string): string {
    const cls: Record<string, string> = {
      open: 'bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300',
      resolved: 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300',
      dismissed: 'bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300',
    };
    return `<span class="text-[10px] uppercase tracking-wider px-1.5 py-0.5 rounded ${cls[s] ?? 'bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-300'}">${escapeHtml(s)}</span>`;
  }

  async function loadDisputes(): Promise<void> {
    if (!listEl || !loadingEl) return;
    loadingEl.classList.remove('hidden');
    emptyEl?.classList.add('hidden');
    notConfiguredEl?.classList.add('hidden');
    listEl.classList.add('hidden');
    listEl.innerHTML = '';
    pagerEl?.classList.add('hidden');

    try {
      const supabase = getSupabase();
      let query = supabase
        .from('license_disputes')
        .select('*', { count: 'exact' })
        .order('created_at', { ascending: false })
        .range(currentPage * PAGE_SIZE, (currentPage + 1) * PAGE_SIZE - 1);

      if (currentFilter !== 'all') {
        query = query.eq('status', currentFilter);
      }

      const { data, count, error } = await query;
      loadingEl.classList.add('hidden');

      if (error) {
        if (error.code === '42P01' || error.message.includes('does not exist') || error.message.includes('relation')) {
          notConfiguredEl?.classList.remove('hidden');
          return;
        }
        listEl.innerHTML = `<p class="text-sm text-red-600">${escapeHtml(error.message)}</p>`;
        listEl.classList.remove('hidden');
        return;
      }

      if (!data || data.length === 0) {
        emptyEl?.classList.remove('hidden');
        return;
      }

      for (const dispute of data) {
        const date = new Date(dispute.created_at as string).toLocaleDateString(
          isEs ? 'es' : 'en',
          { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' },
        );

        const row = document.createElement('div');
        row.className = 'rounded-lg border border-zinc-200 dark:border-zinc-800 p-3 flex items-start justify-between gap-3';
        row.innerHTML = `
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 text-sm">
              <span class="font-medium text-zinc-900 dark:text-zinc-100">${escapeHtml(String(dispute.observation_id ?? dispute.id).slice(0, 8))}…</span>
              ${statusPill(dispute.status as string)}
            </div>
            <p class="text-xs text-zinc-500 mt-0.5 truncate">${escapeHtml(String(dispute.reason ?? (isEs ? 'Sin razón' : 'No reason')))}</p>
            <p class="text-xs text-zinc-400 mt-0.5">${escapeHtml(date)}</p>
          </div>
        `;
        listEl.appendChild(row);
      }

      listEl.classList.remove('hidden');

      const total = count ?? 0;
      const totalPages = Math.ceil(total / PAGE_SIZE);
      if (totalPages > 1) {
        pagerEl?.classList.remove('hidden');
        if (pageLabel) pageLabel.textContent = `${currentPage + 1} / ${totalPages}`;
        if (prevBtn) prevBtn.disabled = currentPage === 0;
        if (nextBtn) nextBtn.disabled = currentPage >= totalPages - 1;
      }
    } catch (err) {
      loadingEl.classList.add('hidden');
      if (notConfiguredEl) {
        notConfiguredEl.classList.remove('hidden');
      }
    }
  }

  filterEl?.addEventListener('change', () => {
    currentFilter = filterEl.value;
    currentPage = 0;
    void loadDisputes();
  });

  prevBtn?.addEventListener('click', () => {
    if (currentPage > 0) { currentPage--; void loadDisputes(); }
  });
  nextBtn?.addEventListener('click', () => {
    currentPage++;
    void loadDisputes();
  });
  refreshBtn?.addEventListener('click', () => void loadDisputes());

  (async () => {
    const supabase = getSupabase();
    const { data: { session } } = await supabase.auth.getSession();
    if (!session?.user) { show('disputes-not-auth'); return; }
    const myRoles = await getUserRoles(session.user.id);
    if (!myRoles.has('moderator') && !myRoles.has('admin')) {
      show('disputes-not-auth');
      return;
    }
    shell?.classList.remove('hidden');
    await loadDisputes();
  })().catch(() => { show('disputes-not-auth'); });
</script>
