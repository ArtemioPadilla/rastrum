---
import { t } from '../i18n/utils';

interface Props { lang: 'en' | 'es' }
const { lang } = Astro.props;
const tr = t(lang);
const isEs = lang === 'es';

interface StackRow { layer: string; choice: string; rationale: string }
const stack: StackRow[] = [
  { layer: isEs ? 'Frontend'         : 'Frontend',         choice: 'Astro 5 (output: static)',     rationale: isEs ? 'Sitio estático + PWA shell, sin servidor Node, deploy a GitHub Pages.' : 'Static site + PWA shell, no Node server, deploys to GitHub Pages.' },
  { layer: isEs ? 'BD local'         : 'Local DB',         choice: 'Dexie (IndexedDB)',             rationale: isEs ? 'Outbox offline-first; observaciones se guardan localmente y sincronizan al reconectar.' : 'Offline-first outbox; observations save locally and sync when online.' },
  { layer: isEs ? 'Backend'          : 'Backend',          choice: 'Supabase (Postgres + PostGIS + RLS)', rationale: isEs ? 'Edge Functions Deno, RLS por fila, particionado mensual, cron en pg_cron.' : 'Deno Edge Functions, row-level RLS, monthly partitioning, pg_cron schedules.' },
  { layer: isEs ? 'Almacenamiento'   : 'Object storage',   choice: 'Cloudflare R2',                 rationale: isEs ? 'Egreso cero; observaciones, modelos ONNX y pmtiles en media.rastrum.org.' : 'Zero egress; observations, ONNX models and pmtiles served from media.rastrum.org.' },
  { layer: isEs ? 'IA en cliente'    : 'In-browser AI',    choice: 'WebLLM + onnxruntime-web',      rationale: isEs ? 'Phi-3.5-vision (~2.4 GB), Llama-3.2-1B, EfficientNet-Lite0, BirdNET-Lite, MegaDetector v5a (~134 MB).' : 'Phi-3.5-vision (~2.4 GB), Llama-3.2-1B, EfficientNet-Lite0, BirdNET-Lite, MegaDetector v5a (~134 MB).' },
  { layer: isEs ? 'Mapas'            : 'Maps',             choice: 'MapLibre + pmtiles',            rationale: isEs ? 'OpenFreeMap online, archivo Mexico pmtiles offline desde R2 (~48 MB).' : 'OpenFreeMap online, offline Mexico pmtiles archive from R2 (~48 MB).' },
];

const externals = [
  { name: 'PlantNet API',    role: isEs ? 'ID de plantas (cuota gratis 500/día)' : 'Plant ID (free 500/day quota)' },
  { name: 'Anthropic Claude', role: isEs ? 'Visión Haiku 4.5 (BYO key)' : 'Haiku 4.5 vision (BYO key)' },
  { name: 'OAuth providers',  role: isEs ? 'Google + GitHub para auth Supabase' : 'Google + GitHub for Supabase auth' },
  { name: 'OpenMeteo',        role: isEs ? 'Backfill de clima (sin key)' : 'Weather backfill (no key)' },
  { name: 'OpenFreeMap',      role: isEs ? 'Mosaicos del estilo base' : 'Base map style tiles' },
];

const intro = isEs
  ? 'Rastrum es un sitio Astro estático con un service worker, un outbox Dexie y un backend Supabase de Postgres + Edge Functions. Todo lo dinámico vive en el navegador (cliente PWA) o en Edge Functions Deno — no hay servidor Node propio. Las cuatro vistas siguientes muestran cómo fluyen los datos entre esas capas.'
  : 'Rastrum is a static Astro site with a service worker, a Dexie outbox, and a Supabase Postgres + Edge Functions backend. Everything dynamic lives in the browser (PWA client) or in Deno Edge Functions — there is no Node server we run. The four diagrams below show how data flows between those layers.';
---

<article class="space-y-10">
  <header>
    <h1 class="text-3xl font-bold tracking-tight mb-4">{tr.docs.sections.architecture}</h1>
    <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-3xl">{tr.docs.descriptions.architecture}</p>
    <p class="text-sm text-zinc-700 dark:text-zinc-300 max-w-3xl mt-4 leading-relaxed">{intro}</p>
  </header>

  <!-- ========================================================== -->
  <!-- DIAGRAM 1 — System overview (5 layers/columns)             -->
  <!-- ========================================================== -->
  <section>
    <h2 id="overview" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-2 flex items-center gap-2">
      <span class="text-zinc-400 dark:text-zinc-600 font-mono">01</span>
      <a href="#overview" class="hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors">{isEs ? 'Vista del sistema' : 'System overview'}</a>
    </h2>
    <p class="text-sm text-zinc-600 dark:text-zinc-400 max-w-3xl mb-4">
      {isEs
        ? 'Cinco capas. El cliente PWA es el centro: lee/escribe en la BD local Dexie y sirve pixeles mientras el service worker cachea el shell. La API y BD viven en Supabase; los binarios viven en R2; los servicios externos son terceros.'
        : 'Five layers. The PWA client is the centre: it reads and writes the local Dexie DB and renders pixels while the service worker caches the shell. The API and DB live in Supabase; binaries live in R2; external services are third-party.'}
    </p>
    <div class="not-prose rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-3 sm:p-4 overflow-x-auto">
      <svg viewBox="0 0 900 460" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto min-w-[720px] max-w-full text-zinc-800 dark:text-zinc-200" aria-label={isEs ? 'Diagrama de arquitectura general' : 'System overview diagram'}>
        <defs>
          <marker id="arr1" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M0,0 L10,5 L0,10 z" fill="currentColor"/>
          </marker>
          <filter id="sh1" x="-10%" y="-10%" width="120%" height="120%">
            <feDropShadow dx="0" dy="2" stdDeviation="2" flood-opacity="0.10"/>
          </filter>
        </defs>

        {/* Column 1 — Client */}
        <g filter="url(#sh1)">
          <rect x="20" y="40" width="155" height="380" rx="14" fill="#ecfdf5" stroke="#10b981" stroke-width="1.5"/>
        </g>
        <text x="97.5" y="64" text-anchor="middle" font-size="13" font-weight="700" fill="#047857">{isEs ? 'Cliente (PWA)' : 'Client (PWA)'}</text>
        <text x="97.5" y="82" text-anchor="middle" font-size="10" fill="#065f46">browser</text>
        <g font-size="11" fill="#065f46">
          <rect x="36" y="100" width="124" height="40" rx="6" fill="#ffffff" stroke="#10b981" stroke-width="1"/>
          <text x="97.5" y="120" text-anchor="middle" font-weight="600">Astro 5 static</text>
          <text x="97.5" y="133" text-anchor="middle" font-size="9">{isEs ? 'EN/ES paridad' : 'EN/ES parity'}</text>
          <rect x="36" y="155" width="124" height="40" rx="6" fill="#ffffff" stroke="#10b981" stroke-width="1"/>
          <text x="97.5" y="175" text-anchor="middle" font-weight="600">Service Worker</text>
          <text x="97.5" y="188" text-anchor="middle" font-size="9">{isEs ? 'shell cache' : 'shell cache'}</text>
          <rect x="36" y="210" width="124" height="40" rx="6" fill="#ffffff" stroke="#10b981" stroke-width="1"/>
          <text x="97.5" y="230" text-anchor="middle" font-weight="600">Dexie outbox</text>
          <text x="97.5" y="243" text-anchor="middle" font-size="9">IndexedDB</text>
          <rect x="36" y="265" width="124" height="40" rx="6" fill="#ffffff" stroke="#10b981" stroke-width="1"/>
          <text x="97.5" y="285" text-anchor="middle" font-weight="600">{isEs ? 'IA on-device' : 'On-device AI'}</text>
          <text x="97.5" y="298" text-anchor="middle" font-size="9">WebLLM · ONNX</text>
        </g>

        {/* Column 2 — CDN */}
        <g filter="url(#sh1)">
          <rect x="195" y="40" width="155" height="380" rx="14" fill="#fef3c7" stroke="#f59e0b" stroke-width="1.5"/>
        </g>
        <text x="272.5" y="64" text-anchor="middle" font-size="13" font-weight="700" fill="#92400e">CDN · R2</text>
        <text x="272.5" y="82" text-anchor="middle" font-size="10" fill="#78350f">media.rastrum.org</text>
        <g font-size="11" fill="#78350f">
          <rect x="211" y="100" width="124" height="40" rx="6" fill="#ffffff" stroke="#f59e0b" stroke-width="1"/>
          <text x="272.5" y="120" text-anchor="middle" font-weight="600">{isEs ? 'Fotos / audio / video' : 'Photos / audio / video'}</text>
          <text x="272.5" y="133" text-anchor="middle" font-size="9">observations/&lt;id&gt;/...</text>
          <rect x="211" y="155" width="124" height="40" rx="6" fill="#ffffff" stroke="#f59e0b" stroke-width="1"/>
          <text x="272.5" y="175" text-anchor="middle" font-weight="600">{isEs ? 'Modelos ONNX' : 'ONNX models'}</text>
          <text x="272.5" y="188" text-anchor="middle" font-size="9">birdnet · efficientnet</text>
          <rect x="211" y="210" width="124" height="40" rx="6" fill="#ffffff" stroke="#f59e0b" stroke-width="1"/>
          <text x="272.5" y="230" text-anchor="middle" font-weight="600">pmtiles MX</text>
          <text x="272.5" y="243" text-anchor="middle" font-size="9">~48 MB offline map</text>
        </g>

        {/* Column 3 — API */}
        <g filter="url(#sh1)">
          <rect x="370" y="40" width="155" height="380" rx="14" fill="#e0f2fe" stroke="#0ea5e9" stroke-width="1.5"/>
        </g>
        <text x="447.5" y="64" text-anchor="middle" font-size="13" font-weight="700" fill="#0369a1">API</text>
        <text x="447.5" y="82" text-anchor="middle" font-size="10" fill="#075985">Edge Functions · Deno</text>
        <g font-size="11" fill="#075985">
          <rect x="386" y="100" width="124" height="32" rx="6" fill="#ffffff" stroke="#0ea5e9" stroke-width="1"/>
          <text x="447.5" y="120" text-anchor="middle" font-weight="600">identify</text>
          <rect x="386" y="138" width="124" height="32" rx="6" fill="#ffffff" stroke="#0ea5e9" stroke-width="1"/>
          <text x="447.5" y="158" text-anchor="middle" font-weight="600">api · mcp</text>
          <rect x="386" y="176" width="124" height="32" rx="6" fill="#ffffff" stroke="#0ea5e9" stroke-width="1"/>
          <text x="447.5" y="196" text-anchor="middle" font-weight="600">export-dwca</text>
          <rect x="386" y="214" width="124" height="32" rx="6" fill="#ffffff" stroke="#0ea5e9" stroke-width="1"/>
          <text x="447.5" y="234" text-anchor="middle" font-weight="600">share-card</text>
          <rect x="386" y="252" width="124" height="32" rx="6" fill="#ffffff" stroke="#0ea5e9" stroke-width="1"/>
          <text x="447.5" y="272" text-anchor="middle" font-weight="600">enrich-environment</text>
          <rect x="386" y="290" width="124" height="32" rx="6" fill="#ffffff" stroke="#0ea5e9" stroke-width="1"/>
          <text x="447.5" y="310" text-anchor="middle" font-weight="600">recompute-streaks</text>
          <rect x="386" y="328" width="124" height="32" rx="6" fill="#ffffff" stroke="#0ea5e9" stroke-width="1"/>
          <text x="447.5" y="348" text-anchor="middle" font-weight="600">award-badges</text>
          <rect x="386" y="366" width="124" height="32" rx="6" fill="#ffffff" stroke="#0ea5e9" stroke-width="1"/>
          <text x="447.5" y="386" text-anchor="middle" font-weight="600">get-upload-url · tokens</text>
        </g>

        {/* Column 4 — Database */}
        <g filter="url(#sh1)">
          <rect x="545" y="40" width="155" height="380" rx="14" fill="#ede9fe" stroke="#8b5cf6" stroke-width="1.5"/>
        </g>
        <text x="622.5" y="64" text-anchor="middle" font-size="13" font-weight="700" fill="#5b21b6">Database</text>
        <text x="622.5" y="82" text-anchor="middle" font-size="10" fill="#4c1d95">Postgres · PostGIS · RLS</text>
        <g font-size="11" fill="#4c1d95">
          <rect x="561" y="100" width="124" height="40" rx="6" fill="#ffffff" stroke="#8b5cf6" stroke-width="1"/>
          <text x="622.5" y="120" text-anchor="middle" font-weight="600">observations</text>
          <text x="622.5" y="133" text-anchor="middle" font-size="9">media_files · taxa</text>
          <rect x="561" y="155" width="124" height="40" rx="6" fill="#ffffff" stroke="#8b5cf6" stroke-width="1"/>
          <text x="622.5" y="175" text-anchor="middle" font-weight="600">identifications</text>
          <text x="622.5" y="188" text-anchor="middle" font-size="9">activity_events</text>
          <rect x="561" y="210" width="124" height="40" rx="6" fill="#ffffff" stroke="#8b5cf6" stroke-width="1"/>
          <text x="622.5" y="230" text-anchor="middle" font-weight="600">users · badges</text>
          <text x="622.5" y="243" text-anchor="middle" font-size="9">follows · watchlists</text>
          <rect x="561" y="265" width="124" height="40" rx="6" fill="#ffffff" stroke="#8b5cf6" stroke-width="1"/>
          <text x="622.5" y="285" text-anchor="middle" font-weight="600">user_api_tokens</text>
          <text x="622.5" y="298" text-anchor="middle" font-size="9">rst_* · SHA-256</text>
          <rect x="561" y="320" width="124" height="40" rx="6" fill="#ffffff" stroke="#8b5cf6" stroke-width="1"/>
          <text x="622.5" y="340" text-anchor="middle" font-weight="600">pg_cron</text>
          <text x="622.5" y="353" text-anchor="middle" font-size="9">{isEs ? 'rachas + insignias' : 'streaks + badges'}</text>
        </g>

        {/* Column 5 — External */}
        <g filter="url(#sh1)">
          <rect x="720" y="40" width="155" height="380" rx="14" fill="#fafafa" stroke="#71717a" stroke-width="1.5"/>
        </g>
        <text x="797.5" y="64" text-anchor="middle" font-size="13" font-weight="700" fill="#27272a">{isEs ? 'Externos' : 'External'}</text>
        <text x="797.5" y="82" text-anchor="middle" font-size="10" fill="#3f3f46">{isEs ? 'terceros' : 'third-party'}</text>
        <g font-size="11" fill="#27272a">
          <rect x="736" y="100" width="124" height="40" rx="6" fill="#ffffff" stroke="#71717a" stroke-width="1"/>
          <text x="797.5" y="120" text-anchor="middle" font-weight="600">PlantNet</text>
          <text x="797.5" y="133" text-anchor="middle" font-size="9">{isEs ? 'cuota gratis 500/día' : 'free 500/day quota'}</text>
          <rect x="736" y="155" width="124" height="40" rx="6" fill="#ffffff" stroke="#71717a" stroke-width="1"/>
          <text x="797.5" y="175" text-anchor="middle" font-weight="600">Anthropic Claude</text>
          <text x="797.5" y="188" text-anchor="middle" font-size="9">BYO key</text>
          <rect x="736" y="210" width="124" height="40" rx="6" fill="#ffffff" stroke="#71717a" stroke-width="1"/>
          <text x="797.5" y="230" text-anchor="middle" font-weight="600">OAuth</text>
          <text x="797.5" y="243" text-anchor="middle" font-size="9">Google · GitHub</text>
          <rect x="736" y="265" width="124" height="40" rx="6" fill="#ffffff" stroke="#71717a" stroke-width="1"/>
          <text x="797.5" y="285" text-anchor="middle" font-weight="600">OpenMeteo</text>
          <text x="797.5" y="298" text-anchor="middle" font-size="9">{isEs ? 'sin key' : 'no key'}</text>
          <rect x="736" y="320" width="124" height="40" rx="6" fill="#ffffff" stroke="#71717a" stroke-width="1"/>
          <text x="797.5" y="340" text-anchor="middle" font-weight="600">OpenFreeMap</text>
          <text x="797.5" y="353" text-anchor="middle" font-size="9">{isEs ? 'estilo base' : 'base style'}</text>
        </g>

        {/* Arrows: client ↔ CDN, client ↔ API, API ↔ DB, API → External */}
        <g stroke="currentColor" stroke-width="1.5" fill="none" marker-end="url(#arr1)">
          {/* Client → CDN */}
          <path d="M175,160 L195,160"/>
          {/* CDN → Client */}
          <path d="M195,180 L175,180" marker-end="url(#arr1)"/>
          {/* Client → API */}
          <path d="M175,290 C260,290 280,290 370,200"/>
          {/* API → DB */}
          <path d="M525,200 L545,200"/>
          {/* DB → API */}
          <path d="M545,260 L525,260" marker-end="url(#arr1)"/>
          {/* API → External */}
          <path d="M525,300 C600,300 650,250 720,200"/>
        </g>
      </svg>
    </div>
    <p class="text-xs text-zinc-500 dark:text-zinc-500 mt-3 italic max-w-3xl">
      {isEs
        ? 'Flujos principales: el cliente carga modelos / fotos desde R2, llama a Edge Functions para identificar y exportar, y nunca habla directamente con servicios externos — la Edge Function intermedia para mantener las API keys del operador en el backend.'
        : 'Principal flows: the client loads models/photos from R2, calls Edge Functions to identify and export, and never talks to external services directly — the Edge Function brokers calls so operator API keys stay backend-side.'}
    </p>
  </section>

  <!-- ========================================================== -->
  <!-- DIAGRAM 2 — Identification cascade (parallel race)         -->
  <!-- ========================================================== -->
  <section>
    <h2 id="cascade" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-2 flex items-center gap-2">
      <span class="text-zinc-400 dark:text-zinc-600 font-mono">02</span>
      <a href="#cascade" class="hover:text-emerald-600 dark:hover:text-emerald-400 transition-colors">{isEs ? 'Cascada de identificación' : 'Identification cascade'}</a>
    </h2>
    <p class="text-sm text-zinc-600 dark:text-zinc-400 max-w-3xl mb-4">
      {isEs
        ? 'En /identify, el blob de la foto se reparte a tres ejecutores en paralelo. El primero que devuelve confianza ≥ 0.5 gana; los demás se cancelan vía AbortController. Esto reemplaza la cascada serial original (PlantNet → Claude → Phi en orden) que hacía esperar ~10 s a fotos de no-plantas.'
        : 'On /identify, the photo blob fans out to three runners in parallel. First responder with confidence ≥ 0.5 wins; the others are cancelled via AbortController. This replaces the original serial cascade (PlantNet → Claude → Phi in order) which made non-plant photos wait ~10 s.'}
    </p>
    <div class="not-prose rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-3 sm:p-4 overflow-x-auto">
      <svg viewBox="0 0 900 400" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto min-w-[720px] max-w-full text-zinc-800 dark:text-zinc-200" aria-label={isEs ? 'Diagrama de cascada de identificación paralela' : 'Parallel identification cascade diagram'}>
        <defs>
          <marker id="arr2" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M0,0 L10,5 L0,10 z" fill="currentColor"/>
          </marker>
          <marker id="arr2-abort" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M0,0 L10,5 L0,10 z" fill="#9ca3af"/>
          </marker>
          <marker id="arr2-win" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
            <path d="M0,0 L10,5 L0,10 z" fill="#10b981"/>
          </marker>
          <filter id="sh2" x="-10%" y="-10%" width="120%" height="120%">
            <feDropShadow dx="0" dy="2" stdDeviation="2" flood-opacity="0.10"/>
          </filter>
        </defs>

        {/* Source — photo blob */}
        <g filter="url(#sh2)">
          <rect x="20" y="170" width="140" height="60" rx="10" fill="#f4f4f5" stroke="#52525b" stroke-width="1.5"/>
        </g>
        <text x="90" y="195" text-anchor="middle" font-size="12" font-weight="700" fill="#27272a">{isEs ? 'Foto' : 'Photo'}</text>
        <text x="90" y="213" text-anchor="middle" font-size="10" fill="#3f3f46">Blob</text>

        {/* Fan-out hub */}
        <g filter="url(#sh2)">
          <rect x="200" y="170" width="160" height="60" rx="10" fill="#dbeafe" stroke="#3b82f6" stroke-width="1.5"/>
        </g>
        <text x="280" y="195" text-anchor="middle" font-size="12" font-weight="700" fill="#1e3a8a">runParallelIdentify</text>
        <text x="280" y="213" text-anchor="middle" font-size="10" fill="#1e40af">{isEs ? 'fan-out · race' : 'fan-out · race'}</text>

        {/* Three parallel runners */}
        <g font-size="11">
          {/* PlantNet — emerald (free-quota / cloud) */}
          <g filter="url(#sh2)">
            <rect x="420" y="40" width="200" height="70" rx="10" fill="#dcfce7" stroke="#16a34a" stroke-width="1.5"/>
          </g>
          <text x="520" y="64" text-anchor="middle" font-weight="700" fill="#166534">PlantNet</text>
          <text x="520" y="80" text-anchor="middle" fill="#166534" font-size="9">{isEs ? 'free-quota · cloud' : 'free-quota · cloud'}</text>
          <text x="520" y="96" text-anchor="middle" fill="#166534" font-size="9" font-style="italic">{isEs ? 'siempre se ejecuta' : 'always runs'}</text>

          {/* Claude — red (BYO key) */}
          <g filter="url(#sh2)">
            <rect x="420" y="165" width="200" height="70" rx="10" fill="#fee2e2" stroke="#dc2626" stroke-width="1.5"/>
          </g>
          <text x="520" y="189" text-anchor="middle" font-weight="700" fill="#991b1b">Claude Haiku 4.5</text>
          <text x="520" y="205" text-anchor="middle" fill="#991b1b" font-size="9">byo-key · cloud</text>
          <text x="520" y="221" text-anchor="middle" fill="#991b1b" font-size="9" font-style="italic">{isEs ? 'si hay BYO key' : 'when BYO key set'}</text>

          {/* Phi — amber (free-NC, on-device when cached) */}
          <g filter="url(#sh2)">
            <rect x="420" y="290" width="200" height="70" rx="10" fill="#fef9c3" stroke="#ca8a04" stroke-width="1.5"/>
          </g>
          <text x="520" y="314" text-anchor="middle" font-weight="700" fill="#854d0e">Phi-3.5-vision</text>
          <text x="520" y="330" text-anchor="middle" fill="#854d0e" font-size="9">{isEs ? 'free-nc · on-device' : 'free-nc · on-device'}</text>
          <text x="520" y="346" text-anchor="middle" fill="#854d0e" font-size="9" font-style="italic">{isEs ? 'si modelo cacheado' : 'when model cached'}</text>
        </g>

        {/* Race judge — accept ≥ 0.5 */}
        <g filter="url(#sh2)">
          <rect x="660" y="170" width="140" height="60" rx="10" fill="#e0e7ff" stroke="#6366f1" stroke-width="1.5"/>
        </g>
        <text x="730" y="192" text-anchor="middle" font-size="12" font-weight="700" fill="#3730a3">{isEs ? 'Primero gana' : 'First wins'}</text>
        <text x="730" y="208" text-anchor="middle" font-size="10" fill="#312e81">accept ≥ 0.5</text>
        <text x="730" y="222" text-anchor="middle" font-size="9" fill="#312e81" font-style="italic">{isEs ? 'AbortController →' : 'AbortController →'}</text>

        {/* IDResult */}
        <g filter="url(#sh2)">
          <rect x="830" y="170" width="60" height="60" rx="10" fill="#10b981" stroke="#047857" stroke-width="1.5"/>
        </g>
        <text x="860" y="195" text-anchor="middle" font-size="11" font-weight="700" fill="#ffffff">IDResult</text>
