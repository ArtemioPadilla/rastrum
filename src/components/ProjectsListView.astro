---
/**
 * ProjectsListView — public + my-projects list. RLS does the gating
 * (the `projects_with_geojson` view returns only rows the caller can
 * see). Hydrates client-side after auth resolution.
 */
import { t, routes } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const tr = t(lang);
const proj = (tr as unknown as { projects: Record<string, string> }).projects;
const newHref = routes.projectNew[lang];
const projectsBase = routes.projects[lang];
---

<section class="max-w-5xl mx-auto px-4 py-8" data-projects-base={projectsBase}>
  <header class="mb-6 flex items-start justify-between gap-3 flex-wrap">
    <div>
      <h1 class="text-2xl font-semibold text-zinc-900 dark:text-zinc-100">{proj.title}</h1>
      <p class="text-sm text-zinc-600 dark:text-zinc-400 mt-1 max-w-2xl">{proj.subtitle}</p>
    </div>
    <a
      id="projects-create-cta"
      href={`/${lang}${newHref}/`}
      class="hidden inline-flex items-center rounded-lg bg-emerald-700 hover:bg-emerald-800 text-white px-3 py-2 text-sm font-semibold min-h-[40px]"
    >{proj.create_cta}</a>
  </header>

  <section class="space-y-8">
    <div data-section="my">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400 mb-2">
        {proj.list_my}
      </h2>
      <div id="projects-mine" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
      <p id="projects-mine-empty" class="hidden text-sm text-zinc-500 dark:text-zinc-400">{proj.empty_mine}</p>
    </div>
    <div data-section="public">
      <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400 mb-2">
        {proj.list_public}
      </h2>
      <div id="projects-public" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
      <p id="projects-public-empty" class="hidden text-sm text-zinc-500 dark:text-zinc-400">{proj.empty_public}</p>
    </div>
  </section>
</section>

<script>
  import { listProjects } from '../lib/projects';
  import { getSupabase } from '../lib/supabase';
  import { escapeHtml } from '../lib/escape';

  const lang = document.documentElement.lang === 'es' ? 'es' : 'en';
  const root = document.querySelector('[data-projects-base]') as HTMLElement | null;
  if (root) {
    const projectsBase = root.dataset.projectsBase ?? '/projects';
    const cta   = document.getElementById('projects-create-cta') as HTMLAnchorElement | null;
    const mine  = document.getElementById('projects-mine');
    const pub   = document.getElementById('projects-public');
    const mineEmpty = document.getElementById('projects-mine-empty');
    const pubEmpty  = document.getElementById('projects-public-empty');

    async function load() {
      const sb = getSupabase();
      const { data: { session } } = await sb.auth.getSession();
      if (session?.user) {
        cta?.classList.remove('hidden');
      }
      let rows;
      try {
        rows = await listProjects();
      } catch (err) {
        console.warn('[rastrum] projects list failed', err);
        rows = [];
      }
      const mineRows = session?.user
        ? rows.filter((r) => r.owner_user_id === session.user.id)
        : [];
      const otherRows = session?.user
        ? rows.filter((r) => r.owner_user_id !== session.user.id && r.visibility === 'public')
        : rows.filter((r) => r.visibility === 'public');

      if (mineRows.length === 0 && session?.user) {
        mineEmpty?.classList.remove('hidden');
      }
      if (otherRows.length === 0) {
        pubEmpty?.classList.remove('hidden');
      }
      if (!session?.user) {
        // Hide the "my projects" section entirely when not signed in.
        document.querySelector('[data-section="my"]')?.classList.add('hidden');
      }

      if (mine) mine.innerHTML = mineRows.map((r) => card(r, projectsBase)).join('');
      if (pub)  pub.innerHTML  = otherRows.map((r) => card(r, projectsBase)).join('');
    }

    function card(r: { slug: string; name: string; name_es: string | null; visibility: string; area_km2: number; updated_at: string }, base: string): string {
      const label = (lang === 'es' && r.name_es) ? r.name_es : r.name;
      const visClass = r.visibility === 'public'
        ? 'bg-emerald-50 dark:bg-emerald-950/40 text-emerald-800 dark:text-emerald-300'
        : 'bg-zinc-100  dark:bg-zinc-800/60     text-zinc-700  dark:text-zinc-300';
      const visText = r.visibility === 'public' ? (lang === 'es' ? 'Público' : 'Public') : (lang === 'es' ? 'Privado' : 'Private');
      const area = (r.area_km2 ?? 0).toFixed(1);
      const href = `/${lang}${base}/detail/?slug=${encodeURIComponent(r.slug)}`;
      return `
        <a href="${href}" class="block rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-4 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 transition">
          <div class="flex items-center justify-between gap-2">
            <span class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 truncate">${escapeHtml(label)}</span>
            <span class="text-[10px] px-1.5 py-0.5 rounded uppercase tracking-wider ${visClass}">${visText}</span>
          </div>
          <div class="mt-1 text-xs text-zinc-500 dark:text-zinc-400 font-mono">${escapeHtml(r.slug)}</div>
          <div class="mt-2 text-xs text-zinc-500 dark:text-zinc-400">${area} km²</div>
        </a>
      `;
    }

    void load();
  }
</script>
