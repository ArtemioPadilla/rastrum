---
/**
 * TimeSlider — phenology month filter for /explore.
 *
 * Renders a 12-segment "All / Jan…Dec" strip below ExploreMap. Picking
 * a month dispatches a `rastrum:time-slider-change` event with
 * `{ month: 0..11 | null }` — ExploreMap's bootstrap script listens
 * and filters the observations layer by `observed_at` month.
 *
 * Year-agnostic — this is a phenology view, not a year-specific filter.
 */
import { t } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;
const tr = t(lang);
const slider = ((tr as unknown as { explore: { time_slider?: Record<string, string> } }).explore.time_slider) ?? {};

const months = [
  slider.month_jan ?? 'Jan',
  slider.month_feb ?? 'Feb',
  slider.month_mar ?? 'Mar',
  slider.month_apr ?? 'Apr',
  slider.month_may ?? 'May',
  slider.month_jun ?? 'Jun',
  slider.month_jul ?? 'Jul',
  slider.month_aug ?? 'Aug',
  slider.month_sep ?? 'Sep',
  slider.month_oct ?? 'Oct',
  slider.month_nov ?? 'Nov',
  slider.month_dec ?? 'Dec',
];
const allYearLabel = slider.all_year ?? 'All year';
const titleLabel = slider.title ?? 'Filter by month';
const showingAll = slider.showing_all ?? 'Showing all months';
---

<section
  id="explore-time-slider"
  class="mt-3"
  aria-label={titleLabel}
  data-no-data={slider.no_data ?? 'No observations to filter yet'}
  data-showing={slider.showing ?? 'Showing {count} observations'}
  data-showing-all={showingAll}
>
  <div class="flex items-center justify-between mb-2 gap-3">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-zinc-700 dark:text-zinc-300">
      {titleLabel}
    </h2>
    <p
      id="time-slider-status"
      class="text-xs text-zinc-500 dark:text-zinc-400 truncate"
      aria-live="polite"
    >
      {showingAll}
    </p>
  </div>

  <div
    class="flex gap-1.5 overflow-x-auto snap-x snap-mandatory pb-2 -mx-1 px-1 scroll-pl-1"
    role="radiogroup"
    aria-label={titleLabel}
  >
    <button
      type="button"
      class="ts-btn snap-start shrink-0 inline-flex min-h-[40px] items-center rounded-full border border-zinc-300 dark:border-zinc-700 px-4 py-1.5 text-xs font-semibold text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 data-[active=true]:bg-emerald-700 data-[active=true]:text-white data-[active=true]:border-emerald-700"
      data-month="all"
      data-active="true"
      role="radio"
      aria-checked="true"
    >
      {allYearLabel}
    </button>
    {months.map((label, i) => (
      <button
        type="button"
        class="ts-btn snap-start shrink-0 inline-flex min-h-[40px] items-center rounded-full border border-zinc-300 dark:border-zinc-700 px-3 py-1.5 text-xs font-semibold text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 data-[active=true]:bg-emerald-700 data-[active=true]:text-white data-[active=true]:border-emerald-700"
        data-month={String(i)}
        data-active="false"
        role="radio"
        aria-checked="false"
      >
        {label}
      </button>
    ))}
  </div>
</section>

<script>
  const root = document.getElementById('explore-time-slider') as HTMLElement | null;
  if (root) {
    const buttons = Array.from(root.querySelectorAll<HTMLButtonElement>('.ts-btn'));
    const status = document.getElementById('time-slider-status') as HTMLElement | null;
    const showingTpl = root.dataset.showing ?? 'Showing {count} observations';
    const showingAll = root.dataset.showingAll ?? 'Showing all months';
    const noData = root.dataset.noData ?? 'No observations to filter yet';

    let dataReady = false;
    let lastCount = 0;

    function setActive(value: string): void {
      buttons.forEach((b) => {
        const match = (b.dataset.month ?? '') === value;
        b.dataset.active = String(match);
        b.setAttribute('aria-checked', String(match));
      });
    }

    function updateStatus(value: string, count: number): void {
      if (!status) return;
      if (!dataReady) {
        status.textContent = noData;
        return;
      }
      if (value === 'all') {
        status.textContent = showingAll;
      } else {
        status.textContent = showingTpl.replace('{count}', String(count));
      }
    }

    buttons.forEach((b) => {
      b.addEventListener('click', () => {
        const value = b.dataset.month ?? 'all';
        setActive(value);
        const month = value === 'all' ? null : Number(value);
        document.dispatchEvent(
          new CustomEvent('rastrum:time-slider-change', { detail: { month } }),
        );
        updateStatus(value, lastCount);
      });
    });

    document.addEventListener('rastrum:time-slider-count', (ev) => {
      const detail = (ev as CustomEvent<{ count: number; ready?: boolean }>).detail || { count: 0 };
      lastCount = detail.count ?? 0;
      if (detail.ready !== undefined) dataReady = !!detail.ready;
      const active = buttons.find((b) => b.dataset.active === 'true');
      updateStatus(active?.dataset.month ?? 'all', lastCount);
    });
  }
</script>
