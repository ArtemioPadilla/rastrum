---
import { t } from '../i18n/utils';
interface Props { lang: 'en' | 'es' }
const { lang } = Astro.props;
const tr = t(lang);
---

<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold tracking-tight mb-2">{tr.export.title}</h1>
  <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-6">{tr.export.subtitle}</p>

  <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-5">
    <p class="text-sm text-zinc-700 dark:text-zinc-300 mb-4">
      <span>{tr.export.count_prefix}</span>
      <span id="count" class="font-semibold">—</span>
      <span>{tr.export.count_suffix}</span>
    </p>
    <div id="empty" class="hidden text-sm text-zinc-500 italic">{tr.export.nothing_to_export}</div>

    <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">{lang === 'es' ? 'Formato' : 'Format'}</label>
    <select id="format" class="block w-full sm:w-auto mb-3 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm">
      <option value="dwc">Darwin Core (full)</option>
      <option value="snib">CONABIO SNIB</option>
      <option value="conanp">CONANP ANP report</option>
    </select>

    <button id="download-btn" class="block rounded-lg bg-emerald-700 hover:bg-emerald-800 px-4 py-2 text-sm font-semibold text-white disabled:opacity-50">
      <span data-label>{tr.export.download_csv}</span>
    </button>
    <p id="err" class="hidden mt-3 text-sm text-red-600 dark:text-red-400"></p>
  </div>

  <section class="mt-8 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-5">
    <h2 class="text-lg font-semibold mb-1">{tr.export.gbif_title}</h2>
    <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-4">{tr.export.gbif_subtitle}</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-3">
      <label class="block text-sm">
        <span class="block font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.export.gbif_since}</span>
        <input id="gbif-since" type="date" class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm" />
      </label>
      <label class="block text-sm">
        <span class="block font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.export.gbif_until}</span>
        <input id="gbif-until" type="date" class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm" />
      </label>
    </div>

    <label class="block text-sm mb-3">
      <span class="block font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.export.gbif_bbox}</span>
      <input id="gbif-bbox" type="text" placeholder="-100,15,-85,22" class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm font-mono" />
      <span class="block text-xs text-zinc-500 mt-1">{tr.export.gbif_bbox_hint}</span>
    </label>

    <label class="block text-sm mb-3">
      <span class="block font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.export.gbif_quality}</span>
      <select id="gbif-quality" class="w-full sm:w-auto rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm">
        <option value="research_grade">{tr.export.gbif_quality_research}</option>
        <option value="all">{tr.export.gbif_quality_all}</option>
      </select>
    </label>

    <label class="block text-sm mb-4">
      <span class="block font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.export.gbif_license}</span>
      <select id="gbif-license" class="w-full sm:w-auto rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm">
        <option value="CC0-1.0">CC0 1.0 (Public Domain)</option>
        <option value="CC-BY-4.0">CC BY 4.0</option>
        <option value="CC-BY-NC-4.0">CC BY-NC 4.0</option>
      </select>
    </label>

    <label class="inline-flex items-center gap-2 text-sm mb-4">
      <input id="gbif-multimedia" type="checkbox" class="rounded border-zinc-300 dark:border-zinc-700" />
      <span>{tr.export.gbif_include_multimedia}</span>
    </label>

    <button id="gbif-download-btn" class="block rounded-lg bg-emerald-700 hover:bg-emerald-800 px-4 py-2 text-sm font-semibold text-white disabled:opacity-50">
      <span data-gbif-label>{tr.export.gbif_download}</span>
    </button>
    <p id="gbif-err" class="hidden mt-3 text-sm text-red-600 dark:text-red-400"></p>
    <p class="mt-3 text-xs text-zinc-500 dark:text-zinc-400">{tr.export.gbif_footer}</p>
  </section>
</div>

<script>
  import { getSupabase } from '../lib/supabase';
  import { toDwCRecord, toCSV, toCsvSnib, toCsvConanp, downloadCSV, type DwCInput } from '../lib/darwin-core';
  import type { UserProfile } from '../lib/types';

  const btn      = document.getElementById('download-btn') as HTMLButtonElement | null;
  const btnLabel = btn?.querySelector('[data-label]') as HTMLElement | null;
  const countEl  = document.getElementById('count');
  const empty    = document.getElementById('empty');
  const err      = document.getElementById('err');

  const ORIGINAL = btnLabel?.textContent ?? 'Download';
  const GENERATING = btnLabel?.textContent?.trim() === 'Descargar CSV DwC' ? 'Generando…' : 'Generating…';

  async function refreshCount() {
    const supabase = getSupabase();
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) { if (countEl) countEl.textContent = '0'; btn && (btn.disabled = true); return; }
    const { count } = await supabase
      .from('observations')
      .select('id', { count: 'exact', head: true })
      .eq('observer_id', user.id)
      .eq('sync_status', 'synced');
    if (countEl) countEl.textContent = String(count ?? 0);
    if ((count ?? 0) === 0) {
      empty?.classList.remove('hidden');
      if (btn) btn.disabled = true;
    }
  }

  btn?.addEventListener('click', async () => {
    if (!btn || !btnLabel) return;
    err?.classList.add('hidden');
    btn.disabled = true;
    btnLabel.textContent = GENERATING;

    try {
      const supabase = getSupabase();
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) throw new Error('Not signed in');

      const { data: profile } = await supabase
        .from('users')
        .select('display_name,username,observer_license')
        .eq('id', user.id)
        .maybeSingle<Pick<UserProfile,'display_name'|'username'|'observer_license'>>();

      const { data: obs, error: obsErr } = await supabase
        .from('observations')
        .select(`
          id, observed_at, accuracy_m, obscure_level,
          state_province, habitat, location,
          identifications!inner(scientific_name, confidence, source, is_primary),
          taxa:primary_taxon_id(kingdom)
        `)
        .eq('observer_id', user.id)
        .eq('sync_status', 'synced')
        .eq('identifications.is_primary', true);

      if (obsErr) throw obsErr;

      const rows: DwCInput[] = (obs ?? []).map(r => {
        const loc = (r.location as unknown) as GeoJSON.Point | null;
        const id0 = Array.isArray(r.identifications) ? r.identifications[0] : r.identifications;
        return {
          id: r.id as string,
          observed_at: r.observed_at as string,
          lat: loc?.coordinates?.[1] ?? 0,
          lng: loc?.coordinates?.[0] ?? 0,
          accuracy_m: r.accuracy_m as number | null,
          obscure_level: (r.obscure_level as string) ?? 'none',
          scientific_name: id0?.scientific_name ?? null,
          confidence: id0?.confidence ?? null,
          id_source: id0?.source ?? null,
          kingdom: (r.taxa as { kingdom: string | null } | null)?.kingdom ?? null,
          state_province: r.state_province as string | null,
          habitat: r.habitat as string | null,
          observer_display_name: profile?.display_name || profile?.username || null,
          observer_license: profile?.observer_license ?? 'CC BY 4.0',
        };
      });

      const dwcRows = rows.map(toDwCRecord);
      const fmt = (document.getElementById('format') as HTMLSelectElement | null)?.value ?? 'dwc';
      let csv = '';
      let suffix = '';
      switch (fmt) {
        case 'snib':   csv = toCsvSnib(dwcRows);   suffix = 'snib';   break;
        case 'conanp': csv = toCsvConanp(dwcRows); suffix = 'conanp'; break;
        default:       csv = toCSV(dwcRows);        suffix = 'dwc';   break;
      }
      const today = new Date().toISOString().slice(0, 10);
      downloadCSV(csv, `rastrum-${suffix}-${today}.csv`);
      window.posthog?.capture('observations_exported', { format: fmt, row_count: rows.length, type: 'csv' });
    } catch (e) {
      if (err) {
        err.textContent = e instanceof Error ? e.message : String(e);
        err.classList.remove('hidden');
      }
    } finally {
      btn.disabled = false;
      btnLabel.textContent = ORIGINAL;
    }
  });

  refreshCount().catch(console.error);

  // ───────────────────────── GBIF DwC-A export ─────────────────────────
  const gbifBtn      = document.getElementById('gbif-download-btn') as HTMLButtonElement | null;
  const gbifBtnLabel = gbifBtn?.querySelector('[data-gbif-label]') as HTMLElement | null;
  const gbifErr      = document.getElementById('gbif-err');
  const GBIF_ORIGINAL = gbifBtnLabel?.textContent ?? 'Download';
  const GBIF_GENERATING = GBIF_ORIGINAL.includes('DwC-A') && document.documentElement.lang === 'es'
    ? 'Generando…' : (gbifBtnLabel?.textContent?.trim()?.includes('Descargar') ? 'Generando…' : 'Generating…');

  gbifBtn?.addEventListener('click', async () => {
    if (!gbifBtn || !gbifBtnLabel) return;
    gbifErr?.classList.add('hidden');
    gbifBtn.disabled = true;
    gbifBtnLabel.textContent = GBIF_GENERATING;
    try {
      const supabase = getSupabase();
      const { data: { session } } = await supabase.auth.getSession();
      if (!session) throw new Error('Not signed in');

      const since = (document.getElementById('gbif-since') as HTMLInputElement | null)?.value;
      const until = (document.getElementById('gbif-until') as HTMLInputElement | null)?.value;
      const bbox  = (document.getElementById('gbif-bbox')  as HTMLInputElement | null)?.value?.trim();
      const quality = (document.getElementById('gbif-quality') as HTMLSelectElement | null)?.value ?? 'research_grade';
      const license = (document.getElementById('gbif-license') as HTMLSelectElement | null)?.value ?? 'CC0-1.0';
      const includeMm = (document.getElementById('gbif-multimedia') as HTMLInputElement | null)?.checked ?? false;

      const params = new URLSearchParams();
      if (since) params.set('since', since);
      if (until) params.set('until', until);
      if (bbox)  params.set('bbox', bbox);
      params.set('quality', quality);
      params.set('license', license);
      if (includeMm) params.set('include_multimedia', '1');

      const projectUrl = import.meta.env.PUBLIC_SUPABASE_URL as string | undefined;
      if (!projectUrl) throw new Error('PUBLIC_SUPABASE_URL not configured');
      const res = await fetch(`${projectUrl}/functions/v1/export-dwca?${params.toString()}`, {
        headers: { Authorization: `Bearer ${session.access_token}` },
      });
      if (!res.ok) {
        const txt = await res.text();
        throw new Error(`HTTP ${res.status}: ${txt}`);
      }
      const blob = await res.blob();
      const today = new Date().toISOString().slice(0, 10);
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `rastrum-dwca-${today}.zip`;
      a.click();
      URL.revokeObjectURL(url);
      window.posthog?.capture('observations_exported', { format: 'dwca', quality, license, type: 'gbif_zip' });
    } catch (e) {
      if (gbifErr) {
        gbifErr.textContent = e instanceof Error ? e.message : String(e);
        gbifErr.classList.remove('hidden');
      }
    } finally {
      gbifBtn.disabled = false;
      gbifBtnLabel.textContent = GBIF_ORIGINAL;
    }
  });
</script>
