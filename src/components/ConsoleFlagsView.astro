---
import { t } from '../i18n/utils';

interface Props { lang: 'en' | 'es' }
const { lang } = Astro.props;
const tr = t(lang);
---

<section class="max-w-5xl">
  <div id="flags-not-auth" class="hidden rounded border border-amber-300 dark:border-amber-700/60 bg-amber-50 dark:bg-amber-900/20 p-3 text-sm text-amber-900 dark:text-amber-100">
    {tr.console.not_authorized}
  </div>

  <div id="flags-shell" class="hidden">
    <div class="rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700 p-8 text-center space-y-3">
      <p class="text-sm font-medium text-zinc-600 dark:text-zinc-400">{tr.console.stub_coming_soon}</p>
      <p class="text-xs text-zinc-500 dark:text-zinc-400">{tr.console.flags_stub_hint}</p>
      <a
        href="https://github.com/ArtemioPadilla/rastrum/issues/259"
        target="_blank"
        rel="noopener"
        class="inline-block text-xs text-zinc-500 dark:text-zinc-400 underline"
      >
        {tr.console.stub_track_issue}
      </a>
    </div>
  </div>
</section>

<script>
  import { getSupabase } from '../lib/supabase';
  import { getUserRoles } from '../lib/user-roles';

  function show(id: string) { document.getElementById(id)?.classList.remove('hidden'); }

  const supabase = getSupabase();

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session?.user) { show('flags-not-auth'); return; }
    const myRoles = await getUserRoles(session.user.id);
    if (!myRoles.has('admin')) {
      show('flags-not-auth');
      return;
    }
    show('flags-shell');
  }

  init().catch(() => { show('flags-not-auth'); });
</script>
