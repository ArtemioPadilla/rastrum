---
import { t } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;
const tr = t(lang);
---

<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold tracking-tight mb-6">{tr.profile.edit}</h1>

  <form id="edit-form" class="space-y-5" novalidate>
    <div>
      <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.profile.username}</label>
      <input name="username" type="text" pattern="[a-zA-Z0-9_]{3,30}" maxlength="30" class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm" />
      <p class="mt-1 text-xs text-zinc-500">{tr.profile.username_hint}</p>
    </div>
    <div>
      <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.profile.display_name}</label>
      <input name="display_name" type="text" maxlength="80" class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm" />
    </div>
    <div>
      <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.profile.bio}</label>
      <textarea name="bio" maxlength="500" rows="3" placeholder={tr.profile.bio_placeholder} class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm"></textarea>
    </div>
    <div>
      <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.profile.region_primary}</label>
      <input name="region_primary" type="text" placeholder={tr.profile.region_placeholder} class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm" />
    </div>
    <div>
      <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.profile.avatar_url}</label>
      <input name="avatar_url" type="url" class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm" />
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.profile.preferred_lang}</label>
        <select name="preferred_lang" class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm">
          <option value="es">Español</option>
          <option value="en">English</option>
          <option value="zap">Zapoteco</option>
          <option value="mix">Mixteco</option>
          <option value="nah">Náhuatl</option>
          <option value="myn">Maya</option>
          <option value="tzo">Tsotsil</option>
          <option value="tze">Tseltal</option>
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.profile.license}</label>
        <select name="observer_license" class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm">
          <option value="CC BY 4.0">CC BY 4.0</option>
          <option value="CC BY-NC 4.0">CC BY-NC 4.0</option>
          <option value="CC0">CC0</option>
        </select>
        <p class="mt-1 text-xs text-zinc-500">{tr.profile.license_hint}</p>
      </div>
    </div>

    <fieldset class="space-y-3 border-t border-zinc-200 dark:border-zinc-800 pt-5">
      <label class="flex items-start gap-3 cursor-pointer">
        <input type="checkbox" name="profile_public" class="mt-1" />
        <div>
          <p class="text-sm font-medium text-zinc-700 dark:text-zinc-300">{tr.profile.public_profile}</p>
          <p class="text-xs text-zinc-500">{tr.profile.public_profile_hint}</p>
        </div>
      </label>
      <label class="flex items-start gap-3 cursor-pointer">
        <input type="checkbox" name="gamification_opt_in" class="mt-1" />
        <div>
          <p class="text-sm font-medium text-zinc-700 dark:text-zinc-300">{tr.profile.gamification}</p>
          <p class="text-xs text-zinc-500">{tr.profile.gamification_hint}</p>
        </div>
      </label>
      <label class="flex items-start gap-3 cursor-pointer">
        <input type="checkbox" name="streak_digest_opt_in" class="mt-1" />
        <div>
          <p class="text-sm font-medium text-zinc-700 dark:text-zinc-300">{tr.profile.streak_digest}</p>
          <p class="text-xs text-zinc-500">{tr.profile.streak_digest_hint}</p>
        </div>
      </label>
    </fieldset>

    <div class="flex items-center gap-3 pt-2">
      <button type="submit" id="save-btn" class="rounded-lg bg-emerald-700 hover:bg-emerald-800 px-4 py-2 text-sm font-semibold text-white disabled:opacity-50">
        <span data-label>{tr.profile.save}</span>
      </button>
      <a href={`/${lang}/${lang === 'es' ? 'perfil' : 'profile'}/`} class="text-sm text-zinc-600 dark:text-zinc-400 hover:underline">
        ← {tr.profile.view_profile}
      </a>
      <span id="save-status" class="hidden text-sm text-emerald-600 dark:text-emerald-400">✓ {tr.profile.saved}</span>
    </div>
    <p id="form-error" class="hidden text-sm text-red-600 dark:text-red-400"></p>
  </form>

  <!-- ── AI settings ── -->
  <section class="mt-10 border-t border-zinc-200 dark:border-zinc-800 pt-8">
    <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider mb-4">
      {tr.auth.ai_settings}
    </h2>

    <!-- BYO Anthropic key -->
    <div class="space-y-3">
      <div>
        <label for="anthropic-key" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">
          {tr.auth.anthropic_key_label}
        </label>
        <input id="anthropic-key" type="password" autocomplete="off" placeholder="sk-ant-…"
          class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm font-mono" />
        <p class="mt-1 text-xs text-zinc-500">{tr.auth.anthropic_key_hint}</p>
        <div class="mt-2 flex items-center gap-2">
          <button id="ak-save"  type="button" class="rounded-lg bg-emerald-700 hover:bg-emerald-800 px-3 py-1.5 text-xs font-semibold text-white">{tr.auth.anthropic_key_save}</button>
          <button id="ak-clear" type="button" class="rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-1.5 text-xs font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40">{tr.auth.anthropic_key_clear}</button>
          <span id="ak-saved" class="hidden text-xs text-emerald-600 dark:text-emerald-400">✓ {tr.auth.anthropic_key_saved}</span>
        </div>
      </div>
    </div>

    <!-- On-device AI -->
    <div class="mt-6 pt-5 border-t border-zinc-100 dark:border-zinc-800/60">
      <h3 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 mb-2">{tr.auth.local_ai_section}</h3>
      <p class="text-xs text-zinc-500 dark:text-zinc-400 mb-3">{tr.auth.local_ai_hint}</p>
      <p id="local-ai-unsup" class="hidden text-xs text-amber-700 dark:text-amber-400">{tr.auth.local_ai_unsupported}</p>

      <label class="flex items-start gap-3 cursor-pointer mt-2">
        <input type="checkbox" id="local-ai-optin" class="mt-1" />
        <div>
          <p class="text-sm text-zinc-700 dark:text-zinc-300">{tr.auth.local_ai_opt_in}</p>
          <p class="text-xs text-amber-700 dark:text-amber-400 mt-1">{tr.auth.local_ai_warning}</p>
        </div>
      </label>

      <!-- Per-model cards -->
      <div class="mt-4 space-y-3">
        <!-- Vision -->
        <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 p-3">
          <div class="flex items-start justify-between gap-3 flex-wrap">
            <div class="min-w-0">
              <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100">Phi-3.5-vision</p>
              <p class="text-xs text-zinc-500" id="vision-status">—</p>
            </div>
            <div class="flex flex-wrap gap-2">
              <button id="vision-download" type="button" data-model="vision" class="rounded-lg border border-emerald-600/60 px-3 py-1.5 text-xs font-medium text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 disabled:opacity-50">
                <span data-vlabel>{tr.auth.local_ai_download_vision}</span>
              </button>
              <button id="vision-delete" type="button" data-model="vision" class="hidden rounded-lg border border-red-300 dark:border-red-900/50 px-3 py-1.5 text-xs font-medium text-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">
                {tr.auth.local_ai_delete}
              </button>
            </div>
          </div>
          <p id="vision-progress" class="hidden mt-2 text-xs text-zinc-600 dark:text-zinc-400 font-mono"></p>
        </div>

        <!-- Text -->
        <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 p-3">
          <div class="flex items-start justify-between gap-3 flex-wrap">
            <div class="min-w-0">
              <p class="text-sm font-medium text-zinc-900 dark:text-zinc-100">Llama-3.2-1B</p>
              <p class="text-xs text-zinc-500" id="text-status">—</p>
            </div>
            <div class="flex flex-wrap gap-2">
              <button id="text-download" type="button" data-model="text" class="rounded-lg border border-emerald-600/60 px-3 py-1.5 text-xs font-medium text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 disabled:opacity-50">
                <span data-tlabel>{tr.auth.local_ai_download_text}</span>
              </button>
              <button id="text-delete" type="button" data-model="text" class="hidden rounded-lg border border-red-300 dark:border-red-900/50 px-3 py-1.5 text-xs font-medium text-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">
                {tr.auth.local_ai_delete}
              </button>
            </div>
          </div>
          <p id="text-progress" class="hidden mt-2 text-xs text-zinc-600 dark:text-zinc-400 font-mono"></p>
        </div>

        <!-- Storage estimate + clear all -->
        <div class="flex items-center justify-between text-xs text-zinc-500">
          <span id="storage-estimate">—</span>
          <div class="flex gap-3">
            <button id="ai-unload" type="button" class="hover:underline">{tr.auth.local_ai_unload}</button>
            <button id="ai-clear-all" type="button" class="text-red-600 dark:text-red-400 hover:underline">{tr.auth.confirm_clear_all_title}</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Confirmation modals (single dialog reused via data attrs) ── -->
  <dialog id="confirm-dialog" class="rounded-xl p-0 m-auto bg-white dark:bg-zinc-900 text-zinc-900 dark:text-zinc-100 shadow-2xl border border-zinc-200 dark:border-zinc-800 max-w-md w-[92vw] backdrop:bg-black/50">
    <form method="dialog" class="p-6">
      <h2 id="cd-title" class="text-lg font-bold mb-3"></h2>
      <div id="cd-body" class="space-y-2 text-sm text-zinc-700 dark:text-zinc-300"></div>
      <div class="mt-6 flex justify-end gap-2">
        <button value="cancel" class="rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-1.5 text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40">
          <span id="cd-cancel">{tr.auth.confirm_download_cancel}</span>
        </button>
        <button id="cd-ok" value="ok" class="rounded-lg bg-emerald-700 hover:bg-emerald-800 px-3 py-1.5 text-sm font-semibold text-white">
          <span id="cd-ok-label">{tr.auth.confirm_download_button}</span>
        </button>
      </div>
    </form>
  </dialog>

  <!-- ── Security ── -->
  <section class="mt-10 border-t border-zinc-200 dark:border-zinc-800 pt-8">
    <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider mb-4">
      {tr.auth.security}
    </h2>
    <div class="space-y-3">
      <button id="passkey-btn" type="button" class="w-full sm:w-auto rounded-lg border border-emerald-600/60 bg-emerald-50 dark:bg-emerald-900/20 px-4 py-2 text-sm font-medium text-emerald-700 dark:text-emerald-300 hover:bg-emerald-100 dark:hover:bg-emerald-900/30 disabled:opacity-50">
        <span data-pk-label>{tr.auth.register_passkey}</span>
      </button>
      <p id="passkey-msg" class="hidden text-sm"></p>
      <p id="passkey-unsupported" class="hidden text-xs text-zinc-500 italic">{tr.auth.passkey_unavailable}</p>

      <div class="pt-2">
        <button id="signout-all-btn" type="button" class="text-sm text-red-600 dark:text-red-400 hover:underline disabled:opacity-50">
          <span data-so-label>{tr.auth.sign_out_everywhere}</span>
        </button>
      </div>
    </div>
  </section>
</div>

<script>
  import { getSupabase } from '../lib/supabase';
  import type { UserProfile } from '../lib/types';

  const form = document.getElementById('edit-form') as HTMLFormElement | null;
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement | null;
  const btnLabel = saveBtn?.querySelector('[data-label]') as HTMLElement | null;
  const status = document.getElementById('save-status');
  const err = document.getElementById('form-error') as HTMLParagraphElement | null;

  const ORIGINAL = btnLabel?.textContent ?? 'Save';
  const SAVING = btnLabel?.textContent?.trim() === 'Guardar' ? 'Guardando…' : 'Saving…';

  type EditableKey =
    | 'username' | 'display_name' | 'bio' | 'region_primary' | 'avatar_url'
    | 'preferred_lang' | 'observer_license'
    | 'profile_public' | 'gamification_opt_in' | 'streak_digest_opt_in';

  async function load() {
    if (!form) return;
    const supabase = getSupabase();
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) {
      window.location.replace(`${window.location.pathname.startsWith('/es/') ? '/es/ingresar/' : '/en/sign-in/'}`);
      return;
    }
    const { data: profile } = await supabase
      .from('users')
      .select('*')
      .eq('id', user.id)
      .maybeSingle<UserProfile>();

    if (!profile) return;

    (form.elements.namedItem('username') as HTMLInputElement).value = profile.username ?? '';
    (form.elements.namedItem('display_name') as HTMLInputElement).value = profile.display_name ?? '';
    (form.elements.namedItem('bio') as HTMLTextAreaElement).value = profile.bio ?? '';
    (form.elements.namedItem('region_primary') as HTMLInputElement).value = profile.region_primary ?? '';
    (form.elements.namedItem('avatar_url') as HTMLInputElement).value = profile.avatar_url ?? '';
    (form.elements.namedItem('preferred_lang') as HTMLSelectElement).value = profile.preferred_lang ?? 'es';
    (form.elements.namedItem('observer_license') as HTMLSelectElement).value = profile.observer_license ?? 'CC BY 4.0';
    (form.elements.namedItem('profile_public') as HTMLInputElement).checked = profile.profile_public;
    (form.elements.namedItem('gamification_opt_in') as HTMLInputElement).checked = profile.gamification_opt_in;
    (form.elements.namedItem('streak_digest_opt_in') as HTMLInputElement).checked = profile.streak_digest_opt_in;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !saveBtn || !btnLabel) return;

    err?.classList.add('hidden');
    status?.classList.add('hidden');
    saveBtn.disabled = true;
    btnLabel.textContent = SAVING;

    const data = new FormData(form);
    const nullableText = (k: EditableKey) => {
      const v = (data.get(k) ?? '').toString().trim();
      return v === '' ? null : v;
    };
    const payload: Record<string, unknown> = {
      username:             nullableText('username'),
      display_name:         nullableText('display_name'),
      bio:                  nullableText('bio'),
      region_primary:       nullableText('region_primary'),
      avatar_url:           nullableText('avatar_url'),
      preferred_lang:       (data.get('preferred_lang') ?? 'es').toString(),
      observer_license:     (data.get('observer_license') ?? 'CC BY 4.0').toString(),
      profile_public:       data.get('profile_public') === 'on',
      gamification_opt_in:  data.get('gamification_opt_in') === 'on',
      streak_digest_opt_in: data.get('streak_digest_opt_in') === 'on',
      updated_at:           new Date().toISOString(),
    };

    const supabase = getSupabase();
    const { data: { user } } = await supabase.auth.getUser();
    if (!user) return;

    const { error } = await supabase.from('users').update(payload).eq('id', user.id);

    saveBtn.disabled = false;
    btnLabel.textContent = ORIGINAL;

    if (error) {
      if (err) {
        err.textContent = error.message;
        err.classList.remove('hidden');
      }
      return;
    }
    status?.classList.remove('hidden');
    setTimeout(() => status?.classList.add('hidden'), 3000);
  });

  load().catch(console.error);

  // ── Security: passkey + sign-out-everywhere ──
  const passkeyBtn  = document.getElementById('passkey-btn') as HTMLButtonElement | null;
  const pkLabel     = passkeyBtn?.querySelector('[data-pk-label]') as HTMLElement | null;
  const pkMsg       = document.getElementById('passkey-msg');
  const pkUnsup     = document.getElementById('passkey-unsupported');
  const soBtn       = document.getElementById('signout-all-btn') as HTMLButtonElement | null;
  const soLabel     = soBtn?.querySelector('[data-so-label]') as HTMLElement | null;

  const isEsLang = document.documentElement.lang === 'es';
  const PK_DEFAULT = pkLabel?.textContent ?? 'Register a passkey';
  const PK_BUSY    = isEsLang ? 'Esperando tu autenticador…' : 'Waiting for your authenticator…';
  const SO_DEFAULT = soLabel?.textContent ?? 'Sign out everywhere';
  const SO_BUSY    = isEsLang ? 'Cerrando sesión…' : 'Signing out…';

  // Hide button when WebAuthn isn't supported
  import('../lib/auth').then(({ passkeySupported }) => {
    if (!passkeySupported()) {
      passkeyBtn?.classList.add('hidden');
      pkUnsup?.classList.remove('hidden');
    }
  });

  passkeyBtn?.addEventListener('click', async () => {
    if (!passkeyBtn || !pkLabel) return;
    pkMsg?.classList.add('hidden');
    passkeyBtn.disabled = true;
    pkLabel.textContent = PK_BUSY;
    try {
      const { enrollPasskey } = await import('../lib/auth');
      const { error } = await enrollPasskey();
      if (error) throw error;
      if (pkMsg) {
        pkMsg.textContent = isEsLang ? '✓ Passkey registrada.' : '✓ Passkey registered.';
        pkMsg.className = 'text-sm text-emerald-600 dark:text-emerald-400';
        pkMsg.classList.remove('hidden');
      }
    } catch (err) {
      if (pkMsg) {
        const m = err instanceof Error ? err.message : String(err);
        pkMsg.textContent = (isEsLang ? 'No se pudo registrar la passkey: ' : 'Couldn’t register passkey: ') + m;
        pkMsg.className = 'text-sm text-red-600 dark:text-red-400';
        pkMsg.classList.remove('hidden');
      }
    } finally {
      passkeyBtn.disabled = false;
      pkLabel.textContent = PK_DEFAULT;
    }
  });

  soBtn?.addEventListener('click', async () => {
    if (!soBtn || !soLabel) return;
    if (!confirm(isEsLang ? '¿Cerrar sesión en todos los dispositivos?' : 'Sign out from all devices?')) return;
    soBtn.disabled = true;
    soLabel.textContent = SO_BUSY;
    const { signOutEverywhere } = await import('../lib/auth');
    await signOutEverywhere();
    window.location.replace(isEsLang ? '/es/' : '/en/');
  });

  // ── AI settings: BYO Anthropic key (localStorage) ──
  const AK_STORAGE = 'rastrum.byoAnthropicKey';
  const akInput = document.getElementById('anthropic-key') as HTMLInputElement | null;
  const akSave  = document.getElementById('ak-save');
  const akClear = document.getElementById('ak-clear');
  const akSaved = document.getElementById('ak-saved');

  function akShow() {
    akSaved?.classList.remove('hidden');
    setTimeout(() => akSaved?.classList.add('hidden'), 2500);
  }
  if (akInput) {
    akInput.value = localStorage.getItem(AK_STORAGE) ?? '';
  }
  akSave?.addEventListener('click', () => {
    if (!akInput) return;
    const v = akInput.value.trim();
    if (v) localStorage.setItem(AK_STORAGE, v);
    else   localStorage.removeItem(AK_STORAGE);
    akShow();
  });
  akClear?.addEventListener('click', () => {
    if (akInput) akInput.value = '';
    localStorage.removeItem(AK_STORAGE);
    akShow();
  });

  // ── AI settings: WebLLM opt-in + per-model download / delete ──
  const LAI_OPTIN = 'rastrum.localAiOptIn';
  const optinBox = document.getElementById('local-ai-optin') as HTMLInputElement | null;
  const unsupNote = document.getElementById('local-ai-unsup');

  const dlg = document.getElementById('confirm-dialog') as HTMLDialogElement | null;
  const cdTitle = document.getElementById('cd-title');
  const cdBody  = document.getElementById('cd-body');
  const cdOkLabel = document.getElementById('cd-ok-label');
  const cdOk = document.getElementById('cd-ok') as HTMLButtonElement | null;

  type ModelKey = 'vision' | 'text';
  const MODELS: Record<ModelKey, { id: string; label: string; sizeLabel: string }> = {
    vision: { id: 'Phi-3.5-vision-instruct-q4f16_1-MLC', label: 'Phi-3.5-vision', sizeLabel: '~4 GB' },
    text:   { id: 'Llama-3.2-1B-Instruct-q4f16_1-MLC',   label: 'Llama-3.2-1B',   sizeLabel: '~880 MB' },
  };

  function bytesHuman(n: number): string {
    if (!n) return '0 B';
    const u = ['B','KB','MB','GB','TB'];
    let i = 0; let v = n;
    while (v >= 1024 && i < u.length - 1) { v /= 1024; i++; }
    return `${v.toFixed(v < 10 ? 1 : 0)} ${u[i]}`;
  }

  function tr(en: string, es: string): string { return isEsLang ? es : en; }

  function fmtTitle(template: string, model: string): string {
    return template.replace('{model}', model);
  }

  /** Promise-based wrapper around <dialog> that returns 'ok' or 'cancel'. */
  function confirmDialog(opts: { title: string; bodyHtml: string; okLabel: string }): Promise<boolean> {
    return new Promise((resolve) => {
      if (!dlg || !cdTitle || !cdBody || !cdOkLabel) { resolve(false); return; }
      cdTitle.textContent = opts.title;
      cdBody.innerHTML = opts.bodyHtml;
      cdOkLabel.textContent = opts.okLabel;
      dlg.returnValue = '';
      const onClose = () => { resolve(dlg.returnValue === 'ok'); dlg.removeEventListener('close', onClose); };
      dlg.addEventListener('close', onClose);
      dlg.showModal();
    });
  }

  // Lazy-load WebGPU detection
  let mod: typeof import('../lib/local-ai') | null = null;
  async function getLib() {
    if (!mod) mod = await import('../lib/local-ai');
    return mod;
  }

  async function refreshAll() {
    const lib = await getLib().catch(() => null);
    if (!lib) return;
    if (!lib.localAISupported()) {
      unsupNote?.classList.remove('hidden');
      (document.getElementById('vision-download') as HTMLButtonElement | null)?.setAttribute('disabled','true');
      (document.getElementById('text-download') as HTMLButtonElement | null)?.setAttribute('disabled','true');
    }
    await Promise.all([refreshModel('vision'), refreshModel('text')]);
    await refreshStorageEstimate();
  }

  async function refreshModel(key: ModelKey) {
    const lib = await getLib();
    const status = await lib.getModelCacheStatus(MODELS[key].id);
    const dl  = document.getElementById(`${key}-download`) as HTMLButtonElement | null;
    const del = document.getElementById(`${key}-delete`) as HTMLButtonElement | null;
    const lbl = document.getElementById(`${key}-status`);
    const dlLabelSpan = dl?.querySelector(`[data-${key === 'vision' ? 'v' : 't'}label]`) as HTMLElement | null;

    if (!dl || !del || !lbl || !dlLabelSpan) return;

    if (status.cached) {
      lbl.textContent = `${tr('Cached on this device','Guardado en este dispositivo')} · ${bytesHuman(status.approxBytes)} (${status.entries} files)`;
      dlLabelSpan.textContent = tr('Re-download','Volver a descargar');
      del.classList.remove('hidden');
    } else {
      lbl.textContent = `${tr('Not downloaded','No descargado')} · ${MODELS[key].sizeLabel}`;
      dlLabelSpan.textContent = (key === 'vision') ? tr('Download vision model (~4 GB)','Descargar modelo de visión (~4 GB)')
                                                   : tr('Download text helpers (~880 MB)','Descargar ayudantes de texto (~880 MB)');
      del.classList.add('hidden');
    }
  }

  async function refreshStorageEstimate() {
    const lib = await getLib();
    const e = await lib.getStorageEstimate();
    const el = document.getElementById('storage-estimate');
    if (el && e.quota > 0) {
      el.textContent = `${tr('Local storage used','Almacenamiento usado')}: ${bytesHuman(e.usage)} / ${bytesHuman(e.quota)}`;
    }
  }

  if (optinBox) {
    optinBox.checked = localStorage.getItem(LAI_OPTIN) === 'true';
    optinBox.addEventListener('change', () => {
      if (optinBox.checked) localStorage.setItem(LAI_OPTIN, 'true');
      else                  localStorage.removeItem(LAI_OPTIN);
    });
  }

  function progressPainter(modelKey: ModelKey) {
    const el = document.getElementById(`${modelKey}-progress`);
    return (p: { progress: number; text: string }) => {
      if (!el) return;
      el.classList.remove('hidden');
      el.textContent = `${Math.round((p.progress ?? 0) * 100)}%  ${p.text ?? ''}`;
    };
  }

  // Download buttons (after confirmation)
  ['vision','text'].forEach((k) => {
    const key = k as ModelKey;
    const btn = document.getElementById(`${key}-download`) as HTMLButtonElement | null;
    btn?.addEventListener('click', async () => {
      const m = MODELS[key];
      const ok = await confirmDialog({
        title: fmtTitle(tr('Download {model}?','¿Descargar {model}?'), m.label),
        bodyHtml: `
          <p><strong>${tr('Size','Tamaño')}:</strong> ${m.sizeLabel}</p>
          <ul class="list-disc pl-4 space-y-1 text-zinc-600 dark:text-zinc-400">
            <li>${tr('After download, the model runs entirely on this device — your photos never leave the browser.','Tras la descarga el modelo se ejecuta totalmente en este dispositivo — tus fotos nunca salen del navegador.')}</li>
            <li>${tr('You only download once. The model stays cached for next time.','Solo se descarga una vez. El modelo queda en caché para la próxima vez.')}</li>
            <li>${tr("We'll request persistent storage so the OS doesn't evict it.",'Pediremos almacenamiento persistente para que el sistema no lo borre.')}</li>
            <li>${tr('Use Wi-Fi if possible — this is a large download.','Usa Wi-Fi si es posible — es una descarga grande.')}</li>
          </ul>
        `,
        okLabel: tr('Download','Descargar'),
      });
      if (!ok || !btn) return;

      btn.disabled = true;
      try {
        const lib = await getLib();
        const loader = key === 'vision' ? lib.loadVisionEngine : lib.loadTextEngine;
        await loader(progressPainter(key));
      } catch (e) {
        const status = document.getElementById(`${key}-status`);
        if (status) status.textContent = (e instanceof Error ? e.message : 'Failed');
      } finally {
        btn.disabled = false;
        await refreshModel(key);
        await refreshStorageEstimate();
      }
    });
  });

  // Delete buttons
  ['vision','text'].forEach((k) => {
    const key = k as ModelKey;
    const btn = document.getElementById(`${key}-delete`);
    btn?.addEventListener('click', async () => {
      const m = MODELS[key];
      const ok = await confirmDialog({
        title: fmtTitle(tr('Delete {model} from this device?','¿Borrar {model} de este dispositivo?'), m.label),
        bodyHtml: `<p>${tr("This frees disk space. You can re-download anytime — your account isn't affected.","Libera espacio en disco. Puedes volver a descargarlo en cualquier momento — tu cuenta no se ve afectada.")}</p>`,
        okLabel: tr('Delete','Borrar'),
      });
      if (!ok) return;
      const lib = await getLib();
      await lib.clearModelCache(m.id);
      await refreshModel(key);
      await refreshStorageEstimate();
    });
  });

  // Free GPU memory (without deleting cached weights)
  document.getElementById('ai-unload')?.addEventListener('click', async () => {
    const lib = await getLib();
    await lib.unloadAll();
    await Promise.all([refreshModel('vision'), refreshModel('text')]);
  });

  // Clear-all nuclear option
  document.getElementById('ai-clear-all')?.addEventListener('click', async () => {
    const ok = await confirmDialog({
      title: tr('Delete all on-device AI data?','¿Borrar todos los datos de IA local?'),
      bodyHtml: `<p>${tr('Removes both models and frees all related storage. You can re-download from this page later.','Quita ambos modelos y libera todo el almacenamiento relacionado. Puedes volver a descargarlos desde esta página más tarde.')}</p>`,
      okLabel: tr('Delete','Borrar'),
    });
    if (!ok) return;
    const lib = await getLib();
    await lib.clearAllModelCaches();
    await refreshAll();
  });

  refreshAll().catch(() => {});
</script>
