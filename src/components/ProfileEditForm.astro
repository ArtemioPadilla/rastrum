    const del = document.getElementById(`${key}-delete`) as HTMLButtonElement | null;
    const lbl = document.getElementById(`${key}-status`);
    const dlLabelSpan = dl?.querySelector(`[data-${key === 'vision' ? 'v' : 't'}label]`) as HTMLElement | null;

    if (!dl || !del || !lbl || !dlLabelSpan) return;

    if (status.cached) {
      lbl.textContent = `${tr('Cached on this device','Guardado en este dispositivo')} · ${bytesHuman(status.approxBytes)} (${status.entries} files)`;
      dlLabelSpan.textContent = tr('Re-download','Volver a descargar');
      del.classList.remove('hidden');
    } else {
      lbl.textContent = `${tr('Not downloaded','No descargado')} · ${MODELS[key].sizeLabel}`;
      dlLabelSpan.textContent = (key === 'vision') ? tr('Download vision model (~4 GB)','Descargar modelo de visión (~4 GB)')
