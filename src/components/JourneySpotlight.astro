---
/**
 * JourneySpotlight — reusable spotlight overlay engine for contextual
 * feature guides. Extracted from the OnboardingTour pattern.
 *
 * Mounted by JourneyGuideLoader.astro in BaseLayout. Controlled entirely
 * via DOM events:
 *   - `rastrum:journey-guide-start` → open a guide (detail: { guideId, steps, lang })
 *   - `rastrum:journey-guide-stop`  → close the current guide
 *
 * Emits `rastrum:onboarding-event` with extended types for analytics.
 */
interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;

const labels = {
  en: { next: 'Next', done: 'Done', skip: 'Skip guide', stepOf: 'Step {current} of {total}', close: 'Close guide' },
  es: { next: 'Siguiente', done: 'Listo', skip: 'Saltar guía', stepOf: 'Paso {current} de {total}', close: 'Cerrar guía' },
};
const l = labels[lang] ?? labels.en;
---

<div
  id="journey-spotlight"
  class="hidden fixed inset-0 z-[65]"
  data-label-next={l.next}
  data-label-done={l.done}
  data-label-skip={l.skip}
  data-label-step-of={l.stepOf}
  data-label-close={l.close}
>
  <div id="js-backdrop" class="absolute inset-0 bg-zinc-950/50" style="clip-path: none;"></div>

  <div
    id="js-ring"
    class="absolute pointer-events-none rounded-xl border-2 border-emerald-400 transition-all duration-200 hidden"
    style="box-shadow: 0 0 0 4px rgba(52,211,153,0.25);"
    aria-hidden="true"
  ></div>

  <div
    id="js-tooltip"
    role="dialog"
    aria-modal="true"
    aria-labelledby="js-title"
    class="absolute w-[calc(100vw-2rem)] max-w-xs sm:max-w-sm bg-white dark:bg-zinc-900 rounded-2xl shadow-2xl border border-zinc-200 dark:border-zinc-800 p-5 focus:outline-none"
    tabindex="-1"
    style="left: 50%; top: 50%; transform: translate(-50%, -50%);"
  >
    <p id="js-step-label" class="text-[10px] font-semibold text-emerald-600 dark:text-emerald-400 uppercase tracking-wider mb-3" aria-live="polite"></p>
    <h2 id="js-title" class="text-lg font-bold tracking-tight text-zinc-900 dark:text-zinc-100 mb-2"></h2>
    <p id="js-body" class="text-sm text-zinc-600 dark:text-zinc-300 leading-relaxed"></p>

    <div class="mt-5 flex items-center justify-between gap-2">
      <button id="js-skip" type="button" class="text-sm text-zinc-500 hover:text-zinc-800 dark:hover:text-zinc-200 min-h-[44px] px-1"></button>
      <div class="flex items-center gap-2">
        <button id="js-next" type="button" class="min-h-[44px] inline-flex items-center rounded-lg bg-emerald-700 hover:bg-emerald-800 px-4 py-2 text-sm font-semibold text-white"></button>
      </div>
    </div>
  </div>
</div>

<script>
  interface GuideStep {
    target: string;
    title: string;
    body: string;
  }

  interface GuideStartDetail {
    guideId: string;
    steps: GuideStep[];
  }

  const root = document.getElementById('journey-spotlight');
  if (root) {
    const backdrop = document.getElementById('js-backdrop') as HTMLDivElement;
    const ring = document.getElementById('js-ring') as HTMLDivElement;
    const tooltip = document.getElementById('js-tooltip') as HTMLDivElement;
    const titleEl = document.getElementById('js-title') as HTMLElement;
    const bodyEl = document.getElementById('js-body') as HTMLElement;
    const stepLabel = document.getElementById('js-step-label') as HTMLElement;
    const skipBtn = document.getElementById('js-skip') as HTMLButtonElement;
    const nextBtn = document.getElementById('js-next') as HTMLButtonElement;

    const labelNext = root.dataset.labelNext ?? 'Next';
    const labelDone = root.dataset.labelDone ?? 'Done';
    const labelSkip = root.dataset.labelSkip ?? 'Skip guide';
    const stepTpl = root.dataset.labelStepOf ?? 'Step {current} of {total}';

    let steps: GuideStep[] = [];
    let current = 0;
    let guideId = '';
    let returnFocus: HTMLElement | null = null;

    function resolveTarget(selector: string): Element | null {
      const parts = selector.split(',').map(s => s.trim());
      for (const sel of parts) {
        try {
          const el = document.querySelector(sel);
          if (el) return el;
        } catch { /* invalid selector */ }
      }
      return null;
    }

    function positionTooltip(targetEl: Element | null): void {
      if (!targetEl) {
        tooltip.style.left = '50%';
        tooltip.style.top = '50%';
        tooltip.style.transform = 'translate(-50%, -50%)';
        ring.classList.add('hidden');
        backdrop.style.clipPath = 'none';
        return;
      }

      const PAD = 8;
      const base = targetEl.getBoundingClientRect();
      const tr = new DOMRect(base.left - PAD, base.top - PAD, base.width + PAD * 2, base.height + PAD * 2);
      const vw = window.innerWidth;
      const vh = window.innerHeight;

      ring.style.left = `${tr.left}px`;
      ring.style.top = `${tr.top}px`;
      ring.style.width = `${tr.width}px`;
      ring.style.height = `${tr.height}px`;
      ring.classList.remove('hidden');

      const x0 = tr.left; const y0 = tr.top;
      const x1 = tr.right; const y1 = tr.bottom;
      backdrop.style.clipPath = `polygon(0 0, 100% 0, 100% 100%, 0 100%, 0 0, ${x0}px ${y0}px, ${x0}px ${y1}px, ${x1}px ${y1}px, ${x1}px ${y0}px, ${x0}px ${y0}px)`;

      const TW = tooltip.getBoundingClientRect().width || 320;
      const TH = tooltip.getBoundingClientRect().height || 180;
      const M = 12;

      let tx = tr.left + tr.width / 2 - TW / 2;
      tx = Math.max(M, Math.min(tx, vw - TW - M));

      let ty: number;
      if (tr.bottom + M + TH <= vh) ty = tr.bottom + M;
      else if (tr.top - M - TH >= 0) ty = tr.top - M - TH;
      else ty = Math.max(M, Math.min(vh / 2 - TH / 2, vh - TH - M));

      tooltip.style.left = `${tx}px`;
      tooltip.style.top = `${ty}px`;
      tooltip.style.transform = 'none';
    }

    function render(): void {
      const step = steps[current];
      if (!step) return;

      titleEl.textContent = step.title;
      bodyEl.textContent = step.body;
      stepLabel.textContent = stepTpl
        .replace('{current}', String(current + 1))
        .replace('{total}', String(steps.length));

      const isLast = current === steps.length - 1;
      skipBtn.textContent = isLast ? '' : labelSkip;
      skipBtn.classList.toggle('hidden', isLast);
      nextBtn.textContent = isLast ? labelDone : labelNext;

      const targetEl = resolveTarget(step.target);
      positionTooltip(targetEl);
    }

    function emit(type: string, extra?: Record<string, unknown>): void {
      try {
        window.dispatchEvent(new CustomEvent('rastrum:onboarding-event', {
          detail: { type, step: current, guideId, ...extra },
        }));
      } catch { /* noop */ }
    }

    function show(detail: GuideStartDetail): void {
      steps = detail.steps;
      guideId = detail.guideId;
      current = 0;
      returnFocus = document.activeElement as HTMLElement | null;

      root.classList.remove('hidden');
      document.documentElement.style.overflow = 'hidden';
      document.body.style.overflow = 'hidden';

      requestAnimationFrame(() => {
        render();
        tooltip.focus();
        emit('guide_opened');
      });
    }

    function hide(completed: boolean): void {
      root.classList.add('hidden');
      ring.classList.add('hidden');
      backdrop.style.clipPath = 'none';
      document.documentElement.style.overflow = '';
      document.body.style.overflow = '';

      emit(completed ? 'guide_completed' : 'guide_dismissed');

      if (completed) {
        try { localStorage.setItem(`rastrum.guide.${guideId.replace('guide-', '')}`, 'done'); } catch { /* noop */ }
      }

      try { returnFocus?.focus(); } catch { /* noop */ }
      steps = [];
      guideId = '';
    }

    nextBtn.addEventListener('click', () => {
      if (current >= steps.length - 1) { hide(true); return; }
      const from = current;
      current++;
      render();
      tooltip.focus();
      emit('guide_step_change', { from, to: current });
    });

    skipBtn.addEventListener('click', () => hide(false));

    document.addEventListener('keydown', (ev) => {
      if (root.classList.contains('hidden')) return;
      if (ev.key === 'Escape') { ev.preventDefault(); hide(false); }
    });

    window.addEventListener('resize', () => {
      if (!root.classList.contains('hidden')) render();
    });

    window.addEventListener('rastrum:journey-guide-start', ((ev: CustomEvent<GuideStartDetail>) => {
      show(ev.detail);
    }) as EventListener);

    window.addEventListener('rastrum:journey-guide-stop', () => {
      if (!root.classList.contains('hidden')) hide(false);
    });
  }
</script>
