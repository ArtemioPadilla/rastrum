---
/**
 * MyObservationsView — paginated list of the signed-in user's own
 * observations with sync-status tabs.
 *
 * RLS: the obs_owner policy returns the user's own rows regardless of
 * sync_status, so we can read pending/error rows here. We never filter on
 * the client beyond the chosen tab.
 *
 * Each row links to /share/obs/?id=<id> (the existing detail page). The
 * empty state pushes the user to the observe form.
 */
import { t, getLocalizedPath, routes } from '../i18n/utils';
import Skeleton from './Skeleton.astro';
import FirstObservationCelebration from './FirstObservationCelebration.astro';

interface Props {
  lang: 'en' | 'es';
}

const { lang } = Astro.props;
const tr = t(lang);
const observePath = getLocalizedPath(lang, routes.observe[lang] + '/');
const profilePath = getLocalizedPath(lang, routes.profile[lang] + '/');
// Share route is locale-neutral: src/pages/share/obs/index.astro.
// Earlier this was built as `/${lang}/share/obs/` and 404'd in
// production — the locale-prefixed share route does not exist.
const shareObsBase = `/share/obs/`;

const profileStrings = tr.profile as unknown as Record<string, string>;
const sgReactions = (tr as unknown as { socialgraph: { reactions: Record<string, string> } }).socialgraph.reactions;
const faveAriaOne = sgReactions.fave_count_aria_one ?? '{{count}} person favorited this';
const faveAriaOther = sgReactions.fave_count_aria_other ?? '{{count}} people favorited this';
const draftsFilterLabel = profileStrings.my_observations_filter_drafts ?? (lang === 'es' ? 'Borradores' : 'Drafts');
const draftStatusLabel  = profileStrings.my_observations_status_draft  ?? (lang === 'es' ? 'Borrador' : 'Draft');
const shareLabel        = profileStrings.my_observations_share         ?? (lang === 'es' ? 'Compartir' : 'Share');
const retryLabel        = profileStrings.my_observations_retry         ?? (lang === 'es' ? 'Reintentar' : 'Retry');
const retryingLabel     = profileStrings.my_observations_retrying      ?? (lang === 'es' ? 'Sincronizando…' : 'Syncing…');
const retryFailedTpl    = profileStrings.my_observations_retry_failed  ?? (lang === 'es' ? 'No se pudo: {error}' : 'Sync failed: {error}');
const syncReportBugLabel = profileStrings.my_observations_sync_report_bug ?? (lang === 'es' ? 'Reportar bug' : 'Report bug');
const retryOkLabel      = profileStrings.my_observations_retry_ok      ?? (lang === 'es' ? 'Sincronizada.' : 'Synced.');
const lastSyncTpl       = profileStrings.my_observations_last_sync     ?? (lang === 'es' ? 'Última sincronización: {when}' : 'Last sync: {when}');
const lastSyncNever     = profileStrings.my_observations_last_sync_never ?? (lang === 'es' ? 'Aún no se ha sincronizado nada.' : 'Nothing has synced yet.');
const lastSyncNow       = profileStrings.my_observations_last_sync_now  ?? (lang === 'es' ? 'ahora mismo' : 'just now');
const lastSyncMin       = profileStrings.my_observations_last_sync_minutes ?? '{n} min';
const lastSyncHr        = profileStrings.my_observations_last_sync_hours   ?? '{n} h';
const lastSyncDay       = profileStrings.my_observations_last_sync_days    ?? '{n} d';
const validation        = (tr as unknown as { validation?: Record<string, string> }).validation ?? {};
const rgLabel           = validation.research_grade        ?? (lang === 'es' ? 'Grado investigación' : 'Research grade');
const rgTitle           = validation.research_grade_title  ?? rgLabel;

const tabs = [
  { id: 'all', label: tr.profile.my_observations_filter_all },
  { id: 'synced', label: tr.profile.my_observations_filter_synced },
  { id: 'pending', label: tr.profile.my_observations_filter_pending },
  { id: 'error', label: tr.profile.my_observations_filter_error },
  { id: 'draft', label: draftsFilterLabel },
] as const;
---

<div
  class="rastrum-my-observations max-w-3xl mx-auto"
  data-lang={lang}
  data-share-obs-base={shareObsBase}
  data-label-loading={tr.profile.my_observations_loading}
  data-label-empty={tr.profile.my_observations_empty}
  data-label-cta={tr.profile.my_observations_cta}
  data-label-load-more={tr.profile.my_observations_load_more}
  data-label-status-synced={tr.profile.my_observations_status_synced}
  data-label-status-pending={tr.profile.my_observations_status_pending}
  data-label-status-error={tr.profile.my_observations_status_error}
  data-label-status-draft={draftStatusLabel}
  data-label-share={shareLabel}
  data-label-retry={retryLabel}
  data-label-retrying={retryingLabel}
  data-label-retry-failed={retryFailedTpl}
  data-label-sync-report-bug={syncReportBugLabel}
  data-label-retry-ok={retryOkLabel}
  data-label-last-sync={lastSyncTpl}
  data-label-last-sync-never={lastSyncNever}
  data-label-last-sync-now={lastSyncNow}
  data-label-last-sync-min={lastSyncMin}
  data-label-last-sync-hr={lastSyncHr}
  data-label-last-sync-day={lastSyncDay}
  data-label-unknown-species={tr.profile.my_observations_unknown_species}
  data-label-research-grade={rgLabel}
  data-label-research-grade-title={rgTitle}
  data-label-fave-aria-one={faveAriaOne}
  data-label-fave-aria-other={faveAriaOther}
  data-observe-path={observePath}
  data-label-hidden-badge={profileStrings.obs_hidden_by_mod_badge ?? (lang === 'es' ? 'Oculto por moderación' : 'Hidden by moderation')}
  data-label-hidden-reason-label={profileStrings.obs_hidden_by_mod_reason_label ?? (lang === 'es' ? 'Razón:' : 'Reason:')}
  data-label-hidden-no-reason={profileStrings.obs_hidden_by_mod_no_reason ?? (lang === 'es' ? 'Sin razón especificada.' : 'No reason provided.')}
  data-label-hidden-appeal-link={profileStrings.obs_hidden_by_mod_appeal_link ?? (lang === 'es' ? 'Ver razón / Apelar' : 'View reason / Appeal')}
  data-appeal-path={lang === 'es' ? '/es/perfil/apelar/' : '/en/profile/appeal/'}
>
  <header class="flex items-start justify-between gap-3 mb-6 flex-wrap">
    <div>
      <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
        {tr.profile.my_observations_title}
      </h1>
      <a href={profilePath} class="text-sm text-zinc-600 dark:text-zinc-400 hover:underline">
        ← {tr.profile.view_profile}
      </a>
      <p id="mo-last-sync" class="mt-1 text-xs text-zinc-500 dark:text-zinc-500" aria-live="polite"></p>
    </div>
    <button
      id="mo-sync-now-btn"
      type="button"
      class="hidden min-h-[40px] inline-flex items-center gap-2 rounded-lg bg-emerald-700 hover:bg-emerald-800 px-4 py-2 text-sm font-semibold text-white transition-colors"
      aria-label={lang === 'es' ? 'Sincronizar observaciones pendientes' : 'Sync pending observations'}
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h5M20 20v-5h-5M4 9a8 8 0 0114-3M20 15a8 8 0 01-14 3"/>
      </svg>
      <span id="mo-sync-now-label">{lang === 'es' ? 'Subir pendientes' : 'Upload pending'}</span>
    </button>
  </header>
  <!-- Self-healing banner — shown when there are error rows older than 24h -->
  <div id="mo-stale-banner" class="hidden mb-4 rounded-lg border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 p-3 flex items-start gap-2">
    <svg class="w-4 h-4 text-amber-700 dark:text-amber-400 flex-none mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M5.07 19h13.86c1.54 0 2.5-1.67 1.73-3L13.73 4a2 2 0 00-3.46 0L3.34 16c-.77 1.33.19 3 1.73 3z"/></svg>
    <div class="text-xs text-amber-900 dark:text-amber-200 flex-1">
      <span id="mo-stale-msg">—</span>
      <button id="mo-stale-retry" type="button" class="ml-2 underline font-semibold">{lang === 'es' ? 'Reintentar todo' : 'Retry all'}</button>
    </div>
  </div>
  <div id="mo-toast" class="hidden fixed bottom-20 left-1/2 -translate-x-1/2 z-50 px-4 py-2 rounded-lg text-sm shadow-lg" role="status" aria-live="polite"></div>

  <div id="mo-signin" class="hidden rounded-lg border border-zinc-300 dark:border-zinc-700 p-4 text-sm space-y-2">
    <p id="mo-signin-msg">{tr.profile.not_signed_in}</p>
    <a
      id="mo-signin-link"
      href={lang === 'es' ? '/es/ingresar/' : '/en/sign-in/'}
      class="inline-flex min-h-[40px] items-center rounded-lg bg-emerald-700 hover:bg-emerald-800 px-4 py-2 text-sm font-semibold text-white"
    >
      {lang === 'es' ? 'Iniciar sesión' : 'Sign in'}
    </a>
  </div>

  <div id="mo-content" class="hidden">
    <nav class="flex gap-1 mb-5 overflow-x-auto" role="tablist" aria-label={tr.profile.my_observations_title}>
      {tabs.map(tab => (
        <button
          type="button"
          role="tab"
          data-tab={tab.id}
          class="mo-tab inline-flex min-h-[40px] items-center px-3 py-1.5 rounded-lg text-sm font-medium border border-zinc-300 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 data-[active=true]:bg-emerald-700 data-[active=true]:text-white data-[active=true]:border-emerald-700"
          aria-selected="false"
        >
          {tab.label}
        </button>
      ))}
    </nav>

    <ul id="mo-list" class="space-y-3"></ul>

    <div id="mo-loading" class="hidden">
      <Skeleton variant="row" count={5} ariaLabel={tr.profile.my_observations_loading} />
    </div>

    <div id="mo-empty" class="hidden rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700 p-8 text-center">
      <p class="text-sm text-zinc-500 dark:text-zinc-400">{tr.profile.my_observations_empty}</p>
      <a
        href={observePath}
        class="mt-4 inline-flex min-h-[44px] items-center rounded-lg bg-emerald-700 hover:bg-emerald-800 px-4 py-2 text-sm font-semibold text-white"
      >
        {tr.profile.my_observations_cta}
      </a>
    </div>

    <div id="mo-load-more-wrap" class="hidden mt-4 text-center">
      <button
        type="button"
        id="mo-load-more"
        class="inline-flex min-h-[44px] items-center rounded-lg border border-zinc-300 dark:border-zinc-700 px-4 py-2 text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40"
      >
        {tr.profile.my_observations_load_more}
      </button>
    </div>
  </div>
</div>

<FirstObservationCelebration lang={lang} />

<script>
  import { getSupabase } from '../lib/supabase';
  import { isSyncFilter, type SyncFilter } from '../lib/social';
  import { buildBugReportUrl } from '../lib/bug-report';

  type Lang = 'en' | 'es';

  type Ident = { scientific_name: string; is_primary: boolean; is_research_grade?: boolean };
  type Media = { url: string; is_primary: boolean; media_type?: string | null };
  type Row = {
    id: string;
    observed_at: string;
    sync_status: 'synced' | 'pending' | 'error' | 'draft';
    sync_error?: string | null;
    state_province: string | null;
    hidden: boolean | null;
    hidden_reason: string | null;
    identifications: Ident[] | Ident | null;
    media_files: Media[];
  };

  const PAGE_SIZE = 20;

  const root = document.querySelector<HTMLElement>('.rastrum-my-observations');
  const lang: Lang = root?.dataset.lang === 'es' ? 'es' : 'en';
  const shareBase = root?.dataset.shareObsBase ?? '/share/obs/';

  let currentTab: SyncFilter = 'all';
  let offset = 0;
  let exhausted = false;
  let busy = false;
  let userId: string | null = null;

  function statusBadge(status: Row['sync_status'], syncError?: string | null, obsId?: string, obsName?: string): string {
    if (!root) return '';
    if (status === 'synced')  return `<span class="inline-flex items-center rounded-full bg-emerald-100 dark:bg-emerald-900/30 px-2 py-0.5 text-[11px] font-semibold text-emerald-800 dark:text-emerald-300">${root.dataset.labelStatusSynced ?? ''}</span>`;
    if (status === 'pending') return `<span class="inline-flex items-center rounded-full bg-amber-100 dark:bg-amber-900/30 px-2 py-0.5 text-[11px] font-semibold text-amber-800 dark:text-amber-300">${root.dataset.labelStatusPending ?? ''}</span>`;
    if (status === 'draft')   return `<span class="inline-flex items-center rounded-full bg-zinc-100 dark:bg-zinc-800 px-2 py-0.5 text-[11px] font-semibold text-zinc-700 dark:text-zinc-300">${root.dataset.labelStatusDraft ?? ''}</span>`;
    // Error status — show error detail and report bug button
    const errorLabel = root.dataset.labelStatusError ?? '';
    const reportLabel = root.dataset.labelSyncReportBug ?? 'Report bug';
    const errorDetail = syncError ? syncError.slice(0, 80) : '';
    let bugBtn = '';
    if (syncError) {
      // Use data attributes — click handler calls buildBugReportUrl() async with full telemetry
      bugBtn = `<button type="button" class="mo-report-bug-btn inline-flex items-center gap-1 rounded px-1.5 py-0.5 text-[10px] font-medium text-red-700 dark:text-red-400 underline hover:no-underline" data-bug-error="${escapeText(syncError)}" data-bug-obs-id="${escapeText(obsId ?? '')}" data-bug-obs-name="${escapeText(obsName ?? '')}" aria-label="${reportLabel}">${reportLabel}</button>`;
    }
    return `<span class="inline-flex flex-wrap items-center gap-1 rounded-full bg-red-100 dark:bg-red-900/30 px-2 py-0.5 text-[11px] font-semibold text-red-800 dark:text-red-300">${errorLabel}${errorDetail ? `<span class="font-normal opacity-80 ml-1">${escapeText(errorDetail)}</span>` : ''}${bugBtn}</span>`;
  }

  function escapeText(s: string): string {
    return s.replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function rowMarkup(r: Row): string {
    const ident = Array.isArray(r.identifications) ? r.identifications[0] : r.identifications;
    const unknown = root?.dataset.labelUnknownSpecies ?? 'Unidentified';
    const name = ident?.scientific_name ?? unknown;
    const photoMedia = (r.media_files ?? []).filter(m => !m.media_type || m.media_type === 'photo');
    const audioMedia = (r.media_files ?? []).filter(m => m.media_type === 'audio');
    const photo = photoMedia.find(m => m.is_primary)?.url ?? photoMedia[0]?.url ?? '';
    const hasAudioOnly = !photo && audioMedia.length > 0;
    const date = new Date(r.observed_at).toLocaleDateString(lang === 'es' ? 'es' : 'en');
    const region = r.state_province ? ' · ' + r.state_province : '';
    const isSynced = r.sync_status === 'synced';
    // Unsynced rows now link to /local/?id=<id> (this view's own
    // detail page) which reads from Dexie. The user can see the
    // photo, notes, and the actual sync error before deciding
    // whether to retry, edit, or discard.
    const localDetailHref = `/${lang}/${lang === 'es' ? 'perfil/observaciones' : 'profile/observations'}/local/?id=${encodeURIComponent(r.id)}`;
    const wrapTag = 'a';
    const wrapAttr = `href="${isSynced ? shareBase + '?id=' + r.id : localDetailHref}"`;
    const shareLabelText = root?.dataset.labelShare ?? 'Share';
    const retryLabelText = root?.dataset.labelRetry ?? 'Retry';
    const retryable = r.sync_status === 'pending' || r.sync_status === 'error';
    let actionBtn = '';
    if (isSynced) {
      actionBtn = `<button type="button" data-share-id="${r.id}" data-share-name="${escapeText(name)}" class="mo-share-btn shrink-0 inline-flex items-center gap-1 rounded-lg border border-emerald-600/60 px-2 py-1 text-xs font-medium text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20" aria-label="${shareLabelText}">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7M16 6l-4-4-4 4M12 2v14"/></svg>
          ${shareLabelText}
        </button>`;
    } else if (retryable) {
      actionBtn = `<button type="button" data-retry-id="${r.id}" class="mo-retry-btn shrink-0 inline-flex items-center gap-1 rounded-lg border border-amber-500/60 px-2 py-1 text-xs font-medium text-amber-700 dark:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-900/20" aria-label="${retryLabelText}">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h5M20 20v-5h-5M4 9a8 8 0 0114-3M20 15a8 8 0 01-14 3"/></svg>
          ${retryLabelText}
        </button>
        <button type="button" data-share-when-id="${r.id}" data-share-when-name="${escapeText(name)}" class="mo-share-when-btn shrink-0 inline-flex items-center gap-1 rounded-lg border border-emerald-600/40 px-2 py-1 text-xs font-medium text-emerald-700/70 dark:text-emerald-400/70 hover:bg-emerald-50 dark:hover:bg-emerald-900/20" title="${shareLabelText}">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 2m6-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          ${shareLabelText}
        </button>`;
    }
    const shareBtn = actionBtn;
    // Reaction-count chip — only on synced rows; populated client-side
    // via batched fetch on observation_reaction_summary view.
    const faveChipHtml = isSynced
      ? `<span class="mo-fave-chip hidden inline-flex items-center gap-1 rounded-full bg-rose-50 dark:bg-rose-950/40 border border-rose-200 dark:border-rose-900/60 px-2 py-0.5 text-[11px] font-semibold text-rose-700 dark:text-rose-300" data-fave-target="${escapeText(r.id)}"><svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21s-7-4.5-9.5-9A5.5 5.5 0 0 1 12 6a5.5 5.5 0 0 1 9.5 6c-2.5 4.5-9.5 9-9.5 9Z"/></svg><span class="mo-fave-count tabular-nums">0</span></span>`
      : '';
    const hiddenBadgeHtml = r.hidden
      ? `<span class="inline-flex items-center rounded-full bg-red-100 dark:bg-red-900/30 px-2 py-0.5 text-[11px] font-semibold text-red-700 dark:text-red-300" title="${escapeText(r.hidden_reason || (root?.dataset.labelHiddenNoReason ?? ''))}">🚫 ${escapeText(root?.dataset.labelHiddenBadge ?? 'Hidden by moderation')}</span>`
      : '';
    const hiddenOverlayClass = r.hidden ? 'relative opacity-60' : '';
    const hiddenDetailHtml = r.hidden
      ? `<div class="px-3 pb-2 text-xs text-zinc-500 dark:text-zinc-400 flex items-center gap-1">
          <span>${escapeText(root?.dataset.labelHiddenReasonLabel ?? 'Reason:')}</span>
          <span class="italic">${escapeText(r.hidden_reason || (root?.dataset.labelHiddenNoReason ?? ''))}</span>
          <a href="${escapeText(root?.dataset.appealPath ?? '/en/profile/appeal/')}" class="ml-2 underline text-emerald-700 dark:text-emerald-400">${escapeText(root?.dataset.labelHiddenAppealLink ?? 'View / Appeal')}</a>
        </div>`
      : '';
    return `<li class="rounded-lg border ${r.hidden ? 'border-red-200 dark:border-red-900/60' : 'border-zinc-200 dark:border-zinc-800'} bg-white dark:bg-zinc-900/50 overflow-hidden">
      <div class="flex items-center gap-3 p-3 ${isSynced ? 'hover:bg-zinc-50 dark:hover:bg-zinc-800/40' : 'opacity-90'} ${hiddenOverlayClass}">
        <${wrapTag} ${wrapAttr} class="flex items-center gap-3 min-w-0 flex-1">
          <div class="w-16 h-16 shrink-0 rounded-lg overflow-hidden bg-zinc-100 dark:bg-zinc-800">
            ${photo ? `<img src="${escapeText(photo)}" alt="${escapeText(name)}" class="w-full h-full object-cover" loading="lazy" />` : hasAudioOnly ? `<div class="w-full h-full flex items-center justify-center text-zinc-400 dark:text-zinc-500"><svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2z"/></svg></div>` : ''}
          </div>
          <div class="min-w-0 flex-1">
            <p class="text-sm italic font-medium text-zinc-900 dark:text-zinc-100 truncate">${escapeText(name)}</p>
            <p class="text-xs text-zinc-500 truncate">${date}${escapeText(region)}</p>
            <div class="mt-1 flex items-center gap-1.5 flex-wrap">
              ${statusBadge(r.sync_status, r.sync_error, r.id, name)}
              ${ident?.is_research_grade ? `<span class="inline-flex items-center gap-1 rounded-full bg-emerald-100 dark:bg-emerald-900/30 px-2 py-0.5 text-[11px] font-semibold text-emerald-800 dark:text-emerald-300" title="${escapeText(root?.dataset.labelResearchGradeTitle ?? '')}"><svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>${escapeText(root?.dataset.labelResearchGrade ?? '')}</span>` : ''}
              ${faveChipHtml}
              ${hiddenBadgeHtml}
            </div>
          </div>
        </${wrapTag}>
        ${shareBtn}
      </div>
      ${hiddenDetailHtml}
    </li>`;
  }

  // Queue a "share when synced" intent. Stored in localStorage so it
  // survives page reloads — the user might tap Share, close the tab,
  // come back later, and we still honour the intent the next time the
  // matching row syncs.
  const SHARE_WHEN_KEY = 'rastrum.shareWhenSynced';
  type ShareIntent = { id: string; name: string };
  function readShareQueue(): ShareIntent[] {
    try { return JSON.parse(localStorage.getItem(SHARE_WHEN_KEY) ?? '[]') as ShareIntent[]; }
    catch { return []; }
  }
  function writeShareQueue(q: ShareIntent[]) {
    try { localStorage.setItem(SHARE_WHEN_KEY, JSON.stringify(q)); } catch { /* full */ }
  }
  function queueShareWhenSynced(id: string, name: string) {
    const q = readShareQueue();
    if (!q.find(x => x.id === id)) q.push({ id, name });
    writeShareQueue(q);
    showToast(lang === 'es'
      ? '✓ Compartiremos cuando se sincronice.'
      : '✓ We\'ll share once it syncs.', 'ok');
  }

  // Listen for row-done events; if the just-synced row matches a queued
  // intent, fire navigator.share() and dequeue.
  window.addEventListener('rastrum:sync-row-done', ((ev: Event) => {
    const detail = (ev as CustomEvent<{ observation_id: string }>).detail;
    if (!detail?.observation_id) return;
    const q = readShareQueue();
    const idx = q.findIndex(x => x.id === detail.observation_id);
    if (idx < 0) return;
    const intent = q[idx];
    q.splice(idx, 1);
    writeShareQueue(q);
    shareObservation(intent.id, intent.name);
  }) as EventListener);

  async function shareObservation(id: string, name: string): Promise<void> {
    const url = `https://rastrum.org/share/obs/?id=${encodeURIComponent(id)}`;
    const text = lang === 'es' ? '¡Mira esta observación!' : 'Look at this observation!';
    type NavShare = Navigator & { share?: (data: ShareData) => Promise<void> };
    const nav = navigator as NavShare;
    try {
      if (typeof nav.share === 'function') {
        await nav.share({ url, title: name, text });
      } else if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(url);
      }
    } catch { /* user cancelled */ }
  }

  async function fetchPage(): Promise<Row[]> {
    if (!userId) return [];

    // Dexie-backed tabs (drafts, pending, error) read from the local
    // outbox — these rows haven't made it to Supabase yet. The "all" tab
    // merges Dexie unsynced rows with Supabase synced rows so users
    // can actually see observations that haven't uploaded yet (offline
    // capture, slow network, server hiccup). Without this merge, a user
    // who took 4 photos with flaky signal sees an empty list and thinks
    // the app dropped their work.
    async function fetchDexie(statuses: ReadonlyArray<'pending' | 'error' | 'draft'>): Promise<Row[]> {
      try {
        const { getDB } = await import('../lib/db');
        const db = getDB();
        const all: Row[] = [];
        for (const status of statuses) {
          const recs = await db.observations
            .where('sync_status').equals(status)
            .reverse()
            .sortBy('created_at');
          for (const rec of recs) {
            // Hydrate the primary photo from the local mediaBlobs store.
            // Without this, pending rows render with no thumbnail — looks
            // like the app lost the photo. URL.createObjectURL is cheap;
            // the URL stays valid until the page navigates away.
            let primaryPhotoUrl = '';
            try {
              const blobs = await db.mediaBlobs.where('observation_id').equals(rec.id).toArray();
              const photo = blobs.find(b => b.mime_type.startsWith('image/')) ?? blobs[0];
              if (photo?.blob) primaryPhotoUrl = URL.createObjectURL(photo.blob);
            } catch { /* mediaBlobs missing — render without thumbnail */ }
            all.push({
              id: rec.id,
              observed_at: rec.created_at,
              sync_status: status,
              state_province: null,
              identifications: rec.data.identification?.scientificName
                ? { scientific_name: rec.data.identification.scientificName, is_primary: true }
                : null,
              media_files: primaryPhotoUrl
                ? [{ url: primaryPhotoUrl, is_primary: true }]
                : [],
            });
          }
        }
        return all;
      } catch { return []; }
    }

    if (currentTab === 'draft' || currentTab === 'pending' || currentTab === 'error') {
      const all = await fetchDexie([currentTab]);
      return all.slice(offset, offset + PAGE_SIZE);
    }

    const supabase = getSupabase();
    let q = supabase
      .from('observations')
      .select('id, observed_at, sync_status, state_province, hidden, hidden_reason, identifications(scientific_name, is_primary, is_research_grade), media_files(url, is_primary, media_type)')
      .eq('observer_id', userId)
      .order('observed_at', { ascending: false })
      .range(offset, offset + PAGE_SIZE - 1);
    if (currentTab !== 'all') q = q.eq('sync_status', currentTab);
    const { data } = await q;
    const remote = ((data ?? []) as unknown) as Row[];

    if (currentTab !== 'all' || offset !== 0) return remote;

    // Top of "All" tab: merge in Dexie unsynced rows so users see their
    // pending/error/draft work alongside successfully synced rows.
    const local = await fetchDexie(['pending', 'error', 'draft']);
    const merged = [...local, ...remote].sort((a, b) =>
      (b.observed_at ?? '').localeCompare(a.observed_at ?? '')
    );
    return merged.slice(0, PAGE_SIZE);
  }

  function setEmptyState(visible: boolean) {
    document.getElementById('mo-empty')?.classList.toggle('hidden', !visible);
  }

  function showToast(msg: string, kind: 'ok' | 'err' = 'ok') {
    const el = document.getElementById('mo-toast');
    if (!el) return;
    el.textContent = msg;
    el.className = `fixed bottom-20 left-1/2 -translate-x-1/2 z-50 px-4 py-2 rounded-lg text-sm shadow-lg ${
      kind === 'ok'
        ? 'bg-emerald-700 text-white'
        : 'bg-red-700 text-white'
    }`;
    el.classList.remove('hidden');
    setTimeout(() => el.classList.add('hidden'), 4_000);
  }

  // Self-healing: any error row older than 24h gets surfaced in a banner
  // with a retry-all button. Without this, a row that the auto-retry-on-
  // mount can't resolve (PlantNet quota, RLS regression, etc.) silently
  // hangs around forever.
  async function paintStaleBanner() {
    const banner = document.getElementById('mo-stale-banner');
    const msg = document.getElementById('mo-stale-msg');
    const retry = document.getElementById('mo-stale-retry') as HTMLButtonElement | null;
    if (!banner || !msg) return;
    try {
      const { getDB } = await import('../lib/db');
      const db = getDB();
      const all = await db.observations.where('sync_status').anyOf('pending', 'error').toArray();
      const stale = all.filter(r => Date.now() - new Date(r.updated_at ?? r.created_at ?? Date.now()).getTime() > 24 * 60 * 60 * 1000);
      if (stale.length === 0) {
        banner.classList.add('hidden');
        return;
      }
      msg.textContent = lang === 'es'
        ? `${stale.length} observación${stale.length === 1 ? '' : 'es'} llevan más de 24 h sin subir.`
        : `${stale.length} observation${stale.length === 1 ? '' : 's'} ${stale.length === 1 ? 'has' : 'have'} been waiting over 24 h.`;
      banner.classList.remove('hidden');
      if (retry && !retry.dataset.bound) {
        retry.dataset.bound = '1';
        retry.addEventListener('click', async (ev) => {
          ev.preventDefault();
          retry.disabled = true;
          try {
            const { syncOutbox } = await import('../lib/sync');
            const res = await syncOutbox();
            if (res.synced > 0) {
              showToast(root?.dataset.labelRetryOk ?? 'Synced.', 'ok');
              await resetAndLoad();
            } else if (res.last_error) {
              const tpl = root?.dataset.labelRetryFailed ?? 'Sync failed: {error}';
              showToast(tpl.replace('{error}', res.last_error), 'err');
            }
          } finally {
            retry.disabled = false;
            await paintStaleBanner();
          }
        });
      }
    } catch { banner.classList.add('hidden'); }
  }

  function paintLastSync() {
    if (typeof localStorage === 'undefined') return;
    const stampEl = document.getElementById('mo-last-sync');
    if (!stampEl || !root) return;
    let raw: string | null = null;
    try { raw = localStorage.getItem('rastrum.lastSyncAt'); } catch { /* noop */ }
    if (!raw) {
      stampEl.textContent = root.dataset.labelLastSyncNever ?? '';
      return;
    }
    const ts = Date.parse(raw);
    if (!Number.isFinite(ts)) return;
    const diffMs = Date.now() - ts;
    const min = Math.floor(diffMs / 60_000);
    const hr = Math.floor(min / 60);
    const day = Math.floor(hr / 24);
    let when: string;
    if (min < 1) when = root.dataset.labelLastSyncNow ?? 'just now';
    else if (min < 60) when = (root.dataset.labelLastSyncMin ?? '{n} min').replace('{n}', String(min));
    else if (hr < 24)  when = (root.dataset.labelLastSyncHr  ?? '{n} h').replace('{n}', String(hr));
    else               when = (root.dataset.labelLastSyncDay ?? '{n} d').replace('{n}', String(day));
    const tpl = root.dataset.labelLastSync ?? 'Last sync: {when}';
    stampEl.textContent = tpl.replace('{when}', when);
  }

  async function retryRow(observationId: string, btn: HTMLButtonElement) {
    if (!root) return;
    const origLabel = btn.innerHTML;
    btn.disabled = true;
    btn.textContent = root.dataset.labelRetrying ?? 'Syncing…';
    try {
      const { syncOutbox } = await import('../lib/sync');
      const res = await syncOutbox();
      if (res.synced > 0) {
        showToast(root.dataset.labelRetryOk ?? 'Synced.', 'ok');
        await resetAndLoad();
      } else if (res.last_error) {
        const tpl = root.dataset.labelRetryFailed ?? 'Sync failed: {error}';
        showToast(tpl.replace('{error}', res.last_error), 'err');
      }
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      const tpl = root.dataset.labelRetryFailed ?? 'Sync failed: {error}';
      showToast(tpl.replace('{error}', msg), 'err');
    } finally {
      btn.disabled = false;
      btn.innerHTML = origLabel;
      paintLastSync();
    }
  }

  async function paintReactionCountsMo(ids: string[]) {
    if (ids.length === 0) return;
    try {
      const sb = getSupabase();
      const { data } = await sb
        .from('observation_reaction_summary')
        .select('observation_id, kind, count')
        .in('observation_id', ids)
        .eq('kind', 'fave');
      const byId = new Map<string, number>();
      for (const row of (data ?? []) as { observation_id: string; kind: string; count: number }[]) {
        byId.set(row.observation_id, row.count);
      }
      const ariaOne = root?.dataset.labelFaveAriaOne ?? '{{count}} person favorited this';
      const ariaOther = root?.dataset.labelFaveAriaOther ?? '{{count}} people favorited this';
      for (const id of ids) {
        const n = byId.get(id) ?? 0;
        if (n <= 0) continue;
        const chip = document.querySelector<HTMLElement>(`.mo-fave-chip[data-fave-target="${CSS.escape(id)}"]`);
        if (!chip) continue;
        const countEl = chip.querySelector<HTMLElement>('.mo-fave-count');
        if (countEl) countEl.textContent = String(n);
        const tpl = n === 1 ? ariaOne : ariaOther;
        chip.setAttribute('aria-label', tpl.replace('{{count}}', String(n)));
        chip.classList.remove('hidden');
      }
    } catch { /* aggregate fetch failures shouldn't break the list */ }
  }

  async function loadMore() {
    if (busy || exhausted) return;
    busy = true;
    document.getElementById('mo-loading')?.classList.remove('hidden');
    try {
      const page = await fetchPage();
      const list = document.getElementById('mo-list');
      if (list) {
        list.insertAdjacentHTML('beforeend', page.map(rowMarkup).join(''));
        const syncedIds = page.filter(r => r.sync_status === 'synced').map(r => r.id);
        paintReactionCountsMo(syncedIds).catch(() => { /* silent */ });
        // Wire freshly-rendered share buttons.
        list.querySelectorAll<HTMLButtonElement>('button.mo-share-btn:not([data-bound])').forEach((btn) => {
          btn.dataset.bound = '1';
          btn.addEventListener('click', (ev) => {
            ev.preventDefault();
            const id = btn.dataset.shareId ?? '';
            const name = btn.dataset.shareName ?? 'Rastrum';
            if (id) shareObservation(id, name);
          });
        });
        // Wire freshly-rendered retry buttons.
        list.querySelectorAll<HTMLButtonElement>('button.mo-retry-btn:not([data-bound])').forEach((btn) => {
          btn.dataset.bound = '1';
          btn.addEventListener('click', (ev) => {
            ev.preventDefault();
            const id = btn.dataset.retryId ?? '';
            if (id) retryRow(id, btn);
          });
        });
        // Wire freshly-rendered "share when synced" buttons.
        list.querySelectorAll<HTMLButtonElement>('button.mo-share-when-btn:not([data-bound])').forEach((btn) => {
          btn.dataset.bound = '1';
          btn.addEventListener('click', (ev) => {
            ev.preventDefault();
            const id = btn.dataset.shareWhenId ?? '';
            const name = btn.dataset.shareWhenName ?? 'Rastrum';
            if (id) queueShareWhenSynced(id, name);
          });
        });
        // Wire freshly-rendered "report bug" buttons.
        list.querySelectorAll<HTMLButtonElement>('button.mo-report-bug-btn:not([data-bound])').forEach((btn) => {
          btn.dataset.bound = '1';
          btn.addEventListener('click', async (ev) => {
            ev.preventDefault();
            btn.textContent = '...';
            btn.disabled = true;
            try {
              const url = await buildBugReportUrl({
                title: `Sync error: ${(btn.dataset.bugError ?? '').slice(0, 60)}`,
                errorMsg: btn.dataset.bugError,
                obsId: btn.dataset.bugObsId,
                obsName: btn.dataset.bugObsName,
              });
              window.open(url, '_blank', 'noopener');
            } finally {
              btn.textContent = root?.dataset.labelSyncReportBug ?? 'Report bug';
              btn.disabled = false;
            }
          });
        });
      }
      offset += page.length;
      if (page.length < PAGE_SIZE) exhausted = true;
      const wrap = document.getElementById('mo-load-more-wrap');
      wrap?.classList.toggle('hidden', exhausted);
      const list2 = document.getElementById('mo-list');
      const empty = list2 ? list2.children.length === 0 : true;
      setEmptyState(empty);
    } finally {
      document.getElementById('mo-loading')?.classList.add('hidden');
      busy = false;
    }
  }

  function resetAndLoad() {
    offset = 0;
    exhausted = false;
    const list = document.getElementById('mo-list');
    if (list) list.innerHTML = '';
    setEmptyState(false);
    return loadMore();
  }

  function wireTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.mo-tab');
    const setActive = (id: string) => {
      tabs.forEach(t => t.dataset.active = String(t.dataset.tab === id));
      tabs.forEach(t => t.setAttribute('aria-selected', String(t.dataset.tab === id)));
    };
    setActive(currentTab);
    tabs.forEach(t => {
      t.addEventListener('click', () => {
        const v = t.dataset.tab ?? 'all';
        if (!isSyncFilter(v) || v === currentTab) return;
        currentTab = v;
        setActive(currentTab);
        resetAndLoad().catch(() => { /* surface no-op; RLS may reject when offline */ });
      });
    });
  }

  function showExpiredSessionUI() {
    const signinEl = document.getElementById('mo-signin');
    const msgEl = document.getElementById('mo-signin-msg');
    if (signinEl) signinEl.classList.remove('hidden');
    if (msgEl) {
      msgEl.textContent = lang === 'es'
        ? 'Tu sesión expiró. Inicia sesión de nuevo para ver tus observaciones.'
        : 'Session expired — please sign in again to view your observations.';
    }
    // Hide the loading skeleton in case it was shown
    document.getElementById('mo-loading')?.classList.add('hidden');
  }

  async function init() {
    if (!root) return;
    let supabase;
    try {
      supabase = getSupabase();
    } catch {
      document.getElementById('mo-signin')?.classList.remove('hidden');
      return;
    }

    // Guard: check session first. getSession() reads from localStorage and
    // is synchronous-ish — it won't hang on a stale token the way getUser()
    // can when the refresh token is invalid and GoTrue retries internally.
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      showExpiredSessionUI();
      return;
    }

    // getUser() validates the JWT server-side. Wrap in a timeout so a
    // stalled token-refresh doesn't leave the page spinning forever.
    let user: import('@supabase/supabase-js').User | null = null;
    try {
      const userPromise = supabase.auth.getUser();
      const timeout = new Promise<never>((_, reject) =>
        setTimeout(() => reject(new Error('auth_timeout')), 8_000),
      );
      const { data } = await Promise.race([userPromise, timeout]);
      user = data.user;
    } catch {
      // Network error or timeout — session exists in localStorage but
      // can't be verified. Show expired-session UI.
      showExpiredSessionUI();
      return;
    }
    if (!user) {
      showExpiredSessionUI();
      return;
    }
    userId = user.id;
    document.getElementById('mo-content')?.classList.remove('hidden');
    wireTabs();
    document.getElementById('mo-load-more')?.addEventListener('click', () => {
      loadMore().catch(() => { /* no-op */ });
    });
    paintLastSync();
    setInterval(paintLastSync, 60_000); // refresh "hace 3 min" once a minute
    await paintStaleBanner();
    await resetAndLoad();

    // Wire "Subir pendientes" button — visible when there are pending/error rows
    const syncNowBtn = document.getElementById('mo-sync-now-btn') as HTMLButtonElement | null;
    const syncNowLabel = document.getElementById('mo-sync-now-label');
    async function refreshSyncNowBtn() {
      if (!syncNowBtn) return;
      const { getDB } = await import('../lib/db');
      const db = getDB();
      const count = await db.observations.where('sync_status').anyOf('pending', 'error').count();
      if (count > 0) {
        syncNowBtn.classList.remove('hidden');
        if (syncNowLabel) syncNowLabel.textContent = lang === 'es' ? `Subir ${count} pendiente${count === 1 ? '' : 's'}` : `Upload ${count} pending`;
      } else {
        syncNowBtn.classList.add('hidden');
      }
    }
    await refreshSyncNowBtn();
    if (syncNowBtn && !syncNowBtn.dataset.bound) {
      syncNowBtn.dataset.bound = '1';
      syncNowBtn.addEventListener('click', async () => {
        if (!navigator.onLine) return;
        syncNowBtn.disabled = true;
        if (syncNowLabel) syncNowLabel.textContent = lang === 'es' ? 'Subiendo…' : 'Uploading…';
        try {
          const { syncOutbox } = await import('../lib/sync');
          const result = await syncOutbox();
          if (result.synced > 0) await resetAndLoad();
          paintLastSync();
          // Toast: si todo se saltó (upgrade guest falló silenciosamente)
          if (result.synced === 0 && result.skipped_guest > 0) {
            showToast(lang === 'es' ? 'No se pudo subir — intenta cerrar y abrir la app' : 'Upload failed — try closing and reopening the app', 'err');
          }
        } catch { /* silent */ } finally {
          syncNowBtn.disabled = false;
          await refreshSyncNowBtn();
          await paintStaleBanner();
        }
      });
    }

    // Auto-retry the outbox in the background. If the user is here looking
    // at their list, they care about anything stuck in 'pending' from a
    // previous session. Re-render the list when sync completes so the
    // pending → synced transition is visible.
    try {
      const { syncOutbox } = await import('../lib/sync');
      const result = await syncOutbox();
      if (result.synced > 0) await resetAndLoad();
      paintLastSync();
      await refreshSyncNowBtn();
    } catch { /* silent — user already sees the list */ }
  }

  init().catch(() => {
    document.getElementById('mo-signin')?.classList.remove('hidden');
  });
</script>
