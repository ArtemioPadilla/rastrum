---
/**
 * Skeleton — content-shaped placeholder used while data loads.
 *
 * Variants:
 *   - "card"      block with title + two text lines (profile activity, etc.)
 *   - "row"       horizontal row with thumbnail + title + meta line
 *   - "thumbnail" square media tile only
 *   - "block"     plain rectangle (callers control sizing via class)
 *
 * Mirrors the shape of the real content so the layout doesn't shift in.
 * Uses Tailwind animate-pulse + bg-zinc-200/dark:bg-zinc-800 for the
 * shimmer.
 */
type Variant = 'card' | 'row' | 'thumbnail' | 'block';

interface Props {
  variant?: Variant;
  class?: string;
  count?: number;
  ariaLabel?: string;
}

const {
  variant = 'block',
  class: className = '',
  count = 1,
  ariaLabel,
} = Astro.props;

const items = Array.from({ length: Math.max(1, count) });
const labelAttr = ariaLabel ?? 'Loading…';
---

<div
  role="status"
  aria-live="polite"
  aria-busy="true"
  aria-label={labelAttr}
  class:list={['rastrum-skeleton-wrap space-y-3', className]}
>
  {items.map(() => (
    <>
      {variant === 'row' && (
        <div class="flex items-center gap-3 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-3 animate-pulse">
          <div class="w-16 h-16 shrink-0 rounded-lg bg-zinc-200 dark:bg-zinc-800"></div>
          <div class="flex-1 min-w-0 space-y-2">
            <div class="h-4 w-2/3 bg-zinc-200 dark:bg-zinc-800 rounded-md"></div>
            <div class="h-3 w-1/3 bg-zinc-200 dark:bg-zinc-800 rounded-md"></div>
            <div class="h-3 w-16 bg-zinc-200 dark:bg-zinc-800 rounded-full"></div>
          </div>
        </div>
      )}
      {variant === 'card' && (
        <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-3 animate-pulse">
          <div class="flex items-start gap-3">
            <div class="mt-1 w-1.5 h-1.5 rounded-full bg-zinc-200 dark:bg-zinc-800 shrink-0"></div>
            <div class="flex-1 min-w-0 space-y-2">
              <div class="h-4 w-3/4 bg-zinc-200 dark:bg-zinc-800 rounded-md"></div>
              <div class="h-3 w-1/4 bg-zinc-200 dark:bg-zinc-800 rounded-md"></div>
            </div>
          </div>
        </div>
      )}
      {variant === 'thumbnail' && (
        <div class="w-16 h-16 rounded-lg bg-zinc-200 dark:bg-zinc-800 animate-pulse"></div>
      )}
      {variant === 'block' && (
        <div class="bg-zinc-200 dark:bg-zinc-800 animate-pulse rounded-md h-4 w-full"></div>
      )}
    </>
  ))}
  <span class="sr-only">{labelAttr}</span>
</div>
