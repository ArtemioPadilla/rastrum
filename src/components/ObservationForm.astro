  async function triggerClientIdentify(file: File) {
    idSpinner?.classList.remove('hidden');
    idResult?.classList.add('hidden');
    if (idSpinnerLbl) idSpinnerLbl.textContent = isEs ? 'Identificando con PlantNet…' : 'Identifying with PlantNet…';

    try {
      // Resolve key from (in order): runtime injection, build-time env,
      // user-supplied BYO key in localStorage. If none, show a hint instead
      // of silently doing nothing — server-side cascade will still run on
      // sync, but the user expects to see why the spinner disappeared.
      let plantnetKey: string = (window as any).__RASTRUM_PLANTNET_KEY__ ?? '';
      if (!plantnetKey) {
        plantnetKey = (import.meta.env.PUBLIC_PLANTNET_KEY as string | undefined) ?? '';
      }
      if (!plantnetKey) {
        try {
          const { getKey } = await import('../lib/byo-keys');
          plantnetKey = getKey('plantnet', 'plantnet') ?? '';
        } catch { /* byo-keys unavailable */ }
      }

      if (!plantnetKey) {
        idSpinner?.classList.add('hidden');
        if (idSpinnerLbl) {
          idSpinnerLbl.textContent = isEs
            ? 'Configura una clave PlantNet en Perfil → Editar para identificar al instante.'
            : 'Add a PlantNet key in Profile → Edit for instant ID.';
        }
        // Reveal the hint by showing the spinner row WITHOUT the spinning icon.
        // Cheaper alternative: a dedicated hint element. Reuse spinner row with the label-only state.
        const spinnerSvg = idSpinner?.querySelector('svg');
        spinnerSvg?.classList.add('hidden');
        idSpinner?.classList.remove('hidden');
        return; // Server-side cascade will still run after sync.
      }

      const form = new FormData();
      form.append('images', file);
      form.append('organs', 'auto');

      const ac = new AbortController();
      const timeoutId = setTimeout(() => ac.abort(), 15_000);
      const res = await fetch(
        `https://my-api.plantnet.org/v2/identify/all?api-key=${plantnetKey}&lang=${isEs ? 'es' : 'en'}&nb-results=3`,
        { method: 'POST', body: form, signal: ac.signal }
      ).finally(() => clearTimeout(timeoutId));

      if (!res.ok) throw new Error(`PlantNet ${res.status}`);
      const data = await res.json();
      const top = data?.results?.[0];
      if (top && top.score >= 0.1) {
        showIdResult(
          top.species?.scientificNameWithoutAuthor ?? top.species?.scientificName ?? '',
          top.score,
          'PlantNet'
        );
      } else {
        idSpinner?.classList.add('hidden');
        if (idSpinnerLbl) {
          idSpinnerLbl.textContent = isEs
            ? 'Sin coincidencia clara. Sincronizaremos para usar la cascada de IA.'
            : 'No confident match. Will use AI cascade on sync.';
        }
        idSpinner?.classList.remove('hidden');
      }
    } catch (err) {
      console.warn('[rastrum] client identify failed:', err);
      idSpinner?.classList.add('hidden');
      if (idSpinnerLbl) {
        idSpinnerLbl.textContent = isEs
          ? 'Identificación local falló. Reintentaremos al sincronizar.'
          : 'Client-side identify failed. Will retry on sync.';
      }
      idSpinner?.classList.remove('hidden');
    }
  }

