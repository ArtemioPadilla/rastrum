---
import { t } from '../i18n/utils';
import MapPicker from './MapPicker.astro';
import {
  HABITATS,
  WEATHERS,
  ESTABLISHMENT_MEANS,
  labelFor,
} from '../lib/observation-enums';

interface Props {
  lang: 'en' | 'es';
  /**
   * 'full' = standard observation form.
   * 'identify-only' = photo + identification only; GPS/habitat/notes/evidence
   * are hidden behind a "Save as observation" reveal. Used by /identify.
   */
  mode?: 'full' | 'identify-only';
}
const { lang, mode = 'full' } = Astro.props;
const tr = t(lang);
const isEs = lang === 'es';
const identifyOnly = mode === 'identify-only';
const idStrings = tr.identify as unknown as Record<string, string>;
const submitFullLabel = isEs ? 'Guardar observación' : 'Save observation';
const submitIdentifyLabel = idStrings.just_identify_cta ?? (isEs ? 'Solo identificar' : 'Just identify');
const saveAsObservationLabel = idStrings.save_as_observation ?? (isEs ? 'Guardar como observación' : 'Save as observation');
const backToIdentifyLabel = idStrings.back_to_identify ?? (isEs ? 'Volver a solo identificar' : 'Back to identify only');
const saveInlineLinkLabel = idStrings.save_inline_link ?? (isEs ? 'Guardar como observación' : 'Save this as an observation');
const saveObservationCtaLabel = idStrings.save_observation_cta ?? submitFullLabel;
const initialSubmitLabel = identifyOnly ? submitIdentifyLabel : submitFullLabel;

// taxon-hint chip strings (extracted to typed locals for the JSX)
const taxonHintStrings = (tr.observe as unknown as { taxon_hint?: Record<string, string> }).taxon_hint ?? {};
const taxonHintLabel = taxonHintStrings.label ?? (isEs ? '¿Qué viste?' : 'What did you see?');
const taxonHintPlant   = taxonHintStrings.plant   ?? (isEs ? 'Planta'   : 'Plant');
const taxonHintBird    = taxonHintStrings.bird    ?? (isEs ? 'Ave'      : 'Bird');
const taxonHintMammal  = taxonHintStrings.mammal  ?? (isEs ? 'Mamífero' : 'Mammal');
const taxonHintInsect  = taxonHintStrings.insect  ?? (isEs ? 'Insecto'  : 'Insect');
const taxonHintFungus  = taxonHintStrings.fungus  ?? (isEs ? 'Hongo'    : 'Fungus');
const taxonHintClear   = taxonHintStrings.clear   ?? (isEs ? 'Quitar pista' : 'Clear hint');
const observeStringsForLabels = tr.observe as unknown as Record<string, string>;
const shareLabel = observeStringsForLabels.share ?? (isEs ? 'Compartir' : 'Share');
const shareUnavailableHint = observeStringsForLabels.share_unavailable_hint ?? (isEs ? 'Guarda primero la observación para compartirla.' : 'Save the observation first to share.');
const draftSaveLabel = observeStringsForLabels.draft_save_button ?? (isEs ? 'Guardar borrador' : 'Save draft');
const dedupeContinueLabel = observeStringsForLabels.photo_dedupe_continue ?? (isEs ? 'Continuar' : 'Continue');
const dedupeReplaceLabel  = observeStringsForLabels.photo_dedupe_replace  ?? (isEs ? 'Reemplazar' : 'Replace');

const habitats = HABITATS;
const weathers = WEATHERS;
const establishmentMeans = ESTABLISHMENT_MEANS;
const observeTree = tr.observe as unknown;

// Pull strings into typed local consts so JSX never needs an inline
// `Record<…>` cast (Astro/esbuild parses the angle brackets as a tag).
const observeStrings = tr.observe as unknown as Record<string, string>;
const cameraOpen        = observeStrings.camera_open         ?? (isEs ? 'Abrir cámara' : 'Open camera');
const cameraTitle       = observeStrings.camera_title        ?? (isEs ? 'Tomar foto' : 'Take a photo');
const cameraCapture     = observeStrings.camera_capture      ?? (isEs ? 'Capturar' : 'Capture');
const cameraCancel      = observeStrings.camera_cancel       ?? (isEs ? 'Cancelar' : 'Cancel');
const cameraFlip        = observeStrings.camera_flip         ?? (isEs ? 'Cambiar cámara' : 'Flip camera');
const cameraStarting    = observeStrings.camera_starting     ?? (isEs ? 'Iniciando cámara…' : 'Starting camera…');
const videoRecord       = observeStrings.video_record        ?? (isEs ? 'Grabar video' : 'Record video');
const videoLabel        = observeStrings.video_label         ?? 'Video';
const videoMaxDuration  = observeStrings.video_max_duration  ?? (isEs ? 'Máximo 30 segundos' : 'Maximum 30 seconds');
const gpsErrPermission  = observeStrings.gps_error_permission_denied ?? (isEs ? 'Permiso de ubicación denegado. Actívalo en ajustes.' : 'Location permission denied. Enable it in settings.');
const gpsErrUnavailable = observeStrings.gps_error_unavailable       ?? (isEs ? 'Ubicación no disponible.' : 'Location unavailable.');
const gpsErrTimeout     = observeStrings.gps_error_timeout           ?? (isEs ? 'Tiempo de espera agotado.' : 'Location timed out.');
const gpsDeniedTitle    = observeStrings.gps_denied_card_title       ?? (isEs ? 'Necesitamos tu ubicación' : 'We need your location');
const gpsDeniedBody     = observeStrings.gps_denied_card_body        ?? (isEs ? 'Tu dispositivo bloqueó el permiso. Vuelve a pedirlo o ingresa las coordenadas a mano.' : 'Your device blocked permission. Ask again or enter coordinates manually.');
const gpsDeniedRetry    = observeStrings.gps_denied_retry            ?? (isEs ? 'Volver a pedir permiso' : 'Ask again');
const gpsDeniedManual   = observeStrings.gps_denied_manual           ?? (isEs ? 'Ingresar manualmente' : 'Enter manually');
const formRestoredBanner   = observeStrings.form_restored_banner    ?? (isEs ? 'Restauramos tu observación en progreso.' : 'We restored your in-progress observation.');
const formRestoredDismiss  = observeStrings.form_restored_dismiss   ?? (isEs ? 'Descartar' : 'Discard');
const uploadProgressTpl    = observeStrings.upload_progress_label   ?? (isEs ? 'Subiendo foto: {pct}%' : 'Uploading photo: {pct}%');
const idAgainLabel         = observeStrings.id_again                ?? (isEs ? 'Identificar de otra forma' : 'Identify another way');
const idAgainRunningLabel  = observeStrings.id_again_running        ?? (isEs ? 'Reintentando identificación…' : 'Re-running identification…');
const idAgainFailedLabel   = observeStrings.id_again_failed         ?? (isEs ? 'No se obtuvo otro resultado.' : 'No new result.');
---

<div class="max-w-xl mx-auto">
  <h1 class="text-2xl font-bold tracking-tight mb-6">{identifyOnly ? tr.identify.title : tr.observe.title}</h1>

  <form id="obs-form" class="space-y-5" novalidate data-mode={mode}
    data-label-full={submitFullLabel}
    data-label-identify={submitIdentifyLabel}
    data-label-save-cta={saveObservationCtaLabel}
    data-label-save-as={saveAsObservationLabel}
    data-label-back-identify={backToIdentifyLabel}
    data-upload-progress-tpl={uploadProgressTpl}
    data-id-again-label={idAgainLabel}
    data-id-again-running={idAgainRunningLabel}
    data-id-again-failed={idAgainFailedLabel}>

    <!-- Pre-filled from chat banner (revealed by consumeChatPrefillIfAny) -->
    <div id="chat-prefill-banner" class="hidden rounded-lg border border-emerald-300 dark:border-emerald-800/40 bg-emerald-50 dark:bg-emerald-900/10 px-3 py-2 text-sm text-emerald-900 dark:text-emerald-200">
      {tr.chat.prefilled_from_chat_banner}
    </div>

    <!-- Pre-filled from share-target (revealed by consumeShareTargetIfAny) -->
    <div id="share-target-banner" class="hidden rounded-lg border border-blue-300 dark:border-blue-800/40 bg-blue-50 dark:bg-blue-900/10 px-3 py-2 text-sm text-blue-900 dark:text-blue-200">
      {lang === 'es' ? '📤 Archivo recibido por Compartir — completa la ubicación y guarda.' : '📤 File received via Share — add location and save.'}
    </div>

    <!-- WebLLM download warning — shown once before first local AI use -->
    <div id="webllm-warning" class="hidden rounded-lg border border-amber-200 bg-amber-50 dark:bg-amber-900/20 dark:border-amber-800 p-3">
      <p class="text-sm font-semibold text-amber-800 dark:text-amber-300 mb-1">🧠 {isEs ? 'IA local — primera descarga' : 'Local AI — first download'}</p>
      <p class="text-sm text-amber-700 dark:text-amber-400">
        {isEs
          ? 'Rastrum usa IA en tu dispositivo para identificar especies. La primera vez descarga ~2.4 GB. Tu foto nunca sale de tu celular.'
          : 'Rastrum uses on-device AI to identify species. First use downloads ~2.4 GB. Your photo never leaves your device.'}
      </p>
      <div class="flex gap-2 mt-2">
        <button id="webllm-ok" class="rounded bg-amber-700 px-3 py-1.5 text-xs text-white hover:bg-amber-800">
          {isEs ? 'Entendido, continuar' : 'Got it, continue'}
        </button>
        <button id="webllm-skip" class="rounded border px-3 py-1.5 text-xs font-semibold text-amber-900 border-amber-500 bg-amber-50 hover:bg-amber-100">
          {isEs ? 'Solo usar PlantNet' : 'Use PlantNet only'}
        </button>
      </div>
    </div>
    <!-- Photos (multi) -->
    <div>
      <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-2">{tr.observe.photo_label}</label>
      <div id="photo-grid" class="hidden mb-3 grid grid-cols-3 gap-2"></div>

      <!-- Primary camera row -->
      <div class="flex gap-2 flex-wrap">
        <!-- PRIMARY: system camera (most reliable, highest resolution) -->
        <button id="camera-legacy-btn" type="button" class="flex-1 cursor-pointer min-h-11 rounded-lg bg-emerald-700 hover:bg-emerald-800 px-3 py-2 text-sm font-semibold text-white text-center flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 0 1 2-2h2l1.5-2h7L17 7h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><circle cx="12" cy="13" r="3.5" fill="none" stroke="currentColor" stroke-width="2"/></svg>
          {tr.observe.use_camera}
        </button>
        <input id="camera-input" type="file" accept="image/*" capture="environment" class="sr-only" aria-label={tr.observe.use_camera} />
        <!-- SECONDARY: in-app getUserMedia viewfinder (opt-in via prefs toggle;
             auto-shown on Android when capture=environment is unreliable) -->
        <button
          id="camera-inapp-btn"
          type="button"
          class="hidden cursor-pointer min-h-11 rounded-lg border border-emerald-600/60 px-3 py-2 text-sm font-medium text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 flex items-center justify-center gap-1.5"
          title={isEs ? 'Cámara con vista previa (getUserMedia)' : 'Camera with live preview (getUserMedia)'}
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10l4.553-2.069A1 1 0 0121 8.882v6.236a1 1 0 01-1.447.894L15 14M3 8a2 2 0 012-2h8a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
          {isEs ? 'Vista previa' : 'Preview'}
        </button>
        <button id="gallery-btn" type="button" class="flex-1 cursor-pointer min-h-11 rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-2 text-sm font-medium text-zinc-700 dark:text-zinc-300 text-center hover:bg-zinc-50 dark:hover:bg-zinc-800/40 flex items-center justify-center gap-2">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 5h16v14H4z"/><path stroke-linecap="round" stroke-linejoin="round" d="m4 16 4-4 4 4 3-3 5 5"/><circle cx="9" cy="9" r="1.5" fill="currentColor"/></svg>
          {tr.observe.choose_file}
        </button>
        <input id="gallery-input" type="file" accept="image/*" multiple class="sr-only" aria-label={tr.observe.choose_file} />
      </div>

      <!-- In-app camera viewfinder overlay (hidden by default) -->
      <div
        id="inapp-camera-overlay"
        class="hidden fixed inset-0 z-[300] bg-black flex flex-col"
        role="dialog"
        aria-modal="true"
        aria-label={isEs ? 'Visor de cámara' : 'Camera viewfinder'}
      >
        <video
          id="inapp-camera-video"
          autoplay
          playsinline
          muted
          class="flex-1 w-full object-cover"
          aria-label={isEs ? 'Vista previa de cámara' : 'Camera preview'}
        ></video>
        <div class="flex items-center justify-around px-8 py-6 bg-black/80">
          <button
            id="inapp-camera-close"
            type="button"
            class="w-12 h-12 rounded-full flex items-center justify-center text-white border border-white/40 hover:bg-white/10"
            aria-label={isEs ? 'Cerrar cámara' : 'Close camera'}
          >
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
          <button
            id="inapp-camera-shutter"
            type="button"
            class="w-20 h-20 rounded-full bg-white border-4 border-zinc-300 hover:bg-zinc-100 active:scale-95 transition-transform"
            aria-label={isEs ? 'Capturar foto' : 'Capture photo'}
          ></button>
          <button
            id="inapp-camera-flip"
            type="button"
            class="w-12 h-12 rounded-full flex items-center justify-center text-white border border-white/40 hover:bg-white/10"
            aria-label={isEs ? 'Cambiar cámara' : 'Flip camera'}
          >
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </button>
        </div>
        <canvas id="inapp-camera-canvas" class="hidden" aria-hidden="true"></canvas>
      </div>
      <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400">{tr.observe.photo_hint}</p>
      <p id="photo-hint-android" class="hidden mt-1 text-xs text-amber-700 dark:text-amber-400">{observeStrings.photo_hint_android}</p>

      <!-- Quick-taxon chips (ux-quick-taxon-chips). Pure routing hint —
           selecting one filters the cascade runners; default = no hint. -->
      <fieldset id="taxon-hint-chips" class="mt-3" aria-label={taxonHintLabel}>
        <legend class="text-xs uppercase tracking-wider text-zinc-500 dark:text-zinc-400 mb-1">{taxonHintLabel}</legend>
        <div class="flex flex-wrap gap-1.5">
          <button type="button" data-hint="Plantae" class="taxon-chip min-h-9 px-2.5 py-1 rounded-full text-xs font-medium border border-zinc-300 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 data-[active=true]:bg-emerald-700 data-[active=true]:text-white data-[active=true]:border-emerald-700"><span aria-hidden="true">🌿</span> {taxonHintPlant}</button>
          <button type="button" data-hint="Animalia.Aves" class="taxon-chip min-h-9 px-2.5 py-1 rounded-full text-xs font-medium border border-zinc-300 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 data-[active=true]:bg-emerald-700 data-[active=true]:text-white data-[active=true]:border-emerald-700"><span aria-hidden="true">🐦</span> {taxonHintBird}</button>
          <button type="button" data-hint="Animalia.Mammalia" class="taxon-chip min-h-9 px-2.5 py-1 rounded-full text-xs font-medium border border-zinc-300 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 data-[active=true]:bg-emerald-700 data-[active=true]:text-white data-[active=true]:border-emerald-700"><span aria-hidden="true">🐾</span> {taxonHintMammal}</button>
          <button type="button" data-hint="Animalia.Insecta" class="taxon-chip min-h-9 px-2.5 py-1 rounded-full text-xs font-medium border border-zinc-300 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 data-[active=true]:bg-emerald-700 data-[active=true]:text-white data-[active=true]:border-emerald-700"><span aria-hidden="true">🐛</span> {taxonHintInsect}</button>
          <button type="button" data-hint="Fungi" class="taxon-chip min-h-9 px-2.5 py-1 rounded-full text-xs font-medium border border-zinc-300 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 data-[active=true]:bg-emerald-700 data-[active=true]:text-white data-[active=true]:border-emerald-700"><span aria-hidden="true">🍄</span> {taxonHintFungus}</button>
          <button type="button" id="taxon-hint-clear" class="hidden min-h-9 px-2.5 py-1 rounded-full text-xs font-medium border border-transparent text-zinc-500 hover:text-zinc-700 dark:hover:text-zinc-200 underline">{taxonHintClear}</button>
        </div>
      </fieldset>

      <!-- Photo dedupe warning (ux-photo-dedupe). Shown when the perceptual
           hash of a freshly-added photo matches one uploaded by this observer
           in the last 7 days. -->
      <div id="photo-dedupe-warn" class="hidden mt-2 rounded-lg border border-amber-300 dark:border-amber-700/40 bg-amber-50 dark:bg-amber-900/10 p-3 text-sm text-amber-800 dark:text-amber-200">
        <p id="photo-dedupe-warn-text"></p>
        <div class="mt-2 flex gap-2">
          <button type="button" id="photo-dedupe-keep" class="rounded bg-amber-700 hover:bg-amber-800 px-3 py-1 text-xs text-white">{dedupeContinueLabel}</button>
          <button type="button" id="photo-dedupe-replace" class="rounded border border-amber-300 px-3 py-1 text-xs text-amber-800 hover:bg-amber-100 dark:hover:bg-amber-800/40">{dedupeReplaceLabel}</button>
        </div>
      </div>
    </div>

    <!-- Video (multi) -->
    <div>
      <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-2">{videoLabel}</label>
      <div id="video-grid" class="hidden mb-3 space-y-2"></div>
      <div class="flex flex-wrap items-center gap-2">
        <button id="video-record-btn" type="button" class="min-h-11 rounded-lg border border-emerald-600/60 px-3 py-2 text-sm font-medium text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 disabled:opacity-50">
          <span data-video-label>{videoRecord}</span>
        </button>
        <!-- Upload existing video (camera trap, WhatsApp clip, etc.) -->
        <button id="video-upload-btn" type="button" class="min-h-11 rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-2 text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
          {lang === 'es' ? 'Subir video' : 'Upload video'}
        </button>
        <input id="video-upload-input" type="file" accept="video/*,.mp4,.mov,.webm,.avi,.mkv" class="sr-only" aria-label={lang === 'es' ? 'Subir archivo de video' : 'Upload video file'} />
        <span id="video-elapsed" class="hidden text-xs text-zinc-500 font-mono"></span>
        <span id="video-error" class="hidden text-xs text-red-600 dark:text-red-400"></span>
      </div>
      <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400">{videoMaxDuration}</p>
    </div>

    <!-- Identification block (overhauled: parallel cascade + progressive disclosure + tooltip) -->
    <div id="id-block" class="min-h-32">
      <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-2">{tr.observe.id_label ?? (isEs ? 'Identificación' : 'Identification')}</label>

      <!-- Single, non-morphing spinner -->
      <div id="id-spinner" class="hidden flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400 mb-2">
        <svg class="animate-spin h-4 w-4 text-emerald-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v8z"></path>
        </svg>
        <span id="id-spinner-label">{idStrings.spinner_label ?? (isEs ? 'Identificando…' : 'Identifying…')}</span>
      </div>

      <!-- Phi-vision offer card (no model cached, no Claude key) -->
      <div id="phi-offer" class="hidden rounded-lg border border-emerald-300/50 dark:border-emerald-700/40 bg-emerald-50/40 dark:bg-emerald-900/10 p-4 mb-3 space-y-3">
        <p class="text-sm font-semibold text-zinc-800 dark:text-zinc-200">{idStrings.phi_offer_title}</p>
        <p class="text-sm text-zinc-700 dark:text-zinc-300">{idStrings.phi_offer_body}</p>
        <div class="flex flex-wrap gap-2">
          <button id="phi-download-btn" type="button" class="min-h-11 inline-flex items-center gap-2 rounded-lg bg-emerald-700 hover:bg-emerald-800 px-3 py-2 text-sm font-semibold text-white">{idStrings.phi_download}</button>
          <button id="phi-skip-btn" type="button" data-phi-skip-hint={idStrings.phi_skip_hint} class="min-h-11 inline-flex items-center gap-2 rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-2 text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40">{idStrings.phi_skip}</button>
        </div>
      </div>

      <!-- Phi-vision download progress -->
      <div id="phi-progress" class="hidden rounded-lg border border-emerald-300/40 bg-white dark:bg-zinc-900 p-3 mb-3">
        <p class="text-xs text-zinc-600 dark:text-zinc-300 mb-1" id="phi-progress-label">{idStrings.phi_progress}</p>
        <div class="w-full h-2 rounded-full bg-zinc-200 dark:bg-zinc-800 overflow-hidden">
          <div id="phi-progress-bar" class="h-full bg-emerald-600" style="width:0%"></div>
        </div>
      </div>

      <!-- Result card -->
      <div id="id-result-card" class="hidden rounded-xl border border-zinc-200 dark:border-zinc-800 p-4 mb-2 bg-white dark:bg-zinc-900/40">
        <div class="flex items-baseline justify-between gap-2 flex-wrap">
          <div class="space-y-0.5 min-w-0">
            <p class="text-xs uppercase tracking-wider text-zinc-500 dark:text-zinc-400">{isEs ? 'Mejor coincidencia' : 'Top match'}</p>
            <p id="id-name" class="text-lg italic font-semibold text-emerald-700 dark:text-emerald-400 break-words"></p>
            <p id="id-common" class="hidden text-sm text-zinc-600 dark:text-zinc-300"></p>
          </div>
          <div class="flex items-center gap-2 flex-none">
            <span id="id-confidence-ring" class="inline-flex items-center" aria-hidden="false"></span>
            <span id="id-uncertain-pill" class="hidden rounded-full bg-amber-50 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300 px-2 py-0.5 text-xs font-semibold">{idStrings.uncertain_pill}</span>
            <button id="id-source-info" type="button" class="min-h-9 min-w-9 rounded-full text-zinc-400 hover:text-zinc-700 dark:hover:text-zinc-200 inline-flex items-center justify-center" aria-label={idStrings.source_info_label} aria-expanded="false">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" d="M12 8v.01M11 12h1v4h1"/></svg>
            </button>
            <button id="id-share-btn" type="button" class="min-h-9 inline-flex items-center gap-1 rounded-lg border border-emerald-600/60 px-2 py-1 text-xs font-medium text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 disabled:opacity-50" disabled title={shareUnavailableHint}>
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M4 12v7a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-7M16 6l-4-4-4 4M12 2v14"/></svg>
              {shareLabel}
            </button>
            <button id="id-clear" type="button" class="text-xs text-zinc-400 hover:text-red-500" aria-label={isEs ? 'Cambiar' : 'Change'}>{isEs ? 'Cambiar' : 'Change'}</button>
          </div>
        </div>
        <p id="id-note" class="hidden mt-2 text-sm text-zinc-700 dark:text-zinc-300"></p>

        <!-- Source chip (always visible after result) -->
        <div id="id-source-chip" class="hidden mt-2 inline-flex items-center gap-1.5 rounded-full bg-zinc-100 dark:bg-zinc-800/60 px-2.5 py-1 text-xs text-zinc-600 dark:text-zinc-300">
          <span id="id-source-chip-text"></span>
          <button id="id-source-chip-info" type="button" class="inline-flex items-center justify-center w-4 h-4 rounded-full hover:bg-zinc-200 dark:hover:bg-zinc-700" aria-label={isEs ? 'Sobre este identificador' : 'About this identifier'}>
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path stroke-linecap="round" d="M12 8v.01M11 12h1v4h1"/></svg>
          </button>
        </div>

        <!-- Source tooltip (expandable panel) -->
        <div id="id-source-tooltip" class="hidden mt-2 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900/60 p-3 text-xs text-zinc-700 dark:text-zinc-300 space-y-1.5" role="region">
          <p id="id-source-tooltip-title" class="font-semibold text-zinc-900 dark:text-zinc-100"></p>
          <p id="id-source-tooltip-body"></p>
          <p id="id-source-tooltip-desc" class="text-zinc-500 dark:text-zinc-400 italic"></p>
          <a id="id-source-tooltip-link" href="#" class="inline-block underline text-emerald-700 dark:text-emerald-400">{idStrings.source_link_label}</a>
        </div>

        <!-- Alternates section (progressive disclosure) -->
        <div id="id-alternates-wrap" class="hidden mt-3">
          <button id="id-alternates-toggle" type="button" class="text-xs text-emerald-700 dark:text-emerald-400 hover:underline" aria-expanded="false"></button>
          <div id="id-alternates" class="hidden mt-2">
            <p class="text-xs uppercase tracking-wider text-zinc-500 dark:text-zinc-400 mb-1">{idStrings.alternates_title}</p>
            <ul id="id-alternates-list" class="space-y-1 text-sm"></ul>
          </div>
        </div>

        <!-- Save-as-observation inline link (only meaningful in identify-only mode after success) -->
        <div id="id-save-inline" class="hidden mt-3 pt-3 border-t border-zinc-200 dark:border-zinc-800">
          <button type="button" id="save-inline-btn" class="text-sm font-medium text-emerald-700 dark:text-emerald-400 hover:underline">{saveInlineLinkLabel} →</button>
        </div>

        <!-- Try-again — re-runs cascade with the next-best taxon hint -->
        <div class="mt-3 pt-3 border-t border-zinc-200 dark:border-zinc-800 flex items-center gap-3 flex-wrap">
          <button type="button" id="id-again-btn" class="text-xs font-medium text-emerald-700 dark:text-emerald-400 hover:underline">↺ {idAgainLabel}</button>
          <span id="id-again-status" class="hidden text-xs text-zinc-500"></span>
        </div>
      </div>

      <!-- All-failed banner -->
      <div id="id-all-failed" class="hidden rounded-lg border border-amber-300 dark:border-amber-700/40 bg-amber-50 dark:bg-amber-900/10 p-3 text-sm text-amber-800 dark:text-amber-200 mb-2"></div>

      <!-- Manual input (always available, pre-filled by cascade) -->
      <input
        id="id-scientific-name"
        name="scientific_name"
        type="text"
        placeholder={isEs ? 'Nombre científico (opcional)' : 'Scientific name (optional)'}
        class="w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm"
        autocomplete="off"
        spellcheck={false}
      />
      <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400">{isEs ? 'Identificación automática al subir la foto. Puedes corregirla aquí.' : 'Auto-identifies on photo upload. Correct it here if needed.'}</p>
    </div>

    <!-- Audio -->
    <div>
      <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-2">{tr.observe.audio_label}</label>
      <div id="audio-grid" class="hidden mb-3 space-y-2"></div>
      <div class="flex flex-wrap items-center gap-2">
        <button id="audio-record-btn" type="button" class="rounded-lg border border-emerald-600/60 px-3 py-2 text-sm font-medium text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 disabled:opacity-50">
          <span data-audio-label>{tr.observe.audio_record}</span>
        </button>
        <!-- Upload existing audio file (e.g. bird call from WhatsApp) -->
        <button id="audio-upload-btn" type="button" class="rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-2 text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 flex items-center gap-1.5">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"/></svg>
          {lang === 'es' ? 'Subir audio' : 'Upload audio'}
        </button>
        <input id="audio-upload-input" type="file" accept="audio/*,.mp3,.wav,.ogg,.m4a,.aac,.flac,.opus" class="sr-only" aria-label={lang === 'es' ? 'Subir archivo de audio' : 'Upload audio file'} />
        <span id="audio-elapsed" class="hidden text-xs text-zinc-500 font-mono"></span>
        <span id="audio-error" class="hidden text-xs text-red-600 dark:text-red-400"></span>
      </div>
      <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400">{tr.observe.audio_max_duration} · {tr.observe.audio_pending_id}</p>
    </div>

    <!-- Evidence type -->
    <div data-identify-hide>
      <label for="obs-evidence-type" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.observe.evidence_type}</label>
      <select id="obs-evidence-type" name="evidence_type" class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm">
        <option value="direct_sighting">{lang === 'es' ? 'Avistamiento directo' : 'Direct sighting'}</option>
        <option value="track">{lang === 'es' ? 'Huella' : 'Track / footprint'}</option>
        <option value="scat">{lang === 'es' ? 'Excremento' : 'Scat'}</option>
        <option value="burrow">{lang === 'es' ? 'Madriguera' : 'Burrow / den'}</option>
        <option value="nest">{lang === 'es' ? 'Nido' : 'Nest'}</option>
        <option value="feather">{lang === 'es' ? 'Pluma' : 'Feather'}</option>
        <option value="bone">{lang === 'es' ? 'Hueso' : 'Bone'}</option>
        <option value="sound">{lang === 'es' ? 'Sonido' : 'Sound'}</option>
        <option value="camera_trap">{lang === 'es' ? 'Cámara trampa' : 'Camera trap'}</option>
      </select>
    </div>

    <!-- Location -->
    <div data-identify-hide>
      <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.observe.gps_label}</label>
      <div id="gps-display" class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900/50 px-3 py-2 text-sm min-h-9">
        <span id="gps-status" class="text-zinc-500 dark:text-zinc-400"
          data-err-permission={gpsErrPermission}
          data-err-unavailable={gpsErrUnavailable}
          data-err-timeout={gpsErrTimeout}
        >{tr.observe.gps_getting}</span>
      </div>
      <div id="gps-denied-card" class="hidden mt-2 rounded-lg border border-amber-300 dark:border-amber-700 bg-amber-50 dark:bg-amber-900/20 p-3">
        <p class="text-sm font-semibold text-amber-900 dark:text-amber-200">{gpsDeniedTitle}</p>
        <p class="text-xs text-amber-800 dark:text-amber-300 mt-0.5">{gpsDeniedBody}</p>
        <div class="mt-2 flex gap-2 flex-wrap">
          <button type="button" id="gps-denied-retry" class="rounded-lg bg-emerald-700 hover:bg-emerald-800 px-3 py-1.5 text-xs font-semibold text-white">{gpsDeniedRetry}</button>
          <button type="button" id="gps-denied-manual" class="rounded-lg border border-amber-500 px-3 py-1.5 text-xs font-medium text-amber-900 dark:text-amber-200">{gpsDeniedManual}</button>
        </div>
      </div>
      <div id="gps-manual-wrap" class="hidden mt-2 grid grid-cols-2 gap-2">
        <input id="manual-lat" name="lat" type="number" step="any" placeholder="Lat" class="rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-base" />
        <input id="manual-lng" name="lng" type="number" step="any" placeholder="Lng" class="rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-base" />
      </div>
      <div class="mt-1 flex gap-3 flex-wrap">
        <button type="button" id="gps-manual-btn" class="text-xs text-emerald-700 dark:text-emerald-400 underline">{tr.observe.gps_manual}</button>
        <MapPicker mode="edit" lang={lang} pickerId="observe" initialCoords={null} />
      </div>
    </div>

    <!-- Habitat / weather -->
    <div class="grid grid-cols-2 gap-3" data-identify-hide>
      <div>
        <label for="obs-habitat" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.observe.habitat}</label>
        <select id="obs-habitat" name="habitat" class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm">
          <option value="">{tr.observe.habitat_placeholder}</option>
          {habitats.map(h => <option value={h}>{labelFor(observeTree, 'habitat_options', h)}</option>)}
        </select>
      </div>
      <div>
        <label for="obs-weather" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.observe.weather}</label>
        <select id="obs-weather" name="weather" class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm">
          <option value="">{tr.observe.weather_placeholder}</option>
          {weathers.map(w => <option value={w}>{labelFor(observeTree, 'weather_options', w)}</option>)}
        </select>
      </div>
    </div>

    <!-- Establishment means (organism origin) -->
    <div data-identify-hide>
      <label for="obs-establishment" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1">
        {observeStrings.establishment_means}
      </label>
      <div class="flex flex-wrap gap-2">
        {establishmentMeans.map((v) => (
          <label class="cursor-pointer">
            <input
              type="radio"
              name="establishment_means"
              value={v}
              class="peer sr-only"
              checked={v === 'wild'}
            />
            <span class="inline-flex items-center rounded-full border border-zinc-300 dark:border-zinc-700 px-3 py-1.5 text-xs font-medium text-zinc-700 dark:text-zinc-300 peer-checked:bg-emerald-700 peer-checked:text-white peer-checked:border-emerald-700 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 transition-colors">
              {labelFor(observeTree, 'establishment_means_options', v)}
            </span>
          </label>
        ))}
      </div>
    </div>

    <!-- Notes -->
    <div data-identify-hide>
      <div class="flex items-end justify-between gap-2 flex-wrap mb-1">
        <label for="obs-notes" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">{tr.observe.notes}</label>
        <div class="flex flex-wrap gap-2 ml-auto">
          <button
            id="auto-narrative-btn"
            type="button"
            class="hidden inline-flex items-center gap-1.5 min-h-11 sm:min-h-0 rounded-lg border border-emerald-600/60 px-3 py-1.5 text-xs font-medium text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 disabled:opacity-50"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            <span data-narrative-label>{tr.observe.auto_narrative}</span>
          </button>
          <button
            id="translate-btn"
            type="button"
            disabled
            class="hidden inline-flex items-center gap-1.5 min-h-11 sm:min-h-0 rounded-lg border border-emerald-600/60 px-3 py-1.5 text-xs font-medium text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 disabled:opacity-50"
          >
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5h12M9 3v2m1.05 6.95L7 17l-3-3m11.95 5L20 13l-3 3" /></svg>
            <span data-translate-label>{tr.observe.translate}</span>
          </button>
        </div>
      </div>
      <textarea id="obs-notes" name="notes" maxlength="2000" rows="3" placeholder={tr.observe.notes_placeholder} class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-base" style="scroll-margin-bottom: 80px"></textarea>
      <div class="mt-1 flex items-center gap-3 flex-wrap">
        <button id="translate-undo-btn" type="button" class="hidden text-xs font-medium text-emerald-700 dark:text-emerald-400 underline">
          {tr.observe.translated_undo}
        </button>
        <span id="ai-helpers-progress" class="hidden text-xs text-zinc-500 dark:text-zinc-400 font-mono"></span>
        <span id="ai-helpers-error" class="hidden text-xs text-red-600 dark:text-red-400"></span>
      </div>
    </div>

    <!-- Privacy notice — always visible. Becomes louder once an ID resolves to a NOM-059 species -->
    <div class="rounded-lg border border-amber-300 dark:border-amber-700/40 bg-amber-50 dark:bg-amber-900/10 p-3 text-xs text-amber-800 dark:text-amber-200" data-identify-hide>
      {lang === 'es'
        ? 'Las coordenadas exactas se guardan privadamente. Si la especie identificada está en NOM-059 o CITES, mostraremos sólo una zona aproximada en el mapa público.'
        : 'Exact coordinates are stored privately. If the identified species is on NOM-059 or CITES, the public map will only show a coarsened area.'}
    </div>

    <!--
      Sticky on mobile: viewport keyboards hide the submit button when the
      notes textarea is focused. Sticky-bottom + scroll-margin-bottom on
      the surrounding form keeps the action row visible above the
      keyboard. Desktop falls through to the static layout (sm:static).
    -->
    <div class="flex items-center gap-3 pt-2 flex-wrap sticky bottom-20 z-10 sm:static sm:bottom-auto bg-white/95 dark:bg-zinc-950/95 sm:bg-transparent dark:sm:bg-transparent backdrop-blur sm:backdrop-blur-0 -mx-2 px-2 py-2 sm:mx-0 sm:px-0 sm:py-0 rounded-lg sm:rounded-none">
      <button type="submit" id="submit-btn" class="min-h-12 rounded-lg bg-emerald-700 hover:bg-emerald-800 px-5 py-2.5 text-base font-semibold text-white disabled:opacity-50 shadow-sm">
        <span data-label>{initialSubmitLabel}</span>
      </button>
      <button type="button" id="save-draft-btn" class={`min-h-11 rounded-lg border border-emerald-600/60 px-4 py-2 text-sm font-medium text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 ${identifyOnly ? 'hidden' : ''}`} data-identify-hide>
        {draftSaveLabel}
      </button>
      <button type="button" id="save-as-observation-btn" class="hidden min-h-11 rounded-lg border border-emerald-600/60 px-4 py-2 text-sm font-medium text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20">
        {saveAsObservationLabel}
      </button>
      <button type="button" id="back-to-identify-btn" class="hidden min-h-11 rounded-lg border border-zinc-300 dark:border-zinc-700 px-4 py-2 text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40">
        {backToIdentifyLabel}
      </button>
    </div>
    <p class="text-xs text-zinc-500 dark:text-zinc-400 max-w-prose" data-identify-hide>
      {lang === 'es'
        ? '✓ Tu observación se guarda incluso si la IA no logra identificarla ahora — la identificación se reintenta cuando estés en línea o cuando descargues los modelos.'
        : "✓ Your observation is saved even if AI can't identify it right now — identification will retry when you're online or after the models finish downloading."}
    </p>
    <p id="err" class="hidden text-sm text-red-600 dark:text-red-400"></p>

    <!-- Upload progress strip (rendered while syncOutbox is pushing blobs) -->
    <div id="upload-progress" class="hidden mt-2" aria-live="polite">
      <p id="upload-progress-label" class="text-xs text-zinc-600 dark:text-zinc-400 mb-1">—</p>
      <div class="h-1.5 w-full rounded-full bg-zinc-200 dark:bg-zinc-800 overflow-hidden">
        <div id="upload-progress-bar" class="h-full bg-emerald-600 transition-[width] duration-150" style="width:0%"></div>
      </div>
    </div>
  </form>

  <!-- Form-restored banner (appears when we re-hydrate a saved draft) -->
  <div id="form-restored" class="hidden mt-3 rounded-lg border border-sky-300 dark:border-sky-800 bg-sky-50 dark:bg-sky-900/20 p-3 flex items-center justify-between gap-2">
    <p class="text-xs text-sky-900 dark:text-sky-200" data-restored-tpl={formRestoredBanner}>{formRestoredBanner}</p>
    <button id="form-restored-dismiss" type="button" class="text-xs font-medium text-sky-700 dark:text-sky-300 underline">{formRestoredDismiss}</button>
  </div>

  <div id="success" class="hidden mt-6 rounded-lg border border-emerald-200 dark:border-emerald-900 bg-emerald-50 dark:bg-emerald-900/20 p-4">
    <p id="success-msg" class="text-sm text-emerald-900 dark:text-emerald-200">—</p>
    <button id="another-btn" class="mt-3 text-xs font-medium text-emerald-700 dark:text-emerald-400 underline">{tr.observe.another}</button>
  </div>
</div>

<!-- Camera modal (getUserMedia) — full-screen on small viewports -->
<div id="camera-modal" class="hidden fixed inset-0 z-50 flex items-stretch sm:items-center justify-center bg-black/80 p-0 sm:p-4" role="dialog" aria-modal="true" aria-labelledby="camera-modal-title">
  <div class="relative w-full sm:max-w-lg bg-black sm:rounded-lg overflow-hidden flex flex-col">
    <div class="flex items-center justify-between px-3 py-2 bg-black/60 text-white">
      <h2 id="camera-modal-title" class="text-sm font-semibold">{cameraTitle}</h2>
      <button id="camera-close-btn" type="button" class="min-h-11 min-w-11 rounded text-white/90 hover:text-white" aria-label={cameraCancel}>
        <svg class="w-5 h-5 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="relative flex-1 min-h-[60vh] sm:min-h-[60vh] bg-black flex items-center justify-center">
      <video id="camera-video" class="w-full h-full max-h-[80vh] object-contain bg-black" autoplay playsinline muted></video>
      <p id="camera-status" class="hidden absolute inset-0 flex items-center justify-center text-white text-sm px-4 text-center">{cameraStarting}</p>
    </div>
    <div class="flex items-center justify-between gap-2 px-3 py-3 bg-black/70">
      <button id="camera-flip-btn" type="button" class="min-h-11 px-3 rounded-lg text-sm font-medium text-white border border-white/30 hover:bg-white/10">
        {cameraFlip}
      </button>
      <button id="camera-capture-btn" type="button" class="min-h-11 rounded-lg bg-emerald-600 hover:bg-emerald-700 px-5 py-2 text-sm font-semibold text-white disabled:opacity-50">
        {cameraCapture}
      </button>
      <button id="camera-cancel-btn" type="button" class="min-h-11 px-3 rounded-lg text-sm font-medium text-white/90 hover:text-white">
        {cameraCancel}
      </button>
    </div>
  </div>
</div>


<style is:global>
  /* identify-only mode: hide observation-only sections until the user
     opts to "Save as observation". The form re-shows them by toggling
     data-mode to 'full' at runtime. */
  form#obs-form[data-mode="identify-only"] [data-identify-hide] { display: none; }
</style>

<script>
  import { parse as parseExif } from 'exifr';
  import { syncOutbox, registerSyncTriggers } from '../lib/sync';
  import { resolveObserverRef, saveObservationToOutbox } from '../lib/observe';
  import type { Observation } from '../lib/types';
  import {
    pickVideoMime,
    VIDEO_MAX_SECS,
    VIDEO_THUMB_PARAMS,
    computeThumbDims,
  } from '../lib/media-helpers';

  const form         = document.getElementById('obs-form') as HTMLFormElement | null;

  // WebLLM download warning — show once before first local AI use
  const webllmWarning = document.getElementById('webllm-warning');
  const webllmOk      = document.getElementById('webllm-ok');
  const webllmSkip    = document.getElementById('webllm-skip');
  const { hasShownLocalAIDownloadWarning, markLocalAIDownloadWarningShown } = await import('../lib/sync');
  const LOCAL_AI_OPTIN = 'rastrum.localAiOptIn';

  if (!hasShownLocalAIDownloadWarning() && localStorage.getItem(LOCAL_AI_OPTIN) !== 'false') {
    webllmWarning?.classList.remove('hidden');
  }
  webllmOk?.addEventListener('click', () => {
    markLocalAIDownloadWarningShown();
    webllmWarning?.classList.add('hidden');
  });
  webllmSkip?.addEventListener('click', () => {
    localStorage.setItem(LOCAL_AI_OPTIN, 'false');
    markLocalAIDownloadWarningShown();
    webllmWarning?.classList.add('hidden');
  });
  const cameraInput  = document.getElementById('camera-input') as HTMLInputElement | null;
  const galleryInput = document.getElementById('gallery-input') as HTMLInputElement | null;
  const photoGrid    = document.getElementById('photo-grid');
  const gpsStatus    = document.getElementById('gps-status');
  const gpsManualBtn = document.getElementById('gps-manual-btn');
  const gpsManualWrap= document.getElementById('gps-manual-wrap');
  const manualLat    = document.getElementById('manual-lat') as HTMLInputElement | null;
  const manualLng    = document.getElementById('manual-lng') as HTMLInputElement | null;
  const submitBtn    = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const btnLabel     = submitBtn?.querySelector('[data-label]') as HTMLElement | null;
  const errBox       = document.getElementById('err') as HTMLParagraphElement | null;
  const successBox   = document.getElementById('success');
  const successMsg   = document.getElementById('success-msg');
  const anotherBtn   = document.getElementById('another-btn');

  const ORIGINAL_LABEL = btnLabel?.textContent ?? 'Save';
  const SUBMITTING = (document.documentElement.lang === 'es') ? 'Guardando…' : 'Saving…';

  type LocState = {
    lat: number; lng: number; accuracyM: number;
    altitudeM: number | null;
    capturedFrom: 'gps' | 'exif' | 'manual';
  } | null;

  type PhotoEntry = { file: File; blobId: string };
  type AudioEntry = { blob: Blob; blobId: string; mimeType: string; durationSec: number };
  type VideoEntry = {
    blob: Blob;
    blobId: string;
    mimeType: string;
    durationSec: number;
    thumbnailUrl: string | null;
  };

  let location: LocState = null;
  const photos: PhotoEntry[] = [];
  const audios: AudioEntry[] = [];
  const videos: VideoEntry[] = [];

  function paintLocation() {
    if (!gpsStatus) return;
    if (!location) {
      gpsStatus.textContent = (document.documentElement.lang === 'es') ? 'Obteniendo tu ubicación…' : 'Getting your location…';
      gpsStatus.className = 'text-zinc-500';
      return;
    }
    const source = location.capturedFrom === 'exif'
      ? (document.documentElement.lang === 'es' ? 'Foto' : 'Photo')
      : location.capturedFrom.toUpperCase();
    gpsStatus.textContent = `${location.lat.toFixed(5)}, ${location.lng.toFixed(5)}  ·  ${source}  ·  ±${Math.round(location.accuracyM)} m`;
    gpsStatus.className = 'text-zinc-900 dark:text-zinc-100 font-mono text-xs';
  }

  function repaintGrid() {
    if (!photoGrid) return;
    photoGrid.classList.toggle('hidden', photos.length === 0);
    photoGrid.innerHTML = photos.map((p, i) => `
      <div class="relative aspect-square rounded-lg overflow-hidden border border-zinc-200 dark:border-zinc-800">
        <img src="${URL.createObjectURL(p.file)}" alt="" class="w-full h-full object-cover" />
        ${i === 0 ? '<span class="absolute top-1 left-1 text-[10px] px-1.5 py-0.5 rounded bg-emerald-600 text-white">primary</span>' : ''}
        <button data-rm="${i}" type="button" class="absolute top-1 right-1 w-5 h-5 rounded-full bg-black/60 text-white text-xs flex items-center justify-center" aria-label="remove">×</button>
      </div>
    `).join('');
    photoGrid.querySelectorAll<HTMLButtonElement>('button[data-rm]').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = Number(btn.dataset.rm);
        photos.splice(idx, 1);
        repaintGrid();
      });
    });
  }

  // ── Identification block (parallel cascade + progressive disclosure) ──
  const idSpinner       = document.getElementById('id-spinner');
  const idResultCard    = document.getElementById('id-result-card');
  const idName          = document.getElementById('id-name');
  const idCommon        = document.getElementById('id-common');
  const idConfidenceRing= document.getElementById('id-confidence-ring');
  const idShareBtn      = document.getElementById('id-share-btn') as HTMLButtonElement | null;
  const idUncertainPill = document.getElementById('id-uncertain-pill');
  const idNote          = document.getElementById('id-note');
  const idSourceInfoBtn = document.getElementById('id-source-info');
  const idSourceTooltip = document.getElementById('id-source-tooltip');
  const idSourceTipTitle= document.getElementById('id-source-tooltip-title');
  const idSourceTipBody = document.getElementById('id-source-tooltip-body');
  const idSourceTipLink = document.getElementById('id-source-tooltip-link') as HTMLAnchorElement | null;
  const idAlternatesWrap = document.getElementById('id-alternates-wrap');
  const idAlternatesToggle = document.getElementById('id-alternates-toggle');
  const idAlternatesPanel = document.getElementById('id-alternates');
  const idAlternatesList = document.getElementById('id-alternates-list');
  const idSaveInline    = document.getElementById('id-save-inline');
  const idAllFailed     = document.getElementById('id-all-failed');
  const idClear         = document.getElementById('id-clear');
  const idInput         = document.getElementById('id-scientific-name') as HTMLInputElement | null;
  const phiOffer        = document.getElementById('phi-offer');
  const phiDownloadBtn  = document.getElementById('phi-download-btn');
  const phiSkipBtn      = document.getElementById('phi-skip-btn');
  const phiProgress     = document.getElementById('phi-progress');
  const phiProgressBar  = document.getElementById('phi-progress-bar');
  const phiProgressLbl  = document.getElementById('phi-progress-label');
  const isEs            = document.documentElement.lang === 'es';

  // Source registry — display name, license, doc-spec link, short description.
  const docLang = document.documentElement.lang === 'es' ? 'es' : 'en';
  const archCascadeUrl = `/${docLang}/docs/architecture/#identifier-cascade`;
  const archInBrowserUrl = `/${docLang}/docs/architecture/#in-browser-ai`;
  const SOURCE_META: Record<string, { name: string; meta: string; desc: string; spec: string; isInterpreter?: boolean }> = {
    plantnet: {
      name: 'PlantNet',
      meta: isEs
        ? 'PlantNet — identificación regional gratuita de plantas por INRIA. Licencia CC BY-SA 4.0 sobre los datos de identificación.'
        : 'PlantNet — free regional plant identification by INRIA. CC BY-SA 4.0 on identification data.',
      desc: isEs
        ? 'Modelo especializado en plantas. Alta precisión para flora.'
        : 'Specialized plant model. High accuracy for flora.',
      spec: archCascadeUrl,
    },
    claude_haiku: {
      name: 'Claude Haiku 4.5',
      meta: isEs
        ? 'Claude Haiku 4.5 — LLM visual de Anthropic, generalista. Pago por consulta (~$0.003).'
        : 'Claude Haiku 4.5 — Anthropic vision LLM, generalist. Pay-per-call (~$0.003).',
      desc: isEs
        ? 'Modelo de lenguaje. Útil cuando los modelos especializados no están seguros.'
        : 'Language model. Useful when specialized models aren\'t confident.',
      spec: archCascadeUrl,
      isInterpreter: true,
    },
    webllm_phi35_vision: {
      name: 'Phi-3.5-vision',
      meta: isEs
        ? 'Phi-3.5-vision — VLM general de Microsoft en el dispositivo. Confianza limitada por diseño (sin entrenamiento taxonómico).'
        : 'Phi-3.5-vision — Microsoft on-device general VLM. Confidence is hard-capped by design (no taxonomic training).',
      desc: isEs
        ? 'IA en tu dispositivo. Funciona sin internet.'
        : 'On-device AI. Works without internet.',
      spec: archInBrowserUrl,
      isInterpreter: true,
    },
    birdnet: {
      name: 'BirdNET',
      meta: isEs
        ? 'BirdNET-Lite v2.4 — identificación de aves por sonido del Cornell Lab. CC BY-NC-SA 4.0.'
        : 'BirdNET-Lite v2.4 — bird call identification by Cornell Lab. CC BY-NC-SA 4.0.',
      desc: isEs
        ? 'Modelo especializado en aves por sonido. Cornell Lab.'
        : 'Specialized bird model by sound. Cornell Lab.',
      spec: archCascadeUrl,
    },
    onnx_base: {
      name: 'EfficientNet-Lite0',
      meta: isEs
        ? 'EfficientNet-Lite0 — clasificador ImageNet genérico (~2.8 MB). Apache-2.0.'
        : 'EfficientNet-Lite0 — generic ImageNet classifier (~2.8 MB). Apache-2.0.',
      desc: isEs
        ? 'Clasificador offline de respaldo. Baja precisión, siempre disponible.'
        : 'Offline fallback classifier. Low accuracy, always available.',
      spec: archInBrowserUrl,
    },
  };

  const idSourceChip = document.getElementById('id-source-chip');
  const idSourceChipText = document.getElementById('id-source-chip-text');
  const idSourceChipInfo = document.getElementById('id-source-chip-info');
  const idSourceTooltipDesc = document.getElementById('id-source-tooltip-desc');

  // Local interface, kept here so the form can stay the single mount point
  // for the cascade UI without needing an extra cross-file abstraction.
  type CascadeUnified = {
    source: string;
    scientific_name: string;
    common_name: string | null;
    confidence: number;
    alternates: Array<{ scientific_name: string; common_name: string | null; score: number }>;
    note?: string | null;
  };

  let currentIdentification: { scientific_name: string; confidence: number; source: string } | null = null;
  let lastFile: File | null = null;
  let activeAbort: AbortController | null = null;

  function hideAllIdStates() {
    idSpinner?.classList.add('hidden');
    idResultCard?.classList.add('hidden');
    idAllFailed?.classList.add('hidden');
    phiOffer?.classList.add('hidden');
    phiProgress?.classList.add('hidden');
  }

  function clearIdResult() {
    currentIdentification = null;
    if (idInput) idInput.value = '';
    hideAllIdStates();
    if (activeAbort) { activeAbort.abort(); activeAbort = null; }
  }
  idClear?.addEventListener('click', clearIdResult);

  // Toggle the source-info popover. Native popover API is preferred but
  // we render a region in-card on browsers without it for robustness.
  function toggleSourceTooltip() {
    if (!idSourceTooltip) return;
    const open = !idSourceTooltip.classList.contains('hidden');
    idSourceTooltip.classList.toggle('hidden', open);
    idSourceInfoBtn?.setAttribute('aria-expanded', String(!open));
  }
  idSourceInfoBtn?.addEventListener('click', toggleSourceTooltip);
  idSourceChipInfo?.addEventListener('click', toggleSourceTooltip);

  // ── Share button (ux-share-button) ────────────────────────────────
  // Enabled only after the observation has been saved (we need an id to
  // build the /share/obs/?id=… URL). On mobile, opens navigator.share();
  // on desktop, falls back to clipboard.
  idShareBtn?.addEventListener('click', async () => {
    if (!lastSavedObservationId) {
      if (errBox) {
        errBox.textContent = shareUnavailableHint;
        errBox.classList.remove('hidden');
      }
      return;
    }
    const url = `https://rastrum.org/share/obs/?id=${encodeURIComponent(lastSavedObservationId)}`;
    const title = idName?.textContent ?? 'Rastrum';
    const text = isEs ? '¡Mira esta observación!' : 'Look at this observation!';
    type NavShare = Navigator & { share?: (data: ShareData) => Promise<void> };
    const nav = navigator as NavShare;
    try {
      if (typeof nav.share === 'function') {
        await nav.share({ url, title, text });
      } else if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(url);
        if (idAllFailed) {
          idAllFailed.textContent = observeStringsRT.share_copied;
          idAllFailed.classList.remove('hidden');
        }
      } else {
        if (errBox) {
          errBox.textContent = observeStringsRT.share_failed + ' ' + url;
          errBox.classList.remove('hidden');
        }
      }
    } catch {
      // User cancelled or clipboard denied — non-fatal.
    }
  });

  idAlternatesToggle?.addEventListener('click', () => {
    if (!idAlternatesPanel) return;
    const open = !idAlternatesPanel.classList.contains('hidden');
    idAlternatesPanel.classList.toggle('hidden', open);
    idAlternatesToggle.setAttribute('aria-expanded', String(!open));
    idAlternatesToggle.textContent = open
      ? (idStringsRT.show_alternates ?? '+ {n} alternatives').replace('{n}', String(currentAlternates.length))
      : (idStringsRT.hide_alternates ?? 'Hide alternatives');
  });

  // Read i18n strings injected on the form via dataset (i18n is a function
  // call in the frontmatter; we dropped the keys we need into static text
  // already, but a couple are dynamic — read them off the existing form).
  const idStringsRT = {
    show_alternates: isEs ? '+ {n} alternativas' : '+ {n} alternatives',
    hide_alternates: isEs ? 'Ocultar alternativas' : 'Hide alternatives',
    all_failed:      isEs ? 'Todos los identificadores fallaron. Revisa tu conexión y prueba con una foto más clara.' : 'All identifiers failed. Check your connection and try a clearer photo.',
    result_unknown:  isEs ? 'No se pudo identificar esta foto con confianza.' : 'Could not identify this photo confidently.',
    phi_running:     isEs ? 'Identificando con IA en el dispositivo…' : 'Identifying with on-device AI…',
    phi_skip_hint:   phiSkipBtn?.dataset.phiSkipHint ?? (isEs ? 'Puedes descargar el modelo más tarde desde Perfil → Editar → Configuración de IA, o escribe el nombre de la especie manualmente.' : 'You can download the model later from Profile → Edit → AI settings, or just type the species name manually.'),
  };

  let currentAlternates: Array<{ scientific_name: string; common_name: string | null; score: number }> = [];

  function paintCard(r: CascadeUnified, uncertain: boolean) {
    if (!idResultCard) return;
    if (idName) idName.textContent = r.scientific_name;
    if (idCommon) {
      if (r.common_name) {
        idCommon.textContent = r.common_name;
        idCommon.classList.remove('hidden');
      } else {
        idCommon.classList.add('hidden');
      }
    }
    if (idConfidenceRing) idConfidenceRing.innerHTML = renderConfidenceRing(r.confidence);
    if (idUncertainPill) idUncertainPill.classList.toggle('hidden', !uncertain);
    if (idNote) {
      if (r.note) {
        idNote.textContent = r.note;
        idNote.classList.remove('hidden');
      } else {
        idNote.classList.add('hidden');
      }
    }
    const meta = SOURCE_META[r.source] ?? { name: r.source, meta: r.source, desc: '', spec: '/en/docs/architecture/' };

    // Source chip: "PlantNet · 87% confianza" or "Claude Haiku · interpretado"
    if (idSourceChip && idSourceChipText) {
      const pct = Math.round(r.confidence * 100);
      const detail = meta.isInterpreter
        ? (isEs ? 'interpretado' : 'interpreted')
        : (isEs ? `${pct}% confianza` : `${pct}% confidence`);
      idSourceChipText.textContent = `${meta.name} · ${detail}`;
      idSourceChip.classList.remove('hidden');
    }

    // Source tooltip (expanded by chip info button or "i" button)
    if (idSourceTipTitle) idSourceTipTitle.textContent = (isEs ? 'Identificado vía ' : 'Identified via ') + meta.name;
    if (idSourceTipBody) idSourceTipBody.textContent = meta.meta;
    if (idSourceTooltipDesc) idSourceTooltipDesc.textContent = meta.desc;
    if (idSourceTipLink) idSourceTipLink.href = meta.spec;
    idSourceTooltip?.classList.add('hidden');
    idSourceInfoBtn?.setAttribute('aria-expanded', 'false');

    // Alternates progressive disclosure.
    currentAlternates = r.alternates.filter(a => a.scientific_name);
    if (idAlternatesList) {
      idAlternatesList.innerHTML = currentAlternates.slice(0, 4).map(a => {
        const pct = Math.round((a.score ?? 0) * 100);
        const safeSci = escapeHtml(a.scientific_name);
        const safeCommon = a.common_name ? escapeHtml(a.common_name) + ' · ' : '';
        return `<li class="flex items-baseline justify-between gap-2"><span class="italic">${safeSci}</span><span class="text-xs text-zinc-500">${safeCommon}${pct}%</span></li>`;
      }).join('');
    }

    if (currentAlternates.length === 0) {
      idAlternatesWrap?.classList.add('hidden');
    } else {
      idAlternatesWrap?.classList.remove('hidden');
      // Visibility rules:
      //   ≥0.85 → collapsed behind toggle
      //   0.5..0.85 → visible
      //   <0.5 → visible (uncertain case)
      const collapsed = r.confidence >= 0.85;
      idAlternatesPanel?.classList.toggle('hidden', collapsed);
      if (idAlternatesToggle) {
        idAlternatesToggle.setAttribute('aria-expanded', String(!collapsed));
        idAlternatesToggle.textContent = collapsed
          ? idStringsRT.show_alternates.replace('{n}', String(currentAlternates.length))
          : idStringsRT.hide_alternates;
      }
    }

    idResultCard.classList.remove('hidden');
    if (idInput) idInput.value = r.scientific_name;
    currentIdentification = {
      scientific_name: r.scientific_name,
      confidence: r.confidence,
      source: r.source,
    };
    // Show the inline "Save as observation" link in identify-only mode.
    if (form?.dataset.mode === 'identify-only') {
      idSaveInline?.classList.remove('hidden');
    } else {
      idSaveInline?.classList.add('hidden');
    }
  }

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string));
  }

  /**
   * Render an SVG confidence ring (replaces the old % text pill).
   * Mirrors src/components/ConfidenceRing.astro for parity — same color
   * thresholds: emerald-500 ≥ 0.85, amber-500 0.5–0.85, red-500 < 0.5.
   */
  function renderConfidenceRing(confidence: number): string {
    const c = Math.max(0, Math.min(1, Number.isFinite(confidence) ? confidence : 0));
    const size = 32;
    const stroke = 3;
    const r = (size - stroke) / 2;
    const circumference = 2 * Math.PI * r;
    const dash = (circumference * c).toFixed(2);
    const gap  = (circumference - (circumference * c)).toFixed(2);
    const colorClass = c >= 0.85 ? 'text-emerald-500' : c >= 0.5 ? 'text-amber-500' : 'text-red-500';
    const pct = Math.round(c * 100);
    return `<span class="relative inline-flex items-center justify-center ${colorClass}" style="width:${size}px;height:${size}px" role="img" aria-label="${pct}% confidence">
      <svg width="${size}" height="${size}" viewBox="0 0 ${size} ${size}" class="absolute inset-0 -rotate-90" aria-hidden="true">
        <circle cx="${size/2}" cy="${size/2}" r="${r}" fill="none" stroke="currentColor" stroke-opacity="0.15" stroke-width="${stroke}"/>
        <circle cx="${size/2}" cy="${size/2}" r="${r}" fill="none" stroke="currentColor" stroke-width="${stroke}" stroke-linecap="round" stroke-dasharray="${dash} ${gap}"/>
      </svg>
      <span class="relative text-[9px] font-semibold tabular-nums leading-none">${pct}</span>
    </span>`;
  }

  // ── Taxon hint chips (ux-quick-taxon-chips) ──────────────────────────
  // Tapping a chip primes the cascade by filtering runners (e.g. 🐦 drops
  // PlantNet, prefers Phi/Claude). Default state = no hint.
  type TaxonHint = 'Plantae' | 'Animalia.Aves' | 'Animalia.Mammalia' | 'Animalia.Insecta' | 'Fungi';
  let activeTaxonHint: TaxonHint | null = null;
  const taxonChipBtns = document.querySelectorAll<HTMLButtonElement>('.taxon-chip');
  const taxonClearBtn = document.getElementById('taxon-hint-clear');

  function paintTaxonChips() {
    taxonChipBtns.forEach((btn) => {
      btn.dataset.active = String(btn.dataset.hint === activeTaxonHint);
    });
    taxonClearBtn?.classList.toggle('hidden', !activeTaxonHint);
  }

  taxonChipBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const v = btn.dataset.hint as TaxonHint | undefined;
      if (!v) return;
      activeTaxonHint = activeTaxonHint === v ? null : v;
      paintTaxonChips();
      // Re-run identify on the first photo if we already have one — the chip
      // is a routing hint, so changing it should re-route.
      if (lastFile) triggerClientIdentify(lastFile);
    });
  });
  taxonClearBtn?.addEventListener('click', () => {
    activeTaxonHint = null;
    paintTaxonChips();
    if (lastFile) triggerClientIdentify(lastFile);
  });

  // ── "Identify another way" ──────────────────────────────────────────
  // Re-runs the cascade, excluding the runner that produced the current
  // result. Used when Phi or PlantNet returns the wrong taxon and the
  // user would rather have the alternate provider's answer than re-type
  // the scientific name.
  document.getElementById('id-again-btn')?.addEventListener('click', async () => {
    const btn = document.getElementById('id-again-btn') as HTMLButtonElement | null;
    const status = document.getElementById('id-again-status');
    if (!lastFile || !btn) return;
    const runningLabel = form?.dataset.idAgainRunning ?? 'Re-running…';
    const failedLabel  = form?.dataset.idAgainFailed  ?? 'No new result.';
    btn.disabled = true;
    if (status) {
      status.textContent = runningLabel;
      status.classList.remove('hidden');
    }
    const prevSource = currentIdentification?.source ?? null;
    const before = currentIdentification?.scientific_name ?? null;
    try {
      await triggerClientIdentify(lastFile, prevSource);
      if (status && currentIdentification?.scientific_name === before) {
        status.textContent = failedLabel;
      } else if (status) {
        status.classList.add('hidden');
      }
    } catch (err) {
      if (status) status.textContent = err instanceof Error ? err.message : String(err);
    } finally {
      btn.disabled = false;
    }
  });

  async function triggerClientIdentify(file: File, excludeSource: string | null = null) {
    lastFile = file;
    hideAllIdStates();

    // Bug #126: video files were entering the photo cascade and the
    // PlantNet/Claude image POST hung indefinitely (the file is not
    // image bytes). Fail fast with a friendly note. Frame extraction
    // for camera-trap videos is tracked as a v1.1 follow-up.
    const fileType = file.type || '';
    if (fileType.startsWith('video/')) {
      idSpinner?.classList.add('hidden');
      if (idAllFailed) {
        idAllFailed.textContent = isEs
          ? 'La identificación de video aún no está soportada. Sube una foto, o usa el botón de cámara para tomar una.'
          : 'Video identification is not yet supported. Upload a photo, or use the camera button to take one.';
        idAllFailed.classList.remove('hidden');
      }
      return;
    }
    idSpinner?.classList.remove('hidden');

    // Build the runner set based on what's actually available.
    const { runParallelIdentify } = await import('../lib/identify-cascade-client');
    const { makePlantNetRunner, makeClaudeRunner, makePhiRunner, resolvePlantNetKey } = await import('../lib/identify-runners');
    const { hasAnthropicKey } = await import('../lib/anthropic-key');

    const runners: Record<string, import('../lib/identify-cascade-client').IdentifierRunner> = {};
    const locale = isEs ? 'es' : 'en';

    if (await resolvePlantNetKey()) {
      runners.plantnet = makePlantNetRunner(locale);
    }
    if (await hasAnthropicKey()) {
      runners.claude_haiku = makeClaudeRunner(locale);
    }
    // Phi-vision: only include if cached (otherwise we offer the download below).
    // Phi-3.5-vision is strict opt-in. The MLC q4f16_1 build crashes
    // with a flood of WebGPU "Binding size 1 isn't a multiple of 4"
    // errors on certain GPU/driver combos (esp. Apple Silicon Metal,
    // Chromium 147+). Until MLC ships an alignment-fixed artifact, we
    // only enable Phi when the user has explicitly opted in via
    // localStorage.rastrum.prefs.usePhiVision = 'true' AND the model
    // is already cached on disk. The session-broken flag inside the
    // runner kicks in if Phi crashes mid-session, so subsequent calls
    // skip it cleanly.
    try {
      const optedIn = (typeof localStorage !== 'undefined')
        ? localStorage.getItem('rastrum.prefs.usePhiVision') === 'true'
        : false;
      if (optedIn) {
        const { getModelCacheStatus, VISION_MODEL_ID, localAISupported } = await import('../lib/local-ai');
        if (localAISupported()) {
          const status = await getModelCacheStatus(VISION_MODEL_ID);
          if (status.cached) runners.webllm_phi35_vision = makePhiRunner(locale);
        }
      }
    } catch { /* WebLLM unavailable in this environment */ }

    // "Identify another way" — exclude the previous winner's runner so the
    // cascade resolves to the next-best provider. The map below covers
    // the result.source values used in paintCard.
    if (excludeSource) {
      const sourceToRunnerId: Record<string, string> = {
        plantnet: 'plantnet',
        claude_haiku: 'claude_haiku',
        webllm_phi35_vision: 'webllm_phi35_vision',
      };
      const runnerId = sourceToRunnerId[excludeSource] ?? excludeSource;
      if (runners[runnerId]) delete runners[runnerId];
    }

    if (Object.keys(runners).length === 0) {
      // No identifier available — show offer for Phi-vision (always free).
      idSpinner?.classList.add('hidden');
      offerPhiVision();
      return;
    }

    if (activeAbort) activeAbort.abort();
    activeAbort = new AbortController();
    const out = await runParallelIdentify(file, { runners, taxonHint: activeTaxonHint }, activeAbort.signal);
    activeAbort = null;
    idSpinner?.classList.add('hidden');

    if (out.kind === 'winner') {
      paintCard(out.result, false);
    } else if (out.kind === 'uncertain') {
      paintCard(out.result, true);
    } else {
      // All failed — if Phi isn't cached, offer it as a recovery path.
      try {
        const { getModelCacheStatus, VISION_MODEL_ID, localAISupported } = await import('../lib/local-ai');
        if (localAISupported()) {
          const status = await getModelCacheStatus(VISION_MODEL_ID);
          if (!status.cached) {
            offerPhiVision();
            return;
          }
        }
      } catch { /* fall through to error banner */ }
      // Tailor the failure message to what the cascade actually had to
      // work with. The generic "todos fallaron" message is misleading
      // when the real cause is "PlantNet only handles plants and no
      // other key was configured" — sending a mammal/bird photo through
      // a plant-only cascade always fails. See feedback report 2026-04-27.
      if (idAllFailed) {
        idAllFailed.textContent = describeAllFailed({
          hint: activeTaxonHint,
          hadPlantNet: !!runners.plantnet,
          hadClaude: !!runners.claude_haiku,
          hadPhi: !!runners.webllm_phi35_vision,
        });
        idAllFailed.classList.remove('hidden');
      }
    }
  }

  /**
   * Build a specific call-to-action when the cascade returns nothing.
   * Branches on (a) what the user told us (taxon chip), (b) which
   * runners were actually available. The goal is to point at the next
   * concrete step the user can take, not just say "try again".
   */
  function describeAllFailed(ctx: {
    hint: TaxonHint | null;
    hadPlantNet: boolean;
    hadClaude: boolean;
    hadPhi: boolean;
  }): string {
    const isAnimal = ctx.hint && ctx.hint !== 'Plantae' && ctx.hint !== 'Fungi';
    const onlyPlantNet = ctx.hadPlantNet && !ctx.hadClaude && !ctx.hadPhi;
    if (isAnimal && onlyPlantNet) {
      return isEs
        ? 'Para identificar animales necesitamos un modelo más allá de PlantNet. Configura tu llave de Claude Haiku (Perfil → Editar) o activa el modelo en el dispositivo (~2.4 GB) para que funcione sin conexión.'
        : "We need a non-plant identifier for animals. Add your Claude Haiku key (Profile → Edit) or enable the on-device model (~2.4 GB) for offline use.";
    }
    if (!ctx.hadClaude && !ctx.hadPhi && !ctx.hadPlantNet) {
      return isEs
        ? 'No hay ningún identificador disponible. Configura una llave en Perfil → Editar, o activa el modelo en el dispositivo.'
        : 'No identifier is available. Configure a key in Profile → Edit, or enable the on-device model.';
    }
    if (ctx.hint === 'Animalia.Aves' && !ctx.hadClaude) {
      return isEs
        ? 'Para aves recomendamos audio (BirdNET) o agregar tu llave de Claude Haiku.'
        : 'Birds work best with audio (BirdNET) or with your Claude Haiku key.';
    }
    return idStringsRT.all_failed;
  }

  function offerPhiVision() {
    if (!phiOffer) return;
    try {
      if (localStorage.getItem(LOCAL_AI_OPTIN) === 'false') return;
    } catch { /* ignore */ }
    phiOffer.classList.remove('hidden');
  }

  phiSkipBtn?.addEventListener('click', () => {
    phiOffer?.classList.add('hidden');
    if (idAllFailed) {
      idAllFailed.textContent = idStringsRT.phi_skip_hint;
      idAllFailed.classList.remove('hidden');
    }
  });

  // beforeunload guard while the Phi-vision download is in flight. The
  // model is multi-MB; closing the tab cancels the fetch and the user
  // wastes the download. WebLLM's Cache API does keep partial chunks,
  // so resumption works on revisit, but we still want to warn first.
  let phiBusy = false;
  window.addEventListener('beforeunload', (e: BeforeUnloadEvent) => {
    if (!phiBusy) return;
    e.preventDefault();
    e.returnValue = '';
  });

  phiDownloadBtn?.addEventListener('click', async () => {
    if (!lastFile) return;
    phiOffer?.classList.add('hidden');
    phiProgress?.classList.remove('hidden');
    if (phiProgressBar) phiProgressBar.style.width = '0%';
    phiBusy = true;

    try {
      const { loadVisionEngine } = await import('../lib/local-ai');
      await loadVisionEngine((p) => {
        const pct = Math.round((p.progress ?? 0) * 100);
        if (phiProgressBar) phiProgressBar.style.width = `${pct}%`;
        if (phiProgressLbl) phiProgressLbl.textContent = `${pct}% — ${p.text ?? ''}`;
      });
      // Now run identification automatically.
      phiProgress?.classList.add('hidden');
      idSpinner?.classList.remove('hidden');
      const idSpinnerLabel = document.getElementById('id-spinner-label');
      if (idSpinnerLabel) idSpinnerLabel.textContent = idStringsRT.phi_running;

      const { makePhiRunner } = await import('../lib/identify-runners');
      const runner = makePhiRunner(isEs ? 'es' : 'en');
      const ctrl = new AbortController();
      const out = await runner(lastFile, ctrl.signal);
      idSpinner?.classList.add('hidden');
      if (out && out.scientific_name) {
        paintCard(out, out.confidence < 0.5);
      } else if (out && out.note) {
        // Phi returned prose, not JSON — show it under an "Identification" header.
        paintCard({
          source: 'webllm_phi35_vision',
          scientific_name: isEs ? 'Identificación' : 'Identification',
          common_name: null,
          confidence: 0.3,
          alternates: [],
          note: out.note,
        }, true);
      } else {
        if (idAllFailed) {
          idAllFailed.textContent = idStringsRT.result_unknown;
          idAllFailed.classList.remove('hidden');
        }
      }
    } catch (err) {
      phiProgress?.classList.add('hidden');
      if (idAllFailed) {
        idAllFailed.textContent = err instanceof Error ? err.message : String(err);
        idAllFailed.classList.remove('hidden');
      }
    } finally {
      phiBusy = false;
    }
  });

  async function addPhotos(fileList: FileList | File[]) {
    const files = (fileList instanceof Array)
      ? fileList
      : Array.from(fileList as FileList);

    // Optional crop / rotate step before compression. Only the first
    // photo opens the modal — multi-select keeps the rest as-is so a
    // batch upload doesn't turn into N modal cycles.
    let toProcess: File[] = files.slice();
    if (toProcess.length > 0 && toProcess[0].type.startsWith('image/')) {
      try {
        const { openCropModal } = await import('../lib/photo-crop-controller');
        const result = await openCropModal(toProcess[0]);
        if (result.kind === 'cancel') {
          toProcess = toProcess.slice(1);
        } else {
          toProcess[0] = result.file;
        }
      } catch (err) {
        console.warn('[rastrum] crop modal failed; using original photo', err);
      }
    }

    // Auto-resize > 4 MP photos before they hit Dexie. Saves R2 bytes,
    // speeds sync on Latin America's mobile networks. PlantNet/Claude
    // downscale anyway; nothing above 1024 px improves top-1 accuracy.
    const { compressIfLarge } = await import('../lib/photo-compress');
    const compressed: File[] = [];
    for (const f of toProcess) {
      try {
        const out = await compressIfLarge(f);
        compressed.push(out.file);
      } catch {
        compressed.push(f);  // not an image / compress failed — keep original
      }
    }

    // Perceptual-hash dedupe — warn if the user has uploaded a near-identical
    // photo in the last 7 days. We hash + warn on the *first* added photo only
    // (the common "double tap upload" failure mode).
    if (compressed.length > 0) {
      void warnIfDuplicatePhoto(compressed[0]);
    }

    for (const file of compressed) {
      photos.push({ file, blobId: crypto.randomUUID() });
      if (photos.length === 1) triggerClientIdentify(file);
    }
    repaintGrid();
  }

  // ── Perceptual-hash dedupe (ux-photo-dedupe) ─────────────────────────
  const photoDedupeWarn = document.getElementById('photo-dedupe-warn');
  const photoDedupeText = document.getElementById('photo-dedupe-warn-text');
  const photoDedupeKeep = document.getElementById('photo-dedupe-keep');
  const photoDedupeReplace = document.getElementById('photo-dedupe-replace');

  photoDedupeKeep?.addEventListener('click', () => {
    photoDedupeWarn?.classList.add('hidden');
  });
  photoDedupeReplace?.addEventListener('click', () => {
    // Drop the freshly-added photo (the last one in the array).
    photos.pop();
    repaintGrid();
    clearIdResult();
    photoDedupeWarn?.classList.add('hidden');
  });

  async function warnIfDuplicatePhoto(file: File): Promise<void> {
    try {
      const { hashFile, hammingDistance } = await import('../lib/perceptual-hash');
      const hash = await hashFile(file);
      const { resolveObserverRef: getRef } = await import('../lib/observe');
      const ref = await getRef(2_000);
      if (ref.kind !== 'user') return;  // guests don't have history to dedupe against
      const db = (await import('../lib/db')).getDB();
      const cutoff = Date.now() - 7 * 24 * 60 * 60 * 1000;
      const recent = await db.observations
        .where('observer_kind').equals('user')
        .toArray();
      for (const rec of recent) {
        if (new Date(rec.created_at).getTime() < cutoff) continue;
        const blobs = await db.mediaBlobs.where('observation_id').equals(rec.id).toArray();
        for (const b of blobs) {
          if (!b.mime_type.startsWith('image/')) continue;
          let storedHash: string | null = null;
          try {
            storedHash = await hashFile(new File([b.blob], b.id, { type: b.mime_type }));
          } catch { continue; }
          if (hammingDistance(hash, storedHash) < 5) {
            const date = new Date(rec.created_at).toLocaleDateString(isEs ? 'es' : 'en');
            const tpl = (observeStringsRT.photo_dedupe_warn ?? 'You uploaded a similar photo on {date}. Continue or replace?');
            if (photoDedupeText) photoDedupeText.textContent = tpl.replace('{date}', date);
            photoDedupeWarn?.classList.remove('hidden');
            return;
          }
        }
      }
    } catch { /* dedupe is best-effort */ }
  }

  // i18n strings used by the dedupe warning + share + draft success
  const observeStringsRT: Record<string, string> = (() => {
    const root = document.getElementById('obs-form');
    return {
      photo_dedupe_warn: isEs
        ? 'Subiste una foto similar el {date}. ¿Continuar o reemplazar?'
        : 'You uploaded a similar photo on {date}. Continue or replace?',
      share_copied: isEs ? 'Enlace copiado al portapapeles.' : 'Link copied to clipboard.',
      share_failed: isEs ? 'No se pudo compartir — copia la URL manualmente.' : 'Could not share — try copying the URL.',
      draft_saved_offline: isEs
        ? 'Guardada como borrador. Agrega una ubicación luego para sincronizar.'
        : 'Saved as draft. Add a location later to sync.',
      draft_no_media: isEs
        ? 'Agrega al menos una foto, audio o video antes de guardar un borrador.'
        : 'Add at least one photo, audio, or video before saving a draft.',
    };
  })();

  /**
   * Map the cascade plugin id (or legacy display label) to the
   * `Observation['identification']['source']` union accepted by the
   * outbox. Falls back to 'human' so a manual edit always saves cleanly.
   */
  function mapIdentificationSource(source: string | undefined): 'plantnet' | 'claude_haiku' | 'claude_sonnet' | 'onnx_offline' | 'human' {
    switch (source) {
      case 'plantnet':
      case 'PlantNet':
        return 'plantnet';
      case 'claude_haiku':
      case 'Claude Haiku':
        return 'claude_haiku';
      case 'claude_sonnet':
        return 'claude_sonnet';
      case 'webllm_phi35_vision':
      case 'onnx_efficientnet_lite0':
      case 'birdnet_lite':
        return 'onnx_offline';
      default:
        return 'human';
    }
  }

  // ── identify-only ↔ full mode toggle ──────────────────────────────────
  const saveAsObsBtn  = document.getElementById('save-as-observation-btn');
  const backToIdBtn   = document.getElementById('back-to-identify-btn');
  const inlineSaveBtn = document.getElementById('save-inline-btn');

  function applyMode(next: 'full' | 'identify-only') {
    if (!form || !btnLabel) return;
    form.dataset.mode = next;
    const draftBtnEl = document.getElementById('save-draft-btn');
    if (next === 'identify-only') {
      btnLabel.textContent = form.dataset.labelIdentify ?? (isEs ? 'Solo identificar' : 'Just identify');
      saveAsObsBtn?.classList.remove('hidden');
      backToIdBtn?.classList.add('hidden');
      draftBtnEl?.classList.add('hidden');
      // Re-show the inline save link if there's a result already.
      if (currentIdentification && idResultCard && !idResultCard.classList.contains('hidden')) {
        idSaveInline?.classList.remove('hidden');
      }
    } else {
      btnLabel.textContent = form.dataset.labelSaveCta ?? (isEs ? 'Guardar observación' : 'Save observation');
      saveAsObsBtn?.classList.add('hidden');
      // Show "back to identify" only when we entered full mode FROM identify-only.
      if (form.dataset.enteredFromIdentify === '1') {
        backToIdBtn?.classList.remove('hidden');
      }
      draftBtnEl?.classList.remove('hidden');
      // Kick off GPS now — the user revealed the location field.
      void getLiveGPS();
      // Hide the inline link in full mode (the main submit button does the save).
      idSaveInline?.classList.add('hidden');
    }
  }

  function switchToFullMode() {
    if (!form) return;
    form.dataset.enteredFromIdentify = '1';
    applyMode('full');
  }

  saveAsObsBtn?.addEventListener('click', switchToFullMode);
  inlineSaveBtn?.addEventListener('click', switchToFullMode);
  backToIdBtn?.addEventListener('click', () => {
    if (!form) return;
    applyMode('identify-only');
    backToIdBtn.classList.add('hidden');
  });

  /**
   * If the user landed here from the chat page after attaching a photo or
   * audio, preload that media + cascade ID into the form so they only need
   * to add location and notes. The contract is `PendingObservation` from
   * `src/lib/chat-attachment-helpers.ts` — see that file for shape.
   */
  async function consumeChatPrefillIfAny(): Promise<void> {
    const { parsePendingObservation, PENDING_OBSERVATION_KEY } = await import('../lib/chat-attachment-helpers');
    const raw = (() => { try { return sessionStorage.getItem(PENDING_OBSERVATION_KEY); } catch { return null; } })();
    const pending = parsePendingObservation(raw);
    if (!pending) return;
    try { sessionStorage.removeItem(PENDING_OBSERVATION_KEY); } catch { /* private mode */ }

    const banner = document.getElementById('chat-prefill-banner');
    banner?.classList.remove('hidden');

    try {
      const res = await fetch(pending.blob_url);
      const blob = await res.blob();
      const ext = pending.kind === 'photo'
        ? (pending.mime_type.includes('png') ? 'png' : 'jpg')
        : (pending.mime_type.includes('mp4') ? 'm4a' : 'webm');
      const filename = `chat-attachment.${ext}`;

      if (pending.kind === 'photo') {
        const file = new File([blob], filename, { type: pending.mime_type });
        photos.push({ file, blobId: crypto.randomUUID() });
        repaintGrid();
        await fillFromExif(file).catch(() => {});
      } else {
        audios.push({
          blob,
          blobId: crypto.randomUUID(),
          mimeType: pending.mime_type,
          durationSec: 0,
        });
        repaintAudioGrid();
      }

      if (pending.scientific_name) {
        paintCard({
          source: pending.source,
          scientific_name: pending.scientific_name,
          common_name: pending.common_name,
          confidence: pending.confidence,
          alternates: [],
        }, pending.confidence < 0.5);
      }
    } catch (err) {
      console.warn('[rastrum] chat prefill failed:', err);
    }
  }
  void consumeChatPrefillIfAny();

  /**
   * If the user arrived from /share-target (Web Share Target API),
   * the share-target page stores the file in sessionStorage under
   * PENDING_OBSERVATION_KEY with share_source_* extras. We handle it
   * here (same key, same flow) but show the share-target banner instead.
   */
  async function consumeShareTargetIfAny(): Promise<void> {
    const raw = (() => { try { return sessionStorage.getItem('rastrum.pendingObservation'); } catch { return null; } })();
    if (!raw) return;
    let parsed: Record<string, unknown>;
    try { parsed = JSON.parse(raw); } catch { return; }
    // Distinguish share-target entries from chat prefills by the extra key
    if (!('share_source_title' in parsed) && !('share_source_text' in parsed)) return;
    // Already handled by consumeChatPrefillIfAny above, but that function
    // removes the item from sessionStorage first. If we get here the item
    // is still present — means chat prefill didn't claim it (no scientific_name
    // check mismatch). Show the share-target banner instead of the chat banner.
    const shareBanner = document.getElementById('share-target-banner');
    const chatBanner  = document.getElementById('chat-prefill-banner');
    chatBanner?.classList.add('hidden');
    shareBanner?.classList.remove('hidden');
  }
  void consumeShareTargetIfAny();

  // ── Audio recording (MediaRecorder, ≤30 s) ──
  const audioGrid     = document.getElementById('audio-grid');
  const audioRecBtn   = document.getElementById('audio-record-btn') as HTMLButtonElement | null;
  const audioRecLabel = audioRecBtn?.querySelector('[data-audio-label]') as HTMLElement | null;
  const audioElapsed  = document.getElementById('audio-elapsed');
  const audioErrEl    = document.getElementById('audio-error');

  let mediaRecorder: MediaRecorder | null = null;
  let audioChunks: Blob[] = [];
  let recordStartedAt = 0;
  let elapsedTimer: number | null = null;
  let durationCutoffTimer: number | null = null;

  const AUDIO_MAX_SECS = 30;
  

  function repaintAudioGrid() {
    if (!audioGrid) return;
    audioGrid.classList.toggle('hidden', audios.length === 0);
    audioGrid.innerHTML = audios.map((a, i) => `
      <div class="flex items-center gap-2 rounded-lg border border-zinc-200 dark:border-zinc-800 p-2">
        <audio controls src="${URL.createObjectURL(a.blob)}" class="flex-1 h-8"></audio>
        <span class="text-[10px] text-zinc-500 font-mono">${a.durationSec.toFixed(1)}s</span>
        <button data-rm-audio="${i}" type="button" class="w-6 h-6 rounded-full bg-zinc-200 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 text-xs flex items-center justify-center" aria-label="remove">×</button>
      </div>
    `).join('');
    audioGrid.querySelectorAll<HTMLButtonElement>('button[data-rm-audio]').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = Number(btn.dataset.rmAudio);
        audios.splice(idx, 1);
        repaintAudioGrid();
      });
    });
  }

  function setAudioBtnLabel(text: string) {
    if (audioRecLabel) audioRecLabel.textContent = text;
  }

  function audioSupported(): boolean {
    return typeof navigator !== 'undefined'
      && !!navigator.mediaDevices
      && typeof navigator.mediaDevices.getUserMedia === 'function'
      && typeof MediaRecorder !== 'undefined';
  }

  if (!audioSupported()) {
    if (audioRecBtn) audioRecBtn.disabled = true;
    if (audioErrEl) {
      audioErrEl.textContent = isEs ? 'La grabación de audio no está disponible en este navegador.' : "Audio recording isn't supported on this browser.";
      audioErrEl.classList.remove('hidden');
    }
  }

  function pickAudioMime(): string {
    const candidates = ['audio/webm;codecs=opus', 'audio/webm', 'audio/ogg;codecs=opus', 'audio/mp4'];
    for (const m of candidates) {
      if (MediaRecorder.isTypeSupported(m)) return m;
    }
    return 'audio/webm';
  }

  async function startRecording() {
    if (!audioRecBtn) return;
    audioErrEl?.classList.add('hidden');
    let stream: MediaStream;
    try {
      stream = await navigator.mediaDevices.getUserMedia({ audio: true });
    } catch {
      if (audioErrEl) {
        audioErrEl.textContent = isEs
          ? 'Acceso al micrófono denegado. Habilítalo en la configuración del navegador para grabar.'
          : 'Microphone access denied. Allow it in your browser settings to record.';
        audioErrEl.classList.remove('hidden');
      }
      return;
    }
    audioChunks = [];
    const mime = pickAudioMime();
    mediaRecorder = new MediaRecorder(stream, { mimeType: mime });
    mediaRecorder.addEventListener('dataavailable', e => {
      if (e.data && e.data.size > 0) audioChunks.push(e.data);
    });
    mediaRecorder.addEventListener('stop', () => {
      stream.getTracks().forEach(t => t.stop());
      const blob = new Blob(audioChunks, { type: mime });
      const durationSec = Math.min((Date.now() - recordStartedAt) / 1000, AUDIO_MAX_SECS);
      audios.push({ blob, blobId: crypto.randomUUID(), mimeType: mime, durationSec });
      repaintAudioGrid();
      setAudioBtnLabel(isEs ? 'Grabar audio' : 'Record audio');
      audioElapsed?.classList.add('hidden');
      if (elapsedTimer != null) { clearInterval(elapsedTimer); elapsedTimer = null; }
      if (durationCutoffTimer != null) { clearTimeout(durationCutoffTimer); durationCutoffTimer = null; }
    });

    recordStartedAt = Date.now();
    mediaRecorder.start();
    setAudioBtnLabel(isEs ? 'Detener' : 'Stop');
    audioElapsed?.classList.remove('hidden');
    if (audioElapsed) audioElapsed.textContent = '0.0s / ' + AUDIO_MAX_SECS + 's';
    elapsedTimer = window.setInterval(() => {
      const e = (Date.now() - recordStartedAt) / 1000;
      if (audioElapsed) audioElapsed.textContent = e.toFixed(1) + 's / ' + AUDIO_MAX_SECS + 's';
    }, 100);
    durationCutoffTimer = window.setTimeout(() => {
      try { mediaRecorder?.stop(); } catch { /* already stopped */ }
    }, AUDIO_MAX_SECS * 1000);
  }

  function stopRecording() {
    try { mediaRecorder?.stop(); } catch { /* already stopped */ }
  }

  audioRecBtn?.addEventListener('click', () => {
    if (mediaRecorder && mediaRecorder.state === 'recording') stopRecording();
    else                                                       startRecording();
  });

  // ── Audio file upload (issue #266) ──────────────────────────────────
  const audioUploadBtn   = document.getElementById('audio-upload-btn') as HTMLButtonElement | null;
  const audioUploadInput = document.getElementById('audio-upload-input') as HTMLInputElement | null;

  audioUploadBtn?.addEventListener('click', () => audioUploadInput?.click());

  audioUploadInput?.addEventListener('change', () => {
    const files = audioUploadInput.files;
    if (!files || files.length === 0) return;
    for (const file of Array.from(files)) {
      if (!file.type.startsWith('audio/') && !file.name.match(/\.(mp3|wav|ogg|m4a|aac|flac|opus|weba)$/i)) {
        if (audioErrEl) {
          audioErrEl.textContent = isEs
            ? `Formato no soportado: ${file.name}. Acepta MP3, WAV, OGG, M4A, AAC, FLAC.`
            : `Unsupported format: ${file.name}. Accepts MP3, WAV, OGG, M4A, AAC, FLAC.`;
          audioErrEl.classList.remove('hidden');
          setTimeout(() => audioErrEl.classList.add('hidden'), 4000);
        }
        continue;
      }
      audios.push({
        blob: file,
        blobId: crypto.randomUUID(),
        mimeType: file.type || 'audio/mpeg',
        durationSec: 0,
      });
    }
    // Reset so same file can be re-selected
    audioUploadInput.value = '';
    repaintAudioGrid();
  });
  const cameraOpenBtn   = document.getElementById('camera-open-btn') as HTMLButtonElement | null;
  const cameraModal     = document.getElementById('camera-modal');
  const cameraVideo     = document.getElementById('camera-video') as HTMLVideoElement | null;
  const cameraStatusEl  = document.getElementById('camera-status');
  const cameraCloseBtn  = document.getElementById('camera-close-btn');
  const cameraCancelBtn = document.getElementById('camera-cancel-btn');
  const cameraCaptureBtn= document.getElementById('camera-capture-btn') as HTMLButtonElement | null;
  const cameraFlipBtn   = document.getElementById('camera-flip-btn');
  const cameraInputEl   = document.getElementById('camera-input') as HTMLInputElement | null;

  let cameraStream: MediaStream | null = null;
  let cameraFacing: 'environment' | 'user' = 'environment';

  function cameraSupported(): boolean {
    return typeof navigator !== 'undefined'
      && !!navigator.mediaDevices
      && typeof navigator.mediaDevices.getUserMedia === 'function';
  }

  // If getUserMedia is unavailable, fall back to the file input with capture
  // attribute (legacy behaviour). The button below the camera-input label
  // still works on its own.
  if (!cameraSupported()) {
    cameraOpenBtn?.classList.add('hidden');
  }

  function showCameraStatus(text: string | null) {
    if (!cameraStatusEl) return;
    if (!text) { cameraStatusEl.classList.add('hidden'); return; }
    cameraStatusEl.textContent = text;
    cameraStatusEl.classList.remove('hidden');
  }

  async function startCameraStream() {
    if (!cameraVideo) return;
    showCameraStatus(isEs ? 'Iniciando cámara…' : 'Starting camera…');
    if (cameraStream) {
      cameraStream.getTracks().forEach(t => t.stop());
      cameraStream = null;
    }
    try {
      cameraStream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: { ideal: cameraFacing } },
        audio: false,
      });
    } catch {
      // Permission denied or device error — fall back to legacy file input
      // with capture=environment.
      showCameraStatus(isEs
        ? 'Acceso a la cámara denegado. Usa el selector de archivos.'
        : 'Camera access denied. Use the file picker instead.');
      cameraInputEl?.click();
      closeCameraModal();
      return;
    }
    cameraVideo.srcObject = cameraStream;
    try { await cameraVideo.play(); } catch { /* autoplay blocked? user can tap */ }
    showCameraStatus(null);
  }

  function closeCameraModal() {
    if (cameraStream) {
      cameraStream.getTracks().forEach(t => t.stop());
      cameraStream = null;
    }
    if (cameraVideo) cameraVideo.srcObject = null;
    cameraModal?.classList.add('hidden');
  }

  async function openCameraModal() {
    if (!cameraSupported()) {
      // Fall back to the legacy capture=environment input.
      cameraInputEl?.click();
      return;
    }
    cameraModal?.classList.remove('hidden');
    await startCameraStream();
  }

  cameraOpenBtn?.addEventListener('click', () => { openCameraModal(); });
  cameraCloseBtn?.addEventListener('click', closeCameraModal);
  cameraCancelBtn?.addEventListener('click', closeCameraModal);
  cameraFlipBtn?.addEventListener('click', async () => {
    cameraFacing = cameraFacing === 'environment' ? 'user' : 'environment';
    await startCameraStream();
  });
  cameraCaptureBtn?.addEventListener('click', async () => {
    if (!cameraVideo || !cameraStream) return;
    const w = cameraVideo.videoWidth;
    const h = cameraVideo.videoHeight;
    if (!Number.isFinite(w) || !Number.isFinite(h) || w === 0 || h === 0) return;
    const canvas = document.createElement('canvas');
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    ctx.drawImage(cameraVideo, 0, 0, w, h);
    const blob: Blob | null = await new Promise(resolve => {
      canvas.toBlob(b => resolve(b), 'image/jpeg', 0.9);
    });
    if (!blob) return;
    const file = new File([blob], `camera-${Date.now()}.jpg`, { type: 'image/jpeg' });
    await addPhotos([file]);
    await fillFromExif(file);
    closeCameraModal();
  });

  // ── Video recording (MediaRecorder, ≤30 s) ───────────────────────────
  const videoGridEl    = document.getElementById('video-grid');
  const videoRecBtn    = document.getElementById('video-record-btn') as HTMLButtonElement | null;
  const videoRecLabel  = videoRecBtn?.querySelector('[data-video-label]') as HTMLElement | null;
  const videoElapsedEl = document.getElementById('video-elapsed');
  const videoErrEl     = document.getElementById('video-error');

  let videoRecorder: MediaRecorder | null = null;
  let videoStream: MediaStream | null = null;
  let videoChunks: Blob[] = [];
  let videoStartedAt = 0;
  let videoElapsedTimer: number | null = null;
  let videoCutoffTimer: number | null = null;

  function videoSupported(): boolean {
    return typeof navigator !== 'undefined'
      && !!navigator.mediaDevices
      && typeof navigator.mediaDevices.getUserMedia === 'function'
      && typeof MediaRecorder !== 'undefined';
  }

  if (!videoSupported()) {
    if (videoRecBtn) videoRecBtn.disabled = true;
    if (videoErrEl) {
      videoErrEl.textContent = isEs
        ? 'La grabación de video no está disponible en este navegador.'
        : "Video recording isn't supported on this browser.";
      videoErrEl.classList.remove('hidden');
    }
  }

  function setVideoBtnLabel(text: string) {
    if (videoRecLabel) videoRecLabel.textContent = text;
  }

  function repaintVideoGrid() {
    if (!videoGridEl) return;
    videoGridEl.classList.toggle('hidden', videos.length === 0);
    videoGridEl.innerHTML = videos.map((v, i) => `
      <div class="flex items-center gap-2 rounded-lg border border-zinc-200 dark:border-zinc-800 p-2">
        ${v.thumbnailUrl
          ? `<img src="${v.thumbnailUrl}" alt="" class="w-16 h-16 rounded object-cover bg-black flex-none" />`
          : '<div class="w-16 h-16 rounded bg-zinc-200 dark:bg-zinc-800 flex-none"></div>'}
        <video controls src="${URL.createObjectURL(v.blob)}" class="flex-1 max-h-28 rounded"></video>
        <span class="text-[10px] text-zinc-500 font-mono">${v.durationSec.toFixed(1)}s</span>
        <button data-rm-video="${i}" type="button" class="w-6 h-6 rounded-full bg-zinc-200 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300 text-xs flex items-center justify-center" aria-label="remove">×</button>
      </div>
    `).join('');
    videoGridEl.querySelectorAll<HTMLButtonElement>('button[data-rm-video]').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = Number(btn.dataset.rmVideo);
        const removed = videos.splice(idx, 1)[0];
        if (removed?.thumbnailUrl) {
          try { URL.revokeObjectURL(removed.thumbnailUrl); } catch { /* noop */ }
        }
        repaintVideoGrid();
      });
    });
  }

  async function extractVideoThumbnail(blob: Blob): Promise<string | null> {
    return new Promise<string | null>((resolve) => {
      const url = URL.createObjectURL(blob);
      const tmp = document.createElement('video');
      tmp.preload = 'auto';
      tmp.muted = true;
      tmp.playsInline = true;
      tmp.src = url;
      let settled = false;
      const finish = (out: string | null) => {
        if (settled) return;
        settled = true;
        try { URL.revokeObjectURL(url); } catch { /* noop */ }
        resolve(out);
      };
      tmp.addEventListener('loadedmetadata', () => {
        try { tmp.currentTime = Math.min(VIDEO_THUMB_PARAMS.seekToSec, Math.max(0, (tmp.duration || 0) / 4)); }
        catch { finish(null); }
      });
      tmp.addEventListener('seeked', () => {
        try {
          const { w, h } = computeThumbDims(tmp.videoWidth, tmp.videoHeight, 320);
          const canvas = document.createElement('canvas');
          canvas.width = w; canvas.height = h;
          const ctx = canvas.getContext('2d');
          if (!ctx) return finish(null);
          ctx.drawImage(tmp, 0, 0, w, h);
          canvas.toBlob(b => finish(b ? URL.createObjectURL(b) : null), VIDEO_THUMB_PARAMS.mime, VIDEO_THUMB_PARAMS.quality);
        } catch { finish(null); }
      });
      tmp.addEventListener('error', () => finish(null));
      // safety net
      setTimeout(() => finish(null), 6_000);
    });
  }

  async function startVideoRecording() {
    if (!videoRecBtn) return;
    videoErrEl?.classList.add('hidden');
    try {
      videoStream = await navigator.mediaDevices.getUserMedia({
        video: { facingMode: { ideal: 'environment' } },
        audio: true,
      });
    } catch {
      if (videoErrEl) {
        videoErrEl.textContent = isEs
          ? 'Acceso a la cámara/micrófono denegado. Habilítalo en la configuración del navegador para grabar.'
          : 'Camera/microphone access denied. Allow it in your browser settings to record.';
        videoErrEl.classList.remove('hidden');
      }
      return;
    }
    videoChunks = [];
    const mime = pickVideoMime((m) => MediaRecorder.isTypeSupported(m));
    try {
      videoRecorder = new MediaRecorder(videoStream, { mimeType: mime });
    } catch {
      // MIME couldn't be applied — fall back to default.
      videoRecorder = new MediaRecorder(videoStream);
    }
    const recorder = videoRecorder;
    recorder.addEventListener('dataavailable', e => {
      if (e.data && e.data.size > 0) videoChunks.push(e.data);
    });
    recorder.addEventListener('stop', async () => {
      videoStream?.getTracks().forEach(t => t.stop());
      videoStream = null;
      const blob = new Blob(videoChunks, { type: recorder.mimeType || mime });
      const durationSec = Math.min((Date.now() - videoStartedAt) / 1000, VIDEO_MAX_SECS);
      const thumbnailUrl = await extractVideoThumbnail(blob).catch(() => null);
      videos.push({
        blob,
        blobId: crypto.randomUUID(),
        mimeType: blob.type || mime,
        durationSec,
        thumbnailUrl,
      });
      repaintVideoGrid();
      setVideoBtnLabel(isEs ? 'Grabar video' : 'Record video');
      videoElapsedEl?.classList.add('hidden');
      if (videoElapsedTimer != null) { clearInterval(videoElapsedTimer); videoElapsedTimer = null; }
      if (videoCutoffTimer != null) { clearTimeout(videoCutoffTimer); videoCutoffTimer = null; }
    });
    videoStartedAt = Date.now();
    recorder.start();
    setVideoBtnLabel(isEs ? 'Detener' : 'Stop');
    videoElapsedEl?.classList.remove('hidden');
    if (videoElapsedEl) videoElapsedEl.textContent = '0.0s / ' + VIDEO_MAX_SECS + 's';
    videoElapsedTimer = window.setInterval(() => {
      const e = (Date.now() - videoStartedAt) / 1000;
      if (videoElapsedEl) videoElapsedEl.textContent = e.toFixed(1) + 's / ' + VIDEO_MAX_SECS + 's';
    }, 100);
    videoCutoffTimer = window.setTimeout(() => {
      try { videoRecorder?.stop(); } catch { /* already stopped */ }
    }, VIDEO_MAX_SECS * 1000);
  }

  function stopVideoRecording() {
    try { videoRecorder?.stop(); } catch { /* already stopped */ }
  }

  videoRecBtn?.addEventListener('click', () => {
    if (videoRecorder && videoRecorder.state === 'recording') stopVideoRecording();
    else                                                      startVideoRecording();
  });

  // ── Video file upload (issue #266) ─────────────────────────────────
  const videoUploadBtn   = document.getElementById('video-upload-btn') as HTMLButtonElement | null;
  const videoUploadInput = document.getElementById('video-upload-input') as HTMLInputElement | null;

  videoUploadBtn?.addEventListener('click', () => videoUploadInput?.click());

  videoUploadInput?.addEventListener('change', async () => {
    const files = videoUploadInput.files;
    if (!files || files.length === 0) return;
    for (const file of Array.from(files)) {
      if (!file.type.startsWith('video/') && !file.name.match(/\.(mp4|mov|webm|avi|mkv|m4v)$/i)) {
        if (videoErrEl) {
          videoErrEl.textContent = isEs
            ? `Formato no soportado: ${file.name}. Acepta MP4, MOV, WebM.`
            : `Unsupported format: ${file.name}. Accepts MP4, MOV, WebM.`;
          videoErrEl.classList.remove('hidden');
          setTimeout(() => videoErrEl?.classList.add('hidden'), 4000);
        }
        continue;
      }
      // Try to generate a thumbnail via canvas
      let thumbnailUrl: string | null = null;
      try {
        thumbnailUrl = await new Promise<string | null>((resolve) => {
          const vid = document.createElement('video');
          vid.preload = 'metadata';
          vid.muted = true;
          vid.playsInline = true;
          const objUrl = URL.createObjectURL(file);
          vid.src = objUrl;
          vid.addEventListener('loadeddata', () => {
            vid.currentTime = Math.min(1, vid.duration * 0.1);
          });
          vid.addEventListener('seeked', () => {
            const canvas = document.createElement('canvas');
            canvas.width = 160; canvas.height = 120;
            const ctx = canvas.getContext('2d');
            if (ctx) { ctx.drawImage(vid, 0, 0, 160, 120); }
            URL.revokeObjectURL(objUrl);
            resolve(canvas.toDataURL('image/jpeg', 0.7));
          });
          vid.addEventListener('error', () => { URL.revokeObjectURL(objUrl); resolve(null); });
          setTimeout(() => { URL.revokeObjectURL(objUrl); resolve(null); }, 5000);
        });
      } catch { thumbnailUrl = null; }

      videos.push({
        blob: file,
        blobId: crypto.randomUUID(),
        mimeType: file.type || 'video/mp4',
        durationSec: 0,
        thumbnailUrl,
      });
    }
    videoUploadInput.value = '';
    repaintVideoGrid();
  });
  // The MapLibre + modal lifecycle now lives in MapPicker.astro. The form
  // pushes the current `location` to the modal's data-attrs on every open
  // click (capture phase, fires before MapPicker's open handler), then
  // listens for the picker's confirm event to update `location` and
  // repaint the GPS status line.
  const obsMapModal = document.querySelector<HTMLElement>('[data-mappicker-modal="observe"]');
  function syncMapPickerInitial() {
    if (!obsMapModal) return;
    if (location) {
      obsMapModal.dataset.mappickerInitialLat = String(location.lat);
      obsMapModal.dataset.mappickerInitialLng = String(location.lng);
    } else {
      obsMapModal.dataset.mappickerInitialLat = '';
      obsMapModal.dataset.mappickerInitialLng = '';
    }
  }

  document.addEventListener('click', (ev) => {
    const target = ev.target as Element | null;
    if (!target) return;
    if (target.closest('[data-mappicker-open="observe"]')) {
      syncMapPickerInitial();
    }
  }, { capture: true });

  window.addEventListener('rastrum:mappicker-save', (ev) => {
    const e = ev as CustomEvent<{ id: string; coords: { lat: number; lng: number } }>;
    if (e.detail.id !== 'observe') return;
    location = {
      lat: e.detail.coords.lat,
      lng: e.detail.coords.lng,
      accuracyM: 50,
      altitudeM: null,
      capturedFrom: 'manual',
    };
    paintLocation();
  });

  async function fillFromExif(file: File) {
    let exif: Record<string, unknown> | undefined;
    try {
      exif = await parseExif(file, { gps: true, tiff: true, exif: true }) as Record<string, unknown> | undefined;
    } catch (err) {
      console.warn('[rastrum] EXIF parse failed', { name: file.name, type: file.type, err });
      return;
    }
    if (!exif) {
      console.warn('[rastrum] EXIF empty', { name: file.name, type: file.type });
      return;
    }
    const lat = pickNumber(exif.latitude, exif.Latitude, exif.GPSLatitude);
    const lng = pickNumber(exif.longitude, exif.Longitude, exif.GPSLongitude);
    if (lat == null || lng == null) {
      console.warn('[rastrum] EXIF has no GPS', { name: file.name, keys: Object.keys(exif).slice(0, 20) });
      return;
    }
    // Reject (0,0) only as a *pair* — null island is the well-known
    // EXIF default-when-stripped. lat=0 alone is the equator (legit
    // for observers in Ecuador, Colombia, Brasil, Kenya, etc.).
    if (lat === 0 && lng === 0) {
      console.warn('[rastrum] EXIF GPS is null island (0,0); ignoring', { name: file.name });
      return;
    }
    // EXIF GPS always wins over live GPS — the photo was taken at that
    // specific location. Live GPS is only a fallback for photos without EXIF.
    location = {
      lat,
      lng,
      accuracyM: 15,
      altitudeM: pickNumber(exif.GPSAltitude, exif.altitude, exif.Altitude),
      capturedFrom: 'exif',
    };
    paintLocation();
  }

  function pickNumber(...candidates: unknown[]): number | null {
    for (const c of candidates) {
      if (typeof c === 'number' && Number.isFinite(c)) return c;
    }
    return null;
  }

  function showGpsError(code: number) {
    if (!gpsStatus) return;
    const d = (gpsStatus as HTMLElement).dataset;
    let msg: string;
    if (code === 1)      msg = d.errPermission ?? '';
    else if (code === 2) msg = d.errUnavailable ?? '';
    else                 msg = d.errTimeout ?? '';
    gpsStatus.textContent = msg;
    gpsStatus.className = 'text-amber-700 dark:text-amber-400 text-xs';
    // Permission-denied gets the bigger recovery card (with explicit
    // "Ask again" + "Enter manually" buttons). Other errors fall back to
    // just revealing the manual-entry inputs as before.
    if (code === 1) {
      document.getElementById('gps-denied-card')?.classList.remove('hidden');
    } else {
      gpsManualWrap?.classList.remove('hidden');
    }
  }

  document.getElementById('gps-denied-retry')?.addEventListener('click', () => {
    document.getElementById('gps-denied-card')?.classList.add('hidden');
    if (gpsStatus) {
      gpsStatus.textContent = (document.documentElement.lang === 'es')
        ? 'Obteniendo tu ubicación…'
        : 'Getting your location…';
      gpsStatus.className = 'text-zinc-500';
    }
    void getLiveGPS();
  });
  document.getElementById('gps-denied-manual')?.addEventListener('click', () => {
    document.getElementById('gps-denied-card')?.classList.add('hidden');
    gpsManualWrap?.classList.remove('hidden');
    document.getElementById('manual-lat')?.focus();
  });

  async function getLiveGPS(): Promise<void> {
    if (!navigator.geolocation) {
      showGpsError(2);
      return;
    }
    return new Promise<void>((resolve) => {
      // First pass: quick low-accuracy fix (coarse network location)
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          // Never overwrite EXIF coords — the photo was taken at that
          // specific location. GPS in-page is only a fallback for photos
          // without EXIF (or when no photo has been uploaded yet).
          if (location?.capturedFrom !== 'exif') {
            location = {
              lat: pos.coords.latitude,
              lng: pos.coords.longitude,
              accuracyM: pos.coords.accuracy,
              altitudeM: pos.coords.altitude,
              capturedFrom: 'gps',
            };
            paintLocation();
          }
          // Second pass: refine with high-accuracy GPS (up to 30s).
          // If the refine fails we silently keep the coarse fix — only
          // show an error if BOTH passes failed (handled below).
          navigator.geolocation.getCurrentPosition(
            (pos2) => {
              if (location?.capturedFrom !== 'exif' && pos2.coords.accuracy < (location?.accuracyM ?? 9999)) {
                location = {
                  lat: pos2.coords.latitude,
                  lng: pos2.coords.longitude,
                  accuracyM: pos2.coords.accuracy,
                  altitudeM: pos2.coords.altitude,
                  capturedFrom: 'gps',
                };
                paintLocation();
              }
              resolve();
            },
            () => resolve(),
            { enableHighAccuracy: true, timeout: 30_000, maximumAge: 0 }
          );
        },
        (err) => {
          // First-pass failed — surface the specific reason so the user
          // knows whether to grant permission, wait, or use manual entry.
          showGpsError(err.code);
          resolve();
        },
        { enableHighAccuracy: false, timeout: 8_000, maximumAge: 60_000 }
      );
    });
  }

  // Explicit button → input.click() — more reliable than wrapping a hidden
  // <input> in a <label>, which fails on some iOS Safari and Android
  // Chromium versions when the input is display:none or even sr-only.
  document.getElementById('camera-legacy-btn')?.addEventListener('click', () => {
    cameraInput?.click();
  });
  document.getElementById('gallery-btn')?.addEventListener('click', () => {
    galleryInput?.click();
  });

  // -------------------------------------------------------------------------
  // In-app camera (getUserMedia) — secondary path
  // Shown when:
  //   a) User opted in via rastrum.prefs.useInAppCamera = 'true', OR
  //   b) Android Chrome (detected via UA) where capture=environment is flaky
  // -------------------------------------------------------------------------
  (function initInAppCamera() {
    const isAndroid = /android/i.test(navigator.userAgent);
    const prefEnabled = localStorage.getItem('rastrum.prefs.useInAppCamera') === 'true';
    const showBtn = prefEnabled || isAndroid;

    const inAppBtn   = document.getElementById('camera-inapp-btn') as HTMLButtonElement | null;
    const overlay    = document.getElementById('inapp-camera-overlay') as HTMLDivElement | null;
    const video      = document.getElementById('inapp-camera-video') as HTMLVideoElement | null;
    const canvas     = document.getElementById('inapp-camera-canvas') as HTMLCanvasElement | null;
    const shutterBtn = document.getElementById('inapp-camera-shutter') as HTMLButtonElement | null;
    const closeBtn2  = document.getElementById('inapp-camera-close') as HTMLButtonElement | null;
    const flipBtn    = document.getElementById('inapp-camera-flip') as HTMLButtonElement | null;

    if (!inAppBtn || !overlay || !video || !canvas || !shutterBtn || !closeBtn2 || !flipBtn) return;

    if (showBtn) inAppBtn.classList.remove('hidden');

    let stream: MediaStream | null = null;
    let facingMode: 'environment' | 'user' = 'environment';

    async function startStream(facing: 'environment' | 'user') {
      if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
      try {
        stream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: facing, width: { ideal: 4096 }, height: { ideal: 3072 } },
        });
        video.srcObject = stream;
      } catch {
        // getUserMedia denied — fall back to system camera input
        closeOverlay();
        cameraInput?.click();
      }
    }

    function closeOverlay() {
      if (stream) { stream.getTracks().forEach(t => t.stop()); stream = null; }
      video.srcObject = null;
      overlay.classList.add('hidden');
      document.body.style.overflow = '';
    }

    inAppBtn.addEventListener('click', async () => {
      if (!navigator.mediaDevices?.getUserMedia) {
        // Browser doesn't support getUserMedia — fall through to system camera
        cameraInput?.click();
        return;
      }
      overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      await startStream(facingMode);
    });

    closeBtn2.addEventListener('click', closeOverlay);

    flipBtn.addEventListener('click', async () => {
      facingMode = facingMode === 'environment' ? 'user' : 'environment';
      await startStream(facingMode);
    });

    shutterBtn.addEventListener('click', async () => {
      if (!video.videoWidth) return;
      canvas.width  = video.videoWidth;
      canvas.height = video.videoHeight;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;
      ctx.drawImage(video, 0, 0);
      canvas.toBlob(async (blob) => {
        if (!blob) return;
        const ts = new Date().toISOString().replace(/[:.]/g, '-');
        const file = new File([blob], `inapp-${ts}.jpg`, { type: 'image/jpeg' });
        closeOverlay();
        const dt = new DataTransfer();
        dt.items.add(file);
        await addPhotos(dt.files);
        // Inject GPS from the current location state (already captured by
        // the form's geolocation watcher) — no EXIF in getUserMedia frames
        if (location) paintLocation();
      }, 'image/jpeg', 0.92);
    });

    // Escape key closes the overlay
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.classList.contains('hidden')) closeOverlay();
    });
  })();
  // -------------------------------------------------------------------------
  cameraInput?.addEventListener('change', async () => {
    if (!cameraInput.files?.length) return;
    // Read EXIF from the original File before any compression / canvas
    // re-encode (which strips EXIF). compressIfLarge doesn't mutate the
    // input, but reading metadata first matches intent and is cheaper.
    await fillFromExif(cameraInput.files[0]);
    await addPhotos(cameraInput.files);
  });
  galleryInput?.addEventListener('change', async () => {
    if (!galleryInput.files?.length) return;
    await fillFromExif(galleryInput.files[0]);
    await addPhotos(galleryInput.files);
  });

  gpsManualBtn?.addEventListener('click', () => {
    gpsManualWrap?.classList.toggle('hidden');
  });
  manualLat?.addEventListener('change', () => maybeManualUpdate());
  manualLng?.addEventListener('change', () => maybeManualUpdate());
  function maybeManualUpdate() {
    const lat = parseFloat(manualLat?.value ?? '');
    const lng = parseFloat(manualLng?.value ?? '');
    if (Number.isFinite(lat) && Number.isFinite(lng)) {
      location = { lat, lng, accuracyM: 1000, altitudeM: null, capturedFrom: 'manual' };
      paintLocation();
    }
  }

  let lastSavedObservationId: string | null = null;

  async function buildSaveDraft(asDraft: boolean): Promise<Parameters<typeof saveObservationToOutbox>[0] | null> {
    if (!form) return null;
    const ref = await resolveObserverRef();
    const draftLoc = (location && Number.isFinite(location.lat) && Number.isFinite(location.lng))
      ? location
      : { lat: 0, lng: 0, accuracyM: 0, altitudeM: null, capturedFrom: 'manual' as const };
    return {
      observerRef: ref,
      media: [
        ...photos.map(p => ({
          blobId: p.blobId,
          blob: p.file,
          mimeType: p.file.type,
          sizeBytes: p.file.size,
          mediaType: 'photo' as const,
        })),
        ...audios.map(a => ({
          blobId: a.blobId,
          blob: a.blob,
          mimeType: a.mimeType,
          sizeBytes: a.blob.size,
          mediaType: 'audio' as const,
        })),
        ...videos.map(v => ({
          blobId: v.blobId,
          blob: v.blob,
          mimeType: v.mimeType,
          sizeBytes: v.blob.size,
          mediaType: 'video' as const,
        })),
      ],
      primaryPhotoIndex: 0,
      location: draftLoc,
      identification: {
        scientificName: idInput?.value.trim() || currentIdentification?.scientific_name || '',
        confidence: currentIdentification?.confidence ?? 0,
        source: mapIdentificationSource(currentIdentification?.source) as Observation['identification']['source'],
        status: (idInput?.value.trim() ? 'accepted' : 'pending') as Observation['identification']['status'],
      },
      habitat: ((form.elements.namedItem('habitat') as HTMLSelectElement).value || null) as Observation['habitat'],
      weather: ((form.elements.namedItem('weather') as HTMLSelectElement).value || null) as Observation['weather'],
      establishmentMeans: (form.querySelector<HTMLInputElement>('input[name="establishment_means"]:checked')?.value ?? 'wild') as 'wild' | 'cultivated' | 'captive' | 'uncertain',
      evidenceType: ((form.elements.namedItem('evidence_type') as HTMLSelectElement).value || 'direct_sighting') as Observation['evidenceType'],
      notes: ((form.elements.namedItem('notes') as HTMLTextAreaElement).value || null),
      asDraft,
    };
  }

  // ── Save as draft (ux-save-as-draft) ────────────────────────────────
  const saveDraftBtn = document.getElementById('save-draft-btn') as HTMLButtonElement | null;
  saveDraftBtn?.addEventListener('click', async () => {
    if (!form) return;
    errBox?.classList.add('hidden');
    if (photos.length === 0 && audios.length === 0 && videos.length === 0) {
      if (errBox) {
        errBox.textContent = observeStringsRT.draft_no_media;
        errBox.classList.remove('hidden');
      }
      return;
    }
    saveDraftBtn.disabled = true;
    try {
      const draft = await buildSaveDraft(true);
      if (!draft) return;
      const obs = await saveObservationToOutbox(draft);
      lastSavedObservationId = obs.id;
      form.classList.add('hidden');
      successBox?.classList.remove('hidden');
      if (successMsg) successMsg.textContent = observeStringsRT.draft_saved_offline;
    } catch (err) {
      if (errBox) {
        errBox.textContent = err instanceof Error ? err.message : String(err);
        errBox.classList.remove('hidden');
      }
    } finally {
      saveDraftBtn.disabled = false;
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form || !submitBtn || !btnLabel) return;
    const isEsSubmit = document.documentElement.lang === 'es';
    errBox?.classList.add('hidden');

    // identify-only mode: submitting just confirms the displayed result.
    // The user must click "Save as observation" to switch to full save mode.
    if (form.dataset.mode === 'identify-only') {
      // No-op: result card is already visible. Re-flash the inline link.
      idSaveInline?.classList.remove('hidden');
      return;
    }

    if (photos.length === 0 && audios.length === 0 && videos.length === 0) {
      if (errBox) { errBox.textContent = isEsSubmit
        ? 'Se requiere al menos una foto, un audio o un video.'
        : 'At least one photo, audio, or video is required.';
        errBox.classList.remove('hidden'); }
      return;
    }
    if (!location || !Number.isFinite(location.lat) || !Number.isFinite(location.lng)) {
      if (errBox) {
        errBox.textContent = isEsSubmit
          ? 'Ubicación inválida. Activa el GPS o ingresa coordenadas válidas.'
          : 'Invalid location. Enable GPS or enter valid coordinates.';
        errBox.classList.remove('hidden');
      }
      return;
    }

    submitBtn.disabled = true;
    btnLabel.textContent = SUBMITTING;

    try {
    // Resolve the ObserverRef from the Supabase session. If not signed in,
    // fall back to a guest ref — observation stays Dexie-only per module 04.
    const ref = await resolveObserverRef();
    const obsDraft = await buildSaveDraft(false);
    if (!obsDraft) return;
    const savedObs = await saveObservationToOutbox(obsDraft);
    lastSavedObservationId = savedObs.id;
    window.posthog?.capture('observation_saved', { observation_id: savedObs.id });
    form.dispatchEvent(new CustomEvent('rastrum:form-saved'));

    // Attempt immediate sync if online; otherwise it'll flush on next online event.
    // Use a timeout to prevent hanging indefinitely if Edge Functions are unavailable.
    let syncedNow = false;
    let syncErrMsg: string | null = null;
    let syncFailedReason: string | null = null;
    if (ref.kind === 'user' && navigator.onLine) {
      try {
        const syncPromise = syncOutbox();
        const timeoutPromise = new Promise<never>((_, reject) =>
          setTimeout(() => reject(new Error('sync timeout')), 15_000)
        );
        const res = await Promise.race([syncPromise, timeoutPromise]);
        syncedNow = res.synced > 0;
        if (res.failed > 0 && res.last_error) {
          syncFailedReason = res.last_error;
        }
      } catch (err) {
        syncErrMsg = err instanceof Error ? err.message : String(err);
        console.warn('[rastrum] sync failed or timed out:', err);
        /* row stays pending — will retry on next online event */
      }
    }

    form.classList.add('hidden');
    successBox?.classList.remove('hidden');
    if (idShareBtn && lastSavedObservationId) {
      idShareBtn.disabled = false;
      idShareBtn.removeAttribute('title');
    }
    if (successMsg) {
      // Surface the real failure reason, not a generic "will sync later".
      // Three states: hard exception (timeout, etc.), per-row failure
      // (sync attempted but a runner threw; last_error is set), and clean
      // success (synced > 0).
      if (syncErrMsg) {
        successMsg.textContent = isEsSubmit
          ? `Guardada en este dispositivo. La sincronización falló: ${syncErrMsg}. Reintentaremos automáticamente.`
          : `Saved on this device. Sync failed: ${syncErrMsg}. We'll retry automatically.`;
      } else if (syncFailedReason) {
        successMsg.textContent = isEsSubmit
          ? `Guardada en este dispositivo. La subida no se completó: ${syncFailedReason}. Reintentaremos al recargar.`
          : `Saved on this device. Upload didn't complete: ${syncFailedReason}. We'll retry on reload.`;
      } else if (syncedNow) {
        successMsg.textContent = isEsSubmit ? 'Guardada y sincronizada.' : 'Saved and synced.';
      } else if (ref.kind === 'guest') {
        successMsg.textContent = isEsSubmit
          ? 'Guardada en este dispositivo. Inicia sesión para sincronizar.'
          : "Saved on this device. Sign in to sync.";
      } else {
        successMsg.textContent = isEsSubmit
          ? 'Guardada en este dispositivo. Se sincronizará al conectarse.'
          : "Saved on this device. Will sync when you're online.";
      }
    }
    } catch (err) {
      const msg = err instanceof Error ? err.message : String(err);
      console.error('[rastrum] submit failed:', err);
      if (errBox) {
        errBox.textContent = isEsSubmit
          ? `No se pudo guardar la observación: ${msg}`
          : `Could not save observation: ${msg}`;
        errBox.classList.remove('hidden');
      }
      // Leave the form visible so the user can retry without losing input.
    } finally {
      submitBtn.disabled = false;
      const restoreLabel = form.dataset.mode === 'identify-only'
        ? form.dataset.labelIdentify ?? ORIGINAL_LABEL
        : form.dataset.labelSaveCta ?? ORIGINAL_LABEL;
      btnLabel.textContent = restoreLabel;
    }
  });

  anotherBtn?.addEventListener('click', () => {
    window.location.reload();
  });

  // ── Upload progress strip ────────────────────────────────────────────
  // Wired against the rastrum:sync-progress event emitted by the upload
  // helper for every PUT chunk to R2. Hidden when no syncing is in flight.
  (function wireUploadProgress() {
    const wrap  = document.getElementById('upload-progress');
    const label = document.getElementById('upload-progress-label');
    const bar   = document.getElementById('upload-progress-bar');
    if (!wrap || !label || !bar) return;
    const tpl = form?.dataset.uploadProgressTpl ?? 'Uploading photo: {pct}%';
    let lastPct = 0;
    window.addEventListener('rastrum:sync-progress', ((ev: Event) => {
      const detail = (ev as CustomEvent<{ loaded: number; total: number }>).detail;
      if (!detail || !detail.total) return;
      const pct = Math.min(100, Math.round((detail.loaded / detail.total) * 100));
      lastPct = pct;
      wrap.classList.remove('hidden');
      label.textContent = tpl.replace('{pct}', String(pct));
      (bar as HTMLElement).style.width = `${pct}%`;
    }) as EventListener);
    window.addEventListener('rastrum:sync-done', () => {
      // Brief delay so the user sees the bar hit 100% before it disappears.
      setTimeout(() => wrap.classList.add('hidden'), 600);
    });
    window.addEventListener('rastrum:sync-start', () => {
      lastPct = 0;
      (bar as HTMLElement).style.width = '0%';
    });
  })();

  // ── Form auto-save / restore ─────────────────────────────────────────
  // Persist text-only fields to localStorage on every input. On remount,
  // restore them so a phone interruption (call, low battery, swipe-away)
  // doesn't lose typed notes / picked dropdowns. Photos/audio/video are
  // intentionally NOT persisted — they're already in the Dexie outbox if
  // the user explicitly saved a draft, and serialising blobs to LS would
  // blow the 5 MB quota immediately.
  (function wireFormAutoSave() {
    if (!form || form.dataset.mode === 'identify-only') return;
    const KEY = 'rastrum.formAutoSave.v1';
    const fields = ['notes', 'habitat', 'weather', 'evidence_type'];

    type Saved = { ts: number; values: Record<string, string> };

    function readFields(): Record<string, string> {
      const out: Record<string, string> = {};
      for (const name of fields) {
        const el = form?.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
        if (el && 'value' in el && el.value) out[name] = String(el.value);
      }
      return out;
    }
    function writeFields(values: Record<string, string>) {
      for (const [name, v] of Object.entries(values)) {
        const el = form?.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
        if (el && 'value' in el) el.value = v;
      }
    }
    function snapshot() {
      try {
        const values = readFields();
        if (Object.keys(values).length === 0) {
          localStorage.removeItem(KEY);
          return;
        }
        const payload: Saved = { ts: Date.now(), values };
        localStorage.setItem(KEY, JSON.stringify(payload));
      } catch { /* full storage */ }
    }

    let debounce: number | undefined;
    form.addEventListener('input',  () => { window.clearTimeout(debounce); debounce = window.setTimeout(snapshot, 400); });
    form.addEventListener('change', () => { window.clearTimeout(debounce); debounce = window.setTimeout(snapshot, 400); });

    // Restore on mount. We only restore if the snapshot is < 24 h old —
    // older drafts are stale enough to be confusing.
    try {
      const raw = localStorage.getItem(KEY);
      if (!raw) return;
      const parsed = JSON.parse(raw) as Saved;
      const ageMs = Date.now() - (parsed?.ts ?? 0);
      if (!parsed?.values || ageMs > 24 * 60 * 60 * 1000) {
        localStorage.removeItem(KEY);
        return;
      }
      const hasContent = Object.values(parsed.values).some(v => v && v.length > 0);
      if (!hasContent) return;
      writeFields(parsed.values);
      document.getElementById('form-restored')?.classList.remove('hidden');
    } catch { /* malformed JSON or LS off */ }

    document.getElementById('form-restored-dismiss')?.addEventListener('click', () => {
      try { localStorage.removeItem(KEY); } catch { /* noop */ }
      const banner = document.getElementById('form-restored');
      banner?.classList.add('hidden');
      // Clear restored values back to defaults.
      for (const name of fields) {
        const el = form?.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement | null;
        if (el && 'value' in el) el.value = '';
      }
    });

    // Clear after a successful save (the form re-renders, so the next mount
    // shouldn't re-restore the just-saved data).
    form.addEventListener('rastrum:form-saved', () => {
      try { localStorage.removeItem(KEY); } catch { /* noop */ }
    });
  })();

  // Kick off GPS + sync triggers on page load.
  // In identify-only mode, defer GPS until the user reveals the location
  // field by tapping "Save as observation" — we don't want a permission
  // prompt for users who only want a quick ID.
  registerSyncTriggers();
  if (form?.dataset.mode !== 'identify-only') {
    getLiveGPS();
  }

  // Show the Android-specific camera hint only on Android user agents —
  // covers the 'capture=environment opens an empty file picker folder'
  // failure mode reported in issue #18.
  if (/Android/i.test(navigator.userAgent)) {
    document.getElementById('photo-hint-android')?.classList.remove('hidden');
  }

  // ── On-device AI helpers: Translate + Auto-narrative ──
  type LocaleEnEs = 'en' | 'es';
  const docLangEnEs: LocaleEnEs = (document.documentElement.lang === 'es') ? 'es' : 'en';
  const isEsAi = docLangEnEs === 'es';

  const notesEl       = document.getElementById('obs-notes') as HTMLTextAreaElement | null;
  const translateBtn  = document.getElementById('translate-btn') as HTMLButtonElement | null;
  const trLabel       = translateBtn?.querySelector('[data-translate-label]') as HTMLElement | null;
  const undoBtn       = document.getElementById('translate-undo-btn') as HTMLButtonElement | null;
  const narrativeBtn  = document.getElementById('auto-narrative-btn') as HTMLButtonElement | null;
  const narrLabel     = narrativeBtn?.querySelector('[data-narrative-label]') as HTMLElement | null;
  const aiProgress    = document.getElementById('ai-helpers-progress');
  const aiError       = document.getElementById('ai-helpers-error');

  const TRANSLATE_DEFAULT = trLabel?.textContent ?? 'Translate';
  const TRANSLATE_BUSY    = isEsAi ? 'Traduciendo…' : 'Translating…';
  const NARRATIVE_DEFAULT = narrLabel?.textContent ?? 'Auto-narrative';
  const NARRATIVE_BUSY    = isEsAi ? 'Escribiendo…' : 'Writing…';

  function setAiError(text: string | null) {
    if (!aiError) return;
    if (!text) { aiError.classList.add('hidden'); aiError.textContent = ''; return; }
    aiError.textContent = text;
    aiError.classList.remove('hidden');
  }
  function setAiProgress(text: string | null) {
    if (!aiProgress) return;
    if (!text) { aiProgress.classList.add('hidden'); aiProgress.textContent = ''; return; }
    aiProgress.textContent = text;
    aiProgress.classList.remove('hidden');
  }

  let undoTimer: number | null = null;
  let originalBeforeTranslate: string | null = null;

  // Show buttons only when the text model is cached on this device. The
  // download flow lives on the profile page — we don't want the obs form
  // triggering a 880 MB download.
  async function maybeShowAiButtons() {
    try {
      const lib = await import('../lib/local-ai');
      if (!lib.localAISupported()) return;
      const status = await lib.getModelCacheStatus(lib.TEXT_MODEL_ID);
      if (status.cached) {
        translateBtn?.classList.remove('hidden');
        narrativeBtn?.classList.remove('hidden');
      }
    } catch { /* env not set */ }
  }
  maybeShowAiButtons();

  function refreshTranslateDisabled() {
    if (!translateBtn || !notesEl) return;
    translateBtn.disabled = notesEl.value.trim().length === 0;
  }
  notesEl?.addEventListener('input', refreshTranslateDisabled);
  refreshTranslateDisabled();

  translateBtn?.addEventListener('click', async () => {
    if (!translateBtn || !trLabel || !notesEl) return;
    const text = notesEl.value.trim();
    if (!text) return;
    setAiError(null);

    const helpers = await import('../lib/local-ai-helpers');
    const source = helpers.detectLocaleFromDoc();
    const target = helpers.flipLocale(source);

    translateBtn.disabled = true;
    trLabel.textContent = TRANSLATE_BUSY;
    setAiProgress(isEsAi ? 'Cargando modelo local…' : 'Loading on-device model…');

    try {
      const lib = await import('../lib/local-ai');
      const engine = await lib.loadTextEngine((p) => {
        setAiProgress(`${Math.round((p.progress ?? 0) * 100)}%  ${p.text ?? ''}`);
      });
      const reply = await engine.chat.completions.create({
        messages: [
          { role: 'system', content: helpers.buildTranslatePrompt(source, target) },
          { role: 'user', content: text },
        ],
        max_tokens: 400,
      });
      const raw = reply.choices?.[0]?.message?.content ?? '';
      const out = (typeof raw === 'string' ? raw : '').trim();
      if (!out) throw new Error(isEsAi ? 'Sin respuesta del modelo.' : 'Empty response from model.');
      originalBeforeTranslate = notesEl.value;
      notesEl.value = out;
      undoBtn?.classList.remove('hidden');
      if (undoTimer != null) window.clearTimeout(undoTimer);
      undoTimer = window.setTimeout(() => {
        undoBtn?.classList.add('hidden');
        originalBeforeTranslate = null;
      }, 10_000);
    } catch (err) {
      setAiError(err instanceof Error ? err.message : String(err));
    } finally {
      setAiProgress(null);
      trLabel.textContent = TRANSLATE_DEFAULT;
      refreshTranslateDisabled();
    }
  });

  undoBtn?.addEventListener('click', () => {
    if (originalBeforeTranslate == null || !notesEl) return;
    notesEl.value = originalBeforeTranslate;
    originalBeforeTranslate = null;
    undoBtn.classList.add('hidden');
    if (undoTimer != null) { window.clearTimeout(undoTimer); undoTimer = null; }
    refreshTranslateDisabled();
  });

  narrativeBtn?.addEventListener('click', async () => {
    if (!narrativeBtn || !narrLabel || !notesEl || !form) return;
    setAiError(null);

    const helpers = await import('../lib/local-ai-helpers');
    const fields: import('../lib/local-ai-helpers').NarrativeFields = {
      species_guess: null,
      location_obscured: location ? `${location.lat.toFixed(2)}, ${location.lng.toFixed(2)}` : null,
      location_raw: location ? { lat: location.lat, lng: location.lng } : null,
      time: new Date().toISOString(),
      habitat: (form.elements.namedItem('habitat') as HTMLSelectElement | null)?.value || null,
      weather: (form.elements.namedItem('weather') as HTMLSelectElement | null)?.value || null,
      establishment_means: form.querySelector<HTMLInputElement>('input[name="establishment_means"]:checked')?.value ?? 'wild',
      evidence_type: (form.elements.namedItem('evidence_type') as HTMLSelectElement | null)?.value || null,
      behavior_tags: null,
      count: null,
    };

    let mode: 'replace' | 'append' = 'replace';
    if (notesEl.value.trim()) {
      const ok = window.confirm(isEsAi
        ? 'Ya hay una nota. ¿Reemplazarla por la generada?\nAceptar = Reemplazar · Cancelar = Añadir'
        : 'There is already a note. Replace it with the generated one?\nOK = Replace · Cancel = Append');
      mode = ok ? 'replace' : 'append';
    }

    narrativeBtn.disabled = true;
    narrLabel.textContent = NARRATIVE_BUSY;
    setAiProgress(isEsAi ? 'Cargando modelo local…' : 'Loading on-device model…');

    try {
      const lib = await import('../lib/local-ai');
      const engine = await lib.loadTextEngine((p) => {
        setAiProgress(`${Math.round((p.progress ?? 0) * 100)}%  ${p.text ?? ''}`);
      });
      const prompt = helpers.buildNarrativePrompt(docLangEnEs, fields);
      const reply = await engine.chat.completions.create({
        messages: [{ role: 'user', content: prompt }],
        max_tokens: 220,
      });
      const raw = reply.choices?.[0]?.message?.content ?? '';
      const out = (typeof raw === 'string' ? raw : '').trim();
      if (!out) throw new Error(isEsAi ? 'Sin respuesta del modelo.' : 'Empty response from model.');
      if (mode === 'replace') notesEl.value = out;
      else notesEl.value = (notesEl.value.trim() + '\n\n' + out).trim();
    } catch (err) {
      setAiError(err instanceof Error ? err.message : String(err));
    } finally {
      setAiProgress(null);
      narrativeBtn.disabled = false;
      narrLabel.textContent = NARRATIVE_DEFAULT;
      refreshTranslateDisabled();
    }
  });
</script>
