      : location.capturedFrom.toUpperCase();
    gpsStatus.textContent = `${location.lat.toFixed(5)}, ${location.lng.toFixed(5)}  ·  ${source}  ·  ±${Math.round(location.accuracyM)} m`;
    gpsStatus.className = 'text-zinc-900 dark:text-zinc-100 font-mono text-xs';
