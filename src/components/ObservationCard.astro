---
interface Props {
  species: string;
  confidence: number;
  location: string;
  date: string;
  lang: string;
}

import { t } from '../i18n/utils';

const { species, confidence, location, date, lang } = Astro.props;
const tr = t(lang);

const confidenceColor = confidence >= 90 ? 'bg-emerald-500' : confidence >= 70 ? 'bg-yellow-500' : 'bg-orange-500';
---

<div class="rounded-xl border border-zinc-200 dark:border-zinc-800 overflow-hidden hover:border-emerald-500/50 transition-colors">
  <div class="aspect-[4/3] bg-zinc-100 dark:bg-zinc-900 flex items-center justify-center">
    <svg class="w-12 h-12 text-zinc-300 dark:text-zinc-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
  </div>
  <div class="p-4 space-y-2">
    <div class="flex items-center justify-between">
      <h3 class="font-semibold text-sm italic">{species}</h3>
      <span class={`text-xs font-medium text-white px-2 py-0.5 rounded-full ${confidenceColor}`}>
        {confidence}%
      </span>
    </div>
    <div class="text-xs text-zinc-500 dark:text-zinc-400 space-y-0.5">
      <p>{tr.common.location}: {location}</p>
      <p>{tr.common.date}: {date}</p>
    </div>
  </div>
</div>
