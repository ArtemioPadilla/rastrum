---
import Comments from './Comments.astro';
import FollowButton from './FollowButton.astro';
import ShareButton from './ShareButton.astro';
import SuggestIdModal from './SuggestIdModal.astro';
import ReactionStrip from './ReactionStrip.astro';
import PhotoGallery from './PhotoGallery.astro';
import MapPicker from './MapPicker.astro';
import ObsManagePanel from './ObsManagePanel.astro';
import AudioPlayer from './AudioPlayer.astro';
import { t } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;
const obsIdPlaceholder = '';

// Pull from the i18n tree in frontmatter — Astro's JSX parser fights with
// inline `Record<…>` casts, so we narrow once here and then read fields off
// typed locals in the markup.
type ObsDetailTree = {
  view: Record<string, string>;
  edit_location: string;
  save_changes: string;
  saved: string;
  edited_badge: string;
};
const tr = t(lang) as { obs_detail: ObsDetailTree };
const v  = tr.obs_detail.view;

// Labels still consumed by ShareObsView itself. Manage-panel labels
// moved into ObsManagePanel.astro in PR4.
const labels = {
  loading:           v.loading,
  region:            v.region,
  date:              v.date,
  habitat:           v.habitat,
  weather:           v.weather,
  establishment:     v.establishment,
  observer:          v.observer,
  sensitive:         v.sensitive,
  reportBtn:         v.report_btn,
  reactionsHelp:     v.reactions_help,
  communityIds:      v.community_ids,
  noSuggestions:     v.no_suggestions,
  suggestBtn:        v.suggest_btn,
  signInToSuggest:   v.signin_to_suggest,
  ownerNote:         v.owner_note,
  editLocation:      tr.obs_detail.edit_location,
  editedBadge:       tr.obs_detail.edited_badge,
  placeChipLabel:    v.place_chip_label,
};
---

<div class="max-w-6xl mx-auto">
  <div id="loading" class="py-16 text-center text-zinc-500">{labels.loading}</div>

  <article id="obs" class="hidden">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6">
      <aside class="md:col-span-7 lg:col-span-7 space-y-3 md:sticky md:top-20 self-start">
        <PhotoGallery photos={[]} lang={lang} mode="viewer" galleryId="obs-detail" />

        <div id="best-shot-mount" class="hidden mt-3">
          <button id="best-shot-btn" type="button" class="text-xs text-zinc-600 dark:text-zinc-400 hover:text-emerald-700 dark:hover:text-emerald-400">
            📸 {lang === 'es' ? 'Nominar como mejor foto' : 'Nominate as best shot'}
          </button>
          <span id="best-shot-count" class="ml-2 text-xs text-zinc-500 dark:text-zinc-400"></span>
        </div>

        <div class="space-y-2">
          <MapPicker mode="view" lang={lang} pickerId="obs-detail" initialCoords={null} />
          <p data-obs-coords class="text-xs text-zinc-500 dark:text-zinc-400"></p>
          <a id="obs-place-chip" href="#" class="hidden inline-flex items-center gap-1.5 mt-1 text-sm text-emerald-700 dark:text-emerald-400 hover:underline">
            <svg class="w-3.5 h-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>{labels.placeChipLabel}</span>
          </a>
          <button
            type="button"
            id="obs-edit-location-btn"
            data-show-when="owner"
            class="hidden text-xs text-emerald-700 dark:text-emerald-400 underline"
            disabled
            aria-disabled="true"
            title={labels.editLocation}
          >{labels.editLocation}</button>
        </div>

        <!-- Audio player mount — populated dynamically when audio media_files exist -->
        <!-- The page script replaces innerHTML when audios are found.
             The div stays hidden until then. -->
        <div id="obs-audio-players" class="hidden space-y-3"></div>
        <!-- Hidden AudioPlayer instance so Astro bundles the <script> that
             listens for `rastrum:audio-players-ready`. The dynamic HTML
             injected by the page script creates `.rastrum-audio-player`
             nodes, but without this anchor the init JS is tree-shaken. -->
        <div class="hidden" aria-hidden="true">
          <AudioPlayer audioUrl="" lang={lang} obsId="__anchor" showSpectrogram={false} />
        </div>
      </aside>

      <section class="md:col-span-5 lg:col-span-5 space-y-6">
        <header class="space-y-2">
          <div class="flex flex-wrap items-start justify-between gap-3">
            <div class="min-w-0">
              <h1 id="species" class="text-3xl md:text-4xl font-bold italic text-zinc-900 dark:text-zinc-100"></h1>
              <p id="meta" class="text-sm text-zinc-500 dark:text-zinc-400"></p>
            </div>
            <div class="flex items-center gap-2">
              <div id="follow-mount">
                <FollowButton lang={lang} />
              </div>
              <ShareButton lang={lang} id="obs-share-btn" />
              <button
                id="obs-report-btn"
                type="button"
                class="hidden inline-flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-200 dark:border-zinc-800 text-zinc-500 dark:text-zinc-400 hover:border-zinc-300 dark:hover:border-zinc-700 hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors"
                aria-label={labels.reportBtn}
                title={labels.reportBtn}
              >
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 22V4a2 2 0 0 1 2-2h11l4 6-4 6H6"/><line x1="4" y1="22" x2="4" y2="14"/></svg>
              </button>
            </div>
          </div>
        </header>

        <div id="reactions-mount" class="flex items-center gap-3">
          <ReactionStrip lang={lang} target="observation" targetId={obsIdPlaceholder} size="md" />
          <span id="reactions-help" class="hidden text-xs text-zinc-500 dark:text-zinc-500">
            {labels.reactionsHelp}
          </span>
        </div>

        <p id="sensitive" class="hidden text-sm text-amber-700 dark:text-amber-400 border-l-4 border-amber-500 pl-3">
          {labels.sensitive}
        </p>

        <p
          id="edited-badge"
          data-edited-badge
          class="hidden text-xs text-amber-700 dark:text-amber-400 border-l-4 border-amber-500 pl-3 py-1"
        >{labels.editedBadge}</p>

        <dl class="grid grid-cols-2 gap-4 text-sm">
          <div>
            <dt class="text-zinc-500 dark:text-zinc-400">{labels.date}</dt>
            <dd id="date" class="font-medium"></dd>
          </div>
          <div>
            <dt class="text-zinc-500 dark:text-zinc-400">{labels.region}</dt>
            <dd id="region" class="font-medium">—</dd>
          </div>
          <div>
            <dt class="text-zinc-500 dark:text-zinc-400">{labels.habitat}</dt>
            <dd id="habitat" class="font-medium">—</dd>
          </div>
          <div>
            <dt class="text-zinc-500 dark:text-zinc-400">{labels.weather}</dt>
            <dd id="weather" class="font-medium">—</dd>
          </div>
          <div>
            <dt class="text-zinc-500 dark:text-zinc-400">{labels.establishment}</dt>
            <dd id="establishment" class="font-medium">—</dd>
          </div>
          <div>
            <dt class="text-zinc-500 dark:text-zinc-400">{labels.observer}</dt>
            <dd id="observer" class="font-medium">—</dd>
          </div>
        </dl>

        <section id="community-ids" class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4 space-y-3">
          <div class="flex items-start justify-between gap-2 flex-wrap">
            <div>
              <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider">{labels.communityIds}</h2>
              <p id="community-ids-empty" class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">
                {labels.noSuggestions}
              </p>
            </div>
            <button id="ci-suggest-btn" type="button" class="hidden rounded-lg bg-emerald-700 hover:bg-emerald-800 px-3 py-1.5 text-xs font-semibold text-white">
              {labels.suggestBtn}
            </button>
            <a id="ci-signin-link" href="/en/sign-in/" class="hidden rounded-lg border border-emerald-600/60 px-3 py-1.5 text-xs font-medium text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20">
              {labels.signInToSuggest}
            </a>
            <span id="ci-owner-note" class="hidden text-xs text-zinc-500 italic">{labels.ownerNote}</span>
          </div>
          <ul id="ci-list" class="space-y-1.5 text-sm"></ul>
        </section>

        <ObsManagePanel lang={lang} />

        <div id="social-mount" class="hidden">
          <Comments lang={lang} observationId={obsIdPlaceholder} />
        </div>
      </section>
    </div>
  </article>

  <div id="err" class="hidden py-16 text-center text-red-600 dark:text-red-400"></div>
</div>

<SuggestIdModal lang={lang} />
