---
import { t } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;
const tr = t(lang);
---

<button
  id="pwa-install-btn"
  type="button"
  class="hidden fixed bottom-[calc(5rem+env(safe-area-inset-bottom))] sm:bottom-4 right-20 z-40 items-center gap-2 rounded-full bg-emerald-700 hover:bg-emerald-800 text-white px-4 py-2 text-sm font-semibold shadow-lg min-h-11"
  aria-label={tr.pwa.install}
>
  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v12m0 0l-4-4m4 4l4-4M4 20h16" />
  </svg>
  <span data-pwa-label>{tr.pwa.install}</span>
</button>

<div
  id="pwa-ios-hint"
  class="hidden fixed bottom-[calc(8rem+env(safe-area-inset-bottom))] sm:bottom-20 right-4 z-40 max-w-xs rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 shadow-lg p-3 text-sm text-zinc-700 dark:text-zinc-300"
  role="status"
>
  <div class="flex items-start gap-2">
    <svg class="w-5 h-5 mt-0.5 text-emerald-700 dark:text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v4a2 2 0 002 2h12a2 2 0 002-2v-4M16 8l-4-4m0 0L8 8m4-4v12" />
    </svg>
    <div class="flex-1 min-w-0">
      <p>{tr.pwa.ios_hint}</p>
      <button id="pwa-ios-close" type="button" class="mt-2 text-xs font-medium text-emerald-700 dark:text-emerald-400 hover:underline min-h-11 sm:min-h-0">
        {tr.pwa.ios_hint_close}
      </button>
    </div>
  </div>
</div>

<script>
  import { isIOS, isStandaloneDisplayMode } from '../lib/local-ai-helpers';

  // The browser's beforeinstallprompt event isn't fully typed in lib.dom yet.
  type InstallPromptEvent = Event & {
    prompt: () => Promise<void>;
    userChoice: Promise<{ outcome: 'accepted' | 'dismissed'; platform: string }>;
  };

  const btn       = document.getElementById('pwa-install-btn');
  const iosHint   = document.getElementById('pwa-ios-hint');
  const iosClose  = document.getElementById('pwa-ios-close');
  const IOS_HINT_DISMISSED_KEY = 'rastrum.pwaIosHintDismissed';

  let saved: InstallPromptEvent | null = null;

  function showAndroidBtn() {
    btn?.classList.remove('hidden');
    btn?.classList.add('inline-flex');
  }
  function hideAndroidBtn() {
    btn?.classList.add('hidden');
    btn?.classList.remove('inline-flex');
  }

  // Check if already installed via getInstalledRelatedApps (Chrome Android)
  // or via localStorage flag (set on appinstalled event), or via display-mode
  // standalone media query (running as installed PWA).
  //
  // NOTE: `getInstalledRelatedApps()` requires the manifest to have a
  // `related_applications` entry with `platform: 'webapp'` (already present).
  // It also requires HTTPS and returns [] on first call in some Chrome versions —
  // that's why we have the localStorage fallback.
  //
  // KNOWN BUG (Eugenio, 2026-04-28): button showed even after install on Android.
  // Root cause: `beforeinstallprompt` fires even when the app is installed if
  // the user opens the site in the browser (not from the home-screen icon).
  // Fix: check localStorage flag first (set by appinstalled), then probe
  // getInstalledRelatedApps async, and only show the button if both are clean.
  async function isAlreadyInstalled(): Promise<boolean> {
    // Fast path: localStorage flag set the moment the user accepted install.
    try { if (localStorage.getItem('rastrum.pwaInstalled') === 'true') return true; } catch { /* ignore */ }
    // Fast path: running in standalone mode = already installed and open from icon.
    if (isStandaloneDisplayMode()) return true;
    // Slow path: ask Chrome directly (async, may be empty on older versions).
    try {
      const nav = window.navigator as Navigator & { getInstalledRelatedApps?: () => Promise<unknown[]> };
      if (nav.getInstalledRelatedApps) {
        const apps = await nav.getInstalledRelatedApps();
        if (apps.length > 0) {
          // Cache the result so future calls are fast.
          try { localStorage.setItem('rastrum.pwaInstalled', 'true'); } catch { /* ignore */ }
          return true;
        }
      }
    } catch { /* not supported */ }
    return false;
  }

  if (!isStandaloneDisplayMode()) {
    if (isIOS()) {
      // Show the iOS Add-to-Home-Screen tooltip once per install (until dismissed).
      const dismissed = localStorage.getItem(IOS_HINT_DISMISSED_KEY) === 'true';
      if (!dismissed) {
        // Small delay so we don't fight first paint.
        setTimeout(() => iosHint?.classList.remove('hidden'), 1500);
      }
    } else {
      window.addEventListener('beforeinstallprompt', async (ev) => {
        ev.preventDefault();
        // Don't show if already installed
        if (await isAlreadyInstalled()) return;
        saved = ev as InstallPromptEvent;
        showAndroidBtn();
      });
    }
  }

  iosClose?.addEventListener('click', () => {
    iosHint?.classList.add('hidden');
    try { localStorage.setItem(IOS_HINT_DISMISSED_KEY, 'true'); } catch { /* ignore */ }
  });

  btn?.addEventListener('click', async () => {
    if (!saved) return;
    try {
      await saved.prompt();
      const choice = await saved.userChoice;
      if (choice.outcome === 'accepted' || choice.outcome === 'dismissed') {
        // The contract is that the prompt is single-use.
        saved = null;
        hideAndroidBtn();
      }
    } catch {
      hideAndroidBtn();
    }
  });

  window.addEventListener('appinstalled', () => {
    saved = null;
    hideAndroidBtn();
    iosHint?.classList.add('hidden');
    // Persist flag so next browser visit also hides the button
    try { localStorage.setItem('rastrum.pwaInstalled', 'true'); } catch { /* ignore */ }
  });
</script>
