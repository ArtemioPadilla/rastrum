---
/**
 * ConsoleExpertValidationView — validation queue scoped to current user's
 * expert_taxa. Read-only; each row links to /explore/validate/?obs=<id>
 * for the actual suggest/vote write path.
 */
import { t } from '../i18n/utils';

interface Props { lang: 'en' | 'es' }
const { lang } = Astro.props;
const tr = t(lang);
---

<section class="max-w-5xl space-y-4">
  <div id="exp-val-not-auth" class="hidden rounded border border-amber-300 dark:border-amber-700/60 bg-amber-50 dark:bg-amber-900/20 p-3 text-sm text-amber-900 dark:text-amber-100">
    {tr.console.not_authorized}
  </div>

  <div id="exp-val-shell" class="hidden space-y-4">
    <p class="text-sm text-zinc-500 dark:text-zinc-400">{tr.console.exp_val_intro}</p>

    <!-- Filter toggle -->
    <div class="flex items-center gap-3">
      <button
        id="exp-val-filter-my"
        class="rounded px-3 py-1.5 text-xs font-medium bg-emerald-600 text-white"
      >
        {tr.console.exp_val_filter_my_taxa}
      </button>
      <button
        id="exp-val-filter-all"
        class="rounded px-3 py-1.5 text-xs font-medium bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300"
      >
        {tr.console.exp_val_filter_all_taxa}
      </button>
    </div>

    <!-- Loading / error -->
    <p id="exp-val-loading" class="text-sm text-zinc-500 dark:text-zinc-400">{tr.console.exp_val_loading}</p>
    <p id="exp-val-error" class="hidden text-sm text-red-600 dark:text-red-400"></p>

    <!-- Table -->
    <div id="exp-val-table-wrap" class="hidden overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-zinc-200 dark:border-zinc-800 text-left text-xs text-zinc-500">
            <th class="py-2 pr-3 font-medium">{tr.console.exp_val_col_taxon}</th>
            <th class="py-2 pr-3 font-medium">{tr.console.exp_val_col_confidence}</th>
            <th class="py-2 pr-3 font-medium">{tr.console.exp_val_col_suggestions}</th>
            <th class="py-2 pr-3 font-medium">{tr.console.exp_val_col_voters}</th>
            <th class="py-2 pr-3 font-medium">{tr.console.exp_val_col_observer}</th>
            <th class="py-2 font-medium">{tr.console.exp_val_col_actions}</th>
          </tr>
        </thead>
        <tbody id="exp-val-tbody" class="divide-y divide-zinc-100 dark:divide-zinc-800/60">
        </tbody>
      </table>
    </div>

    <!-- Empty state (unfiltered) -->
    <div id="exp-val-empty" class="hidden rounded-md border border-dashed border-zinc-300 dark:border-zinc-700 p-6 text-sm text-center text-zinc-500">
      {tr.console.exp_val_empty}
    </div>

    <!-- Empty state when "My taxa only" is active but matches nothing in a non-empty queue -->
    <div id="exp-val-empty-filtered" class="hidden rounded-md border border-dashed border-zinc-300 dark:border-zinc-700 p-6 text-sm text-center text-zinc-500">
      {tr.console.exp_val_empty_filtered}
    </div>
  </div>
</section>

<script>
  import { getSupabase } from '../lib/supabase';
  import { getUserRoles } from '../lib/user-roles';
  import { readFilterState, writeFilterState } from '../lib/console-filter-state';

  function show(id: string) { document.getElementById(id)?.classList.remove('hidden'); }
  function hide(id: string) { document.getElementById(id)?.classList.add('hidden'); }

  function escHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  const supabase = getSupabase();

  type QueueRow = {
    observation_id: string;
    current_scientific_name: string | null;
    current_taxon_id: string | null;
    current_confidence: number | null;
    suggestion_count: number | null;
    distinct_voter_count: number | null;
    observer_id: string | null;
  };

  let allRows: QueueRow[] = [];
  let kingdomMap = new Map<string, string>();
  let expertTaxa: string[] = [];
  let myTaxaOnly = true;

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session?.user) { show('exp-val-not-auth'); return; }
    const myRoles = await getUserRoles(session.user.id);
    if (!myRoles.has('expert') && !myRoles.has('admin')) {
      show('exp-val-not-auth');
      return;
    }
    show('exp-val-shell');
    const saved = readFilterState();
    if (saved['scope'] === 'all') myTaxaOnly = false;

    // Fetch expert_taxa
    const { data: userData } = await supabase.from('users').select('expert_taxa').eq('id', session.user.id).single();
    expertTaxa = userData?.expert_taxa ?? [];

    // Fetch queue
    const { data: queueData, error: queueError } = await supabase
      .from('validation_queue')
      .select('observation_id, current_scientific_name, current_taxon_id, current_confidence, suggestion_count, distinct_voter_count, observer_id')
      .order('suggestion_count', { ascending: true })
      .limit(200);

    hide('exp-val-loading');

    if (queueError) {
      const errEl = document.getElementById('exp-val-error')!;
      errEl.textContent = queueError.message;
      show('exp-val-error');
      return;
    }

    allRows = (queueData ?? []) as QueueRow[];

    // Batch-fetch kingdoms for all taxon IDs
    const taxonIds = [...new Set(allRows.map(r => r.current_taxon_id).filter(Boolean))] as string[];
    if (taxonIds.length > 0) {
      const { data: taxaData } = await supabase.from('taxa').select('id, kingdom').in('id', taxonIds);
      kingdomMap = new Map((taxaData ?? []).map(t => [t.id, t.kingdom]));
    }

    renderTable();
    wireFilters();
  }

  function filteredRows(): QueueRow[] {
    if (!myTaxaOnly || expertTaxa.length === 0) return allRows;
    // users.expert_taxa stores capitalised kingdom names ('Aves', 'Plantae')
    // matching taxa.kingdom convention (verified via the consensus function's
    // `t.kingdom = ANY(u.expert_taxa)`). If a future migration introduces
    // case-mismatch, this filter would silently drop everything — verify the
    // data invariant if that path ever becomes possible.
    return allRows.filter(r => {
      const kingdom = kingdomMap.get(r.current_taxon_id ?? '');
      return kingdom && expertTaxa.includes(kingdom);
    });
  }

  function renderTable() {
    const rows = filteredRows();
    const tbody = document.getElementById('exp-val-tbody')!;

    hide('exp-val-empty');
    hide('exp-val-empty-filtered');

    if (rows.length === 0) {
      hide('exp-val-table-wrap');
      // Distinguish: taxa-scoped filter active but unfiltered queue has items
      if (myTaxaOnly && allRows.length > 0) {
        show('exp-val-empty-filtered');
      } else {
        show('exp-val-empty');
      }
      return;
    }

    hide('exp-val-empty');
    show('exp-val-table-wrap');

    tbody.innerHTML = rows.map(r => {
      const conf = r.current_confidence != null ? `${Math.round(r.current_confidence * 100)}%` : '—';
      // uuid is structurally safe but escape for uniformity with the rest of the component
      const obsUrl = `/explore/validate/?obs=${escHtml(r.observation_id)}`;
      const name = r.current_scientific_name ?? '—';
      const suggestions = r.suggestion_count ?? 0;
      const voters = r.distinct_voter_count ?? 0;
      return `<tr class="hover:bg-zinc-50 dark:hover:bg-zinc-800/40 transition-colors">
        <td class="py-2 pr-3 font-medium italic text-zinc-800 dark:text-zinc-200">${name}</td>
        <td class="py-2 pr-3 text-zinc-500">${conf}</td>
        <td class="py-2 pr-3 text-zinc-500">${suggestions}</td>
        <td class="py-2 pr-3 text-zinc-500">${voters}</td>
        <td class="py-2 pr-3 text-zinc-500 font-mono text-xs">${r.observer_id ? r.observer_id.slice(0, 8) + '…' : '—'}</td>
        <td class="py-2"><a href="${obsUrl}" class="text-xs text-emerald-700 dark:text-emerald-400 underline whitespace-nowrap">Open in queue →</a></td>
      </tr>`;
    }).join('');
  }

  function wireFilters() {
    const myBtn = document.getElementById('exp-val-filter-my')!;
    const allBtn = document.getElementById('exp-val-filter-all')!;

    myBtn.addEventListener('click', () => {
      myTaxaOnly = true;
      myBtn.className = 'rounded px-3 py-1.5 text-xs font-medium bg-emerald-600 text-white';
      allBtn.className = 'rounded px-3 py-1.5 text-xs font-medium bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300';
      writeFilterState({ scope: 'my' });
      renderTable();
    });

    allBtn.addEventListener('click', () => {
      myTaxaOnly = false;
      allBtn.className = 'rounded px-3 py-1.5 text-xs font-medium bg-emerald-600 text-white';
      myBtn.className = 'rounded px-3 py-1.5 text-xs font-medium bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300';
      writeFilterState({ scope: 'all' });
      renderTable();
    });
  }

  init().catch(err => {
    hide('exp-val-loading');
    const errEl = document.getElementById('exp-val-error')!;
    errEl.textContent = (err as Error).message;
    show('exp-val-error');
  });
</script>
