---
import { t } from '../i18n/utils';

interface Props {
  lang: 'en' | 'es';
}
const { lang } = Astro.props;
const tr = t(lang);
---

<!-- The chat lays out as full-height with a fixed input bar on small screens.
     `pb-44` reserves room above the sticky composer + the iOS home indicator. -->
<div class="max-w-3xl mx-auto -mt-2 sm:mt-0">
  <div class="mb-4 flex items-baseline justify-between gap-3 flex-wrap">
    <h1 class="text-2xl font-bold tracking-tight">{tr.chat.title}</h1>
    <button
      id="chat-clear-btn"
      type="button"
      class="hidden text-xs font-medium text-zinc-600 dark:text-zinc-400 hover:underline min-h-11 sm:min-h-0"
    >
      {tr.chat.clear}
    </button>
  </div>
  <p class="text-sm text-zinc-500 mb-4">{tr.chat.subtitle}</p>

  <!-- Consent / setup gate -->
  <div id="chat-consent" class="hidden rounded-xl border border-amber-300 dark:border-amber-700/40 bg-amber-50 dark:bg-amber-900/10 p-4 mb-4">
    <p class="text-sm text-amber-900 dark:text-amber-100">{tr.chat.consent_required}</p>
    <p id="chat-unsup" class="hidden mt-2 text-xs text-amber-900 dark:text-amber-200">{tr.chat.consent_unsupported}</p>
    <div class="mt-3 flex flex-wrap gap-2">
      <button
        id="chat-download-btn"
        type="button"
        class="inline-flex items-center min-h-11 rounded-lg bg-emerald-700 hover:bg-emerald-800 px-4 py-2 text-sm font-semibold text-white disabled:opacity-50"
      >
        <span data-cdl>{tr.chat.consent_download}</span>
      </button>
      <a
        href={`/${lang}/${lang === 'es' ? 'perfil/editar' : 'profile/edit'}/`}
        class="inline-flex items-center min-h-11 rounded-lg border border-zinc-300 dark:border-zinc-700 px-4 py-2 text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/40"
      >
        {tr.chat.consent_open_settings}
      </a>
    </div>
    <p id="chat-dl-progress" class="hidden mt-3 text-xs text-zinc-700 dark:text-zinc-300 font-mono"></p>
  </div>

  <!-- Conversation -->
  <div
    id="chat-history"
    class="hidden space-y-3 mb-4 pb-44 sm:pb-4"
    role="log"
    aria-live="polite"
  >
    <div id="chat-empty" class="text-sm text-zinc-500 italic px-1 py-12 text-center">
      {tr.chat.empty_state}
    </div>
  </div>

  <!-- Composer (sticky on mobile, inline on desktop) -->
  <form
    id="chat-form"
    class="hidden fixed bottom-0 left-0 right-0 sm:static border-t border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950 sm:border-0 sm:bg-transparent z-30"
    style="padding-bottom: env(safe-area-inset-bottom);"
  >
    <div class="max-w-3xl mx-auto px-4 sm:px-0 py-3 sm:py-0 flex items-end gap-2">
      <textarea
        id="chat-input"
        rows="1"
        placeholder={tr.chat.placeholder}
        class="flex-1 resize-none rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-base min-h-11 max-h-40"
      ></textarea>
      <button
        id="chat-send-btn"
        type="submit"
        class="rounded-lg bg-emerald-700 hover:bg-emerald-800 disabled:opacity-50 px-4 py-2 text-sm font-semibold text-white min-h-11 whitespace-nowrap"
      >
        <span data-csl>{tr.chat.send}</span>
      </button>
    </div>
  </form>
</div>

<script>
  import {
    detectLocaleFromDoc,
    CHAT_SYSTEM_PROMPT,
    type Locale as ChatLocale,
  } from '../lib/local-ai-helpers';

  type ChatRole = 'user' | 'assistant';
  interface ChatTurn { role: ChatRole; content: string; }

  const isEs = (document.documentElement.lang === 'es');
  const docLocale: ChatLocale = detectLocaleFromDoc();

  const consentBox      = document.getElementById('chat-consent');
  const unsupNote       = document.getElementById('chat-unsup');
  const downloadBtn     = document.getElementById('chat-download-btn') as HTMLButtonElement | null;
  const downloadLabel   = downloadBtn?.querySelector('[data-cdl]') as HTMLElement | null;
  const dlProgress      = document.getElementById('chat-dl-progress');
  const historyEl       = document.getElementById('chat-history');
  const emptyState      = document.getElementById('chat-empty');
  const formEl          = document.getElementById('chat-form') as HTMLFormElement | null;
  const inputEl         = document.getElementById('chat-input') as HTMLTextAreaElement | null;
  const sendBtn         = document.getElementById('chat-send-btn') as HTMLButtonElement | null;
  const sendLabel       = sendBtn?.querySelector('[data-csl]') as HTMLElement | null;
  const clearBtn        = document.getElementById('chat-clear-btn') as HTMLButtonElement | null;

  const SEND_DEFAULT  = sendLabel?.textContent ?? 'Send';
  const SEND_BUSY     = isEs ? 'Pensando…' : 'Thinking…';
  const DL_DEFAULT    = downloadLabel?.textContent ?? 'Download';
  const DL_LOADING    = isEs ? 'Cargando modelo en la GPU…' : 'Loading model into GPU…';

  let modelReady = false;
  let busy = false;
  const conversation: ChatTurn[] = [];

  function escapeHtml(s: string): string {
    return s.replace(/[<>&'"]/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;',"'":'&#39;','"':'&quot;'}[c]!));
  }

  function paintConversation() {
    if (!historyEl) return;
    if (conversation.length === 0) {
      historyEl.innerHTML = '';
      historyEl.appendChild(emptyState ?? document.createTextNode(''));
      clearBtn?.classList.add('hidden');
      return;
    }
    emptyState?.remove();
    historyEl.innerHTML = conversation.map((t, i) => bubbleHtml(t, i)).join('');
    clearBtn?.classList.remove('hidden');
    historyEl.scrollIntoView({ block: 'end', behavior: 'smooth' });
    window.scrollTo({ top: document.body.scrollHeight, behavior: 'smooth' });
  }

  function bubbleHtml(turn: ChatTurn, idx: number): string {
    const isUser = turn.role === 'user';
    const align  = isUser ? 'ml-auto' : 'mr-auto';
    const bg     = isUser
      ? 'bg-emerald-700 text-white'
      : 'bg-zinc-100 dark:bg-zinc-900 text-zinc-900 dark:text-zinc-100 border border-zinc-200 dark:border-zinc-800';
    const role   = isUser ? (isEs ? 'Tú' : 'You') : 'Rastrum';
    return `
      <div class="${align} max-w-[85%] sm:max-w-[75%]" data-bubble="${idx}">
        <p class="text-[10px] uppercase tracking-wider text-zinc-400 mb-0.5 ${isUser ? 'text-right' : ''}">${escapeHtml(role)}</p>
        <div data-bubble-body class="${bg} rounded-2xl px-3 py-2 text-sm whitespace-pre-wrap break-words">${escapeHtml(turn.content)}</div>
      </div>
    `;
  }

  function setBubbleStreaming(idx: number, content: string) {
    const wrap = historyEl?.querySelector(`[data-bubble="${idx}"] [data-bubble-body]`);
    if (wrap) wrap.textContent = content;
    window.scrollTo({ top: document.body.scrollHeight, behavior: 'auto' });
  }

  function autosize() {
    if (!inputEl) return;
    inputEl.style.height = 'auto';
    inputEl.style.height = Math.min(inputEl.scrollHeight, 160) + 'px';
  }

  // Wire textarea Enter / Shift+Enter
  inputEl?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' && !e.shiftKey) {
      e.preventDefault();
      formEl?.requestSubmit();
    }
  });
  inputEl?.addEventListener('input', autosize);

  clearBtn?.addEventListener('click', () => {
    conversation.length = 0;
    paintConversation();
  });

  // ── Consent + setup ──
  async function refreshState() {
    try {
      const lib = await import('../lib/local-ai');
      if (!lib.localAISupported()) {
        consentBox?.classList.remove('hidden');
        unsupNote?.classList.remove('hidden');
        if (downloadBtn) downloadBtn.disabled = true;
        return;
      }
      const status = await lib.getModelCacheStatus(lib.TEXT_MODEL_ID);
      if (status.cached) {
        modelReady = true;
        consentBox?.classList.add('hidden');
        historyEl?.classList.remove('hidden');
        formEl?.classList.remove('hidden');
        paintConversation();
      } else {
        consentBox?.classList.remove('hidden');
        historyEl?.classList.add('hidden');
        formEl?.classList.add('hidden');
      }
    } catch {
      consentBox?.classList.remove('hidden');
    }
  }
  refreshState();

  downloadBtn?.addEventListener('click', async () => {
    if (!downloadBtn || !downloadLabel) return;
    downloadBtn.disabled = true;
    downloadLabel.textContent = isEs ? 'Descargando…' : 'Downloading…';
    if (dlProgress) dlProgress.classList.remove('hidden');
    try {
      const lib = await import('../lib/local-ai');
      await lib.loadTextEngine((p) => {
        if (dlProgress) dlProgress.textContent = `${Math.round((p.progress ?? 0) * 100)}%  ${p.text ?? ''}`;
      });
      modelReady = true;
      consentBox?.classList.add('hidden');
      historyEl?.classList.remove('hidden');
      formEl?.classList.remove('hidden');
      paintConversation();
    } catch (err) {
      if (dlProgress) dlProgress.textContent = err instanceof Error ? err.message : String(err);
    } finally {
      downloadBtn.disabled = false;
      downloadLabel.textContent = DL_DEFAULT;
    }
  });

  // ── Send ──
  formEl?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (busy || !inputEl || !sendBtn || !sendLabel) return;
    const text = inputEl.value.trim();
    if (!text) return;
    if (!modelReady) {
      consentBox?.classList.remove('hidden');
      return;
    }
    busy = true;
    sendBtn.disabled = true;
    sendLabel.textContent = SEND_BUSY;

    conversation.push({ role: 'user', content: text });
    conversation.push({ role: 'assistant', content: '' });
    inputEl.value = '';
    autosize();
    paintConversation();
    const assistantIdx = conversation.length - 1;

    try {
      const lib = await import('../lib/local-ai');
      if (dlProgress) dlProgress.classList.remove('hidden');
      const engine = await lib.loadTextEngine((p) => {
        if (dlProgress) dlProgress.textContent = `${Math.round((p.progress ?? 0) * 100)}%  ${p.text ?? ''}`;
        if ((p.progress ?? 0) >= 1) dlProgress?.classList.add('hidden');
      });
      dlProgress?.classList.add('hidden');

      const messages = [
        { role: 'system' as const, content: CHAT_SYSTEM_PROMPT },
        ...conversation.slice(0, -1).map(t => ({ role: t.role, content: t.content })),
      ];

      let assembled = '';
      try {
        const stream = await engine.chat.completions.create({
          messages,
          max_tokens: 512,
          stream: true,
        });
        for await (const chunk of stream as AsyncIterable<{ choices?: Array<{ delta?: { content?: string } }> }>) {
          const delta = chunk.choices?.[0]?.delta?.content ?? '';
          if (!delta) continue;
          assembled += delta;
          conversation[assistantIdx].content = assembled;
          setBubbleStreaming(assistantIdx, assembled);
        }
      } catch {
        // Streaming not supported — fall back to a single completion
        const reply = await engine.chat.completions.create({ messages, max_tokens: 512 });
        const raw = reply.choices?.[0]?.message?.content ?? '';
        assembled = typeof raw === 'string' ? raw : '';
        conversation[assistantIdx].content = assembled;
      }
      paintConversation();
    } catch (err) {
      conversation[assistantIdx].content = (isEs ? 'Error: ' : 'Error: ') + (err instanceof Error ? err.message : String(err));
      paintConversation();
    } finally {
      busy = false;
      sendBtn.disabled = false;
      sendLabel.textContent = SEND_DEFAULT;
      // The system prompt is intentionally locale-aware via doc lang
      void docLocale;
      void DL_LOADING;
    }
  });
</script>
