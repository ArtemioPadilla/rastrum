---
/**
 * ConsoleWebhooksView — admin-only CRUD over admin_webhooks. Create
 * form (URL + event checkboxes) returns the per-subscription HMAC secret
 * once. The list shows last-delivery status, consecutive-failure count,
 * and a Test button. Recent deliveries (last 20) are shown below.
 */
import { t } from '../i18n/utils';
import ConsoleSlideOver from './ConsoleSlideOver.astro';

interface Props { lang: 'en' | 'es' }
const { lang } = Astro.props;
const tr = t(lang);
const c = tr.console as unknown as Record<string, string>;
const wNs = (tr.console as unknown as Record<string, Record<string, unknown>>).webhooksView as
  unknown as Record<string, Record<string, string> | string>;
const wTitle = (wNs?.title as string) ?? 'Webhooks';
const wDesc  = (wNs?.description as string) ?? '';
const wCreate = (wNs?.create as Record<string, string>) ?? {};
const wEvents = (wNs?.events as Record<string, string>) ?? {};
const wCols   = (wNs?.columns as Record<string, string>) ?? {};
const wActions = (wNs?.actions as Record<string, string>) ?? {};
const wDeliv  = (wNs?.deliveries as Record<string, string>) ?? {};
const wEmpty  = (wNs?.empty as string) ?? 'No webhooks configured.';
const wDelivEmpty = (wNs?.deliveriesEmpty as string) ?? 'No deliveries yet.';
const wDelivPerWebhookHeading = (wDeliv?.perWebhookHeading as string) ?? 'Delivery history';
const wDelivPerWebhookEmpty = (wDeliv?.perWebhookEmpty as string) ?? 'No deliveries for this webhook yet.';
const wDelivFilters = {
  all: (wDeliv?.filterAll as string) ?? 'All',
  success: (wDeliv?.filterSuccess as string) ?? 'Successful',
  failed: (wDeliv?.filterFailed as string) ?? 'Failed',
  pending: (wDeliv?.filterPending as string) ?? 'Pending',
};
const wDelivStatusPending = (wDeliv?.statusPending as string) ?? 'pending';
const wDelivReplayLast = (wDeliv?.replayLast as string) ?? 'Replay last delivery';
const wDelivReplayConfirmReason = (wDeliv?.replayConfirmReason as string) ?? 'Reason for replaying this delivery?';
const wDelivReplayDoneTmpl = (wDeliv?.replayDone as string) ?? 'Replay sent (HTTP {status}).';
const wDelivReplayFailedTmpl = (wDeliv?.replayFailed as string) ?? 'Replay failed: {error}';
const wDelivNonceCopied = (wDeliv?.nonceCopied as string) ?? 'Nonce copied.';
const wDelivLoadFailedTmpl = (wDeliv?.loadFailed as string) ?? 'Could not load deliveries: {error}';
const labelDeliveriesBtn = (wActions?.deliveries as string) ?? 'Deliveries';
const labelHideDeliveriesBtn = (wActions?.hideDeliveries as string) ?? 'Hide deliveries';
const eventKeys: Array<keyof typeof wEvents> = [
  'anomaly_created', 'user_banned', 'user_unbanned', 'role_granted', 'role_revoked',
];
---

<section
  class="max-w-6xl space-y-6"
  data-label-action-test={wActions.test ?? 'Test'}
  data-label-action-enable={wActions.enable ?? 'Enable'}
  data-label-action-disable={wActions.disable ?? 'Disable'}
  data-label-action-delete={wActions.delete ?? 'Delete'}
  data-label-action-deliveries={labelDeliveriesBtn}
  data-label-action-hide-deliveries={labelHideDeliveriesBtn}
  data-label-deliv-heading={wDelivPerWebhookHeading}
  data-label-deliv-empty={wDelivPerWebhookEmpty}
  data-label-deliv-prev={wDeliv?.prev ?? 'Prev'}
  data-label-deliv-next={wDeliv?.next ?? 'Next'}
  data-label-deliv-filter-all={wDelivFilters.all}
  data-label-deliv-filter-success={wDelivFilters.success}
  data-label-deliv-filter-failed={wDelivFilters.failed}
  data-label-deliv-filter-pending={wDelivFilters.pending}
  data-label-deliv-status-pending={wDelivStatusPending}
  data-label-deliv-replay-last={wDelivReplayLast}
  data-label-deliv-replay-confirm={wDelivReplayConfirmReason}
  data-label-deliv-replay-done-tmpl={wDelivReplayDoneTmpl}
  data-label-deliv-replay-failed-tmpl={wDelivReplayFailedTmpl}
  data-label-deliv-nonce-copied={wDelivNonceCopied}
  data-label-deliv-load-failed-tmpl={wDelivLoadFailedTmpl}
  data-label-col-event={wDeliv.event ?? 'Event'}
  data-label-col-status={wDeliv.status ?? 'Status'}
  data-label-col-time={wDeliv.time ?? 'Time'}
  data-label-col-error={wDeliv.error ?? 'Error'}
  data-label-col-nonce="Nonce"
>
  <header>
    <h1 class="text-xl font-semibold mb-1">{wTitle}</h1>
    <p class="text-sm text-zinc-500 dark:text-zinc-400">{wDesc}</p>
  </header>

  <div id="webhooks-not-auth" class="hidden rounded border border-amber-300 dark:border-amber-700/60 bg-amber-50 dark:bg-amber-900/20 p-3 text-sm text-amber-900 dark:text-amber-100">
    {tr.console.not_authorized}
  </div>

  <div id="webhooks-shell" class="hidden space-y-6">
    <!-- Create form -->
    <div class="rounded border border-zinc-200 dark:border-zinc-800 p-4">
      <h2 class="text-sm font-semibold mb-3">{wCreate.heading ?? 'New webhook'}</h2>
      <form id="webhook-create-form" class="space-y-3">
        <label class="block text-sm">
          <span class="block text-xs font-medium text-zinc-700 dark:text-zinc-300 mb-1">{wCreate.url ?? 'URL'}</span>
          <input
            id="webhook-url"
            type="url"
            required
            pattern="https://.*"
            placeholder="https://your-service.example.com/hook"
            class="w-full rounded border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-2 py-1.5 text-sm"
          />
        </label>
        <fieldset class="space-y-1">
          <legend class="text-xs font-medium text-zinc-700 dark:text-zinc-300 mb-1">{wCreate.events ?? 'Events'}</legend>
          {eventKeys.map(k => (
            <label class="flex items-center gap-2 text-xs">
              <input type="checkbox" data-event-key={k} class="rounded" />
              <span>{wEvents[k] ?? k}</span>
            </label>
          ))}
        </fieldset>
        <label class="block text-sm">
          <span class="block text-xs font-medium text-zinc-700 dark:text-zinc-300 mb-1">{tr.console.slideover_reason_label}</span>
          <input
            id="webhook-create-reason"
            type="text"
            minlength="5"
            placeholder={tr.console.slideover_reason_placeholder}
            class="w-full rounded border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-2 py-1.5 text-sm"
          />
        </label>
        <button type="submit" class="px-3 py-1.5 rounded bg-emerald-700 hover:bg-emerald-800 text-white text-sm font-medium">
          {wCreate.submit ?? 'Create webhook'}
        </button>
      </form>
      <div id="webhook-secret-banner" class="hidden mt-3 rounded border border-amber-300 bg-amber-50 dark:border-amber-700/60 dark:bg-amber-900/20 p-2 text-xs text-amber-900 dark:text-amber-100">
        <div class="font-medium mb-1">{wCreate.secretShown ?? 'Secret (shown once):'}</div>
        <code id="webhook-secret-value" class="block break-all bg-white dark:bg-zinc-950 px-2 py-1 rounded text-[11px] font-mono"></code>
      </div>
      <p id="webhook-create-error" class="hidden mt-2 text-sm text-red-600 dark:text-red-400"></p>
    </div>

    <!-- List -->
    <div>
      <h2 class="text-sm font-semibold mb-2">Webhooks</h2>
      <div id="webhooks-loading" class="flex items-center gap-2 text-sm text-zinc-500 italic">
        <svg class="animate-spin h-4 w-4 text-zinc-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <span>{c.loading}</span>
      </div>
      <div id="webhooks-empty" class="hidden rounded border border-dashed border-zinc-200 dark:border-zinc-700 p-6 text-center text-sm text-zinc-500">
        {wEmpty}
      </div>
      <div id="webhooks-rows" class="hidden overflow-x-auto rounded border border-zinc-200 dark:border-zinc-800">
        <table class="min-w-full text-sm">
          <thead class="bg-zinc-50 dark:bg-zinc-900/40 text-left text-xs uppercase tracking-wide text-zinc-500">
            <tr>
              <th class="px-3 py-2">{wCols.url ?? 'URL'}</th>
              <th class="px-3 py-2">{wCols.events ?? 'Events'}</th>
              <th class="px-3 py-2">{wCols.enabled ?? 'Enabled'}</th>
              <th class="px-3 py-2">{wCols.lastDelivery ?? 'Last delivery'}</th>
              <th class="px-3 py-2 text-right">{wCols.consecutiveFailures ?? 'Failures'}</th>
              <th class="px-3 py-2 text-right">{wCols.actions ?? 'Actions'}</th>
            </tr>
          </thead>
          <tbody id="webhooks-tbody" class="divide-y divide-zinc-100 dark:divide-zinc-800"></tbody>
        </table>
      </div>
    </div>

    <!-- Deliveries -->
    <div>
      <h2 class="text-sm font-semibold mb-2">{wDeliv.heading ?? 'Recent deliveries'}</h2>
      <div id="deliveries-empty" class="hidden rounded border border-dashed border-zinc-200 dark:border-zinc-700 p-4 text-center text-xs text-zinc-500">
        {wDelivEmpty}
      </div>
      <div id="deliveries-rows" class="hidden overflow-x-auto rounded border border-zinc-200 dark:border-zinc-800">
        <table class="min-w-full text-xs">
          <thead class="bg-zinc-50 dark:bg-zinc-900/40 text-left uppercase tracking-wide text-zinc-500">
            <tr>
              <th class="px-3 py-2">{wDeliv.event ?? 'Event'}</th>
              <th class="px-3 py-2">{wDeliv.status ?? 'Status'}</th>
              <th class="px-3 py-2">{wDeliv.time ?? 'Time'}</th>
              <th class="px-3 py-2">{wDeliv.error ?? 'Error'}</th>
            </tr>
          </thead>
          <tbody id="deliveries-tbody" class="divide-y divide-zinc-100 dark:divide-zinc-800"></tbody>
        </table>
      </div>
    </div>

    <p id="webhooks-error" class="hidden text-sm text-red-600 dark:text-red-400"></p>
  </div>
</section>

<ConsoleSlideOver
  lang={lang}
  id="console-slideover-webhook-action"
  titleKey="Webhook action"
/>

<script>
  import { getSupabase } from '../lib/supabase';
  import { getUserRoles } from '../lib/user-roles';
  import { adminClient, AdminClientError } from '../lib/admin-client';

  type WebhookRow = {
    id: string;
    url: string;
    events: string[];
    enabled: boolean;
    last_delivery_at: string | null;
    last_delivery_status: number | null;
    consecutive_failures: number;
    created_at: string;
  };

  type DeliveryRow = {
    id: string;
    webhook_id: string;
    event: string;
    status_code: number | null;
    error: string | null;
    attempted_at: string;
    nonce?: string | null;
  };

  const sectionEl = document.querySelector<HTMLElement>('section[data-label-action-test]');
  const labelTest = sectionEl?.dataset.labelActionTest ?? 'Test';
  const labelEnable = sectionEl?.dataset.labelActionEnable ?? 'Enable';
  const labelDisable = sectionEl?.dataset.labelActionDisable ?? 'Disable';
  const labelDelete = sectionEl?.dataset.labelActionDelete ?? 'Delete';
  const labelDeliveries = sectionEl?.dataset.labelActionDeliveries ?? 'Deliveries';
  const labelHideDeliveries = sectionEl?.dataset.labelActionHideDeliveries ?? 'Hide deliveries';
  const labelDelivHeading = sectionEl?.dataset.labelDelivHeading ?? 'Delivery history';
  const labelDelivEmpty = sectionEl?.dataset.labelDelivEmpty ?? 'No deliveries for this webhook yet.';
  const labelDelivPrev = sectionEl?.dataset.labelDelivPrev ?? 'Prev';
  const labelDelivNext = sectionEl?.dataset.labelDelivNext ?? 'Next';
  const labelDelivFilterAll = sectionEl?.dataset.labelDelivFilterAll ?? 'All';
  const labelDelivFilterSuccess = sectionEl?.dataset.labelDelivFilterSuccess ?? 'Successful';
  const labelDelivFilterFailed = sectionEl?.dataset.labelDelivFilterFailed ?? 'Failed';
  const labelDelivFilterPending = sectionEl?.dataset.labelDelivFilterPending ?? 'Pending';
  const labelDelivStatusPending = sectionEl?.dataset.labelDelivStatusPending ?? 'pending';
  const labelDelivReplayLast = sectionEl?.dataset.labelDelivReplayLast ?? 'Replay last delivery';
  const labelDelivReplayConfirm = sectionEl?.dataset.labelDelivReplayConfirm ?? 'Reason for replaying this delivery?';
  const labelDelivReplayDoneTmpl = sectionEl?.dataset.labelDelivReplayDoneTmpl ?? 'Replay sent (HTTP {status}).';
  const labelDelivReplayFailedTmpl = sectionEl?.dataset.labelDelivReplayFailedTmpl ?? 'Replay failed: {error}';
  const labelDelivNonceCopied = sectionEl?.dataset.labelDelivNonceCopied ?? 'Nonce copied.';
  const labelDelivLoadFailedTmpl = sectionEl?.dataset.labelDelivLoadFailedTmpl ?? 'Could not load deliveries: {error}';
  const labelColEvent = sectionEl?.dataset.labelColEvent ?? 'Event';
  const labelColStatus = sectionEl?.dataset.labelColStatus ?? 'Status';
  const labelColTime = sectionEl?.dataset.labelColTime ?? 'Time';
  const labelColError = sectionEl?.dataset.labelColError ?? 'Error';
  const labelColNonce = sectionEl?.dataset.labelColNonce ?? 'Nonce';

  let allWebhooks: WebhookRow[] = [];
  let allDeliveries: DeliveryRow[] = [];
  let jwt: string | null = null;
  let reconcileInFlight = false;

  const DRILLDOWN_PAGE_SIZE = 50;

  type DrillState = { perWebhookRows: DeliveryRow[]; filter: 'all' | 'success' | 'failed' | 'pending'; page: number; totalCount: number };
  const drilldown = new Map<string, DrillState>();
  const expanded = new Set<string>();

  function show(id: string) { document.getElementById(id)?.classList.remove('hidden'); }
  function hide(id: string) { document.getElementById(id)?.classList.add('hidden'); }
  function esc(s: string): string {
    return s.replace(/[<>&'"]/g, ch => ({'<':'&lt;','>':'&gt;','&':'&amp;',"'":'&#39;','"':'&quot;'}[ch]!));
  }

  function fmtDate(iso: string | null): string {
    if (!iso) return '—';
    return new Date(iso).toISOString().replace('T', ' ').slice(0, 16);
  }

  function statusPill(code: number | null): string {
    if (code === null) return `<span class="inline-flex items-center rounded px-1.5 py-0.5 text-[10px] bg-zinc-200 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400">${esc(labelDelivStatusPending)}</span>`;
    let cls: string;
    if (code >= 200 && code < 300) {
      cls = 'bg-emerald-100 dark:bg-emerald-900/30 text-emerald-800 dark:text-emerald-300';
    } else if (code >= 400 && code < 500) {
      cls = 'bg-amber-100 dark:bg-amber-900/30 text-amber-800 dark:text-amber-300';
    } else {
      cls = 'bg-red-100 dark:bg-red-900/30 text-red-800 dark:text-red-300';
    }
    return `<span class="inline-flex items-center rounded px-1.5 py-0.5 text-[10px] font-mono ${cls}">${code}</span>`;
  }

  function deliveryMatchesFilter(d: DeliveryRow, f: DrillState['filter']): boolean {
    if (f === 'all') return true;
    if (f === 'pending') return d.status_code === null;
    if (f === 'success') return d.status_code !== null && d.status_code >= 200 && d.status_code < 300;
    if (f === 'failed') return d.status_code !== null && (d.status_code < 200 || d.status_code >= 300);
    return true;
  }

  function renderDrilldown(webhookId: string): string {
    const state = drilldown.get(webhookId);
    if (!state) {
      return `<tr id="drilldown-${esc(webhookId)}"><td colspan="6" class="px-3 py-3 bg-zinc-50/60 dark:bg-zinc-900/40 text-xs text-zinc-500 italic">Loading deliveries…</td></tr>`;
    }
    const filtered = state.perWebhookRows.filter(d => deliveryMatchesFilter(d, state.filter));
    const hasReplayable = state.perWebhookRows.length > 0;

    const totalPages = Math.max(1, Math.ceil(state.totalCount / DRILLDOWN_PAGE_SIZE));
    const rangeStart = state.page * DRILLDOWN_PAGE_SIZE + 1;
    const rangeEnd = Math.min((state.page + 1) * DRILLDOWN_PAGE_SIZE, state.totalCount);
    const pageInfo = state.totalCount > 0
      ? `${rangeStart}–${rangeEnd} of ${state.totalCount}`
      : '';

    const filterButton = (key: DrillState['filter'], label: string) => {
      const active = state.filter === key;
      return `<button type="button" data-deliv-filter="${esc(webhookId)}" data-deliv-filter-key="${key}" aria-pressed="${active ? 'true' : 'false'}" class="px-2.5 py-1 text-[11px] ${active ? 'bg-zinc-900 dark:bg-zinc-100 text-white dark:text-zinc-900 font-medium' : 'bg-white dark:bg-zinc-900 text-zinc-700 dark:text-zinc-300'}">${esc(label)}</button>`;
    };

    const tableBody = filtered.length === 0
      ? `<tr><td colspan="5" class="px-3 py-4 text-center text-xs text-zinc-500 italic">${esc(labelDelivEmpty)}</td></tr>`
      : filtered.map(d => {
          const noncePart = d.nonce ? d.nonce.slice(0, 10) + '…' : '—';
          return `
            <tr>
              <td class="px-3 py-2 font-mono text-[11px]">${esc(d.event)}</td>
              <td class="px-3 py-2">${statusPill(d.status_code)}</td>
              <td class="px-3 py-2 text-zinc-500 text-[11px]">${esc(fmtDate(d.attempted_at))}</td>
              <td class="px-3 py-2 text-zinc-500 text-[11px] font-mono">
                ${d.nonce
                  ? `<button type="button" data-copy-nonce="${esc(d.nonce)}" title="${esc(d.nonce)}" class="hover:underline">${esc(noncePart)}</button>`
                  : '—'}
              </td>
              <td class="px-3 py-2 text-zinc-500 text-[11px] max-w-[260px] truncate" title="${esc(d.error ?? '')}">${esc(d.error ?? '')}</td>
            </tr>
          `;
        }).join('');

    const pagerHtml = totalPages > 1
      ? `<div class="flex items-center justify-between mt-2">
           <button type="button" data-deliv-prev="${esc(webhookId)}" class="px-2.5 py-1 rounded border border-zinc-300 dark:border-zinc-700 text-[11px] hover:bg-zinc-50 dark:hover:bg-zinc-800 disabled:opacity-50" ${state.page === 0 ? 'disabled' : ''}>${esc(labelDelivPrev)}</button>
           <span class="text-[11px] text-zinc-500">${esc(pageInfo)}</span>
           <button type="button" data-deliv-next="${esc(webhookId)}" class="px-2.5 py-1 rounded border border-zinc-300 dark:border-zinc-700 text-[11px] hover:bg-zinc-50 dark:hover:bg-zinc-800 disabled:opacity-50" ${state.page >= totalPages - 1 ? 'disabled' : ''}>${esc(labelDelivNext)}</button>
         </div>`
      : (pageInfo ? `<div class="mt-2 text-[11px] text-zinc-500 text-center">${esc(pageInfo)}</div>` : '');

    return `
      <tr id="drilldown-${esc(webhookId)}">
        <td colspan="6" class="px-3 py-3 bg-zinc-50/60 dark:bg-zinc-900/40">
          <div class="flex flex-wrap items-center justify-between gap-2 mb-2">
            <p class="text-xs font-semibold text-zinc-700 dark:text-zinc-300">${esc(labelDelivHeading)}</p>
            <div class="flex flex-wrap items-center gap-2">
              <div class="flex rounded border border-zinc-300 dark:border-zinc-700 overflow-hidden">
                ${filterButton('all', labelDelivFilterAll)}
                ${filterButton('success', labelDelivFilterSuccess)}
                ${filterButton('failed', labelDelivFilterFailed)}
                ${filterButton('pending', labelDelivFilterPending)}
              </div>
              <button type="button" data-replay-last="${esc(webhookId)}" class="px-2.5 py-1 rounded border border-emerald-500 text-[11px] text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20 disabled:opacity-50" ${hasReplayable ? '' : 'disabled'}>${esc(labelDelivReplayLast)}</button>
            </div>
          </div>
          <div class="overflow-x-auto rounded border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-950">
            <table class="min-w-full text-xs">
              <thead class="bg-zinc-50 dark:bg-zinc-900/40 text-left uppercase tracking-wide text-zinc-500">
                <tr>
                  <th class="px-3 py-2">${esc(labelColEvent)}</th>
                  <th class="px-3 py-2">${esc(labelColStatus)}</th>
                  <th class="px-3 py-2">${esc(labelColTime)}</th>
                  <th class="px-3 py-2">${esc(labelColNonce)}</th>
                  <th class="px-3 py-2">${esc(labelColError)}</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-zinc-100 dark:divide-zinc-800">${tableBody}</tbody>
            </table>
          </div>
          ${pagerHtml}
        </td>
      </tr>
    `;
  }

  function renderWebhooks() {
    const tbody = document.getElementById('webhooks-tbody');
    const empty = document.getElementById('webhooks-empty');
    const wrap = document.getElementById('webhooks-rows');
    if (!tbody || !empty || !wrap) return;
    if (allWebhooks.length === 0) {
      empty.classList.remove('hidden');
      wrap.classList.add('hidden');
      return;
    }
    empty.classList.add('hidden');
    wrap.classList.remove('hidden');

    tbody.innerHTML = allWebhooks.map(w => {
      const eventsTxt = w.events.join(', ');
      const enabledPill = w.enabled
        ? '<span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] bg-emerald-100 dark:bg-emerald-900/30 text-emerald-800 dark:text-emerald-300">on</span>'
        : '<span class="inline-flex items-center rounded-full px-2 py-0.5 text-[11px] bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400">off</span>';
      const isExpanded = expanded.has(w.id);
      const deliveriesLabel = isExpanded ? labelHideDeliveries : labelDeliveries;
      const mainRow = `
        <tr>
          <td class="px-3 py-2 font-mono text-xs break-all max-w-[260px]">${esc(w.url)}</td>
          <td class="px-3 py-2 text-xs text-zinc-500">${esc(eventsTxt)}</td>
          <td class="px-3 py-2">${enabledPill} ${statusPill(w.last_delivery_status)}</td>
          <td class="px-3 py-2 text-xs text-zinc-500">${esc(fmtDate(w.last_delivery_at))}</td>
          <td class="px-3 py-2 text-right tabular-nums text-zinc-700 dark:text-zinc-300">${w.consecutive_failures}</td>
          <td class="px-3 py-2 text-right whitespace-nowrap">
            <button data-test-id="${esc(w.id)}" class="px-2 py-1 rounded border border-zinc-300 dark:border-zinc-700 text-xs hover:bg-zinc-50 dark:hover:bg-zinc-800 mr-1">${esc(labelTest)}</button>
            <button data-toggle-id="${esc(w.id)}" data-toggle-to="${w.enabled ? 'false' : 'true'}" class="px-2 py-1 rounded border border-zinc-300 dark:border-zinc-700 text-xs hover:bg-zinc-50 dark:hover:bg-zinc-800 mr-1">${esc(w.enabled ? labelDisable : labelEnable)}</button>
            <button data-deliveries-id="${esc(w.id)}" aria-expanded="${isExpanded ? 'true' : 'false'}" class="px-2 py-1 rounded border border-zinc-300 dark:border-zinc-700 text-xs hover:bg-zinc-50 dark:hover:bg-zinc-800 mr-1 ${isExpanded ? 'bg-zinc-100 dark:bg-zinc-800' : ''}">${esc(deliveriesLabel)}</button>
            <button data-delete-id="${esc(w.id)}" class="px-2 py-1 rounded border border-red-500 text-xs text-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">${esc(labelDelete)}</button>
          </td>
        </tr>
      `;
      const drillRow = isExpanded ? renderDrilldown(w.id) : '';
      return mainRow + drillRow;
    }).join('');
  }

  async function loadDrilldown(webhookId: string, page = 0) {
    const supabase = getSupabase();
    const offset = page * DRILLDOWN_PAGE_SIZE;
    const { data, count, error } = await supabase
      .from('admin_webhook_deliveries')
      .select('id, webhook_id, event, status_code, error, attempted_at, nonce', { count: 'exact' })
      .eq('webhook_id', webhookId)
      .order('attempted_at', { ascending: false })
      .range(offset, offset + DRILLDOWN_PAGE_SIZE - 1);
    if (error) throw new Error(error.message);
    const rows = ((data ?? []) as unknown) as DeliveryRow[];
    const existing = drilldown.get(webhookId);
    drilldown.set(webhookId, {
      perWebhookRows: rows,
      filter: existing?.filter ?? 'all',
      page,
      totalCount: count ?? 0,
    });
  }

  function showActionToast(msg: string, ok = true) {
    const eEl = document.getElementById('webhooks-error');
    if (!eEl) return;
    eEl.textContent = msg;
    eEl.classList.remove('hidden');
    eEl.classList.toggle('text-emerald-700', ok);
    eEl.classList.toggle('dark:text-emerald-400', ok);
    eEl.classList.toggle('text-red-600', !ok);
    eEl.classList.toggle('dark:text-red-400', !ok);
    setTimeout(() => eEl.classList.add('hidden'), 4000);
  }

  function renderDeliveries() {
    const tbody = document.getElementById('deliveries-tbody');
    const empty = document.getElementById('deliveries-empty');
    const wrap = document.getElementById('deliveries-rows');
    if (!tbody || !empty || !wrap) return;
    if (allDeliveries.length === 0) {
      empty.classList.remove('hidden');
      wrap.classList.add('hidden');
      return;
    }
    empty.classList.add('hidden');
    wrap.classList.remove('hidden');

    tbody.innerHTML = allDeliveries.map(d => `
      <tr>
        <td class="px-3 py-2 font-mono">${esc(d.event)}</td>
        <td class="px-3 py-2">${statusPill(d.status_code)}</td>
        <td class="px-3 py-2 text-zinc-500">${esc(fmtDate(d.attempted_at))}</td>
        <td class="px-3 py-2 text-zinc-500 max-w-[300px] truncate" title="${esc(d.error ?? '')}">${esc(d.error ?? '')}</td>
      </tr>
    `).join('');
  }

  async function loadAll() {
    const supabase = getSupabase();
    const [wh, dl] = await Promise.all([
      supabase.from('admin_webhooks').select('*').order('created_at', { ascending: false }),
      supabase.from('admin_webhook_deliveries').select('*').order('attempted_at', { ascending: false }).limit(20),
    ]);
    if (wh.error) throw new Error(wh.error.message);
    if (dl.error) throw new Error(dl.error.message);
    allWebhooks   = (wh.data ?? []) as WebhookRow[];
    allDeliveries = (dl.data ?? []) as DeliveryRow[];
    renderWebhooks();
    renderDeliveries();
  }

  async function init() {
    let supabase;
    try { supabase = getSupabase(); } catch { show('webhooks-not-auth'); return; }
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { show('webhooks-not-auth'); return; }
    const myRoles = await getUserRoles(session.user.id);
    if (!myRoles.has('admin')) { show('webhooks-not-auth'); return; }
    jwt = session.access_token;
    show('webhooks-shell');
    try {
      await loadAll();
    } catch (err) {
      const e = document.getElementById('webhooks-error');
      if (e) { e.textContent = (err as Error).message; e.classList.remove('hidden'); }
    } finally {
      hide('webhooks-loading');
    }
  }

  document.getElementById('webhook-create-form')?.addEventListener('submit', async (ev) => {
    ev.preventDefault();
    if (!jwt) return;
    const urlEl = document.getElementById('webhook-url') as HTMLInputElement;
    const reasonEl = document.getElementById('webhook-create-reason') as HTMLInputElement;
    const events: string[] = [];
    document.querySelectorAll<HTMLInputElement>('[data-event-key]').forEach(cb => {
      if (cb.checked) events.push(cb.dataset.eventKey!);
    });
    const errEl = document.getElementById('webhook-create-error');
    if (events.length === 0) {
      if (errEl) { errEl.textContent = 'Select at least one event.'; errEl.classList.remove('hidden'); }
      return;
    }
    if (reasonEl.value.trim().length < 5) {
      if (errEl) { errEl.textContent = 'Reason must be at least 5 characters.'; errEl.classList.remove('hidden'); }
      return;
    }
    if (errEl) errEl.classList.add('hidden');
    try {
      const res = await adminClient.webhook.create(
        { url: urlEl.value, events: events as Parameters<typeof adminClient.webhook.create>[0]['events'] },
        reasonEl.value.trim(),
        jwt,
      );
      const banner = document.getElementById('webhook-secret-banner');
      const code = document.getElementById('webhook-secret-value');
      if (banner && code && res.result) {
        code.textContent = res.result.secret;
        banner.classList.remove('hidden');
      }
      urlEl.value = '';
      document.querySelectorAll<HTMLInputElement>('[data-event-key]').forEach(cb => { cb.checked = false; });
      reasonEl.value = '';
      await loadAll();
    } catch (err) {
      if (errEl) {
        errEl.textContent = err instanceof AdminClientError ? err.message : (err as Error).message;
        errEl.classList.remove('hidden');
      }
    }
  });

  document.getElementById('webhooks-tbody')?.addEventListener('click', async (ev) => {
    if (!jwt) return;
    const target = ev.target as HTMLElement;
    const testId = target.closest<HTMLElement>('[data-test-id]')?.dataset.testId;
    const toggleEl = target.closest<HTMLElement>('[data-toggle-id]');
    const deleteId = target.closest<HTMLElement>('[data-delete-id]')?.dataset.deleteId;
    const deliveriesId = target.closest<HTMLElement>('[data-deliveries-id]')?.dataset.deliveriesId;
    const filterEl = target.closest<HTMLElement>('[data-deliv-filter]');
    const replayLastId = target.closest<HTMLElement>('[data-replay-last]')?.dataset.replayLast;
    const copyNonce = target.closest<HTMLElement>('[data-copy-nonce]')?.dataset.copyNonce;

    try {
      if (testId) {
        if (reconcileInFlight) return;
        reconcileInFlight = true;
        try {
          const res = await adminClient.webhook.test({ webhookId: testId }, 'manual webhook test', jwt);
          const code = res.result?.statusCode;
          alert(code ? `Test delivery: HTTP ${code}` : `Test delivery failed: ${res.result?.error ?? 'unknown'}`);
          await loadAll();
        } finally { reconcileInFlight = false; }
        return;
      }
      if (toggleEl) {
        if (reconcileInFlight) return;
        const id = toggleEl.dataset.toggleId!;
        const enabled = toggleEl.dataset.toggleTo === 'true';
        const reason = prompt(`Reason for ${enabled ? 'enabling' : 'disabling'} this webhook?`);
        if (!reason || reason.length < 5) return;
        reconcileInFlight = true;
        try {
          await adminClient.webhook.update({ webhookId: id, enabled }, reason, jwt);
          await loadAll();
        } finally { reconcileInFlight = false; }
        return;
      }
      if (deleteId) {
        if (reconcileInFlight) return;
        if (!confirm('Delete this webhook? This cannot be undone.')) return;
        const reason = prompt('Reason for deletion?');
        if (!reason || reason.length < 5) return;
        reconcileInFlight = true;
        try {
          await adminClient.webhook.delete({ webhookId: deleteId }, reason, jwt);
          await loadAll();
        } finally { reconcileInFlight = false; }
        return;
      }
      if (deliveriesId) {
        if (expanded.has(deliveriesId)) {
          expanded.delete(deliveriesId);
          drilldown.delete(deliveriesId);
          renderWebhooks();
        } else {
          expanded.add(deliveriesId);
          renderWebhooks();
          try {
            await loadDrilldown(deliveriesId);
            renderWebhooks();
          } catch (err) {
            showActionToast(labelDelivLoadFailedTmpl.replace('{error}', (err as Error).message), false);
            expanded.delete(deliveriesId);
            renderWebhooks();
          }
        }
        return;
      }
      if (filterEl) {
        const id = filterEl.dataset.delivFilter!;
        const key = filterEl.dataset.delivFilterKey as ('all' | 'success' | 'failed' | 'pending');
        const state = drilldown.get(id);
        if (state) {
          state.filter = key;
          renderWebhooks();
        }
        return;
      }
      const prevPageEl = target.closest<HTMLElement>('[data-deliv-prev]');
      if (prevPageEl) {
        const id = prevPageEl.dataset.delivPrev!;
        const state = drilldown.get(id);
        if (state && state.page > 0) {
          try {
            await loadDrilldown(id, state.page - 1);
            renderWebhooks();
          } catch (err) {
            showActionToast(labelDelivLoadFailedTmpl.replace('{error}', (err as Error).message), false);
          }
        }
        return;
      }
      const nextPageEl = target.closest<HTMLElement>('[data-deliv-next]');
      if (nextPageEl) {
        const id = nextPageEl.dataset.delivNext!;
        const state = drilldown.get(id);
        if (state) {
          const totalPages = Math.ceil(state.totalCount / DRILLDOWN_PAGE_SIZE);
          if (state.page < totalPages - 1) {
            try {
              await loadDrilldown(id, state.page + 1);
              renderWebhooks();
            } catch (err) {
              showActionToast(labelDelivLoadFailedTmpl.replace('{error}', (err as Error).message), false);
            }
          }
        }
        return;
      }
      if (replayLastId) {
        if (reconcileInFlight) return;
        const state = drilldown.get(replayLastId);
        const last = state?.perWebhookRows[0];
        if (!last) return;
        const reason = prompt(labelDelivReplayConfirm);
        if (!reason || reason.length < 5) return;
        reconcileInFlight = true;
        try {
          const res = await adminClient.webhook.replayDelivery({ deliveryId: last.id }, reason, jwt);
          const code = res.result?.statusCode;
          if (code !== null && code !== undefined) {
            showActionToast(labelDelivReplayDoneTmpl.replace('{status}', String(code)), true);
          } else {
            showActionToast(labelDelivReplayFailedTmpl.replace('{error}', res.result?.error ?? 'unknown'), false);
          }
          await loadDrilldown(replayLastId);
          await loadAll();
          renderWebhooks();
        } catch (err) {
          const msg = err instanceof AdminClientError ? err.message : (err as Error).message;
          showActionToast(labelDelivReplayFailedTmpl.replace('{error}', msg), false);
        } finally { reconcileInFlight = false; }
        return;
      }
      if (copyNonce) {
        try {
          await navigator.clipboard.writeText(copyNonce);
          showActionToast(labelDelivNonceCopied, true);
        } catch {
          // Clipboard API gates on https/secure context — fall back silently.
        }
        return;
      }
    } catch (err) {
      const e = document.getElementById('webhooks-error');
      if (e) {
        e.textContent = err instanceof AdminClientError ? err.message : (err as Error).message;
        e.classList.remove('hidden');
      }
    }
  });

  init().catch(() => { show('webhooks-not-auth'); });
</script>
