---
import ObservationForm from './ObservationForm.astro';

interface Props { lang: 'en' | 'es' }
const { lang } = Astro.props;
---

<!--
  /identify and /identificar render the same surface as /observe, but in
  identify-only mode: photo + identification is the entire frame; GPS,
  habitat, evidence, notes are hidden behind a "Save as observation"
  reveal. See ObservationForm.astro for the mode-prop contract.
-->
<ObservationForm lang={lang} mode="identify-only" />
