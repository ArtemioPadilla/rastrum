---
import { t } from '../i18n/utils';
import { FEATURE_FLAGS } from '../lib/feature-flags';

interface Props { lang: 'en' | 'es' }
const { lang } = Astro.props;
const tr = t(lang);

const categoryOrder = ['identification', 'pwa', 'social', 'admin', 'media'] as const;
const grouped = categoryOrder.map(cat => ({
  cat,
  flags: FEATURE_FLAGS.filter(f => f.category === cat),
})).filter(g => g.flags.length > 0);
---

<section class="max-w-4xl">
  <p class="mb-4 text-sm text-zinc-600 dark:text-zinc-400">{tr.console.features_intro}</p>

  <div id="features-not-auth" class="hidden rounded border border-amber-300 dark:border-amber-700/60 bg-amber-50 dark:bg-amber-900/20 p-3 text-sm text-amber-900 dark:text-amber-100">
    {tr.console.not_authorized}
  </div>

  <div id="features-shell" class="hidden space-y-6">
    <div class="rounded-lg border border-amber-200 dark:border-amber-700/60 bg-amber-50 dark:bg-amber-900/20 p-3 text-xs text-amber-800 dark:text-amber-200">
      {tr.console.features_static_notice}
    </div>

    {grouped.map(({ cat, flags }) => (
      <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 overflow-hidden">
        <div class="bg-zinc-50 dark:bg-zinc-900/60 px-4 py-2 border-b border-zinc-200 dark:border-zinc-800">
          <h2 class="text-xs font-semibold uppercase tracking-wide text-zinc-500 capitalize">{cat}</h2>
        </div>
        <div class="divide-y divide-zinc-100 dark:divide-zinc-800">
          {flags.map(flag => (
            <div class="flex items-start gap-4 px-4 py-3">
              <div class="flex-1 min-w-0">
                <div class="flex items-center gap-2">
                  <span class="font-medium text-sm text-zinc-900 dark:text-zinc-100">{flag.name}</span>
                  <code class="text-[10px] rounded bg-zinc-100 dark:bg-zinc-800 text-zinc-500 px-1.5 py-0.5">{flag.key}</code>
                </div>
                <p class="text-xs text-zinc-500 mt-0.5">{flag.description}</p>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <span class:list={[
                  'inline-flex items-center px-2.5 py-1 rounded-full text-xs font-semibold',
                  flag.value
                    ? 'bg-emerald-100 dark:bg-emerald-900/40 text-emerald-800 dark:text-emerald-300'
                    : 'bg-zinc-100 dark:bg-zinc-800 text-zinc-500',
                ]}>
                  {flag.value ? tr.console.features_on : tr.console.features_off}
                </span>
                <button
                  disabled
                  title={tr.console.features_toggle_coming}
                  class="opacity-40 cursor-not-allowed inline-flex items-center px-2.5 py-1 rounded border border-zinc-300 dark:border-zinc-700 text-xs text-zinc-600 dark:text-zinc-400"
                >
                  {tr.console.features_toggle_btn}
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  import { getSupabase } from '../lib/supabase';
  import { getUserRoles } from '../lib/user-roles';

  function show(id: string) { document.getElementById(id)?.classList.remove('hidden'); }

  async function init() {
    const supabase = getSupabase();
    const { data: { session } } = await supabase.auth.getSession();
    if (!session?.user) { show('features-not-auth'); return; }
    const myRoles = await getUserRoles(session.user.id);
    if (!myRoles.has('admin')) { show('features-not-auth'); return; }
    show('features-shell');
  }

  init().catch(() => show('features-not-auth'));
</script>
