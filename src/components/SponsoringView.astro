  async function refreshCreds() {
    const credsList = document.getElementById('creds-list');
    const credsSection = document.getElementById('creds-section');
    if (!credsList || !credsSection) return;
    let creds: Awaited<ReturnType<typeof listCredentials>> = [];
    try { creds = await listCredentials(); } catch { /* not authed or fn unavailable */ }
    credsList.innerHTML = '';
    if (creds.length === 0) {
      const emptyMsg = (credsSection as HTMLElement).dataset.emptyMsg ?? '';
      credsList.innerHTML = `<li class="py-3 text-sm text-zinc-500">${escHtml(emptyMsg)}</li>`;
      return;
    }
    for (const c of creds) {
      const li = document.createElement('li');
      li.className = 'py-3 flex items-center justify-between';
