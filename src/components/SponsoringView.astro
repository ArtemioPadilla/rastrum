      li.innerHTML = `
        <div>
          <div class="font-medium">${escHtml(c.label)} <span class="text-xs text-zinc-500">${escHtml(c.kind)} · ${escHtml(c.preferred_model ?? "")}</span></div>
          <div class="text-xs text-zinc-500">${escHtml(validated)}</div>
        </div>
        <div class="flex gap-2 items-center">
          <button data-test="${escHtml(c.id)}" class="text-xs px-2 py-1 rounded border border-emerald-600 text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/30">Test</button>
          <button data-rotate="${escHtml(c.id)}" class="text-xs px-2 py-1 rounded border border-zinc-300 dark:border-zinc-700 text-zinc-600 dark:text-zinc-400 hover:bg-zinc-50 dark:hover:bg-zinc-800">Rotate</button>
          <button data-delete="${escHtml(c.id)}" class="text-xs px-2 py-1 rounded border border-red-300 dark:border-red-800 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">Delete</button>
        </div>`;
      credsList.appendChild(li);
    }
  }

  const addCredDialog = document.getElementById('add-cred-dialog') as HTMLDialogElement | null;
  document.getElementById('add-cred-btn')?.addEventListener('click', () => {
    // Reset form on open so stale state from previous opens doesn't linger
    const modelInput = document.getElementById('cred-model-input') as HTMLInputElement | null;
    if (modelInput) modelInput.value = '';
    const kindSel = document.getElementById('cred-kind-select') as HTMLSelectElement | null;
    if (kindSel) { kindSel.value = 'api_key'; delete kindSel.dataset.touched; }
    const preview = document.getElementById('cred-kind-preview');
    if (preview) preview.textContent = '';
    const errEl = document.getElementById('cred-submit-error');
    if (errEl) errEl.classList.add('hidden');
    const testRes = document.getElementById('cred-test-result');
    if (testRes) { testRes.textContent = ''; testRes.classList.add('hidden'); }
    syncModelPlaceholder(); // sets correct placeholder for api_key (Anthropic default)
    syncEndpointRow();
    addCredDialog?.showModal();
  });
  document.getElementById('cred-cancel')?.addEventListener('click', () => addCredDialog?.close());

  // Test button — probe the secret WITHOUT saving. Calls the new
  // /credentials/validate endpoint which runs a minimal liveness ping
  // against the provider (Anthropic / OpenAI / Gemini); Bedrock /
  // Azure / Vertex return `test_not_supported_for_provider` and we
  // surface that as an amber hint.
  document.getElementById('cred-test')?.addEventListener('click', async () => {
    const secret = (document.getElementById('cred-secret-input') as HTMLInputElement).value.trim();
    const kindSel = document.getElementById('cred-kind-select') as HTMLSelectElement | null;
    const kind = (kindSel?.value ?? 'api_key') as
      'api_key'|'oauth_token'|'bedrock'|'openai_api_key'|'azure_openai'|'gemini_api_key'|'vertex_ai';
    const modelInput = document.getElementById('cred-model-input') as HTMLInputElement | null;
    const modelDefaults = JSON.parse(modelInput?.dataset.defaults ?? '{}') as Record<string, string>;
    const preferred_model = modelInput?.value.trim() || modelDefaults[kind] || 'claude-haiku-4-5';
    const errEl  = document.getElementById('cred-submit-error');
    const resEl  = document.getElementById('cred-test-result');
    const testBtn = document.getElementById('cred-test') as HTMLButtonElement | null;
    if (errEl) errEl.classList.add('hidden');
    if (!secret) {
      if (resEl) {
        resEl.textContent = tr.test_paste_first;
        resEl.className = 'text-xs text-amber-600 dark:text-amber-400';
      }
      return;
    }
    const originalText = testBtn?.textContent ?? '';
    if (testBtn) { testBtn.disabled = true; testBtn.textContent = tr.testing; }
    if (resEl) { resEl.textContent = ''; resEl.classList.add('hidden'); }
    try {
      const { validateUnsavedCredential } = await import('../lib/sponsorships');
      const r = await validateUnsavedCredential({ secret, kind, preferred_model });
      if (resEl) {
        resEl.classList.remove('hidden');
        if (r.error === 'test_not_supported_for_provider') {
          resEl.textContent = `⚠ ${tr.test_not_supported}`;
          resEl.className = 'text-xs text-amber-600 dark:text-amber-400';
        } else if (r.ok) {
          resEl.textContent = `✓ ${tr.test_success_tmpl.replace('{ms}', String(r.latency_ms))}`;
          resEl.className = 'text-xs text-emerald-700 dark:text-emerald-400';
        } else {
          resEl.textContent = `✗ ${tr.test_failed_tmpl.replace('{error}', r.error ?? 'unknown')}`;
          resEl.className = 'text-xs text-red-600 dark:text-red-400';
        }
      }
    } catch (e) {
      if (resEl) {
        resEl.classList.remove('hidden');
        resEl.textContent = `✗ ${(e as Error).message}`;
        resEl.className = 'text-xs text-red-600 dark:text-red-400';
      }
    } finally {
      if (testBtn) { testBtn.disabled = false; testBtn.textContent = originalText; }
    }
  });
  // M32 (#152): auto-detect kind from secret prefix; fall back to
  // user-selected dropdown for Bedrock / Azure / Vertex (JSON envelopes
  // share no prefix). The endpoint row only shows for kinds that need it.
  function syncEndpointRow() {
    const kindSel = document.getElementById('cred-kind-select') as HTMLSelectElement | null;
    const row     = document.getElementById('cred-endpoint-row');
    const help    = document.getElementById('cred-endpoint-help');
    const endpointKinds: Record<string, string> = {
      azure_openai: 'Full deployment URL (e.g. https://<resource>.openai.azure.com/openai/deployments/<dep>/chat/completions?api-version=2024-02-01)',
      bedrock:      'Optional region override (defaults to us-east-1 or the JSON envelope value)',
      vertex_ai:    'GCP region (defaults to us-central1)',
    };
    const kind = kindSel?.value ?? 'api_key';
    if (kind in endpointKinds) {
      row?.classList.remove('hidden');
      if (help) help.textContent = endpointKinds[kind];
    } else {
      row?.classList.add('hidden');
    }
  }
  document.getElementById('cred-kind-select')?.addEventListener('change', syncEndpointRow);
  syncEndpointRow();

  const MODEL_DOCS: Record<string, string> = {
    api_key:        'https://docs.anthropic.com/en/docs/about-claude/models/overview',
    oauth_token:    'https://docs.anthropic.com/en/docs/about-claude/models/overview',
    bedrock:        'https://docs.aws.amazon.com/bedrock/latest/userguide/models-supported.html',
    openai_api_key: 'https://platform.openai.com/docs/models',
    azure_openai:   'https://learn.microsoft.com/en-us/azure/ai-services/openai/concepts/models',
    gemini_api_key: 'https://ai.google.dev/gemini-api/docs/models/gemini',
