---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ShareObsView from '../../../components/ShareObsView.astro';

// SSG: query string is unknown at build time. Components read observation_id
// from data attributes set by the load() script below. Page is locale-neutral
// (CLAUDE.md regression note: there is no /en/share/obs/ or /es/share/obs/).
const lang: 'en' | 'es' = 'en';
---

<BaseLayout title="Observation — Rastrum" description="View a shared biodiversity observation from the Rastrum community — species identification, photo, audio, GPS location, and observer notes." lang={lang}>
  <ShareObsView lang={lang} />

  <script>
    import { getSupabase } from '../../../lib/supabase';
    import { labelFor } from '../../../lib/observation-enums';
    import { wireManagePanelDetails, wireManagePanelLocation, wireManagePanelPhotos } from '../../../lib/manage-panel';
    import { t } from '../../../i18n/utils';

    const id = new URLSearchParams(window.location.search).get('id');
    if (!id) {
      document.getElementById('loading')?.classList.add('hidden');
      const err = document.getElementById('err');
      if (err) { err.textContent = 'No observation id in URL.'; err.classList.remove('hidden'); }
    } else {
      load(id).catch(e => {
        document.getElementById('loading')?.classList.add('hidden');
        const err = document.getElementById('err');
        if (err) { err.textContent = e.message; err.classList.remove('hidden'); }
      });
    }

    async function load(id: string) {
      const supabase = getSupabase();
      // LEFT join on identifications: observations that haven't been
      // through the identify cascade yet still load with "Unidentified" as
      // the species name.
      const { data: obs, error } = await supabase
        .from('observations')
        .select(`
          id, observed_at, obscure_level, state_province, habitat, weather, establishment_means, observer_id, notes,
          last_material_edit_at, location, location_obscured,
          identifications(scientific_name, is_primary, is_research_grade),
          users:observer_id(display_name, username, profile_public)
        `)
        .eq('id', id)
        .maybeSingle();

      if (error) throw error;
      if (!obs) throw new Error('Observation not found.');

      const idArr = Array.isArray(obs.identifications) ? obs.identifications : (obs.identifications ? [obs.identifications] : []);
      const ident = idArr.find((x: { is_primary?: boolean }) => x?.is_primary) ?? idArr[0];
      const user  = Array.isArray(obs.users) ? obs.users[0] : obs.users;

      document.getElementById('loading')?.classList.add('hidden');
      document.getElementById('obs')?.classList.remove('hidden');
      const speciesName = ident?.scientific_name ?? 'Unknown species';
      document.getElementById('species')!.textContent = speciesName;

      const shareBtn = document.getElementById('obs-share-btn');
      if (shareBtn) {
        shareBtn.dataset.shareTitle = speciesName + ' — Rastrum';
        const lang = document.documentElement.lang === 'es' ? 'es' : 'en';
        shareBtn.dataset.shareText  = lang === 'es'
          ? `Observación de ${speciesName} en Rastrum`
          : `Observation of ${speciesName} on Rastrum`;
        shareBtn.dataset.shareUrl   = window.location.href;
      }
      const date = new Date(obs.observed_at as string);
      document.getElementById('date')!.textContent = date.toLocaleDateString();
      document.getElementById('meta')!.textContent = `${date.toLocaleDateString()}${obs.state_province ? '  ·  ' + obs.state_province : ''}`;
      if (obs.state_province)        document.getElementById('region')!.textContent        = obs.state_province as string;
      const observeTree = (() => {
        const lang = document.documentElement.lang === 'es' ? 'es' : 'en';
        const tree = t(lang) as { observe?: unknown };
        return tree.observe;
      })();
      if (obs.habitat)               document.getElementById('habitat')!.textContent       = labelFor(observeTree, 'habitat_options',            obs.habitat as string);
      if (obs.weather)               document.getElementById('weather')!.textContent       = labelFor(observeTree, 'weather_options',            obs.weather as string);
      if (obs.establishment_means)   document.getElementById('establishment')!.textContent = labelFor(observeTree, 'establishment_means_options', obs.establishment_means as string);

      // Privacy rule: a private profile shows as "Anonymous" to everyone
      // EXCEPT the observer themselves.
      const isPublic = user?.profile_public;
      let viewerIsObserver = false;
      try {
        const { data: { user: viewer } } = await supabase.auth.getUser();
        viewerIsObserver = !!(viewer?.id && obs.observer_id && viewer.id === obs.observer_id);
      } catch { /* signed out viewer */ }
      const fallback = (document.documentElement.lang === 'es') ? 'Anónimo' : 'Anonymous';
      const name = user?.display_name || user?.username || '—';
      document.getElementById('observer')!.textContent = (isPublic || viewerIsObserver) ? name : fallback;

      // Hydrate PhotoGallery with non-deleted photos (PR2 added deleted_at).
      // The gallery's static SSR markup is empty; this dispatch fills it.
      const { data: media } = await supabase
        .from('media_files')
        .select('id, url, thumbnail_url, is_primary, sort_order, deleted_at')
        .eq('observation_id', id)
        .is('deleted_at', null)
        .order('is_primary', { ascending: false })
        .order('sort_order', { ascending: true });
      const photos = (media ?? []).map((m: { id: string; url: string; thumbnail_url: string | null }) => ({
        id: m.id, url: m.url, thumbnail_url: m.thumbnail_url, caption: null,
      }));
      window.dispatchEvent(new CustomEvent('rastrum:photos-ready', {
        detail: { photos, galleryId: 'obs-detail' },
      }));

      // Coords readout + view-mode mini-map hydration. PostgREST returns
      // `location` as a GeoJSON Point; for non-owner viewers we prefer
      // `location_obscured` when present (sensitive species). The
      // MapPicker mini-map SSRs with `initialCoords={null}` — we hydrate
      // it now via `rastrum:mappicker-set` (PR5).
      const obsLoc = (obs as { location?: { coordinates?: [number, number] } | null }).location;
      const obscuredLoc = (obs as { location_obscured?: { coordinates?: [number, number] } | null }).location_obscured;
      const usePoint = (!viewerIsObserver && obscuredLoc?.coordinates) ? obscuredLoc : obsLoc;
      const coords = usePoint?.coordinates;
      if (Array.isArray(coords) && coords.length >= 2) {
        const lng = coords[0];
        const lat = coords[1];
        window.dispatchEvent(new CustomEvent('rastrum:mappicker-set', {
          detail: { id: 'obs-detail', coords: { lat, lng } },
        }));
        const coordsEl = document.querySelector('[data-obs-coords]');
        if (coordsEl) {
          const isEs = document.documentElement.lang === 'es';
          const obscured = (obs as { obscure_level?: string }).obscure_level;
          const isObscured = !!obscured && obscured !== 'none';
          const formatted = `${lat.toFixed(4)}, ${lng.toFixed(4)}`;
          coordsEl.textContent = isObscured
            ? (isEs ? `~${formatted} (aproximado)` : `~${formatted} (coarsened)`)
            : formatted;
        }
      }

      if (obs.obscure_level && obs.obscure_level !== 'none') {
        document.getElementById('sensitive')?.classList.remove('hidden');
      }

      const observerId = (obs as { observer_id?: string }).observer_id;
      if (observerId) {
        const followRoot = document.querySelector<HTMLElement>('#follow-mount .rastrum-follow-btn');
        if (followRoot) {
          followRoot.dataset.targetId = observerId;
          document.dispatchEvent(new CustomEvent('rastrum:follow-ready'));
        }
      }

      const reactRoot = document.querySelector<HTMLElement>('#reactions-mount .rastrum-reactions');
      if (reactRoot) {
        reactRoot.dataset.reactionTargetId = id;
        document.dispatchEvent(new CustomEvent('rastrum:reactions-ready'));
      }

      const reportBtn = document.getElementById('obs-report-btn');
      if (reportBtn && !viewerIsObserver) {
        reportBtn.classList.remove('hidden');
        reportBtn.addEventListener('click', () => {
          const dialog = document.getElementById('rastrum-report-dialog');
          if (!dialog) return;
          (dialog as HTMLElement).dataset.target = 'observation';
          (dialog as HTMLElement).dataset.targetId = id;
          (dialog as HTMLElement).dataset.targetLabel = speciesName;
          dialog.classList.remove('hidden');
        });
      }
      const social = document.getElementById('social-mount');
      social?.classList.remove('hidden');
      const commentsRoot = social?.querySelector<HTMLElement>('.rastrum-comments');
      if (commentsRoot) {
        commentsRoot.dataset.observationId = id;
        document.dispatchEvent(new CustomEvent('rastrum:comments-ready'));
      }

      if (viewerIsObserver) {
        // ObsManagePanel.astro renders Details / Location / Photos tabs.
        // PR4 wires Details; PR5 wires Location; PR6 wires Photos
        // (atomic delete via the delete-photo Edge Function — soft-delete
        // + ID demote + last_material_edit_at bump in one transaction).
        // The left-aside "Edit location" button (`obs-edit-location-btn`)
        // is a shortcut that scrolls to the manage panel and activates
        // the Location tab — the actual Edit Location modal lives inside
        // the tab via `MapPicker mode='edit'` with pickerId 'obs-detail-edit'.
        const editLocBtn = document.getElementById('obs-edit-location-btn') as HTMLButtonElement | null;
        if (editLocBtn) {
          editLocBtn.classList.remove('hidden');
          editLocBtn.disabled = false;
          editLocBtn.removeAttribute('aria-disabled');
          editLocBtn.addEventListener('click', () => {
            const tab = document.getElementById('m-tab-location') as HTMLButtonElement | null;
            tab?.click();
            tab?.scrollIntoView({ behavior: 'smooth', block: 'center' });
          });
        }
        await wireManagePanelDetails(id, obs as Record<string, unknown>, ident);
        await wireManagePanelLocation(id, obs as Record<string, unknown>);
        await wireManagePanelPhotos(id);
      }

      // Surface the "edited after IDs" badge (PR2 schema column).
      const lastEdit = (obs as { last_material_edit_at?: string | null }).last_material_edit_at;
      const editedBadge = document.querySelector('[data-edited-badge]');
      if (lastEdit && editedBadge) {
        // The badge is suppressed when there are no community IDs; we
        // re-evaluate after wireCommunityIds resolves.
        editedBadge.setAttribute('data-pending-show', '1');
      }

      await wireCommunityIds(id, viewerIsObserver);

      if (lastEdit && editedBadge?.getAttribute('data-pending-show') === '1') {
        const list = document.getElementById('ci-list');
        if (list && list.children.length > 0) {
          editedBadge.classList.remove('hidden');
        }
        editedBadge.removeAttribute('data-pending-show');
      }
    }

    /**
     * Render the community-suggestions section: a list of every
     * `identifications` row with `validated_by IS NOT NULL` for this
     * observation, plus the right CTA depending on viewer state.
     */
    async function wireCommunityIds(obsId: string, viewerIsObserver: boolean) {
      const supabase = getSupabase();
      const section = document.getElementById('community-ids');
      const listEl = document.getElementById('ci-list') as HTMLUListElement | null;
      const emptyEl = document.getElementById('community-ids-empty');
      const suggestBtn = document.getElementById('ci-suggest-btn') as HTMLButtonElement | null;
      const signInLink = document.getElementById('ci-signin-link') as HTMLAnchorElement | null;
      const ownerNote = document.getElementById('ci-owner-note');
      if (!section || !listEl) return;

      const { data: { user } } = await supabase.auth.getUser();
      const isEs = document.documentElement.lang === 'es';
      if (viewerIsObserver) {
        ownerNote?.classList.remove('hidden');
      } else if (user) {
        suggestBtn?.classList.remove('hidden');
        suggestBtn?.addEventListener('click', () => {
          const observerName = document.getElementById('observer')?.textContent ?? null;
          const opener = (window as unknown as { __rastrumOpenSuggestId?: (id: string, n: string | null) => void }).__rastrumOpenSuggestId;
          if (typeof opener === 'function') opener(obsId, observerName);
        });
      } else if (signInLink) {
        const lang = isEs ? 'es' : 'en';
        signInLink.href = `/${lang}/${lang === 'es' ? 'ingresar' : 'sign-in'}/`;
        signInLink.classList.remove('hidden');
      }

      async function refresh() {
        const { data: rows } = await supabase
          .from('identifications')
          .select('id, scientific_name, confidence, validated_by, created_at, is_research_grade, source')
          .eq('observation_id', obsId)
          .not('validated_by', 'is', null)
          .order('created_at', { ascending: true });
        const arr = (rows ?? []) as Array<{
          id: string; scientific_name: string | null; confidence: number | null;
          validated_by: string | null; is_research_grade: boolean | null;
          source: string | null;
        }>;

        if (arr.length === 0) {
          emptyEl?.classList.remove('hidden');
          listEl!.innerHTML = '';
          return;
        }
        emptyEl?.classList.add('hidden');

        const validatorIds = Array.from(new Set(arr.map(r => r.validated_by!).filter(Boolean)));
        const nameById = new Map<string, string>();
        if (validatorIds.length > 0) {
          const { data: users } = await supabase
            .from('users')
            .select('id, display_name, username, profile_public')
            .in('id', validatorIds);
          for (const u of (users ?? [])) {
            const uid = (u as { id: string }).id;
            const pub = (u as { profile_public?: boolean }).profile_public;
            const display = (u as { display_name?: string }).display_name;
            const username = (u as { username?: string }).username;
            nameById.set(uid, pub ? (display || username || (isEs ? 'Anónimo' : 'Anonymous')) : (isEs ? 'Anónimo' : 'Anonymous'));
          }
        }

        const byName = new Map<string, number>();
        for (const r of arr) {
          if (!r.scientific_name) continue;
          byName.set(r.scientific_name, (byName.get(r.scientific_name) ?? 0) + 1);
        }

        function escAttr(s: string): string {
          const map: Record<string, string> = { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' };
          return s.replace(/[&<>"']/g, c => map[c] ?? c);
        }

        listEl!.innerHTML = arr.map(r => {
          const name = r.scientific_name ?? (isEs ? 'Sin nombre' : 'No name');
          const supportCount = byName.get(name) ?? 1;
          const supportLine = supportCount > 1 ? ` · ${supportCount} ${isEs ? 'sugerencias' : 'suggestions'}` : '';
          const validator = nameById.get(r.validated_by ?? '') ?? '?';
          const conf = typeof r.confidence === 'number' ? `${Math.round(r.confidence * 100)}%` : '';
          const rgChip = r.is_research_grade
            ? `<span class="ml-1 inline-flex items-center rounded-full bg-emerald-100 dark:bg-emerald-900/30 px-1.5 py-0.5 text-[10px] font-semibold text-emerald-800 dark:text-emerald-300">${isEs ? 'Grado investigación' : 'Research grade'}</span>`
            : '';
          return `<li class="flex items-baseline gap-2 flex-wrap py-1.5 border-b border-zinc-100 dark:border-zinc-800/60 last:border-b-0">
            <span class="italic font-medium text-emerald-700 dark:text-emerald-400">${escAttr(name)}</span>
            ${rgChip}
            <span class="text-xs text-zinc-500">${escAttr(validator)}${conf ? ' · ' + conf : ''}${supportLine}</span>
          </li>`;
        }).join('');
      }

      window.addEventListener('rastrum:suggestion-submitted', () => { void refresh(); });
      await refresh();
    }

  </script>
</BaseLayout>
