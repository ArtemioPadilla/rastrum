---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Comments from '../../../components/Comments.astro';
import FollowButton from '../../../components/FollowButton.astro';

// SSG: query string is unknown at build time. Comments component reads
// observation_id from data attribute, which we set at runtime in the
// load() script below.
const lang: 'en' | 'es' = 'en';
const obsIdPlaceholder = '';
---

<BaseLayout title="Observation — Rastrum" description="View a shared biodiversity observation from the Rastrum community — species identification, photo, audio, GPS location, and observer notes." lang={lang}>
  <div class="max-w-3xl mx-auto">
    <div id="loading" class="py-16 text-center text-zinc-500">Loading observation…</div>
    <article id="obs" class="hidden space-y-6">
      <header class="space-y-1 flex flex-wrap items-start justify-between gap-3">
        <div class="min-w-0">
          <h1 id="species" class="text-3xl md:text-4xl font-bold italic text-zinc-900 dark:text-zinc-100"></h1>
          <p id="meta" class="text-sm text-zinc-500 dark:text-zinc-400"></p>
        </div>
        <div id="follow-mount">
          <FollowButton lang={lang} />
        </div>
      </header>

      <img id="img" src="" alt="" class="w-full max-h-[500px] object-contain rounded-xl border border-zinc-200 dark:border-zinc-800 hidden" />

      <dl class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <dt class="text-zinc-500 dark:text-zinc-400">Date</dt>
          <dd id="date" class="font-medium"></dd>
        </div>
        <div>
          <dt class="text-zinc-500 dark:text-zinc-400">Region</dt>
          <dd id="region" class="font-medium">—</dd>
        </div>
        <div>
          <dt class="text-zinc-500 dark:text-zinc-400">Habitat</dt>
          <dd id="habitat" class="font-medium">—</dd>
        </div>
        <div>
          <dt class="text-zinc-500 dark:text-zinc-400">Observed by</dt>
          <dd id="observer" class="font-medium">—</dd>
        </div>
      </dl>

      <p id="sensitive" class="hidden text-sm text-amber-700 dark:text-amber-400 border-l-4 border-amber-500 pl-3">
        This observation is of a sensitive species. Precise coordinates are obscured to protect it.
      </p>

      {/* TODO(local-contexts): when public.observations gains a
          `local_contexts_notice_url` column (schema gap as of 2026-04-25 —
          see docs/specs/modules/07-licensing.md and the local-contexts
          roadmap item), render the BC/TK notice badge + link here.
          Schema must NOT be modified from this UI; wait for the migration. */}
    </article>

    <div id="err" class="hidden py-16 text-center text-red-600 dark:text-red-400"></div>

    <div id="social-mount" class="hidden">
      <Comments lang={lang} observationId={obsIdPlaceholder} />
    </div>
  </div>

  <script>
    import { getSupabase } from '../../../lib/supabase';

    const id = new URLSearchParams(window.location.search).get('id');
    if (!id) {
      document.getElementById('loading')?.classList.add('hidden');
      const err = document.getElementById('err');
      if (err) { err.textContent = 'No observation id in URL.'; err.classList.remove('hidden'); }
    } else {
      load(id).catch(e => {
        document.getElementById('loading')?.classList.add('hidden');
        const err = document.getElementById('err');
        if (err) { err.textContent = e.message; err.classList.remove('hidden'); }
      });
    }

    async function load(id: string) {
      const supabase = getSupabase();
      // LEFT join on identifications: observations that haven't been
      // through the identify cascade yet (or whose cascade returned no
      // result) still load, just with "Unidentified" as the species
      // name. The earlier !inner version filtered them out entirely
      // and surfaced as "Observation not found" — which made every
      // newly-synced observation invisible until the cascade
      // completed.
      const { data: obs, error } = await supabase
        .from('observations')
        .select(`
          id, observed_at, obscure_level, state_province, habitat, observer_id,
          identifications(scientific_name, is_primary, is_research_grade),
          users(display_name, username, profile_public)
        `)
        .eq('id', id)
        .maybeSingle();

      if (error) throw error;
      if (!obs) throw new Error('Observation not found.');

      // Without the inner join, identifications may be empty, contain
      // multiple rows (community votes — non-primary), or one primary.
      // Prefer the primary; if there isn't one, take the first row;
      // if there are no rows at all, ident stays undefined and the
      // species line reads "Unidentified".
      const idArr = Array.isArray(obs.identifications) ? obs.identifications : (obs.identifications ? [obs.identifications] : []);
      const ident = idArr.find((x: { is_primary?: boolean }) => x?.is_primary) ?? idArr[0];
      const user  = Array.isArray(obs.users) ? obs.users[0] : obs.users;

      document.getElementById('loading')?.classList.add('hidden');
      document.getElementById('obs')?.classList.remove('hidden');
      document.getElementById('species')!.textContent = ident?.scientific_name ?? 'Unknown species';
      const date = new Date(obs.observed_at as string);
      document.getElementById('date')!.textContent = date.toLocaleDateString();
      document.getElementById('meta')!.textContent = `${date.toLocaleDateString()}${obs.state_province ? '  ·  ' + obs.state_province : ''}`;
      if (obs.state_province)  document.getElementById('region')!.textContent  = obs.state_province as string;
      if (obs.habitat)         document.getElementById('habitat')!.textContent = (obs.habitat as string).replace(/_/g, ' ');
      // Privacy rule: a private profile shows as "Anonymous" to everyone
      // EXCEPT the observer themselves. The observer always sees their
      // own name on their own observation — otherwise looking at your
      // own list is bizarre. ("Why is my own photo by Anónimo?")
      const isPublic = user?.profile_public;
      let viewerIsObserver = false;
      try {
        const { data: { user: viewer } } = await supabase.auth.getUser();
        viewerIsObserver = !!(viewer?.id && obs.observer_id && viewer.id === obs.observer_id);
      } catch { /* signed out viewer */ }
      const fallback = (document.documentElement.lang === 'es') ? 'Anónimo' : 'Anonymous';
      const name = user?.display_name || user?.username || '—';
      document.getElementById('observer')!.textContent = (isPublic || viewerIsObserver) ? name : fallback;

      // Pull the primary photo if we can read media_files (RLS gates this)
      const { data: media } = await supabase
        .from('media_files')
        .select('url, is_primary')
        .eq('observation_id', id)
        .order('is_primary', { ascending: false })
        .limit(1);
      const photo = media?.[0]?.url;
      const img = document.getElementById('img') as HTMLImageElement | null;
      if (photo && img) {
        img.src = photo;
        img.classList.remove('hidden');
      }

      if (obs.obscure_level && obs.obscure_level !== 'none') {
        document.getElementById('sensitive')?.classList.remove('hidden');
      }

      // Wire follow button + reveal comments now that we know who posted.
      const observerId = (obs as { observer_id?: string }).observer_id;
      if (observerId) {
        const followRoot = document.querySelector<HTMLElement>('#follow-mount .rastrum-follow-btn');
        if (followRoot) {
          followRoot.dataset.targetId = observerId;
          document.dispatchEvent(new CustomEvent('rastrum:follow-ready'));
        }
      }
      const social = document.getElementById('social-mount');
      social?.classList.remove('hidden');
      const commentsRoot = social?.querySelector<HTMLElement>('.rastrum-comments');
      if (commentsRoot) {
        commentsRoot.dataset.observationId = id;
        document.dispatchEvent(new CustomEvent('rastrum:comments-ready'));
      }
    }
  </script>
</BaseLayout>
