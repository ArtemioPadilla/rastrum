---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Comments from '../../../components/Comments.astro';
import FollowButton from '../../../components/FollowButton.astro';
import SuggestIdModal from '../../../components/SuggestIdModal.astro';

// SSG: query string is unknown at build time. Comments component reads
// observation_id from data attribute, which we set at runtime in the
// load() script below.
const lang: 'en' | 'es' = 'en';
const obsIdPlaceholder = '';
---

<BaseLayout title="Observation — Rastrum" description="View a shared biodiversity observation from the Rastrum community — species identification, photo, audio, GPS location, and observer notes." lang={lang}>
  <div class="max-w-3xl mx-auto">
    <div id="loading" class="py-16 text-center text-zinc-500">Loading observation…</div>
    <article id="obs" class="hidden space-y-6">
      <header class="space-y-1 flex flex-wrap items-start justify-between gap-3">
        <div class="min-w-0">
          <h1 id="species" class="text-3xl md:text-4xl font-bold italic text-zinc-900 dark:text-zinc-100"></h1>
          <p id="meta" class="text-sm text-zinc-500 dark:text-zinc-400"></p>
        </div>
        <div id="follow-mount">
          <FollowButton lang={lang} />
        </div>
      </header>

      <img id="img" src="" alt="" class="w-full max-h-[500px] object-contain rounded-xl border border-zinc-200 dark:border-zinc-800 hidden" />

      <dl class="grid grid-cols-2 gap-4 text-sm">
        <div>
          <dt class="text-zinc-500 dark:text-zinc-400">Date</dt>
          <dd id="date" class="font-medium"></dd>
        </div>
        <div>
          <dt class="text-zinc-500 dark:text-zinc-400">Region</dt>
          <dd id="region" class="font-medium">—</dd>
        </div>
        <div>
          <dt class="text-zinc-500 dark:text-zinc-400">Habitat</dt>
          <dd id="habitat" class="font-medium">—</dd>
        </div>
        <div>
          <dt class="text-zinc-500 dark:text-zinc-400">Observed by</dt>
          <dd id="observer" class="font-medium">—</dd>
        </div>
      </dl>

      <p id="sensitive" class="hidden text-sm text-amber-700 dark:text-amber-400 border-l-4 border-amber-500 pl-3">
        This observation is of a sensitive species. Precise coordinates are obscured to protect it.
      </p>

      <!--
        Community identifications + suggest CTA. Visible to ALL viewers
        (so the public can see what experts and other observers have
        proposed). The "Suggest identification" button is only enabled
        for signed-in non-owners — owner uses the Manage panel below
        instead, anonymous users see a sign-in prompt.
      -->
      <section id="community-ids" class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4 space-y-3">
        <div class="flex items-start justify-between gap-2 flex-wrap">
          <div>
            <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider">Community suggestions</h2>
            <p id="community-ids-empty" class="text-xs text-zinc-500 dark:text-zinc-400 mt-1">
              No one has suggested an identification yet. Be the first.
            </p>
          </div>
          <button id="ci-suggest-btn" type="button" class="hidden rounded-lg bg-emerald-700 hover:bg-emerald-800 px-3 py-1.5 text-xs font-semibold text-white">
            Suggest identification
          </button>
          <a id="ci-signin-link" href="/en/sign-in/" class="hidden rounded-lg border border-emerald-600/60 px-3 py-1.5 text-xs font-medium text-emerald-700 dark:text-emerald-400 hover:bg-emerald-50 dark:hover:bg-emerald-900/20">
            Sign in to suggest
          </a>
          <span id="ci-owner-note" class="hidden text-xs text-zinc-500 italic">Use the Manage panel below to update your own identification.</span>
        </div>
        <ul id="ci-list" class="space-y-1.5 text-sm"></ul>
      </section>

      <!--
        Owner-only Manage panel. Visible only when the signed-in viewer
        IS the observation's observer. Edit updates notes + scientific
        name + obscure_level. Delete removes the observation row (FK
        cascade on identifications + media_files; the R2 photo blobs
        are left as orphans, acceptable for v1).
      -->
      <section id="manage-panel" class="hidden rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 p-4 space-y-3">
        <h2 class="text-sm font-semibold text-zinc-700 dark:text-zinc-300 uppercase tracking-wider">Manage your observation</h2>
        <p class="text-xs text-zinc-500 dark:text-zinc-400">Only you see this. Other viewers won't.</p>
        <form id="manage-form" class="space-y-3" novalidate>
          <div>
            <label for="m-sci" class="block text-xs font-medium text-zinc-700 dark:text-zinc-300 mb-1">Scientific name (override)</label>
            <input id="m-sci" type="text" autocomplete="off" placeholder="e.g. Quercus oleoides" class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm font-mono italic" />
            <p class="mt-1 text-[11px] text-zinc-500 dark:text-zinc-400">Replaces the primary identification with a manual one (you as validator). Leave blank to keep current.</p>
          </div>
          <div>
            <label for="m-notes" class="block text-xs font-medium text-zinc-700 dark:text-zinc-300 mb-1">Notes</label>
            <textarea id="m-notes" rows="3" maxlength="2000" class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm"></textarea>
          </div>
          <div>
            <label for="m-obscure" class="block text-xs font-medium text-zinc-700 dark:text-zinc-300 mb-1">Location privacy</label>
            <select id="m-obscure" class="block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm">
              <option value="none">Show precise coordinates</option>
              <option value="0.1deg">Coarsen to ~10 km</option>
              <option value="0.2deg">Coarsen to ~20 km</option>
              <option value="5km">Coarsen to ~5 km</option>
              <option value="full">Hide location entirely</option>
            </select>
          </div>
          <p id="m-error" class="hidden text-xs text-red-600 dark:text-red-400" role="alert"></p>
          <p id="m-saved" class="hidden text-xs text-emerald-700 dark:text-emerald-400" aria-live="polite">Saved.</p>
          <div class="flex flex-wrap items-center gap-2 pt-2">
            <button type="submit" id="m-save" class="rounded-lg bg-emerald-700 hover:bg-emerald-800 px-4 py-2 text-sm font-semibold text-white disabled:opacity-50">Save changes</button>
            <button type="button" id="m-delete" class="rounded-lg border border-red-300 dark:border-red-800 px-4 py-2 text-sm font-medium text-red-700 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20">Delete observation</button>
          </div>
        </form>
      </section>

      {/* TODO(local-contexts): when public.observations gains a
          `local_contexts_notice_url` column (schema gap as of 2026-04-25 —
          see docs/specs/modules/07-licensing.md and the local-contexts
          roadmap item), render the BC/TK notice badge + link here.
          Schema must NOT be modified from this UI; wait for the migration. */}
    </article>

    <div id="err" class="hidden py-16 text-center text-red-600 dark:text-red-400"></div>

    <div id="social-mount" class="hidden">
      <Comments lang={lang} observationId={obsIdPlaceholder} />
    </div>
  </div>

  <!-- Suggest-identification modal — opened by the Suggest CTA above. -->
  <SuggestIdModal lang={lang} />

  <script>
    import { getSupabase } from '../../../lib/supabase';

    const id = new URLSearchParams(window.location.search).get('id');
    if (!id) {
      document.getElementById('loading')?.classList.add('hidden');
      const err = document.getElementById('err');
      if (err) { err.textContent = 'No observation id in URL.'; err.classList.remove('hidden'); }
    } else {
      load(id).catch(e => {
        document.getElementById('loading')?.classList.add('hidden');
        const err = document.getElementById('err');
        if (err) { err.textContent = e.message; err.classList.remove('hidden'); }
      });
    }

    async function load(id: string) {
      const supabase = getSupabase();
      // LEFT join on identifications: observations that haven't been
      // through the identify cascade yet (or whose cascade returned no
      // result) still load, just with "Unidentified" as the species
      // name. The earlier !inner version filtered them out entirely
      // and surfaced as "Observation not found" — which made every
      // newly-synced observation invisible until the cascade
      // completed.
      const { data: obs, error } = await supabase
        .from('observations')
        .select(`
          id, observed_at, obscure_level, state_province, habitat, observer_id,
          identifications(scientific_name, is_primary, is_research_grade),
          users(display_name, username, profile_public)
        `)
        .eq('id', id)
        .maybeSingle();

      if (error) throw error;
      if (!obs) throw new Error('Observation not found.');

      // Without the inner join, identifications may be empty, contain
      // multiple rows (community votes — non-primary), or one primary.
      // Prefer the primary; if there isn't one, take the first row;
      // if there are no rows at all, ident stays undefined and the
      // species line reads "Unidentified".
      const idArr = Array.isArray(obs.identifications) ? obs.identifications : (obs.identifications ? [obs.identifications] : []);
      const ident = idArr.find((x: { is_primary?: boolean }) => x?.is_primary) ?? idArr[0];
      const user  = Array.isArray(obs.users) ? obs.users[0] : obs.users;

      document.getElementById('loading')?.classList.add('hidden');
      document.getElementById('obs')?.classList.remove('hidden');
      document.getElementById('species')!.textContent = ident?.scientific_name ?? 'Unknown species';
      const date = new Date(obs.observed_at as string);
      document.getElementById('date')!.textContent = date.toLocaleDateString();
      document.getElementById('meta')!.textContent = `${date.toLocaleDateString()}${obs.state_province ? '  ·  ' + obs.state_province : ''}`;
      if (obs.state_province)  document.getElementById('region')!.textContent  = obs.state_province as string;
      if (obs.habitat)         document.getElementById('habitat')!.textContent = (obs.habitat as string).replace(/_/g, ' ');
      // Privacy rule: a private profile shows as "Anonymous" to everyone
      // EXCEPT the observer themselves. The observer always sees their
      // own name on their own observation — otherwise looking at your
      // own list is bizarre. ("Why is my own photo by Anónimo?")
      const isPublic = user?.profile_public;
      let viewerIsObserver = false;
      try {
        const { data: { user: viewer } } = await supabase.auth.getUser();
        viewerIsObserver = !!(viewer?.id && obs.observer_id && viewer.id === obs.observer_id);
      } catch { /* signed out viewer */ }
      const fallback = (document.documentElement.lang === 'es') ? 'Anónimo' : 'Anonymous';
      const name = user?.display_name || user?.username || '—';
      document.getElementById('observer')!.textContent = (isPublic || viewerIsObserver) ? name : fallback;

      // Pull the primary photo if we can read media_files (RLS gates this)
      const { data: media } = await supabase
        .from('media_files')
        .select('url, is_primary')
        .eq('observation_id', id)
        .order('is_primary', { ascending: false })
        .limit(1);
      const photo = media?.[0]?.url;
      const img = document.getElementById('img') as HTMLImageElement | null;
      if (photo && img) {
        img.src = photo;
        img.classList.remove('hidden');
      }

      if (obs.obscure_level && obs.obscure_level !== 'none') {
        document.getElementById('sensitive')?.classList.remove('hidden');
      }

      // Wire follow button + reveal comments now that we know who posted.
      const observerId = (obs as { observer_id?: string }).observer_id;
      if (observerId) {
        const followRoot = document.querySelector<HTMLElement>('#follow-mount .rastrum-follow-btn');
        if (followRoot) {
          followRoot.dataset.targetId = observerId;
          document.dispatchEvent(new CustomEvent('rastrum:follow-ready'));
        }
      }
      const social = document.getElementById('social-mount');
      social?.classList.remove('hidden');
      const commentsRoot = social?.querySelector<HTMLElement>('.rastrum-comments');
      if (commentsRoot) {
        commentsRoot.dataset.observationId = id;
        document.dispatchEvent(new CustomEvent('rastrum:comments-ready'));
      }

      // Owner-only Manage panel.
      if (viewerIsObserver) wireManagePanel(id, obs as Record<string, unknown>, ident);

      // Community suggestions list + Suggest CTA — visible to everyone,
      // actionable for signed-in non-owners.
      await wireCommunityIds(id, viewerIsObserver);
    }

    /**
     * Render the community-suggestions section: a list of every
     * `identifications` row with `validated_by IS NOT NULL` for this
     * observation, plus the right CTA depending on viewer state.
     */
    async function wireCommunityIds(obsId: string, viewerIsObserver: boolean) {
      const supabase = getSupabase();
      const section = document.getElementById('community-ids');
      const listEl = document.getElementById('ci-list') as HTMLUListElement | null;
      const emptyEl = document.getElementById('community-ids-empty');
      const suggestBtn = document.getElementById('ci-suggest-btn') as HTMLButtonElement | null;
      const signInLink = document.getElementById('ci-signin-link') as HTMLAnchorElement | null;
      const ownerNote = document.getElementById('ci-owner-note');
      if (!section || !listEl) return;

      // Pick the right CTA.
      const { data: { user } } = await supabase.auth.getUser();
      const isEs = document.documentElement.lang === 'es';
      if (viewerIsObserver) {
        ownerNote?.classList.remove('hidden');
      } else if (user) {
        suggestBtn?.classList.remove('hidden');
        suggestBtn?.addEventListener('click', () => {
          // Look up observer username for the modal's target line
          // (stored in the page's <h1 #observer> we already populated).
          const observerName = document.getElementById('observer')?.textContent ?? null;
          const opener = (window as unknown as { __rastrumOpenSuggestId?: (id: string, n: string | null) => void }).__rastrumOpenSuggestId;
          if (typeof opener === 'function') opener(obsId, observerName);
        });
      } else if (signInLink) {
        const lang = isEs ? 'es' : 'en';
        signInLink.href = `/${lang}/${lang === 'es' ? 'ingresar' : 'sign-in'}/`;
        signInLink.classList.remove('hidden');
      }

      async function refresh() {
        const { data: rows } = await supabase
          .from('identifications')
          .select('id, scientific_name, confidence, validated_by, created_at, is_research_grade, source')
          .eq('observation_id', obsId)
          .not('validated_by', 'is', null)
          .order('created_at', { ascending: true });
        const arr = (rows ?? []) as Array<{
          id: string; scientific_name: string | null; confidence: number | null;
          validated_by: string | null; is_research_grade: boolean | null;
          source: string | null;
        }>;

        if (arr.length === 0) {
          emptyEl?.classList.remove('hidden');
          listEl!.innerHTML = '';
          return;
        }
        emptyEl?.classList.add('hidden');

        // Hydrate validator names. RLS lets us read the user's
        // display_name when profile_public; otherwise fall back.
        const validatorIds = Array.from(new Set(arr.map(r => r.validated_by!).filter(Boolean)));
        const nameById = new Map<string, string>();
        if (validatorIds.length > 0) {
          const { data: users } = await supabase
            .from('users')
            .select('id, display_name, username, profile_public')
            .in('id', validatorIds);
          for (const u of (users ?? [])) {
            const uid = (u as { id: string }).id;
            const pub = (u as { profile_public?: boolean }).profile_public;
            const display = (u as { display_name?: string }).display_name;
            const username = (u as { username?: string }).username;
            nameById.set(uid, pub ? (display || username || (isEs ? 'Anónimo' : 'Anonymous')) : (isEs ? 'Anónimo' : 'Anonymous'));
          }
        }

        // Group by scientific name to make consensus visible.
        const byName = new Map<string, number>();
        for (const r of arr) {
          if (!r.scientific_name) continue;
          byName.set(r.scientific_name, (byName.get(r.scientific_name) ?? 0) + 1);
        }

        function escAttr(s: string): string {
          return s.replace(/[&<>"']/g, c => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' } as Record<string, string>)[c]);
        }

        listEl!.innerHTML = arr.map(r => {
          const name = r.scientific_name ?? (isEs ? 'Sin nombre' : 'No name');
          const supportCount = byName.get(name) ?? 1;
          const supportLine = supportCount > 1 ? ` · ${supportCount} ${isEs ? 'sugerencias' : 'suggestions'}` : '';
          const validator = nameById.get(r.validated_by ?? '') ?? '?';
          const conf = typeof r.confidence === 'number' ? `${Math.round(r.confidence * 100)}%` : '';
          const rgChip = r.is_research_grade
            ? `<span class="ml-1 inline-flex items-center rounded-full bg-emerald-100 dark:bg-emerald-900/30 px-1.5 py-0.5 text-[10px] font-semibold text-emerald-800 dark:text-emerald-300">${isEs ? 'Grado investigación' : 'Research grade'}</span>`
            : '';
          return `<li class="flex items-baseline gap-2 flex-wrap py-1.5 border-b border-zinc-100 dark:border-zinc-800/60 last:border-b-0">
            <span class="italic font-medium text-emerald-700 dark:text-emerald-400">${escAttr(name)}</span>
            ${rgChip}
            <span class="text-xs text-zinc-500">${escAttr(validator)}${conf ? ' · ' + conf : ''}${supportLine}</span>
          </li>`;
        }).join('');
      }

      // Initial paint + refresh on every successful suggestion.
      window.addEventListener('rastrum:suggestion-submitted', () => { void refresh(); });
      await refresh();
    }

    /**
     * Wire the owner-only Manage panel: pre-populate fields, handle
     * save (UPDATE observations + UPSERT primary identification when
     * the user types an override), and handle delete (DELETE observation
     * with FK cascade to identifications + media_files).
     */
    function wireManagePanel(
      obsId: string,
      obs: Record<string, unknown>,
      ident: { scientific_name?: string; is_primary?: boolean } | undefined,
    ) {
      const supabase = getSupabase();
      const panel = document.getElementById('manage-panel');
      if (!panel) return;
      panel.classList.remove('hidden');

      const sciInput = document.getElementById('m-sci') as HTMLInputElement | null;
      const notesEl  = document.getElementById('m-notes') as HTMLTextAreaElement | null;
      const obsEl    = document.getElementById('m-obscure') as HTMLSelectElement | null;
      const errEl    = document.getElementById('m-error');
      const savedEl  = document.getElementById('m-saved');
      const saveBtn  = document.getElementById('m-save') as HTMLButtonElement | null;
      const deleteBtn = document.getElementById('m-delete') as HTMLButtonElement | null;
      const form     = document.getElementById('manage-form') as HTMLFormElement | null;

      // Pre-populate
      if (sciInput) sciInput.value = '';                           // override field; blank = keep current
      if (notesEl)  notesEl.value  = (obs.notes as string | null) ?? '';
      if (obsEl)    obsEl.value    = (obs.obscure_level as string) ?? 'none';

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!saveBtn) return;
        errEl?.classList.add('hidden');
        savedEl?.classList.add('hidden');
        saveBtn.disabled = true;
        const origLabel = saveBtn.textContent ?? 'Save';
        saveBtn.textContent = 'Saving…';
        try {
          // 1. Update the observation row (notes + obscure_level).
          const { error: obsErr } = await supabase
            .from('observations')
            .update({
              notes: notesEl?.value.trim() || null,
              obscure_level: obsEl?.value ?? 'none',
              updated_at: new Date().toISOString(),
            })
            .eq('id', obsId);
          if (obsErr) throw obsErr;

          // 2. If the user typed a scientific-name override, upsert a
          //    new primary identification with source='human'. Demote
          //    the previous primary by setting is_primary=false on
          //    everything else first.
          const sci = sciInput?.value.trim();
          if (sci) {
            await supabase.from('identifications')
              .update({ is_primary: false })
              .eq('observation_id', obsId)
              .eq('is_primary', true);
            const { data: { user: viewer } } = await supabase.auth.getUser();
            const { error: idErr } = await supabase.from('identifications').insert({
              observation_id: obsId,
              scientific_name: sci,
              confidence: 0.95,
              source: 'human',
              is_primary: true,
              validated_by: null,                    // observer-set, not validator
              validated_at: new Date().toISOString(),
              raw_response: { manual_override: true, by: viewer?.id ?? null },
            });
            if (idErr) throw idErr;
          }

          savedEl?.classList.remove('hidden');
          // Reflect in the page header without a full reload.
          const speciesEl = document.getElementById('species');
          if (sci && speciesEl) speciesEl.textContent = sci;
        } catch (err) {
          if (errEl) {
            errEl.textContent = err instanceof Error ? err.message : String(err);
            errEl.classList.remove('hidden');
          }
        } finally {
          saveBtn.disabled = false;
          saveBtn.textContent = origLabel;
        }
      });

      deleteBtn?.addEventListener('click', async () => {
        const confirmed = window.confirm(
          'Delete this observation? This cannot be undone. Photos, identifications, and metadata will all be removed.',
        );
        if (!confirmed) return;
        deleteBtn.disabled = true;
        try {
          // Call the delete-observation Edge Function. It owns the
          // atomic delete across R2 (photos + OG card) and the DB
          // (cascades to identifications + media_files). Without
          // this, a direct client-side DELETE leaves orphan R2 blobs.
          const { data, error: invokeErr } = await supabase.functions.invoke<{
            ok: boolean; r2_deleted?: number; r2_errors?: unknown[]; error?: string;
          }>('delete-observation', {
            body: { observation_id: obsId },
          });
          if (invokeErr) throw invokeErr;
          if (data && !data.ok) throw new Error(data.error ?? 'Delete failed');
          const lang = document.documentElement.lang === 'es' ? 'es' : 'en';
          window.location.href = `/${lang}/${lang === 'es' ? 'perfil/observaciones' : 'profile/observations'}/`;
        } catch (err) {
          if (errEl) {
            errEl.textContent = err instanceof Error ? err.message : String(err);
            errEl.classList.remove('hidden');
          }
          deleteBtn.disabled = false;
        }
      });
    }
  </script>
</BaseLayout>
