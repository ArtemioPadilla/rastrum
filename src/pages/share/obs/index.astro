---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ShareObsView from '../../../components/ShareObsView.astro';

// SSG: query string is unknown at build time. Components read observation_id
// from data attributes set by the load() script below. Page is locale-neutral
// (CLAUDE.md regression note: there is no /en/share/obs/ or /es/share/obs/).
const lang: 'en' | 'es' = 'en';
---

<BaseLayout title="Observation — Rastrum" description="View a shared biodiversity observation from the Rastrum community — species identification, photo, audio, GPS location, and observer notes." lang={lang}>
  <ShareObsView lang={lang} />

  <script>
    import { getSupabase } from '../../../lib/supabase';
    import { labelFor } from '../../../lib/observation-enums';
    import { wireManagePanelDetails, wireManagePanelLocation, wireManagePanelPhotos } from '../../../lib/manage-panel';
    import { t } from '../../../i18n/utils';
    import { parseLocationToGeoJSON } from '../../../lib/geo';

    const id = new URLSearchParams(window.location.search).get('id');
    if (!id) {
      document.getElementById('loading')?.classList.add('hidden');
      const err = document.getElementById('err');
      if (err) { err.textContent = 'No observation id in URL.'; err.classList.remove('hidden'); }
    } else {
      load(id).catch(e => {
        document.getElementById('loading')?.classList.add('hidden');
        const err = document.getElementById('err');
        if (err) { err.textContent = e.message; err.classList.remove('hidden'); }
      });

      // ── Stale-data guard ──
      // Track when the page was last fetched so we can re-fetch when the
      // user returns to the tab after being away. This covers:
      //   - AI cascade completing while the user was on another tab
      //   - Species correction saved in the manage panel (same or other tab)
      //   - Another user suggesting an identification
      let lastFetchedAt = Date.now();
      const STALE_THRESHOLD_MS = 30_000; // 30 seconds

      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState !== 'visible') return;
        if (Date.now() - lastFetchedAt < STALE_THRESHOLD_MS) return;
        refreshObservationData(id);
      });

      // Listen for in-page updates from the manage panel (same tab).
      window.addEventListener('rastrum:observation-updated', () => {
        refreshObservationData(id);
      });

      /**
       * Re-fetch the primary identification and update the species name
       * without a full page reload. Lightweight: only queries the
       * identifications table, not the full observation.
       */
      async function refreshObservationData(obsId: string) {
        lastFetchedAt = Date.now();
        try {
          const supabase = getSupabase();
          const { data: ids } = await supabase
            .from('identifications')
            .select('scientific_name, is_primary, is_research_grade, confidence')
            .eq('observation_id', obsId)
            .order('created_at', { ascending: false });

          if (ids && ids.length > 0) {
            const primary = (ids as Array<{ scientific_name: string; is_primary: boolean }>)
              .find(i => i.is_primary) ?? ids[0];
            const speciesEl = document.getElementById('species');
            if (speciesEl && primary.scientific_name) {
              speciesEl.textContent = primary.scientific_name;
            }
          }
        } catch {
          // Silent — background refresh, not user-initiated.
        }
      }
    }

    async function load(id: string) {
      const supabase = getSupabase();
      // LEFT join on identifications: observations that haven't been
      // through the identify cascade yet still load with "Unidentified" as
      // the species name.
      const { data: obs, error } = await supabase
        .from('observations')
        .select(`
          id, observed_at, obscure_level, state_province, habitat, weather, establishment_means, observer_id, notes,
          last_material_edit_at, location, location_obscured, evidence_type,
          places:place_id(id, slug, name, place_type),
          identifications(scientific_name, is_primary, is_research_grade),
          users:observer_id(display_name, username, profile_public)
        `)
        .eq('id', id)
        .maybeSingle();

      if (error) throw error;
      if (!obs) throw new Error('Observation not found.');

      const idArr = Array.isArray(obs.identifications) ? obs.identifications : (obs.identifications ? [obs.identifications] : []);
      const ident = idArr.find((x: { is_primary?: boolean }) => x?.is_primary) ?? idArr[0];
      const user  = Array.isArray(obs.users) ? obs.users[0] : obs.users;

      document.getElementById('loading')?.classList.add('hidden');
      document.getElementById('obs')?.classList.remove('hidden');
      const speciesName = ident?.scientific_name ?? 'Unknown species';
      document.getElementById('species')!.textContent = speciesName;

      // Expose evidence_type for the Ask-my-AI cascade so buildCascadeOptions
      // can prefer MegaDetector for camera-trap photos (#583).
      const askAiBtnInit = document.getElementById('ci-ask-ai-btn');
      if (askAiBtnInit && obs.evidence_type) {
        askAiBtnInit.dataset.evidenceType = obs.evidence_type as string;
      }

      const shareBtn = document.getElementById('obs-share-btn');
      if (shareBtn) {
        shareBtn.dataset.shareTitle = speciesName + ' — Rastrum';
        const lang = document.documentElement.lang === 'es' ? 'es' : 'en';
        shareBtn.dataset.shareText  = lang === 'es'
          ? `Observación de ${speciesName} en Rastrum`
          : `Observation of ${speciesName} on Rastrum`;
        shareBtn.dataset.shareUrl   = window.location.href;
      }
      const date = new Date(obs.observed_at as string);
      document.getElementById('date')!.textContent = date.toLocaleDateString();
      document.getElementById('meta')!.textContent = `${date.toLocaleDateString()}${obs.state_province ? '  ·  ' + obs.state_province : ''}`;
      if (obs.state_province)        document.getElementById('region')!.textContent        = obs.state_province as string;
      const observeTree = (() => {
        const lang = document.documentElement.lang === 'es' ? 'es' : 'en';
        const tree = t(lang) as { observe?: unknown };
        return tree.observe;
      })();
      if (obs.habitat)               document.getElementById('habitat')!.textContent       = labelFor(observeTree, 'habitat_options',            obs.habitat as string);
      if (obs.weather)               document.getElementById('weather')!.textContent       = labelFor(observeTree, 'weather_options',            obs.weather as string);
      if (obs.establishment_means)   document.getElementById('establishment')!.textContent = labelFor(observeTree, 'establishment_means_options', obs.establishment_means as string);

      // Privacy rule: a private profile shows as "Anonymous" to everyone
      // EXCEPT the observer themselves.
      const isPublic = user?.profile_public;
      let viewerIsObserver = false;
      try {
        const { data: { user: viewer } } = await supabase.auth.getUser();
        viewerIsObserver = !!(viewer?.id && obs.observer_id && viewer.id === obs.observer_id);
      } catch { /* signed out viewer */ }
      const fallback = (document.documentElement.lang === 'es') ? 'Anónimo' : 'Anonymous';
      const name = user?.display_name || user?.username || '—';
      const observerEl = document.getElementById('observer')!;
      const showReal = isPublic || viewerIsObserver;
      const displayName = showReal ? name : fallback;
      const username = user?.username;
      if (showReal && username) {
        const lang = document.documentElement.lang === 'es' ? 'es' : 'en';
        const profilePath = lang === 'es' ? '/es/u/' : '/en/u/';
        const link = document.createElement('a');
        link.href = `${profilePath}?username=${encodeURIComponent(username)}`;
        link.textContent = displayName;
        link.className = 'text-emerald-700 dark:text-emerald-400 hover:underline';
        observerEl.textContent = '';
        observerEl.appendChild(link);
      } else {
        observerEl.textContent = displayName;
      }

      // Hydrate PhotoGallery with non-deleted photos (PR2 added deleted_at).
      // The gallery's static SSR markup is empty; this dispatch fills it.
      const { data: media } = await supabase
        .from('media_files')
        .select('id, url, thumbnail_url, is_primary, sort_order, deleted_at, media_type, mime_type')
        .eq('observation_id', id)
        .is('deleted_at', null)
        .order('is_primary', { ascending: false })
        .order('sort_order', { ascending: true });

      type MediaRow = { id: string; url: string; thumbnail_url: string | null; media_type?: string; mime_type?: string | null };

      const photos = (media ?? []).filter((m: MediaRow) => !m.media_type || m.media_type === 'photo').map((m: MediaRow) => ({
        id: m.id, url: m.url, thumbnail_url: m.thumbnail_url, caption: null,
      }));
      window.dispatchEvent(new CustomEvent('rastrum:photos-ready', {
        detail: { photos, galleryId: 'obs-detail' },
      }));

      // Hide the photo gallery entirely for audio-only observations so
      // there's no broken/empty image placeholder.
      const audioFiles = (media ?? []).filter((m: MediaRow) => m.media_type === 'audio');
      const isAudioOnly = photos.length === 0 && audioFiles.length > 0;
      if (isAudioOnly) {
        const galleryRoot = document.querySelector<HTMLElement>('[data-gallery-id="obs-detail"]');
        if (galleryRoot) galleryRoot.classList.add('hidden');
      }

      // ── Audio players ──
      // The actual player is built by `mountAudioPlayer` (src/lib/audio-player.ts)
      // which is wired up by AudioPlayer.astro's inline <script>. Here we just
      // emit empty mount points; AudioPlayer.astro listens for the
      // `rastrum:audio-players-ready` event and initialises them.
      if (audioFiles.length > 0) {
        const playersEl = document.getElementById('obs-audio-players');
        if (playersEl) {
          const lang = document.documentElement.lang === 'es' ? 'es' : 'en';
          playersEl.classList.remove('hidden');
          playersEl.innerHTML = audioFiles.map((af: MediaRow, idx: number) => {
            const obsIdAttr = `obs-detail-audio-${idx}`;
            const mimeType  = af.mime_type ?? 'audio/mpeg';
            return `<div
              class="rastrum-audio-player-mount"
              data-audio-url="${af.url}"
              data-mime-type="${mimeType}"
              data-obs-id="${obsIdAttr}"
              data-lang="${lang}"
              data-auto-expand="${isAudioOnly ? 'true' : 'false'}"
            ></div>`;
          }).join('');

          document.dispatchEvent(new CustomEvent('rastrum:audio-players-ready'));

          // ── Fetch BirdNET detections from the identifications table ──
          // Query the primary identification for this observation to get
          // raw_response.segments (sliding-window detections with timestamps).
          const { data: ident } = await supabase
            .from('identifications')
            .select('raw_response, source')
            .eq('observation_id', id)
            .eq('is_primary', true)
            .eq('source', 'birdnet_lite')
            .maybeSingle();

          if (ident?.raw_response) {
            type RawResponse = {
              segments?: Array<{ startSec: number; endSec: number; top: Array<{ scientific_name: string; common_name_en: string | null; score: number }> }>;
              durationSec?: number;
            };
            const raw = ident.raw_response as RawResponse;
            if (raw.segments && raw.segments.length > 0) {
              // Known limitation (v1): the BirdNET identification is stored once
              // per observation, not per audio file. If an observation has multiple
              // audio files, all players show the same segment detections from the
              // primary identification. Fix in a future PR by storing a media_file_id
              // FK on the identifications row.
              audioFiles.forEach((_af: unknown, idx: number) => {
                const obsIdAttr = `obs-detail-audio-${idx}`;
                document.dispatchEvent(new CustomEvent('rastrum:audio-birdnet-ready', {
                  detail: {
                    obsId: obsIdAttr,
                    segments: raw.segments,
                    durationSec: raw.durationSec ?? (raw.segments[raw.segments.length - 1]?.endSec ?? 0),
                  },
                }));
              });
            }
          }
        }
      }

      // Coords readout + view-mode mini-map hydration. PostgREST returns
      // `location` as EWKB hex for geography columns (e.g. "0101000020E6100000...").
      // Parse it to {coordinates:[lng,lat]} before use. If it's already an object
      // (future PostgREST versions or cached GeoJSON), use it directly.
            // Coords readout + view-mode mini-map hydration. PostgREST returns
      // `location` as EWKB hex for geography columns — parsed via geo.ts.
      // For non-owner viewers we prefer `location_obscured` when present.
      const obsLoc = parseLocationToGeoJSON((obs as Record<string,unknown>).location);
      const obscuredLoc = parseLocationToGeoJSON((obs as Record<string,unknown>).location_obscured);
      const usePoint = (!viewerIsObserver && obscuredLoc?.coordinates) ? obscuredLoc : obsLoc;
      const coords = usePoint?.coordinates;
      if (Array.isArray(coords) && coords.length >= 2) {
        const lng = coords[0];
        const lat = coords[1];
        window.dispatchEvent(new CustomEvent('rastrum:mappicker-set', {
          detail: { id: 'obs-detail', coords: { lat, lng } },
        }));
        const coordsEl = document.querySelector('[data-obs-coords]');
        if (coordsEl) {
          const isEs = document.documentElement.lang === 'es';
          const obscured = (obs as { obscure_level?: string }).obscure_level;
          const isObscured = !!obscured && obscured !== 'none';
          const formatted = `${lat.toFixed(4)}, ${lng.toFixed(4)}`;
          coordsEl.textContent = isObscured
            ? (isEs ? `~${formatted} (aproximado)` : `~${formatted} (coarsened)`)
            : formatted;
        }
      }

      // ── Place chip ──
      const placeData = (obs as Record<string, unknown>).places as { id: string; slug: string; name: string; place_type?: string } | null | undefined;
      const place = Array.isArray(placeData) ? (placeData[0] ?? null) : (placeData ?? null);
      if (place?.slug && place?.name) {
        const chipEl = document.getElementById('obs-place-chip') as HTMLAnchorElement | null;
        if (chipEl) {
          const lang = document.documentElement.lang === 'es' ? 'es' : 'en';
          const href = lang === 'es'
            ? `/es/explorar/lugares/?slug=${place.slug}`
            : `/en/explore/places/?slug=${place.slug}`;
          chipEl.href = href;
          const labelSpan = chipEl.querySelector('span');
          if (labelSpan) labelSpan.textContent = place.name;
          chipEl.classList.remove('hidden');
        }
      }

      if (obs.obscure_level && obs.obscure_level !== 'none') {
        document.getElementById('sensitive')?.classList.remove('hidden');
      }

      const observerId = (obs as { observer_id?: string }).observer_id;
      if (observerId) {
        const followRoot = document.querySelector<HTMLElement>('#follow-mount .rastrum-follow-btn');
        if (followRoot) {
          followRoot.dataset.targetId = observerId;
          document.dispatchEvent(new CustomEvent('rastrum:follow-ready'));
        }
      }

      const reactRoot = document.querySelector<HTMLElement>('#reactions-mount .rastrum-reactions');
      if (reactRoot) {
        reactRoot.dataset.reactionTargetId = id;
        document.dispatchEvent(new CustomEvent('rastrum:reactions-ready'));
      }

      const reportBtn = document.getElementById('obs-report-btn');
      if (reportBtn && !viewerIsObserver) {
        reportBtn.classList.remove('hidden');
        reportBtn.addEventListener('click', () => {
          const dialog = document.getElementById('rastrum-report-dialog');
          if (!dialog) return;
          (dialog as HTMLElement).dataset.target = 'observation';
          (dialog as HTMLElement).dataset.targetId = id;
          (dialog as HTMLElement).dataset.targetLabel = speciesName;
          dialog.classList.remove('hidden');
        });
      }
      const social = document.getElementById('social-mount');
      social?.classList.remove('hidden');
      const commentsRoot = social?.querySelector<HTMLElement>('.rastrum-comments');
      if (commentsRoot) {
        commentsRoot.dataset.observationId = id;
        document.dispatchEvent(new CustomEvent('rastrum:comments-ready'));
      }

      if (viewerIsObserver) {
        // ObsManagePanel.astro renders Details / Location / Photos tabs.
        // PR4 wires Details; PR5 wires Location; PR6 wires Photos
        // (atomic delete via the delete-photo Edge Function — soft-delete
        // + ID demote + last_material_edit_at bump in one transaction).
        // The left-aside "Edit location" button (`obs-edit-location-btn`)
        // is a shortcut that scrolls to the manage panel and activates
        // the Location tab — the actual Edit Location modal lives inside
        // the tab via `MapPicker mode='edit'` with pickerId 'obs-detail-edit'.
        const editLocBtn = document.getElementById('obs-edit-location-btn') as HTMLButtonElement | null;
        if (editLocBtn) {
          editLocBtn.classList.remove('hidden');
          editLocBtn.disabled = false;
          editLocBtn.removeAttribute('aria-disabled');
          editLocBtn.addEventListener('click', () => {
            const tab = document.getElementById('m-tab-location') as HTMLButtonElement | null;
            tab?.click();
            tab?.scrollIntoView({ behavior: 'smooth', block: 'center' });
          });
        }
        await wireManagePanelDetails(id, obs as Record<string, unknown>, ident);
        await wireManagePanelLocation(id, obs as Record<string, unknown>);
        await wireManagePanelPhotos(id);

        // M34: Best shot nomination
        const isEs = document.documentElement.lang === 'es';
        if ((obs as { primary_taxon_id?: string }).primary_taxon_id) {
          const bestShotMount = document.getElementById('best-shot-mount');
          if (bestShotMount) {
            bestShotMount.classList.remove('hidden');
            const btnEl = document.getElementById('best-shot-btn') as HTMLButtonElement | null;
            const labelEl = document.getElementById('best-shot-label');
            const countEl = document.getElementById('best-shot-count');

            // Get primary media id
            const primaryMedia = (media ?? []).find((m: {is_primary?: boolean}) => m.is_primary);
            const mediaId = (primaryMedia as {id?: string} | undefined)?.id;
            const taxonName = (obs as {scientific_name?: string}).scientific_name
              || (obs as {primary_taxon_id?: string}).primary_taxon_id;

            if (labelEl && taxonName) {
              labelEl.textContent = (isEs ? 'Nominar como mejor foto de ' : 'Nominate as best shot for ') + taxonName;
            }

            if (mediaId) {
              // Get current viewer
              let currentViewer: { id?: string } | null = null;
              try {
                const { data: { user: v } } = await supabase.auth.getUser();
                currentViewer = v;
              } catch { /* signed out */ }

              // Check if already voted
              const { data: existingVote } = await supabase
                .from('reactions')
                .select('id')
                .eq('target_type', 'media')
                .eq('target_id', mediaId)
                .eq('reaction_type', 'best_shot')
                .eq('user_id', currentViewer?.id ?? '')
                .maybeSingle();

              let hasVoted = !!existingVote;
              if (countEl) {
                const { count } = await supabase
                  .from('reactions')
                  .select('id', { count: 'exact', head: true })
                  .eq('target_type', 'media')
                  .eq('target_id', mediaId)
                  .eq('reaction_type', 'best_shot');
                countEl.textContent = count ? `${count} ${isEs ? 'votos' : 'votes'}` : '';
              }

              if (btnEl) {
                const isLoggedIn = !!currentViewer?.id;

                if (!isLoggedIn) {
                  // Not logged in: show read-only count, disable button with hint
                  btnEl.textContent = isEs ? '\ud83d\udcf8 Inicia sesi\u00f3n para nominar' : '\ud83d\udcf8 Sign in to nominate';
                  btnEl.className = 'text-xs text-zinc-400 dark:text-zinc-600 cursor-not-allowed';
                  btnEl.disabled = true;
                  btnEl.title = isEs ? 'Necesitas iniciar sesi\u00f3n para nominar fotos' : 'You need to sign in to nominate photos';
                } else {
                  btnEl.textContent = hasVoted
                    ? (isEs ? '\u2713 Nominada' : '\u2713 Nominated')
                    : (isEs ? '\ud83d\udcf8 Nominar como mejor foto' : '\ud83d\udcf8 Nominate as best shot');
                  btnEl.className = hasVoted
                    ? 'text-xs text-emerald-700 dark:text-emerald-400'
                    : 'text-xs text-zinc-600 dark:text-zinc-400 hover:text-emerald-700 dark:hover:text-emerald-400';

                  btnEl.addEventListener('click', async () => {
                    if (hasVoted) {
                      await supabase.from('reactions').delete()
                        .eq('target_type', 'media').eq('target_id', mediaId)
                        .eq('reaction_type', 'best_shot').eq('user_id', currentViewer!.id ?? '');
                      hasVoted = false;
                    } else {
                      await supabase.from('reactions').insert({
                        target_type: 'media', target_id: mediaId,
                        reaction_type: 'best_shot', user_id: currentViewer!.id,
                      });
                      hasVoted = true;
                    }
                    btnEl.textContent = hasVoted
                      ? (isEs ? '\u2713 Nominada' : '\u2713 Nominated')
                      : (isEs ? '\ud83d\udcf8 Nominar como mejor foto' : '\ud83d\udcf8 Nominate as best shot');
                    btnEl.className = hasVoted
                      ? 'text-xs text-emerald-700 dark:text-emerald-400'
                      : 'text-xs text-zinc-600 dark:text-zinc-400 hover:text-emerald-700 dark:hover:text-emerald-400';
                  });
                }
              }
            }
          }
        }
      }

      // Surface the "edited after IDs" badge (PR2 schema column).
      const lastEdit = (obs as { last_material_edit_at?: string | null }).last_material_edit_at;
      const editedBadge = document.querySelector('[data-edited-badge]');
      if (lastEdit && editedBadge) {
        // The badge is suppressed when there are no community IDs; we
        // re-evaluate after wireCommunityIds resolves.
        editedBadge.setAttribute('data-pending-show', '1');
      }

      await wireCommunityIds(id, viewerIsObserver);

      if (lastEdit && editedBadge?.getAttribute('data-pending-show') === '1') {
        const list = document.getElementById('ci-list');
        if (list && list.children.length > 0) {
          editedBadge.classList.remove('hidden');
        }
        editedBadge.removeAttribute('data-pending-show');
      }
    }

    /**
     * Render the community-suggestions section: a list of every
     * `identifications` row with `validated_by IS NOT NULL` for this
     * observation, plus the right CTA depending on viewer state.
     */
    async function wireCommunityIds(obsId: string, viewerIsObserver: boolean) {
      const supabase = getSupabase();
      const section = document.getElementById('community-ids');
      const listEl = document.getElementById('ci-list') as HTMLUListElement | null;
      const emptyEl = document.getElementById('community-ids-empty');
      const suggestBtn = document.getElementById('ci-suggest-btn') as HTMLButtonElement | null;
      const signInLink = document.getElementById('ci-signin-link') as HTMLAnchorElement | null;
      const ownerNote = document.getElementById('ci-owner-note');
      if (!section || !listEl) return;

      const { data: { user } } = await supabase.auth.getUser();
      const isEs = document.documentElement.lang === 'es';
      if (viewerIsObserver) {
        ownerNote?.classList.remove('hidden');
      } else if (user) {
        suggestBtn?.classList.remove('hidden');
        suggestBtn?.addEventListener('click', () => {
          const observerName = document.getElementById('observer')?.textContent ?? null;
          const opener = (window as unknown as { __rastrumOpenSuggestId?: (id: string, n: string | null) => void }).__rastrumOpenSuggestId;
          if (typeof opener === 'function') opener(obsId, observerName);
        });
      } else if (signInLink) {
        const lang = isEs ? 'es' : 'en';
        signInLink.href = `/${lang}/${lang === 'es' ? 'ingresar' : 'sign-in'}/`;
        signInLink.classList.remove('hidden');
      }

      // ── Ask my AI button ──
      const askAiBtn = document.getElementById('ci-ask-ai-btn') as HTMLButtonElement | null;
      const aiResultEl = document.getElementById('ci-ai-result');
      const aiResultText = document.getElementById('ci-ai-result-text');
      const aiResultMeta = document.getElementById('ci-ai-result-meta');
      const aiSubmitBtn = document.getElementById('ci-ai-submit-btn') as HTMLButtonElement | null;

      if (askAiBtn && user) {
        askAiBtn.classList.remove('hidden');
        let lastAiResult: { scientific_name: string; confidence: number; source: string } | null = null;

        askAiBtn.addEventListener('click', async () => {
          const idleLabel = askAiBtn.dataset.labelIdle ?? 'Ask my AI';
          const runningLabel = askAiBtn.dataset.labelRunning ?? 'Identifying…';
          const noPhotoLabel = askAiBtn.dataset.labelNoPhoto ?? 'No photo available.';
          const noResultLabel = askAiBtn.dataset.labelNoResult ?? 'AI could not identify.';

          const heroImg = document.querySelector<HTMLImageElement>('[data-photo-hero] img');
          if (!heroImg?.src) {
            askAiBtn.textContent = noPhotoLabel;
            setTimeout(() => { askAiBtn.textContent = idleLabel; }, 3000);
            return;
          }

          askAiBtn.disabled = true;
          askAiBtn.textContent = runningLabel;
          aiResultEl?.classList.add('hidden');

          try {
            const resp = await fetch(heroImg.src);
            const blob = await resp.blob();

            const { bootstrapIdentifiers, runCascade } = await import('../../../lib/identifiers');
            const { listConfiguredPluginIds, getAllKeysForPlugin } = await import('../../../lib/byo-keys');
            bootstrapIdentifiers();

            const byoKeys: Record<string, string> = {};
            for (const pluginId of listConfiguredPluginIds()) {
              const keys = getAllKeysForPlugin(pluginId);
              for (const [k, v] of Object.entries(keys)) {
                byoKeys[`${pluginId}.${k}`] = v;
              }
            }

            const { buildCascadeOptions } = await import('../../../lib/identify-options');
            const evidenceType = askAiBtn.dataset.evidenceType;
            const opts = await buildCascadeOptions({ mediaKind: 'photo', evidenceType });

            const result = await runCascade(
              {
                media: { kind: 'blob', blob, mime: blob.type || 'image/jpeg' },
                mediaKind: 'photo',
                byo_keys: byoKeys,
              },
              { media: 'photo', ...opts },
            );

            if (result.best) {
              lastAiResult = {
                scientific_name: result.best.scientific_name,
                confidence: result.best.confidence,
                source: result.best.source,
              };
              if (aiResultText) aiResultText.textContent = result.best.scientific_name;
              if (aiResultMeta) {
                aiResultMeta.textContent = `${Math.round(result.best.confidence * 100)}% — ${result.best.source}`;
              }
              aiResultEl?.classList.remove('hidden');
              aiSubmitBtn?.classList.remove('hidden');
            } else {
              askAiBtn.textContent = noResultLabel;
              setTimeout(() => { askAiBtn.textContent = idleLabel; }, 3000);
            }
          } catch {
            askAiBtn.textContent = isEs ? 'Error al identificar' : 'Identification failed';
            setTimeout(() => { askAiBtn.textContent = idleLabel; }, 3000);
          } finally {
            askAiBtn.disabled = false;
            if (lastAiResult) {
              askAiBtn.textContent = idleLabel;
            }
          }
        });

        aiSubmitBtn?.addEventListener('click', () => {
          if (!lastAiResult) return;
          const opener = (window as unknown as { __rastrumOpenSuggestId?: (id: string, n: string | null) => void }).__rastrumOpenSuggestId;
          if (typeof opener === 'function') {
            opener(obsId, document.getElementById('observer')?.textContent ?? null);
            const nameInput = document.getElementById('sid-name') as HTMLInputElement | null;
            if (nameInput) nameInput.value = lastAiResult.scientific_name;
          }
        });
      }

      async function refresh() {
        const { data: rows } = await supabase
          .from('identifications')
          .select('id, scientific_name, confidence, validated_by, created_at, is_research_grade, source')
          .eq('observation_id', obsId)
          .not('validated_by', 'is', null)
          .order('created_at', { ascending: true });
        const arr = (rows ?? []) as Array<{
          id: string; scientific_name: string | null; confidence: number | null;
          validated_by: string | null; is_research_grade: boolean | null;
          source: string | null;
        }>;

        if (arr.length === 0) {
          emptyEl?.classList.remove('hidden');
          listEl!.innerHTML = '';
          return;
        }
        emptyEl?.classList.add('hidden');

        const validatorIds = Array.from(new Set(arr.map(r => r.validated_by!).filter(Boolean)));
        const nameById = new Map<string, string>();
        if (validatorIds.length > 0) {
          const { data: users } = await supabase
            .from('users')
            .select('id, display_name, username, profile_public')
            .in('id', validatorIds);
          for (const u of (users ?? [])) {
            const uid = (u as { id: string }).id;
            const pub = (u as { profile_public?: boolean }).profile_public;
            const display = (u as { display_name?: string }).display_name;
            const username = (u as { username?: string }).username;
            nameById.set(uid, pub ? (display || username || (isEs ? 'Anónimo' : 'Anonymous')) : (isEs ? 'Anónimo' : 'Anonymous'));
          }
        }

        const byName = new Map<string, number>();
        for (const r of arr) {
          if (!r.scientific_name) continue;
          byName.set(r.scientific_name, (byName.get(r.scientific_name) ?? 0) + 1);
        }

        function escAttr(s: string): string {
          const map: Record<string, string> = { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' };
          return s.replace(/[&<>"']/g, c => map[c] ?? c);
        }

        listEl!.innerHTML = arr.map(r => {
          const name = r.scientific_name ?? (isEs ? 'Sin nombre' : 'No name');
          const supportCount = byName.get(name) ?? 1;
          const supportLine = supportCount > 1 ? ` · ${supportCount} ${isEs ? 'sugerencias' : 'suggestions'}` : '';
          const validator = nameById.get(r.validated_by ?? '') ?? '?';
          const conf = typeof r.confidence === 'number' ? `${Math.round(r.confidence * 100)}%` : '';
          const rgChip = r.is_research_grade
            ? `<span class="ml-1 inline-flex items-center rounded-full bg-emerald-100 dark:bg-emerald-900/30 px-1.5 py-0.5 text-[10px] font-semibold text-emerald-800 dark:text-emerald-300">${isEs ? 'Grado investigación' : 'Research grade'}</span>`
            : '';
          return `<li class="flex items-baseline gap-2 flex-wrap py-1.5 border-b border-zinc-100 dark:border-zinc-800/60 last:border-b-0">
            <span class="italic font-medium text-emerald-700 dark:text-emerald-400">${escAttr(name)}</span>
            ${rgChip}
            <span class="text-xs text-zinc-500">${escAttr(validator)}${conf ? ' · ' + conf : ''}${supportLine}</span>
          </li>`;
        }).join('');
      }

      window.addEventListener('rastrum:suggestion-submitted', () => { void refresh(); });
      await refresh();
    }

  </script>
</BaseLayout>
