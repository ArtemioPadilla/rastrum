---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <title>Rastrum — Redirecting</title>
    <script is:inline define:vars={{ base }}>
      const langs = ['es', 'en'];
      // 1. Prefer a previously saved choice
      const saved = localStorage.getItem('rastrum.lang');
      if (saved && langs.includes(saved)) {
        window.location.replace(base + '/' + saved + '/');
      } else {
        // 2. Use browser language, defaulting to 'es' (primary audience)
        const browserLang = navigator.language?.slice(0, 2);
        const lang = langs.includes(browserLang) ? browserLang : 'es';
        window.location.replace(base + '/' + lang + '/');
      }
    </script>
    <meta http-equiv="refresh" content={`0;url=${base}/es/`} />
  </head>
  <body></body>
</html>
