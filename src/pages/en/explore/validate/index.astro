---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ValidationQueueView from '../../../../components/ValidationQueueView.astro';
import { t } from '../../../../i18n/utils';

const lang = 'en';
const tr = t(lang);
const v = (tr as unknown as { validation: Record<string, string> }).validation;
---

<BaseLayout title={`${v.queue_title} — Rastrum`} description="Suggest identifications for observations that need community help. Expert suggestions carry more weight in consensus." lang={lang}>
  <ValidationQueueView lang={lang} />
</BaseLayout>
