---
import DocLayout from '../../../layouts/DocLayout.astro';
import { t } from '../../../i18n/utils';

const lang = 'en';
const tr = t(lang);

const modules = [
  { n: 1,  name: 'Photo / Audio / Video ID',    ver: 'v0.1-v0.3', status: 'current',       desc: 'Multi-modal species identification using PlantNet, BirdNET, and Claude Vision ensemble' },
  { n: 2,  name: 'GPS Observation Map',          ver: 'v0.2',      status: 'current',       desc: 'Geotagged observation log with habitat, weather, and field notes' },
  { n: 3,  name: 'EXIF / Metadata Extraction',   ver: 'v0.2',      status: 'current',       desc: 'Auto-extract EXIF, XMP, and ID3 metadata from photo, audio, and video files' },
  { n: 4,  name: 'Environmental Context',         ver: 'v0.3',      status: 'current',       desc: 'Lunar cycle, solar/seasonal, precipitation, phenological auto-enrichment' },
  { n: 5,  name: 'Expert Curation',               ver: 'v0.3',      status: 'current',       desc: 'Community validation with taxonomic badges, dispute resolution, and 2/3 consensus' },
  { n: 6,  name: 'Offline PWA + Darwin Core',     ver: 'v1.0',      status: 'planned',       desc: 'Full offline mode with cached ONNX models, IndexedDB outbox, Darwin Core export' },
  { n: 7,  name: 'Media Enhancement',             ver: 'v1.0',      status: 'deprioritized', desc: 'In-app crop, denoise, background removal — deprioritized per strategic review' },
  { n: 8,  name: 'Community & Gamification',       ver: 'v1.0',      status: 'planned',       desc: 'Profiles, badges, levels, streaks, BioBlitz events, challenges — no dark patterns' },
  { n: 9,  name: 'Biodiversity Trails',           ver: 'v1.5',      status: 'planned',       desc: 'Transect creation, waypoint observations, diversity metrics per trail segment' },
  { n: 10, name: 'PITs + QR Anchors',             ver: 'v1.5',      status: 'planned',       desc: 'Territorial Information Points with QR/NFC anchors linking place to living species data' },
  { n: 11, name: 'Spatial Analysis + Diversity',   ver: 'v1.5',      status: 'planned',       desc: 'Shannon-Wiener, Simpson, Chao1, Pielou J, rarefaction curves, community matrices' },
  { n: 12, name: 'Camera Trap Analysis',           ver: 'v2.0',      status: 'planned',       desc: 'Bulk upload, motion detection, SpeciesNet AI, individual animal identification' },
  { n: 13, name: 'Institutional Exports',          ver: 'v2.0',      status: 'planned',       desc: 'GBIF publisher, iNaturalist bridge, CONABIO SNIB, CONANP ANP, INAH biocultural' },
  { n: 14, name: 'Regional ML Models',            ver: 'v2.0',      status: 'planned',       desc: 'Community-trained Neotropical models with federated learning, Oaxaca-endemic focus' },
  { n: 15, name: 'Rastrum Scout AI',              ver: 'v2.5',      status: 'planned',       desc: 'Conversational AI field assistant with RAG over regional species data' },
  { n: 16, name: 'AR Species Overlay',            ver: 'v2.5',      status: 'planned',       desc: 'Augmented reality species overlay in camera viewfinder' },
];

function badgeClasses(status: string): string {
  if (status === 'current') return 'bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 border-emerald-500/30';
  if (status === 'deprioritized') return 'bg-zinc-500/20 text-zinc-500 dark:text-zinc-500 dark:text-zinc-600 dark:text-zinc-400 border-zinc-500/30';
  return 'bg-zinc-200/50 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-500 dark:text-zinc-600 dark:text-zinc-400 border-zinc-300 dark:border-zinc-700';
}
---

<DocLayout title={tr.docs.sections.features} lang={lang} section="features" editPath="src/pages/en/docs/features.astro">
  <article class="space-y-8">
    <div>
      <h1 class="text-3xl font-bold tracking-tight mb-4">{tr.docs.sections.features}</h1>
      <p class="text-lg text-zinc-600 dark:text-zinc-600 dark:text-zinc-400 max-w-3xl">{tr.docs.descriptions.features}</p>
    </div>

    <!-- Legend -->
    <div class="not-prose flex flex-wrap gap-2 text-xs">
      <span class="px-2 py-1 rounded border bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 border-emerald-500/30">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500 mr-1"></span>
        v0.1 {(tr.docs.status as any).current}
      </span>
      <span class="px-2 py-1 rounded border bg-zinc-200/50 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-500 dark:text-zinc-600 dark:text-zinc-400 border-zinc-300 dark:border-zinc-700">
        v1.0+ {(tr.docs.status as any).planned}
      </span>
      <span class="px-2 py-1 rounded border bg-zinc-500/20 text-zinc-500 dark:text-zinc-500 dark:text-zinc-600 dark:text-zinc-400 border-zinc-500/30">
        {(tr.docs.status as any).deprioritized}
      </span>
    </div>

    <!-- Module grid -->
    <section>
      <h2 id="modules" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#modules" class="text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors">#</a> All Modules
      </h2>
      <div class="not-prose grid sm:grid-cols-2 gap-3">
        {modules.map(m => (
          <div class="p-4 rounded-xl border border-zinc-200 dark:border-zinc-200 dark:border-zinc-800">
            <div class="flex items-center gap-2 flex-wrap mb-2">
              <span class="text-xs text-zinc-500 dark:text-zinc-500 dark:text-zinc-600 font-mono w-5">{String(m.n).padStart(2, '0')}</span>
              <span class="text-sm font-semibold text-zinc-900 dark:text-zinc-900 dark:text-zinc-100">{m.name}</span>
              <span class:list={["text-xs px-1.5 py-0.5 rounded border font-mono", badgeClasses(m.status)]}>{m.ver}</span>
              {m.status === 'deprioritized' && (
                <span class="text-xs px-1.5 py-0.5 rounded border bg-zinc-500/20 text-zinc-500 dark:text-zinc-500 dark:text-zinc-600 dark:text-zinc-400 border-zinc-500/30 uppercase tracking-wide">
                  {(tr.docs.status as any).deprioritized}
                </span>
              )}
            </div>
            <p class="text-sm text-zinc-600 dark:text-zinc-500 dark:text-zinc-500 leading-relaxed">{m.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Core AI Pipeline -->
    <section>
      <h2 id="ai-pipeline" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#ai-pipeline" class="text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Core AI Pipeline
      </h2>
      <div class="not-prose p-4 rounded-xl border border-zinc-200 dark:border-zinc-800 font-mono text-sm text-zinc-700 dark:text-zinc-700 dark:text-zinc-300 overflow-x-auto whitespace-pre leading-relaxed">Input (photo / audio / video / evidence)
  |
  |-- Plant detected? --&gt; PlantNet Pro API (78K species)
  |-- Bird sound?     --&gt; BirdNET (commercial license)
  +-- General media   --&gt; Gemini Flash-Lite (triage, ~$0.001)
                           |
                           +-- High confidence --&gt; Done
                           +-- Medium conf.    --&gt; Haiku 4.5 (~$0.01) --&gt; Done
                           +-- Low confidence  --&gt; PlantNet Pro (specialist) --&gt; Expert queue

Offline fallback:
  EfficientNet-Lite0 INT8 ONNX (&lt;3MB)
  + Regional packs (Oaxaca/Yucatan, 10-30MB, lazy-loaded)</div>
    </section>

    <!-- Offline-First -->
    <section>
      <h2 id="offline" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#offline" class="text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Offline-First Architecture
      </h2>
      <p class="text-zinc-700 dark:text-zinc-700 dark:text-zinc-300">
        Every observation is written to a local Dexie IndexedDB outbox first. On reconnect, the queue flushes to Supabase via REST POST. No data is lost without connectivity. Regional ONNX model packs are cached in IndexedDB for on-device inference via WebAssembly.
      </p>
    </section>
  </article>
</DocLayout>
