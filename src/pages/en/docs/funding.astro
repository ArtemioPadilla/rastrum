---
import DocLayout from '../../../layouts/DocLayout.astro';
import { t } from '../../../i18n/utils';

const lang = 'en';
const tr = t(lang);
---

<DocLayout title={tr.docs.sections.funding} lang={lang} section="funding" editPath="src/pages/en/docs/funding.astro">
  <article class="space-y-8">
    <div>
      <h1 class="text-3xl font-bold tracking-tight mb-4">{tr.docs.sections.funding}</h1>
      <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-3xl">{tr.docs.descriptions.funding}</p>
    </div>

    <!-- Dual Entity -->
    <section>
      <h2 id="legal-structure" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#legal-structure" class="text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Dual Entity Structure
      </h2>
      <p class="text-zinc-700 dark:text-zinc-300 mb-4">Two entities, one mission:</p>
      <div class="grid sm:grid-cols-2 gap-4 not-prose">
        <div class="p-4 rounded-xl border border-zinc-200 dark:border-zinc-800">
          <p class="font-semibold text-zinc-900 dark:text-zinc-100 text-lg mb-2">Rastrum A.C.</p>
          <p class="text-xs font-mono text-emerald-600 dark:text-emerald-400 mb-3">Asociacion Civil (Nonprofit)</p>
          <div class="space-y-2 text-sm text-zinc-600 dark:text-zinc-500">
            <p>Holds mission, trademark, grants, community, and data-governance rules</p>
            <p>3-8 weeks to incorporate, MXN 15-40K notario fees</p>
            <p>Pursue <span class="font-medium text-zinc-700 dark:text-zinc-300">donataria autorizada</span> (SAT, 12 months) to unlock FMCN, FAHHO, Fomento Banamex grants</p>
            <p class="text-xs text-zinc-500">Model: Mozilla Foundation, WordPress.org, iNaturalist 501(c)(3)</p>
          </div>
        </div>
        <div class="p-4 rounded-xl border border-zinc-200 dark:border-zinc-800">
          <p class="font-semibold text-zinc-900 dark:text-zinc-100 text-lg mb-2">Rastrum S.A.S.</p>
          <p class="text-xs font-mono text-emerald-600 dark:text-emerald-400 mb-3">Sociedad por Acciones Simplificada (For-Profit)</p>
          <div class="space-y-2 text-sm text-zinc-600 dark:text-zinc-500">
            <p>Commercial licensing, SaaS contracts, government B2G, eventual VC equity</p>
            <p>Same-day incorporation via tuempresa.gob.mx, ~MXN 0</p>
            <p>A.C. owns 100% initially; trademark + services agreement between entities</p>
            <p class="text-xs text-zinc-500">B Corp certification via SAPI (Sistema B)</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Credits -->
    <section>
      <h2 id="credits" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#credits" class="text-zinc-400 hover:text-emerald-500 transition-colors">#</a> ~$400K in Credits Available Now
      </h2>
      <p class="text-zinc-700 dark:text-zinc-300 mb-4">No legal entity required. Most applications take under 30 minutes.</p>
      <div class="not-prose overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-zinc-200 dark:border-zinc-800">
              <th class="text-left py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Program</th>
              <th class="text-left py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Value</th>
              <th class="text-left py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Time to Activate</th>
            </tr>
          </thead>
          <tbody class="text-zinc-700 dark:text-zinc-300">
            <tr class="border-b border-zinc-100 dark:border-zinc-900 bg-zinc-50/50 dark:bg-zinc-950/50">
              <td class="py-2 px-3 font-medium text-zinc-900 dark:text-zinc-100">NVIDIA Inception</td>
              <td class="py-2 px-3">$100K AWS + $150K Nebius + GPU pricing</td>
              <td class="py-2 px-3">Free, no equity</td>
            </tr>
            <tr class="border-b border-zinc-100 dark:border-zinc-900">
              <td class="py-2 px-3 font-medium text-zinc-900 dark:text-zinc-100">Microsoft for Startups</td>
              <td class="py-2 px-3">$150K Azure + $2,500 OpenAI</td>
              <td class="py-2 px-3">1-2 days</td>
            </tr>
            <tr class="border-b border-zinc-100 dark:border-zinc-900 bg-zinc-50/50 dark:bg-zinc-950/50">
              <td class="py-2 px-3 font-medium text-zinc-900 dark:text-zinc-100">Anthropic AI for Science</td>
              <td class="py-2 px-3">$20K API credits</td>
              <td class="py-2 px-3">~1 week</td>
            </tr>
            <tr class="border-b border-zinc-100 dark:border-zinc-900">
              <td class="py-2 px-3 font-medium text-zinc-900 dark:text-zinc-100">Cloudflare for Startups</td>
              <td class="py-2 px-3">$2,500 credits</td>
              <td class="py-2 px-3">Same day</td>
            </tr>
            <tr class="border-b border-zinc-100 dark:border-zinc-900 bg-zinc-50/50 dark:bg-zinc-950/50">
              <td class="py-2 px-3 font-medium text-zinc-900 dark:text-zinc-100">AWS Activate Founders</td>
              <td class="py-2 px-3">$1K</td>
              <td class="py-2 px-3">7-10 days</td>
            </tr>
            <tr>
              <td class="py-2 px-3 font-medium text-zinc-900 dark:text-zinc-100">Supabase OSS</td>
              <td class="py-2 px-3">Pro credits</td>
              <td class="py-2 px-3">Email request</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Grant Pipeline -->
    <section>
      <h2 id="grants" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#grants" class="text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Grant Pipeline
      </h2>
      <p class="text-zinc-700 dark:text-zinc-300 mb-4">Year 1 target: $1-2M across grants and partnerships.</p>
      <div class="space-y-4 not-prose">
        <div class="p-4 rounded-xl border border-zinc-200 dark:border-zinc-800">
          <p class="font-semibold text-zinc-900 dark:text-zinc-100 mb-3">Immediate Opportunities</p>
          <div class="space-y-2 text-sm text-zinc-700 dark:text-zinc-300">
            <div class="flex items-start gap-2">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></span>
              <p><span class="font-medium">MIT Solve</span> (AI for Humanity + Indigenous tracks) — up to $150K</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></span>
              <p><span class="font-medium">National Geographic Society Level II</span> — up to $100K, rolling</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></span>
              <p><span class="font-medium">Mohamed bin Zayed Species Conservation Fund</span> — up to $25K</p>
            </div>
            <div class="flex items-start gap-2">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-emerald-500 shrink-0"></span>
              <p><span class="font-medium">Bezos Earth Fund AI for Climate & Nature</span> — $50K-$2M (requires US fiscal sponsor)</p>
            </div>
          </div>
        </div>
        <div class="p-4 rounded-xl border border-emerald-500/20 bg-emerald-500/5">
          <p class="font-semibold text-zinc-900 dark:text-zinc-100 mb-2">High Local Fit</p>
          <p class="text-sm text-zinc-700 dark:text-zinc-300">
            <span class="font-medium">Fundacion Alfredo Harp Helu Oaxaca (FAHHO)</span> — $50-200K. Highest strategic fit given Oaxaca roots and indigenous-language angle. Direct partnership, not grant competition.
          </p>
        </div>
      </div>
    </section>

    <!-- Revenue Model -->
    <section>
      <h2 id="revenue" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#revenue" class="text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Revenue Model
      </h2>
      <p class="text-zinc-700 dark:text-zinc-300 mb-4">
        Realistic 5-year ARR ceiling: <span class="font-semibold text-emerald-600 dark:text-emerald-400">$3-6M</span> (sustainable 25-40 person team). Mix of grants, SaaS, training, and API revenue.
      </p>
      <div class="not-prose overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-zinc-200 dark:border-zinc-800">
              <th class="text-left py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Tier</th>
              <th class="text-left py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Price</th>
              <th class="text-left py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Includes</th>
            </tr>
          </thead>
          <tbody class="text-zinc-700 dark:text-zinc-300">
            <tr class="border-b border-zinc-100 dark:border-zinc-900 bg-zinc-50/50 dark:bg-zinc-950/50">
              <td class="py-2 px-3 font-medium text-zinc-900 dark:text-zinc-100">Free</td>
              <td class="py-2 px-3 font-mono">$0</td>
              <td class="py-2 px-3">10 IDs/day, basic map, community features</td>
            </tr>
            <tr class="border-b border-zinc-100 dark:border-zinc-900">
              <td class="py-2 px-3 font-medium text-zinc-900 dark:text-zinc-100">Pro</td>
              <td class="py-2 px-3 font-mono">$5/mo</td>
              <td class="py-2 px-3">Unlimited IDs, expert review, offline regional packs, camera trap (500 img/mo)</td>
            </tr>
            <tr class="border-b border-zinc-100 dark:border-zinc-900 bg-zinc-50/50 dark:bg-zinc-950/50">
              <td class="py-2 px-3 font-medium text-zinc-900 dark:text-zinc-100">Institutional</td>
              <td class="py-2 px-3 font-mono">$200-2,000/mo</td>
              <td class="py-2 px-3">API access, SNIB/CONANP export, multi-user, SLA, audit logs</td>
            </tr>
            <tr>
              <td class="py-2 px-3 font-medium text-zinc-900 dark:text-zinc-100">B2G Custom</td>
              <td class="py-2 px-3 font-mono">MXN 500K-3M/yr</td>
              <td class="py-2 px-3">Per agency (CONANP, CONABIO, state SEMARNAT, INAH)</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </article>
</DocLayout>
