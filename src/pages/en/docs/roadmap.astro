---
import DocLayout from '../../../layouts/DocLayout.astro';
import { t } from '../../../i18n/utils';

const lang = 'en';
const tr = t(lang);

const phases = [
  {
    ver: 'v0.1', name: 'Foundation', period: 'Month 1-2', status: 'in_progress',
    items: [
      'Astro PWA shell with full i18n (EN/ES/Zapoteco pilot)',
      'Supabase schema: observations, species, users, media',
      'PlantNet MVP — single-photo plant identification',
      'GitHub Pages deploy with CI/CD',
      'Documentation site with 8-page spec',
    ],
  },
  {
    ver: 'v0.2', name: 'Intelligence', period: 'Month 3-4', status: 'planned',
    items: [
      'Claude Vision + Gemini Flash-Lite ensemble pipeline',
      'Observation log with GPS geotagging',
      'Media preprocessing: resize, quality check, blur detection',
      'EXIF / XMP / ID3 metadata auto-extraction',
      'GPS observation map with MapLibre GL',
    ],
  },
  {
    ver: 'v0.3', name: 'Community', period: 'Month 5-6', status: 'planned',
    items: [
      'BirdNET audio identification (commercial license)',
      'Expert validation with taxonomic badges and 2/3 consensus',
      'Dispute resolution queue for contested identifications',
      'Species pages with range maps and regional data',
      'Environmental context auto-enrichment (lunar, weather, phenology)',
    ],
  },
  {
    ver: 'v1.0', name: 'Field Ready', period: 'Month 7-9', status: 'planned',
    items: [
      'Video identification support (up to 30s clips)',
      'Ecological evidence: tracks, scat, burrows, nests with structured fields',
      'Full offline PWA with ONNX models cached in IndexedDB',
      'Darwin Core Archive export to GBIF',
      'Community and gamification: profiles, badges, levels, BioBlitz',
    ],
  },
  {
    ver: 'v1.5', name: 'Spatial Intelligence', period: 'Month 10-14', status: 'planned',
    items: [
      'Biodiversity Trails: transects, waypoints, diversity metrics',
      'PITs + QR/NFC territorial information points',
      'Spatial analysis: ANP, INEGI, INAH, hydrological layers',
      'Diversity indices: Shannon-Wiener, Simpson, Chao1, rarefaction curves',
      'Phenological calendar and community matrix export',
    ],
  },
  {
    ver: 'v2.0', name: 'Regional Intelligence', period: 'Month 15-20', status: 'planned',
    items: [
      'Camera trap analysis: bulk upload, SpeciesNet, occupancy modeling',
      'Institutional exports: GBIF publisher, CONABIO SNIB, CONANP, INAH',
      'Regional ML model training with federated learning',
      'iNaturalist bridge for cross-platform observation sync',
      'B2G SaaS dashboard for state agencies',
    ],
  },
  {
    ver: 'v2.5', name: 'Rastrum Scout', period: 'Month 21-30', status: 'planned',
    items: [
      'Scout AI conversational field assistant with regional RAG',
      'AR species overlay in camera viewfinder',
      'Advanced acoustic analysis beyond BirdNET',
      'Full CONABIO / CONANP / INAH partnership APIs',
      'Indigenous language voice I/O (Zapoteco, Mixteco, Nahuatl, Maya)',
    ],
  },
];
---

<DocLayout title={tr.docs.sections.roadmap} lang={lang} section="roadmap" editPath="src/pages/en/docs/roadmap.astro">
  <article class="space-y-8">
    <div>
      <h1 class="text-3xl font-bold tracking-tight mb-4">{tr.docs.sections.roadmap}</h1>
      <p class="text-lg text-zinc-600 dark:text-zinc-600 dark:text-zinc-400 max-w-3xl">{tr.docs.descriptions.roadmap}</p>
    </div>

    <!-- Visual timeline -->
    <section>
      <h2 id="timeline" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-6">
        <a href="#timeline" class="text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Development Timeline
      </h2>
      <div class="not-prose space-y-0">
        {phases.map((p, i) => {
          const isCurrent = p.status === 'in_progress';
          return (
            <div class="relative pl-10 pb-10 last:pb-0">
              {/* Vertical line */}
              {i < phases.length - 1 && (
                <div class:list={[
                  "absolute left-[15px] top-7 w-0.5 h-full",
                  isCurrent ? "bg-emerald-500/40" : "bg-zinc-200 dark:bg-zinc-800"
                ]} />
              )}
              {/* Dot */}
              <div class:list={[
                "absolute left-0 top-1.5 w-8 h-8 rounded-full border-2 flex items-center justify-center text-xs font-bold",
                isCurrent
                  ? "border-emerald-500 bg-emerald-500/20 text-emerald-600 dark:text-emerald-400"
                  : "border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 text-zinc-500 dark:text-zinc-400 dark:text-zinc-500"
              ]}>
                {isCurrent ? '\u25B6' : i + 1}
              </div>
              {/* Content */}
              <div class="pt-0.5">
                <div class="flex flex-wrap items-center gap-2 mb-2">
                  <span class:list={[
                    "text-xs font-mono px-2 py-0.5 rounded border",
                    isCurrent
                      ? "bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 border-emerald-500/30"
                      : "bg-zinc-100 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 border-zinc-200 dark:border-zinc-700"
                  ]}>{p.ver}</span>
                  <span class:list={[
                    "font-semibold",
                    isCurrent ? "text-zinc-900 dark:text-zinc-100" : "text-zinc-500 dark:text-zinc-400"
                  ]}>{p.name}</span>
                  <span class="text-xs text-zinc-500 dark:text-zinc-400 dark:text-zinc-600">{p.period}</span>
                  {isCurrent && (
                    <span class="text-xs bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 px-2 py-0.5 rounded-full border border-emerald-500/30">
                      {(tr.docs.status as any).in_progress}
                    </span>
                  )}
                </div>
                <ul class="space-y-1">
                  {p.items.map(item => (
                    <li class:list={[
                      "flex items-start gap-2 text-sm",
                      isCurrent ? "text-zinc-700 dark:text-zinc-300" : "text-zinc-500 dark:text-zinc-400 dark:text-zinc-500 dark:text-zinc-400 dark:text-zinc-500"
                    ]}>
                      <span class:list={[
                        "mt-1.5 w-1.5 h-1.5 rounded-full shrink-0",
                        isCurrent ? "bg-emerald-500" : "bg-zinc-300 dark:bg-zinc-700"
                      ]} />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <!-- Design principles -->
    <section>
      <h2 id="principles" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#principles" class="text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Design Principles
      </h2>
      <div class="space-y-3 text-zinc-700 dark:text-zinc-300">
        <div class="flex items-start gap-3">
          <span class="mt-1 w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span>
          <p>v0.1 proves offline works, nothing else</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="mt-1 w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span>
          <p>Each release adds one new modality (audio, ecological evidence, camera traps, AI, AR)</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="mt-1 w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span>
          <p>PITs and trails wait until the core observation loop is stable</p>
        </div>
        <div class="flex items-start gap-3">
          <span class="mt-1 w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span>
          <p>Institutional exports ship when there is data worth exporting</p>
        </div>
      </div>
    </section>
  </article>
</DocLayout>
