---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectsListView from '../../../components/ProjectsListView.astro';
import { t } from '../../../i18n/utils';

const lang = 'en';
const tr = t(lang);
const proj = (tr as unknown as { projects: { title: string; subtitle: string } }).projects;
---

<BaseLayout title={`${proj.title} — Rastrum`} description={proj.subtitle} lang={lang}>
  <ProjectsListView lang={lang} />
</BaseLayout>
