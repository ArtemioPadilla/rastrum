---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'en';
const tr = t(lang);
---

<BaseLayout title={`${tr.auth.sign_in_title} — Rastrum`} lang={lang}>
  <div class="max-w-md mx-auto mt-8 md:mt-16">
    <h1 class="text-2xl md:text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-100">
      {tr.auth.sign_in_title}
    </h1>
    <p class="mt-2 text-sm text-zinc-600 dark:text-zinc-400">
      {tr.auth.sign_in_subtitle}
    </p>

    <form id="sign-in-form" class="mt-6 space-y-4" novalidate>
      <div>
        <label for="email" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300">
          {tr.auth.email_label}
        </label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder={tr.auth.email_placeholder}
          class="mt-1 block w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 py-2 text-sm text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-400 focus:border-emerald-500 focus:outline-none focus:ring-1 focus:ring-emerald-500"
        />
      </div>
      <button
        type="submit"
        id="submit-btn"
        class="w-full rounded-lg bg-emerald-700 hover:bg-emerald-800 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
      >
        <span data-label>{tr.auth.send_link}</span>
      </button>
      <p id="error-msg" class="hidden text-sm text-red-600 dark:text-red-400"></p>
    </form>

    <div id="success" class="hidden mt-6 rounded-lg border border-emerald-200 dark:border-emerald-900 bg-emerald-50 dark:bg-emerald-900/20 p-4">
      <h2 class="text-sm font-semibold text-emerald-900 dark:text-emerald-200">
        {tr.auth.check_inbox_title}
      </h2>
      <p class="mt-1 text-sm text-emerald-800 dark:text-emerald-300" id="success-body"></p>
      <button
        id="try-again"
        class="mt-3 text-xs font-medium text-emerald-700 dark:text-emerald-400 underline underline-offset-2"
      >
        {tr.auth.try_again}
      </button>
    </div>
  </div>

  <script>
    import { sendMagicLink } from '../../lib/auth';

    const form = document.getElementById('sign-in-form') as HTMLFormElement | null;
    const emailInput = document.getElementById('email') as HTMLInputElement | null;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const btnLabel = submitBtn?.querySelector('[data-label]') as HTMLElement | null;
    const errorMsg = document.getElementById('error-msg') as HTMLParagraphElement | null;
    const successBox = document.getElementById('success') as HTMLDivElement | null;
    const successBody = document.getElementById('success-body') as HTMLParagraphElement | null;
    const tryAgain = document.getElementById('try-again') as HTMLButtonElement | null;

    const ORIGINAL_LABEL = btnLabel?.textContent ?? 'Send magic link';
    const SENDING_LABEL = 'Sending…';
    const INBOX_TEMPLATE = "We sent a sign-in link to {email}. Click it on this device to continue.";

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!emailInput || !submitBtn || !btnLabel) return;

      const email = emailInput.value.trim();
      if (!email) return;

      errorMsg?.classList.add('hidden');
      submitBtn.disabled = true;
      btnLabel.textContent = SENDING_LABEL;

      const { error } = await sendMagicLink(email);

      if (error) {
        submitBtn.disabled = false;
        btnLabel.textContent = ORIGINAL_LABEL;
        if (errorMsg) {
          errorMsg.textContent = error.message;
          errorMsg.classList.remove('hidden');
        }
        return;
      }

      form.classList.add('hidden');
      successBox?.classList.remove('hidden');
      if (successBody) {
        successBody.textContent = INBOX_TEMPLATE.replace('{email}', email);
      }
    });

    tryAgain?.addEventListener('click', () => {
      successBox?.classList.add('hidden');
      form?.classList.remove('hidden');
      if (submitBtn && btnLabel) {
        submitBtn.disabled = false;
        btnLabel.textContent = ORIGINAL_LABEL;
      }
      emailInput?.focus();
    });
  </script>
</BaseLayout>
