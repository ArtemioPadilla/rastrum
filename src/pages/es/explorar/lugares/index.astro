---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ExplorePlacesView from '../../../../components/ExplorePlacesView.astro';
import { t } from '../../../../i18n/utils';

const lang = 'es';
const tr = t(lang);
const page = tr.explore_pages.places;
---
<BaseLayout
  title={`${page.title} — Rastrum`}
  description="Explora áreas protegidas, zonas H3 y lugares comunitarios con observaciones de biodiversidad en Rastrum."
  lang={lang}
>
  <ExplorePlacesView lang={lang} />
</BaseLayout>
