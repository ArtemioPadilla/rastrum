import PublicProfileViewV2 from '../../../components/PublicProfileViewV2.astro';
import { t } from '../../../i18n/utils';

const lang = 'es';
const tr = t(lang);
---

<BaseLayout
  title={`${tr.profile.public_profile_title} — Rastrum`}
  description="Perfil público de un observador de Rastrum: sus observaciones de biodiversidad, insignias y lista de especies — controlado por privacidad por faceta."
  lang={lang}
>
  <PublicProfileViewV2 lang={lang} />
