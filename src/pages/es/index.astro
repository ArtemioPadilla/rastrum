---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, getLocalizedPath, getDocPath, routes } from '../../i18n/utils';

const lang = 'es';
const tr = t(lang);
---

<BaseLayout title={`${tr.site.title} — ${tr.home.hero_title}`} description={tr.site.description} lang={lang}>
  <!-- Hero -->
  <section class="text-center py-16 sm:py-24 space-y-6">
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight max-w-3xl mx-auto">
      {tr.home.hero_title}
    </h1>
    <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-2xl mx-auto">
      {tr.home.hero_subtitle}
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <!-- CTA principal: Observar (guarda con GPS + compartir) -->
      <a
        href={getLocalizedPath(lang, routes.observe[lang] + '/')}
        class="inline-flex flex-col items-center px-6 py-3 bg-emerald-700 hover:bg-emerald-800 text-white font-medium rounded-lg transition-colors"
      >
        <span>{tr.home.cta}</span>
        <span class="text-xs font-normal opacity-80">{tr.home.cta_subtitle}</span>
      </a>
      <!-- CTA secundario: Identificación rápida (sin guardar) -->
      <a
        href={getLocalizedPath(lang, routes.identify[lang] + '/')}
        class="inline-block px-6 py-3 border border-zinc-300 dark:border-zinc-700 hover:border-emerald-500/50 text-zinc-700 dark:text-zinc-300 font-medium rounded-lg transition-colors"
      >
        {tr.home.cta_identify}
      </a>
      <a
        href={getDocPath(lang)}
        class="inline-block px-6 py-3 border border-zinc-300 dark:border-zinc-700 hover:border-emerald-500/50 text-zinc-700 dark:text-zinc-300 font-medium rounded-lg transition-colors"
      >
        {tr.home.docs_cta}
      </a>
      <a
        href="https://github.com/ArtemIOPadilla/rastrum"
        target="_blank"
        rel="noopener"
        class="inline-block px-6 py-3 border border-zinc-300 dark:border-zinc-700 hover:border-emerald-500/50 text-zinc-700 dark:text-zinc-300 font-medium rounded-lg transition-colors"
      >
        {tr.home.github_cta}
      </a>
    </div>
  </section>

  <!-- Cómo Funciona -->
  <section class="py-12 border-t border-zinc-200 dark:border-zinc-800">
    <h2 class="text-2xl font-bold tracking-tight text-center mb-10">{tr.home.how_title}</h2>
    <div class="grid sm:grid-cols-3 gap-6">
      {tr.home.how_steps.map((step: { title: string; description: string }, i: number) => (
        <div class="text-center space-y-3">
          <div class="w-10 h-10 rounded-full bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 font-bold text-lg flex items-center justify-center mx-auto">
            {i + 1}
          </div>
          <h3 class="font-semibold text-zinc-900 dark:text-zinc-100">{step.title}</h3>
          <p class="text-sm text-zinc-600 dark:text-zinc-400">{step.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ¿Por Qué Rastrum? -->
  <section class="py-12 border-t border-zinc-200 dark:border-zinc-800">
    <h2 class="text-2xl font-bold tracking-tight text-center mb-10">{tr.home.why_title}</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {tr.home.why_items.map((item: { title: string; description: string }) => (
        <div class="p-5 rounded-xl border border-zinc-200 dark:border-zinc-800 hover:border-emerald-500/50 transition-colors">
          <h3 class="font-semibold text-zinc-900 dark:text-zinc-100 mb-2">{item.title}</h3>
          <p class="text-sm text-zinc-600 dark:text-zinc-400">{item.description}</p>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
