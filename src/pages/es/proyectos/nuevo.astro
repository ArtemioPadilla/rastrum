---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectNewView from '../../../components/ProjectNewView.astro';
import { t } from '../../../i18n/utils';

const lang = 'es';
const tr = t(lang);
const proj = (tr as unknown as { projects: { form_title_new: string; subtitle: string } }).projects;
---

<BaseLayout title={`${proj.form_title_new} — Rastrum`} description={proj.subtitle} lang={lang}>
  <ProjectNewView lang={lang} />
</BaseLayout>
