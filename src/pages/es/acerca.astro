---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/utils';

const lang = 'es';
const tr = t(lang);
---

<BaseLayout title={`${tr.about.title} — Rastrum`} description="Rastrum es una plataforma open-source de observación de biodiversidad construida para América Latina. IA multi-modal, lenguas indígenas, alineada con CARE." lang={lang}>

  <!-- Hero -->
  <section class="relative -mx-4 px-4 py-16 md:py-24 text-center border-b border-zinc-800">
    <div class="max-w-3xl mx-auto space-y-6">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-zinc-100">
        {tr.about.title}
      </h1>
      <p class="text-lg md:text-xl text-emerald-400 font-medium">
        {tr.about.description}
      </p>
      <p class="text-zinc-400 text-base md:text-lg leading-relaxed max-w-2xl mx-auto">
        {tr.vision.statement}
      </p>
    </div>
  </section>

  <!-- Vision -->
  <section class="py-16 border-b border-zinc-800">
    <h2 class="text-2xl md:text-3xl font-bold text-zinc-100 mb-10">{tr.vision.title}</h2>
    <div class="grid md:grid-cols-2 gap-8 md:gap-12">
      <div class="space-y-4">
        <h3 class="text-xl font-semibold text-emerald-400">{tr.vision.problem_title}</h3>
        <p class="text-zinc-400 leading-relaxed">{tr.vision.problem}</p>
      </div>
      <div class="space-y-4">
        <h3 class="text-xl font-semibold text-emerald-400">{tr.vision.solution_title}</h3>
        <p class="text-zinc-400 leading-relaxed">{tr.vision.solution}</p>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 border-b border-zinc-800">
    <h2 class="text-2xl md:text-3xl font-bold text-zinc-100 mb-10">{tr.how_it_works.title}</h2>
    <div class="grid md:grid-cols-3 gap-6 relative">
      {(tr.how_it_works.steps as any[]).map((step: any, i: number) => (
        <div class="relative flex flex-col items-center text-center p-6 rounded-xl bg-zinc-900 border border-zinc-800">
          {/* Connector arrow (hidden on mobile, shown between cards on desktop) */}
          {i < 2 && (
            <div class="hidden md:block absolute -right-3 top-1/2 -translate-y-1/2 z-10">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-emerald-500">
                <path d="M5 12h14m0 0l-4-4m4 4l-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}
          <div class="w-14 h-14 rounded-full bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center mb-4">
            {i === 0 && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-emerald-400">
                <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="2"/>
                <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="2"/>
                <circle cx="17" cy="7" r="1" fill="currentColor"/>
              </svg>
            )}
            {i === 1 && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-emerald-400">
                <path d="M12 2a4 4 0 0 1 4 4v2a4 4 0 0 1-8 0V6a4 4 0 0 1 4-4z" stroke="currentColor" stroke-width="2"/>
                <path d="M6 12v1a6 6 0 0 0 12 0v-1" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M9 18l-1 4m7-4l1 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            )}
            {i === 2 && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" class="text-emerald-400">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
                <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z" stroke="currentColor" stroke-width="2"/>
              </svg>
            )}
          </div>
          <span class="text-xs font-mono text-emerald-500 mb-2">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="text-lg font-semibold text-zinc-100 mb-2">{step.title}</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">{step.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Roadmap -->
  <section class="py-16 border-b border-zinc-800">
    <h2 class="text-2xl md:text-3xl font-bold text-zinc-100 mb-10">{tr.roadmap.title}</h2>
    <div class="space-y-0">
      {(tr.roadmap.phases as any[]).map((phase: any, i: number) => (
        <div class="relative pl-8 pb-10 last:pb-0">
          {/* Vertical timeline line */}
          {i < (tr.roadmap.phases as any[]).length - 1 && (
            <div class:list={[
              "absolute left-[11px] top-6 w-0.5 h-full",
              i === 0 ? "bg-emerald-500/50" : "bg-zinc-700"
            ]} />
          )}
          {/* Timeline dot */}
          <div class:list={[
            "absolute left-0 top-1.5 w-6 h-6 rounded-full border-2 flex items-center justify-center",
            i === 0
              ? "border-emerald-500 bg-emerald-500/20"
              : "border-zinc-600 bg-zinc-800"
          ]}>
            {i === 0 && (
              <div class="w-2 h-2 rounded-full bg-emerald-400" />
            )}
          </div>
          <div class="space-y-2">
            <div class="flex items-center gap-3">
              <span class:list={[
                "text-xs font-mono px-2 py-0.5 rounded",
                i === 0
                  ? "bg-emerald-500/20 text-emerald-400"
                  : "bg-zinc-800 text-zinc-500"
              ]}>{phase.version}</span>
              <h3 class:list={[
                "font-semibold",
                i === 0 ? "text-zinc-100" : "text-zinc-400"
              ]}>{phase.name}</h3>
            </div>
            <ul class="space-y-1 ml-1">
              {(phase.items as any[]).map((item: string) => (
                <li class="flex items-center gap-2 text-sm text-zinc-400">
                  <span class:list={[
                    "w-1 h-1 rounded-full shrink-0",
                    i === 0 ? "bg-emerald-500" : "bg-zinc-600"
                  ]} />
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Conservation Impact -->
  <section class="py-16 border-b border-zinc-800">
    <h2 class="text-2xl md:text-3xl font-bold text-zinc-100 mb-10">{tr.impact.title}</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      {(tr.impact.items as any[]).map((item: string) => (
        <div class="flex items-start gap-3 p-4 rounded-lg bg-zinc-900 border border-zinc-800">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="text-emerald-400 shrink-0 mt-0.5">
            <path d="M17 8C17 8 12 2 7 8c0 0-2 3 0 6s5 5 5 8c0-3 3-5 5-8s0-6 0-6z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M12 22v-6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <span class="text-sm text-zinc-300 leading-relaxed">{item}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Tech Stack -->
  <section class="py-16 border-b border-zinc-800">
    <h2 class="text-2xl md:text-3xl font-bold text-zinc-100 mb-10">{tr.tech.title}</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {(tr.tech.items as any[]).map((tech: any) => (
        <div class="p-5 rounded-xl bg-zinc-900 border border-zinc-800 hover:border-emerald-500/30 transition-colors">
          <h3 class="text-base font-semibold text-zinc-100 mb-1">{tech.name}</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">{tech.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Open Source / Team -->
  <section class="py-16">
    <div class="text-center max-w-2xl mx-auto space-y-6">
      <h2 class="text-2xl md:text-3xl font-bold text-zinc-100">{tr.team.title}</h2>
      <p class="text-zinc-400 leading-relaxed">{tr.team.description}</p>
      <a
        href="https://github.com/ArtemIO/rastrum"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white font-medium transition-colors"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="shrink-0">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 17.07 3.633 16.7 3.633 16.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.694.825.576C20.565 21.795 24 17.295 24 12 24 5.37 18.63 0 12 0z"/>
        </svg>
        GitHub
      </a>
    </div>
  </section>

</BaseLayout>
