---
import DocLayout from '../../../layouts/DocLayout.astro';
import TermsView from '../../../components/TermsView.astro';
import { t } from '../../../i18n/utils';

const lang = 'es';
const tr = t(lang);
const sections = tr.docs.sections as Record<string, string>;
---

<DocLayout title={sections.terms} lang={lang} section="terms" editPath="docs/terms.md">
  <TermsView lang={lang} />
</DocLayout>
