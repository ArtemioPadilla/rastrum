---
import DocLayout from '../../../layouts/DocLayout.astro';
import { t } from '../../../i18n/utils';

const lang = 'es';
const tr = t(lang);

const stack = [
  { layer: 'Frontend',         choice: 'SvelteKit',          rationale: 'Ligero, SSR+SPA, buena historia offline para una PWA con escritura intensa' },
  { layer: 'BD local',         choice: 'Dexie (IndexedDB)',  rationale: 'Sin conexión primero, lista para sincronizar, patrón append-heavy con autor único' },
  { layer: 'Runtime de IA',    choice: 'ONNX Runtime Web',   rationale: 'Inferencia en dispositivo vía WebAssembly, fallback a WebGPU' },
  { layer: 'Almacenamiento',   choice: 'Cloudflare R2',      rationale: 'Compatible con S3, cero tarifas de egreso ($150/mes vs $4,710/mes en Supabase a 10K MAU)' },
  { layer: 'Backend',          choice: 'Supabase',           rationale: 'Postgres + PostGIS + pgvector + Auth + Realtime + Storage' },
  { layer: 'Mapas',            choice: 'MapLibre GL JS',     rationale: 'Open-source, autoalojable, pmtiles en R2 para mosaicos sin conexión' },
];

const costModel = [
  { scale: '10K MAU',  monthly: '~$2,000',  perUser: '$0.20', breakdown: 'Inferencia IA $800, almacenamiento $400, cómputo $500, varios $300' },
  { scale: '50K MAU',  monthly: '~$6,000',  perUser: '$0.12', breakdown: '' },
  { scale: '100K MAU', monthly: '~$11,500', perUser: '$0.12', breakdown: '' },
];
---

<DocLayout title={tr.docs.sections.architecture} lang={lang} section="architecture" editPath="src/pages/es/docs/architecture.astro">
  <article class="space-y-8">
    <div>
      <h1 class="text-3xl font-bold tracking-tight mb-4">{tr.docs.sections.architecture}</h1>
      <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-3xl">{tr.docs.descriptions.architecture}</p>
    </div>

    <!-- Decisiones de stack -->
    <section>
      <h2 id="stack" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#stack" class="text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Decisiones de stack
      </h2>
      <div class="not-prose overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-zinc-200 dark:border-zinc-800">
              <th class="text-left py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Capa</th>
              <th class="text-left py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Elección</th>
              <th class="text-left py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Justificación</th>
            </tr>
          </thead>
          <tbody class="text-zinc-700 dark:text-zinc-300">
            {stack.map((row, i) => (
              <tr class:list={["border-b border-zinc-100 dark:border-zinc-900", i % 2 === 0 ? "bg-zinc-50/50 dark:bg-zinc-950/50" : ""]}>
                <td class="py-2 px-3 font-medium text-zinc-900 dark:text-zinc-100 whitespace-nowrap">{row.layer}</td>
                <td class="py-2 px-3 font-mono text-emerald-600 dark:text-emerald-400 whitespace-nowrap">{row.choice}</td>
                <td class="py-2 px-3">{row.rationale}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- Pipeline de identificación IA -->
    <section>
      <h2 id="pipeline" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#pipeline" class="text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Pipeline de identificación con IA
      </h2>
      <div class="not-prose p-4 rounded-xl bg-zinc-950 border border-zinc-800 font-mono text-xs text-emerald-300 overflow-x-auto whitespace-pre leading-relaxed">El usuario sube medios
  |
  v
Extracción EXIF en el cliente (exifr) --&gt; GPS, timestamp, dispositivo
  |
  v
Comprobación de calidad pre-ID --&gt; aviso de desenfoque / poca luz
  |
  |--- ¿Planta detectada? ----&gt; PlantNet Pro API (78K especies)
  |
  |--- ¿Sonido de ave? -------&gt; BirdNET (licencia comercial)
  |
  +--- Imagen / video general &gt; Gemini 2.5 Flash-Lite (~$0.001)
                                  |
                                  +-- conf &gt;= 0.8 --&gt; Resultado
                                  |
                                  +-- conf &lt; 0.8  --&gt; Claude Haiku 4.5 (~$0.01)
                                                       |
                                                       +-- conf &gt;= 0.7 --&gt; Resultado
                                                       |
                                                       +-- Conf baja  --&gt; Cola de expertos

Respaldo offline:
  EfficientNet-Lite0 INT8 ONNX (&lt;3 MB, top 500 especies)
  + Paquetes regionales (Oaxaca/Yucatán, 10-30 MB, carga diferida en IndexedDB)</div>
    </section>

    <!-- Modelo de costos -->
    <section>
      <h2 id="costos" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#costos" class="text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Modelo de costos
      </h2>
      <div class="not-prose overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-zinc-200 dark:border-zinc-800">
              <th class="text-left py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Escala</th>
              <th class="text-right py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Costo mensual</th>
              <th class="text-right py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Por usuario</th>
            </tr>
          </thead>
          <tbody class="text-zinc-700 dark:text-zinc-300">
            {costModel.map((row, i) => (
              <tr class:list={["border-b border-zinc-100 dark:border-zinc-900", i % 2 === 0 ? "bg-zinc-50/50 dark:bg-zinc-950/50" : ""]}>
                <td class="py-2 px-3 font-medium text-zinc-900 dark:text-zinc-100">{row.scale}</td>
                <td class="py-2 px-3 text-right font-mono">{row.monthly}</td>
                <td class="py-2 px-3 text-right font-mono">{row.perUser}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-sm text-zinc-600 dark:text-zinc-400 mt-3">
        Desglose 10K MAU: inferencia IA $800, almacenamiento de objetos $400, cómputo $500, monitoreo y otros $300. Incluye Supabase Pro, Cloudflare R2, ~500K llamadas a Haiku, 600K llamadas a PlantNet Pro y la primera pasada con Gemini Flash-Lite.
      </p>
    </section>

    <!-- Modelo de datos -->
    <section>
      <h2 id="datos" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#datos" class="text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Modelo de datos
      </h2>
      <p class="text-zinc-700 dark:text-zinc-300 mb-4">
        Tablas centrales del esquema Postgres en Supabase, particionadas mensualmente con pg_partman. Tipos geography de PostGIS para consultas espaciales y pgvector para búsqueda semántica de especies.
      </p>
      <div class="not-prose overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-zinc-200 dark:border-zinc-800">
              <th class="text-left py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Tabla</th>
              <th class="text-left py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Propósito</th>
              <th class="text-left py-2 px-3 text-zinc-500 dark:text-zinc-400 font-medium">Campos clave</th>
            </tr>
          </thead>
          <tbody class="text-zinc-700 dark:text-zinc-300">
            <tr class="border-b border-zinc-100 dark:border-zinc-900 bg-zinc-50/50 dark:bg-zinc-950/50">
              <td class="py-2 px-3 font-mono text-emerald-600 dark:text-emerald-400">users</td>
              <td class="py-2 px-3">Cuentas y perfiles de usuario</td>
              <td class="py-2 px-3 font-mono text-xs">id, display_name, role, language_pref</td>
            </tr>
            <tr class="border-b border-zinc-100 dark:border-zinc-900">
              <td class="py-2 px-3 font-mono text-emerald-600 dark:text-emerald-400">observations</td>
              <td class="py-2 px-3">Registros de observación con ubicación y entorno</td>
              <td class="py-2 px-3 font-mono text-xs">id, observer_id, observed_at, location (PostGIS), moon_phase, precipitation</td>
            </tr>
            <tr class="border-b border-zinc-100 dark:border-zinc-900 bg-zinc-50/50 dark:bg-zinc-950/50">
              <td class="py-2 px-3 font-mono text-emerald-600 dark:text-emerald-400">species</td>
              <td class="py-2 px-3">Referencia taxonómica con categorías NOM-059</td>
              <td class="py-2 px-3 font-mono text-xs">id, scientific_name, common_names (jsonb), nom_059_category</td>
            </tr>
            <tr class="border-b border-zinc-100 dark:border-zinc-900">
              <td class="py-2 px-3 font-mono text-emerald-600 dark:text-emerald-400">media_files</td>
              <td class="py-2 px-3">Fotos, audio, video con metadatos EXIF</td>
              <td class="py-2 px-3 font-mono text-xs">id, observation_id, media_type, r2_key, exif_data (jsonb)</td>
            </tr>
            <tr class="border-b border-zinc-100 dark:border-zinc-900 bg-zinc-50/50 dark:bg-zinc-950/50">
              <td class="py-2 px-3 font-mono text-emerald-600 dark:text-emerald-400">identifications</td>
              <td class="py-2 px-3">Resultados de IA y de humanos con puntajes de confianza</td>
              <td class="py-2 px-3 font-mono text-xs">id, observation_id, taxon_id, confidence, source, is_research_grade</td>
            </tr>
            <tr>
              <td class="py-2 px-3 font-mono text-emerald-600 dark:text-emerald-400">expert_validations</td>
              <td class="py-2 px-3">Revisión experta con verificación de insignias taxonómicas</td>
              <td class="py-2 px-3 font-mono text-xs">id, identification_id, validator_id, verdict, notes</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>
  </article>
</DocLayout>
