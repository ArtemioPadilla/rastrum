function verColor(v: string) {
  if (v.startsWith('v0.1') || v.startsWith('v0.2') || v.startsWith('v0.3')) return 'bg-emerald-500/20 text-emerald-300 border-emerald-500/30';
  if (v.startsWith('v1.0')) return 'bg-sky-500/20 text-sky-300 border-sky-500/30';
  if (v.startsWith('v1.5')) return 'bg-violet-500/20 text-violet-300 border-violet-500/30';
  if (v.startsWith('v2.')) return 'bg-amber-500/20 text-amber-300 border-amber-500/30';
  return 'bg-zinc-800 text-zinc-400 border-zinc-700';
}
