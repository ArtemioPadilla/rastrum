---
import DocLayout from '../../../layouts/DocLayout.astro';
import { t } from '../../../i18n/utils';

const lang = 'es';
const tr = t(lang);

const modules = [
  { n: 1,  name: 'ID de foto / audio / video',     ver: 'v0.1-v0.3', status: 'current',       desc: 'Identificación multi-modal de especies usando el ensamble PlantNet, BirdNET y Claude Vision' },
  { n: 2,  name: 'Mapa de observaciones GPS',       ver: 'v0.2',      status: 'current',       desc: 'Registro georreferenciado con hábitat, clima y notas de campo' },
  { n: 3,  name: 'Extracción EXIF / metadatos',     ver: 'v0.2',      status: 'current',       desc: 'Auto-extracción de metadatos EXIF, XMP e ID3 desde archivos de foto, audio y video' },
  { n: 4,  name: 'Contexto ambiental',              ver: 'v0.3',      status: 'current',       desc: 'Auto-enriquecimiento con ciclo lunar, datos solares/estacionales, precipitación y fenología' },
  { n: 5,  name: 'Curación experta',                ver: 'v0.3',      status: 'current',       desc: 'Validación comunitaria con insignias taxonómicas, resolución de disputas y consenso 2/3' },
  { n: 6,  name: 'PWA offline + Darwin Core',       ver: 'v1.0',      status: 'planned',       desc: 'Modo offline completo con modelos ONNX en caché, outbox IndexedDB y exportación Darwin Core' },
  { n: 7,  name: 'Mejora de medios',                ver: 'v1.0',      status: 'deprioritized', desc: 'Recorte, eliminación de ruido y eliminación de fondo en la app — despriorizado tras revisión estratégica' },
  { n: 8,  name: 'Comunidad y gamificación',        ver: 'v1.0',      status: 'planned',       desc: 'Perfiles, insignias, niveles, rachas, eventos BioBlitz, retos — sin patrones oscuros' },
  { n: 9,  name: 'Senderos de biodiversidad',       ver: 'v1.5',      status: 'planned',       desc: 'Creación de transectos, observaciones por waypoint, métricas de diversidad por segmento' },
  { n: 10, name: 'PITs + anclas QR',                ver: 'v1.5',      status: 'planned',       desc: 'Puntos de Información Territorial con anclas QR/NFC que enlazan el lugar con datos vivos de especies' },
  { n: 11, name: 'Análisis espacial + diversidad',  ver: 'v1.5',      status: 'planned',       desc: 'Shannon-Wiener, Simpson, Chao1, Pielou J, curvas de rarefacción, matrices comunitarias' },
  { n: 12, name: 'Análisis de cámaras trampa',      ver: 'v2.0',      status: 'planned',       desc: 'Carga masiva, detección de movimiento, IA SpeciesNet, identificación de individuos' },
  { n: 13, name: 'Exportaciones institucionales',   ver: 'v2.0',      status: 'planned',       desc: 'Publicador GBIF, puente iNaturalist, CONABIO SNIB, CONANP ANP, INAH biocultural' },
  { n: 14, name: 'Modelos ML regionales',           ver: 'v2.0',      status: 'planned',       desc: 'Modelos neotropicales entrenados con datos comunitarios, aprendizaje federado, enfoque endémicas de Oaxaca' },
  { n: 15, name: 'Rastrum Scout AI',                ver: 'v2.5',      status: 'planned',       desc: 'Asistente de campo conversacional con RAG sobre datos regionales de especies' },
  { n: 16, name: 'Superposición AR de especies',    ver: 'v2.5',      status: 'planned',       desc: 'Realidad aumentada con superposición de especies en el visor de la cámara' },
];

function badgeClasses(status: string): string {
  if (status === 'current') return 'bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 border-emerald-500/30';
  if (status === 'deprioritized') return 'bg-zinc-500/20 text-zinc-500 dark:text-zinc-400 border-zinc-500/30';
  return 'bg-zinc-200/50 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 border-zinc-300 dark:border-zinc-700';
}

const statusLabels = tr.docs.status as { current: string; planned: string; deprioritized: string };
---

<DocLayout title={tr.docs.sections.features} lang={lang} section="features" editPath="src/pages/es/docs/features.astro">
  <article class="space-y-8">
    <div>
      <h1 class="text-3xl font-bold tracking-tight mb-4">{tr.docs.sections.features}</h1>
      <p class="text-lg text-zinc-600 dark:text-zinc-400 max-w-3xl">{tr.docs.descriptions.features}</p>
    </div>

    <!-- Leyenda -->
    <div class="not-prose flex flex-wrap gap-2 text-xs">
      <span class="px-2 py-1 rounded border bg-emerald-500/20 text-emerald-600 dark:text-emerald-400 border-emerald-500/30">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-emerald-500 mr-1"></span>
        v0.1 {statusLabels.current}
      </span>
      <span class="px-2 py-1 rounded border bg-zinc-200/50 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-400 border-zinc-300 dark:border-zinc-700">
        v1.0+ {statusLabels.planned}
      </span>
      <span class="px-2 py-1 rounded border bg-zinc-500/20 text-zinc-500 dark:text-zinc-400 border-zinc-500/30">
        {statusLabels.deprioritized}
      </span>
    </div>

    <!-- Lista de módulos -->
    <section>
      <h2 id="modulos" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#modulos" class="text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Todos los módulos
      </h2>
      <div class="not-prose grid sm:grid-cols-2 gap-3">
        {modules.map(m => (
          <div class="p-4 rounded-xl border border-zinc-200 dark:border-zinc-800">
            <div class="flex items-center gap-2 flex-wrap mb-2">
              <span class="text-xs text-zinc-500 dark:text-zinc-600 font-mono w-5">{String(m.n).padStart(2, '0')}</span>
              <span class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">{m.name}</span>
              <span class:list={["text-xs px-1.5 py-0.5 rounded border font-mono", badgeClasses(m.status)]}>{m.ver}</span>
              {m.status === 'deprioritized' && (
                <span class="text-xs px-1.5 py-0.5 rounded border bg-zinc-500/20 text-zinc-500 dark:text-zinc-400 border-zinc-500/30 uppercase tracking-wide">
                  {statusLabels.deprioritized}
                </span>
              )}
            </div>
            <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">{m.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Pipeline central de IA -->
    <section>
      <h2 id="pipeline" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#pipeline" class="text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Pipeline central de IA
      </h2>
      <div class="not-prose p-4 rounded-xl bg-zinc-950 border border-zinc-800 font-mono text-xs text-emerald-300 overflow-x-auto whitespace-pre leading-relaxed">Entrada (foto / audio / video / evidencia)
  |
  |-- ¿Planta detectada?     --&gt; PlantNet Pro API (78K especies)
  |-- ¿Sonido de ave?        --&gt; BirdNET (licencia comercial)
  +-- Medios generales       --&gt; Gemini Flash-Lite (triage, ~$0.001)
                                  |
                                  +-- Alta confianza  --&gt; Listo
                                  +-- Confianza media --&gt; Haiku 4.5 (~$0.01) --&gt; Listo
                                  +-- Baja confianza  --&gt; PlantNet Pro especialista --&gt; Cola de expertos

Respaldo offline:
  EfficientNet-Lite0 INT8 ONNX (&lt;3 MB)
  + Paquetes regionales (Oaxaca/Yucatán, 10-30 MB, carga diferida)</div>
    </section>

    <!-- Arquitectura sin conexión -->
    <section>
      <h2 id="offline" class="text-xl font-semibold text-zinc-900 dark:text-zinc-100 mb-4">
        <a href="#offline" class="text-zinc-600 dark:text-zinc-400 hover:text-emerald-500 transition-colors">#</a> Arquitectura sin conexión primero
      </h2>
      <p class="text-zinc-700 dark:text-zinc-300">
        Cada observación se escribe primero en un outbox local de Dexie IndexedDB. Al reconectar, la cola se vacía a Supabase vía REST POST. Ningún dato se pierde por falta de conexión. Los paquetes ONNX regionales se guardan en IndexedDB para inferencia en el dispositivo vía WebAssembly.
      </p>
    </section>
  </article>
</DocLayout>
