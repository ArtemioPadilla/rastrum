---
/**
 * Module 25 v1.2.0 — legacy public-profile route (ES).
 * See en/profile/u/index.astro for the rationale.
 */
const lang = 'es';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <title>Redirigiendo…</title>
    <meta name="robots" content="noindex,nofollow" />
    <link rel="canonical" href="https://rastrum.org/es/u/" />
  </head>
  <body>
    <p>Redirigiendo al nuevo perfil público…</p>
    <script>
      (function () {
        const params = new URLSearchParams(window.location.search);
        const username = params.get('username') || params.get('u') || '';
        const target = '/es/u/' + (username ? `?username=${encodeURIComponent(username)}` : '');
        window.location.replace(target);
      })();
    </script>
    <noscript>
      <p>Habilita JavaScript para ver este perfil, o visita
      <code>/es/u/?username=&lt;nombre&gt;</code> directamente.</p>
    </noscript>
  </body>
</html>
