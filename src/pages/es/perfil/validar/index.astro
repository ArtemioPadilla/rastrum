---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import ValidationDashboardView from '../../../../components/ValidationDashboardView.astro';
import { t } from '../../../../i18n/utils';

const lang = 'es';
const tr = t(lang);
const v = (tr as unknown as { validation: Record<string, string> }).validation;
---

<BaseLayout title={`${v.dashboard_title} — Rastrum`} description={v.dashboard_subtitle} lang={lang}>
  <ValidationDashboardView lang={lang} />
</BaseLayout>
